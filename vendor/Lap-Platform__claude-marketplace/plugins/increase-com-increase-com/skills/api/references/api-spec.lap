@desc Update an Entity
@required {entity_id: str}
@optional {corporation: map{address: map{city!: str, line1!: str, line2: str, state!: str, zip!: str}, email: str(email), incorporation_state: str, industry_code: str, name: str, tax_identifier: str} # Details of the corporation entity to update. If you specify this parameter and the entity is not a corporation, the request will fail., details_confirmed_at: str(date-time) # When your user last confirmed the Entity's details. Depending on your program, you may be required to affirmatively confirm details with your users on an annual basis., government_authority: map{address: map{city!: str, line1!: str, line2: str, state!: str, zip!: str}, name: str} # Details of the government authority entity to update. If you specify this parameter and the entity is not a government authority, the request will fail., natural_person: map{address: map{city!: str, line1!: str, line2: str, state!: str, zip!: str}, name: str} # Details of the natural person entity to update. If you specify this parameter and the entity is not a natural person, the request will fail., risk_rating: map{rated_at!: str(date-time), rating!: str} # An assessment of the entity’s potential risk of involvement in financial crimes, such as money laundering., third_party_verification: map{reference!: str, vendor!: str} # If you are using a third-party service for identity verification, you can use this field to associate this Entity with the identifier that represents them in that service., trust: map{address: map{city!: str, line1!: str, line2: str, state!: str, zip!: str}, name: str} # Details of the trust entity to update. If you specify this parameter and the entity is not a trust, the request will fail.}
