 returned: map}, consumer_merchandise_not_as_described: map{merchant_resolution_attempted!: str, received_at!: str(date), return_attempted: map, return_outcome!: str, returned: map}, consumer_merchandise_not_received: map{cancellation_outcome!: str, cardholder_cancellation_prior_to_expected_receipt: map, delayed: map, delivered_to_wrong_location: map, delivery_issue!: str, last_expected_receipt_at!: str(date), merchant_cancellation: map, merchant_resolution_attempted!: str, no_cancellation: map, purchase_info_and_explanation!: str}, consumer_non_receipt_of_cash: map, consumer_original_credit_transaction_not_accepted: map{explanation!: str, reason!: str}, consumer_quality_merchandise: map{expected_at!: str(date), merchant_resolution_attempted!: str, not_returned: map, ongoing_negotiations: map, purchase_info_and_quality_issue!: str, received_at!: str(date), return_attempted: map, return_outcome!: str, returned: map}, consumer_quality_services: map{cardholder_cancellation!: map, cardholder_paid_to_have_work_redone: str, non_fiat_currency_or_non_fungible_token_related_and_not_matching_description!: str, ongoing_negotiations: map, purchase_info_and_quality_issue!: str, restaurant_food_related: str, services_received_at!: str(date)}, consumer_services_misrepresentation: map{cardholder_cancellation!: map, merchant_resolution_attempted!: str, misrepresentation_explanation!: str, purchase_explanation!: str, received_at!: str(date)}, consumer_services_not_as_described: map{cardholder_cancellation!: map, explanation!: str, merchant_resolution_attempted!: str, received_at!: str(date)}, consumer_services_not_received: map{cancellation_outcome!: str, cardholder_cancellation_prior_to_expected_receipt: map, last_expected_receipt_at!: str(date), merchant_cancellation: map, merchant_resolution_attempted!: str, no_cancellation: map, purchase_info_and_explanation!: str}, fraud: map{fraud_type!: str}, processing_error: map{duplicate_transaction: map, error_reason!: str, incorrect_amount: map, merchant_resolution_attempted!: str, paid_by_other_means: map}} # The Visa-specific parameters for the dispute. Required if and only if `network` is `visa`.}
