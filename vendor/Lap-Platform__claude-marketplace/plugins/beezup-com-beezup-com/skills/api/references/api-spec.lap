@endpoint PUT /v2/user/catalogs/{storeId}/beezUPColumns
@desc Replace the BeezUPColumns' Mapping of a Store.
@required {storeId: any # Your store identifier, request: [map]}
@returns(204) BeezUPColumns' Mapping of a Store Replaced
@errors {404: StoreId not found}

@endpoint PUT /v2/user/catalogs/{storeId}/beezUPColumns/{beezUPColumnName}
@desc Replace the BeezUPColumns' Mapping of a Store.
@required {storeId: any # Your store identifier, beezUPColumnName: any # BeezUP Column Name, request: map}
@returns(204) BeezUPColumn' Mapping saved
@errors {404: StoreId or BeezUPColumnName or ColumnId not found}

@endpoint DELETE /v2/user/catalogs/{storeId}/beezUPColumns/{beezUPColumnName}
@desc Delete the BeezUPColumn' Mapping of a Store.
@required {storeId: any # Your store identifier, beezUPColumnName: any # BeezUP Column Name}
@returns(204) BeezUPColumn' Mapping deleted
@errors {404: StoreId or BeezUPColumnName not found}

@endpoint GET /v2/user/catalogs/importations
@desc Get the latest catalog importation reporting for all your stores
@returns(200) The last importation reportings
@errors {404: UserId not found}

@endpoint GET /v2/user/catalogs/{storeId}/importations
@desc Get the latest catalog importation reporting
@required {storeId: any # Your store identifier}
@returns(200) The last importation reportings
@errors {404: StoreId not found}

@endpoint POST /v2/user/catalogs/{storeId}/importations/start
@desc Start Manual Import
@required {storeId: any # Your store identifier, request: map}
