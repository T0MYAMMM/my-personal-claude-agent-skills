@returns(200) OK
@errors {404: StoreId or Manual Update last configuration not found}

@endpoint GET /v2/user/catalogs/{storeId}/catalogColumns
@desc Get catalog column list
@required {storeId: any # Your store identifier}
@returns(200) Catalog column list
@errors {404: StoreId not found}

@endpoint POST /v2/user/catalogs/{storeId}/catalogColumns/{columnId}/rename
@desc Change Catalog Column User Name
@required {storeId: any # Your store identifier, columnId: any # The catalog column identifier, request: map}
@returns(204) Catalog column user name changed
@errors {400: When a user column name is duplicate., 404: Occurs when a user tries to work on the wrong store. Occurs when a catalog column is not found., 409: A catalog importation is already in progress!}

@endpoint GET /v2/user/catalogs/{storeId}/customColumns
@desc Get custom column list
@required {storeId: any # Your store identifier}
@returns(200) Custom column list
@errors {404: StoreId not found}

@endpoint PUT /v2/user/catalogs/{storeId}/customColumns/{columnId}
@desc Create or replace a custom column
@required {storeId: any # Your store identifier, columnId: any # The custom column identifier, request: map}
@returns(204) Custom column saved
@errors {400: Occurs when a catalog custom column id is already used by a catalog column. When the catalog custom column count limit has been reached., 404: Occurs when a user tries to work on the wrong store., 409: A catalog importation is already in progress!}

@endpoint DELETE /v2/user/catalogs/{storeId}/customColumns/{columnId}
@desc Delete custom column
@required {storeId: any # Your store identifier, columnId: any # The custom column identifier}
@returns(204) Custom column deleted
@errors {403: Occurs when the parent category is not found., 404: Occurs when a user tries to work on the wrong store., 409: When a catalog importation is already in progress!}

@endpoint POST /v2/user/catalogs/{storeId}/customColumns/{columnId}/rename
@desc Change Custom Column User Name
@required {storeId: any # Your store identifier, columnId: any # The custom column identifier, request: map}
@returns(204) Custom column renamed
@errors {400: When a user column name is duplicate., 404: Occurs when a user tries to work on the wrong store. Occurs when a catalog column is not found., 409: A catalog importation is already in progress!}

@endpoint GET /v2/user/catalogs/{storeId}/customColumns/{columnId}/expression
@desc Get the encrypted custom column expression
@required {storeId: any # Your store identifier, columnId: any # The custom column identifier}
@returns(200) Encrypted expression
@errors {404: Occurs when a user tries to work on the wrong store. Occurs when a catalog custom column is not found.}

@endpoint PUT /v2/user/catalogs/{storeId}/customColumns/{columnId}/expression
@desc Change custom column expression
@required {storeId: any # Your store identifier, columnId: any # The custom column identifier, request: map}
@returns(204) Custom column expression saved
@errors {403: Occurs when the user try to change a custom column related to a Category. If you want to change this custom column expression you have to make a new manual importation., 404: Occurs when a user tries to work on the wrong store. Occurs when a catalog custom column is not found., 409: A catalog importation is already in progress!}

@endpoint POST /v2/user/catalogs/{storeId}/customColumns/computeExpression
@desc Compute the expression for this catalog.
@required {storeId: any # Your store identifier, request: map}
@returns(200) Compute an expression
@errors {400: Occurs when the expression cannot be computed}

@endpoint GET /v2/user/catalogs/{storeId}/categories
@desc Get category list
@required {storeId: any # Your store identifier, Accept-Encoding: any # Indicates that the client accepts that the response will be compressed to reduce traffic size.}
@returns(200) Categories
@errors {404: StoreId not found}

@endpoint POST /v2/user/catalogs/{storeId}/products/list
@desc Get product list
@required {storeId: any # Your store identifier, request: map}
