@returns(200) User account information
@errors {304: The ETag sent in the http header If-None-Match did not change. So you are up to date !}

@endpoint POST /v2/user/customer/account/resendEmailActivation
@desc Resend email activation
@returns(204) Email activation resent
@errors {400: Email activation not sent because of email problem. Ensure that your email is the correct one., 429: Email activation sent recently, must retry later. (One per hour), 409: Email activation not available because user account already activated., 502: Email activate send failed because of our email service. Ensure that your email is the correct one otherwise please contact our support if the problem persists.}

@endpoint POST /v2/user/customer/account/activate
@desc Activate the user account
@required {emailActivationId: str(guid) # The email activation id received by email.}
@returns(204) User account activated.
@errors {403: Invalid email activation id, 409: User account already activated.}

@endpoint PUT /v2/user/customer/account/personalInfo
@desc Save user personal information
@required {request: map}
@returns(204) User account information updated
@errors {400: Bad Request}

@endpoint PUT /v2/user/customer/account/companyInfo
@desc Change company information
@required {request: map}
@returns(204) Company information saved
@errors {400: Bad request or invalid VATNumber., 403: User not found or unauthorized}

@endpoint GET /v2/user/customer/account/profilePictureInfo
@desc Get profile picture information
@optional {If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
@returns(200) Profile picture information
@errors {304: The ETag sent in the http header If-None-Match did not change. So you are up to date !}

@endpoint PUT /v2/user/customer/account/profilePictureInfo
@desc Change user picture information
@required {request: map}
@returns(204) User profile picture information saved.
@errors {400: BadRequest (Url invalid), 413: The picture size is too large, 415: The content type of the image must be an image}

@endpoint GET /v2/user/customer/account/creditCardInfo
@desc Get credit card information
@optional {If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
@returns(200) User credit card information
@errors {304: The ETag sent in the http header If-None-Match did not change. So you are up to date !, 404: Credit Card not found, 503: We are unable to get your credit card info. This is a temporary state. Please retry later}

@endpoint PUT /v2/user/customer/account/creditCardInfo
@desc Save user credit card info
@required {request: map # Credit card info}
@returns(202) The credit card information has been accepted for processing, the authorization will be processed shortly.
@errors {400: BadRequest, 502: Communication problem with our payment service}

@endpoint POST /v2/user/customer/account/changeEmail
@desc Change user email
@required {request: map}
@returns(204) Email updated
@errors {400: New email does not respect the emails's constraints}

@endpoint POST /v2/user/customer/account/changePassword
@desc Change user password
@required {request: map}
@returns(204) Password updated
@errors {400: Old password is invalid or the new password does not respect the password's constraints}

@endpoint POST /v2/user/customer/security/logout
@desc Log out the current user from go2
@returns(204) User logout

@endpoint GET /v2/user/customer/zendeskToken
@desc Zendesk token
@returns(200) A JWT token to connect the Zendesk Web Widget
@errors {500: Occurs when something goes wrong}

@endpoint GET /v2/user/customer/stores
@desc Get store list
@optional {If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
@returns(200) Store list
@errors {304: The ETag sent in the http header If-None-Match did not change. So you are up to date !}

@endpoint POST /v2/user/customer/stores
@desc Create a new store
@required {request: map}
@returns(201) The store has been created successfully. The http header Location contains the new resource url. The body contains the link to the new resource.
@errors {402: The maximum amount of store has been reached. Please upgrade your contract., 409: The customer has a store with the same name}

@endpoint GET /v2/user/customer/stores/{storeId}
@desc Get store's information
@required {storeId: any # Your store identifier}
@optional {If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
