@errors {403: The ownerId is not found or not authorized, 404: The order invoice design is not found}

@endpoint POST /v2/user/marketplaces/orders/invoices/settings/design/preview
@desc View a preview an Order Invoice using custom design settings
@required {Accept-Encoding: any # Allows the client to indicate wether it accepts a compressed encoding to reduce traffic size, request: map}
@returns(200) Design Preview successfully retrieved
@errors {403: The ownerId is not found or not authorized}

@endpoint POST /v2/user/marketplaces/orders/invoices/{marketplaceTechnicalCode}/{accountId}/{beezUPOrderUUID}/generate
@desc Generate an Order Invoice
@required {marketplaceTechnicalCode: any # The Marketplace Technical Code, accountId: any # The Account Identifier, beezUPOrderUUID: any # The BeezUP Order UUID, userName: any # Sometimes the user in the e-commerce application is not the same as user associated with the current subscription key. We recommend providing your application's user login., request: map}
@returns(202) Request Accepted.
@errors {403: OwnerId not authorized The required order invoice settings have not been set BeezUPOrderStatus forbidden, 404: The order cannot be retrieved, 409: The InvoiceNumber is already used There is already an invoice for this order, 429: Too many Requests. Please retry in a few seconds}

@endpoint POST /v2/user/marketplaces/orders/invoices/generate
@desc Generate an Order Invoice batch
@required {userName: any # Sometimes the user in the e-commerce application is not the same as user associated with the current subscription key. We recommend providing your application's user login., request: [map]}
@returns(202) The locations of the generated invoice. Might take a few seconds to be available
@errors {400: GenerateBatchOrderInvoiceErrorResponse, 403: OwnerId not authorized The required order invoice settings have not been set BeezUPOrderStatus forbidden, 404: The order cannot be retrieved, 409: The InvoiceNumber is already used There is already an invoice for this order, 429: Too many Requests. Please retry in a few seconds}

@endpoint POST /v2/user/marketplaces/orders/invoices/{marketplaceTechnicalCode}/{accountId}/{beezUPOrderUUID}/preview
@desc View a preview an Order Invoice
@required {marketplaceTechnicalCode: any # The Marketplace Technical Code, accountId: any # The Account Identifier, beezUPOrderUUID: any # The BeezUP Order UUID, Accept-Encoding: any # Allows the client to indicate wether it accepts a compressed encoding to reduce traffic size, request: map}
@returns(200) Order Invoice preview successfully returned.
@errors {403: OwnerId not authorized The required order invoice settings have not been set BeezUPOrderStatus forbidden, 404: The order cannot be retrieved, 409: The InvoiceNumber is already used There is already an invoice for this order}

@endpoint POST /v2/user/marketplaces/orders/invoices/getPdfInvoice
@desc Returns the PDF version of the invoice
@required {request: map}
@returns(200) The PDF version of the HTML invoice URL in the request
@errors {403: The ownerId is not found or not authorized, 404: The order invoice does not exist}

@endgroup

@end
