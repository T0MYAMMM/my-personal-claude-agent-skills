@desc Update Rule
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier, request: map}
@returns(204) Rule updated
@errors {400: Filter does not exist or period on filter cannot be custom, 401: Store not allowed to use rules. Please upgrade your offer or contact us., 404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

@endpoint DELETE /v2/user/analytics/{storeId}/rules/{ruleId}
@desc Delete Rule
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier}
@returns(204) Rule deleted
@errors {404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

@endpoint POST /v2/user/analytics/{storeId}/rules/{ruleId}/moveup
@desc Move the rule up
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier}
@returns(204) Rule moved up
@errors {400: Priority can only be changed when more than one rule is defined, 404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

@endpoint POST /v2/user/analytics/{storeId}/rules/{ruleId}/movedown
@desc Move the rule down
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier}
@returns(204) Rule moved down
@errors {400: Priority can only be changed when more than one rule is defined, 404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

@endpoint POST /v2/user/analytics/{storeId}/rules/{ruleId}/enable
@desc Enable rule
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier}
@returns(204) Rune enabled
@errors {404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

@endpoint POST /v2/user/analytics/{storeId}/rules/{ruleId}/disable
@desc Disable rule
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier}
@returns(204) Rule disabled
@errors {404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

@endpoint POST /v2/user/analytics/{storeId}/rules/run
@desc Run all rules for this store
@required {storeId: any # Your store identifier}
@returns(204) All rules executed.
@errors {401: Store not allowed to use rules. Please upgrade your offer or contact us., 404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

@endpoint POST /v2/user/analytics/{storeId}/rules/{ruleId}/run
@desc Run rule
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier}
@returns(204) Rule executed
@errors {400: Rule is not enabled. Please enable this run before trying to run it., 401: Store not allowed to use rules. Please upgrade your offer or contact us., 404: Rule not found, 409: Rules for this store are currently running. Please try again later.}

