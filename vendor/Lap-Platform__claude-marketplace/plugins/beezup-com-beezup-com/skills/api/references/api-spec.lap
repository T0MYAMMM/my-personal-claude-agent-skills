@endpoint GET /v2/user/catalogs/
@desc Get the index of the catalog API
@returns(200) OK

@endpoint GET /v2/user/catalogs/beezupColumns
@desc Get the BeezUP columns
@returns(200) The catalog API index

@endpoint GET /v2/user/catalogs/{storeId}
@desc Get the index of the catalog API for this store
@required {storeId: any # Your store identifier}
@returns(200) The catalog index

