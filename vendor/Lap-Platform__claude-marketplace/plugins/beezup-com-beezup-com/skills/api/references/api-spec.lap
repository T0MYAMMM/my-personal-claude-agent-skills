@endpoint POST /v2/user/analytics/{storeId}/rules
@desc Rule creation
@required {storeId: any # Your store identifier, request: map}
@returns(204) Rule created
@errors {400: Period on filter cannot be custom or filter does not exist, 401: Store not allowed to use rules. Please upgrade your offer or contact us., 404: Store or resource not found, 403: Reached the maximum amount of rules allowed for your offer. Please upgrade your offer or contact us.}

@endpoint GET /v2/user/analytics/{storeId}/rules/{ruleId}
@desc Gets the rule
@required {storeId: any # Your store identifier, ruleId: any # Your rule identifier}
@returns(200) Get Rule
@errors {404: Store or resource not found}

