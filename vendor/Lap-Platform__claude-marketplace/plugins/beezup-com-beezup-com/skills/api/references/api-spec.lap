@errors {304: The ETag sent in the http header If-None-Match did not change. So you are up to date !, 404: Store not found or not authorized}

@endpoint PATCH /v2/user/customer/stores/{storeId}
@desc Update some store's information.
@required {storeId: any # Your store identifier, request: map}
@returns(204) Store updated
@errors {404: Store not found or customer not the owner, 409: The store name already used}

@endpoint DELETE /v2/user/customer/stores/{storeId}
@desc Delete a store
@required {storeId: any # Your store identifier}
@returns(204) Store deleted
@errors {404: Store not found or customer not the owner}

