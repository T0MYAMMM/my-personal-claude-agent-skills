@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api BeezUP Merchant API
@base https://api.beezup.com
@version 2.0
@auth ApiKey Ocp-Apim-Subscription-Key in header
@endpoints 249
@hint download_for_search
@toc public(8), user(222), orders(19)

@group public
@endpoint POST /v2/public/security/login
@desc Login
@required {request: map}
@returns(200) Your tokens
@errors {400: Bad Request, 403: Invalid credentials, 500: Occurs when something goes wrong}

@endpoint POST /v2/public/security/login/mfa
@desc Login
@required {request: map}
@returns(200) Your tokens
@returns(202) One time password sent by email
@errors {400: Bad Request, 401: OTP required for authentication, 403: Invalid credentials, 500: Occurs when something goes wrong}

@endpoint POST /v2/public/security/register
@desc User Registration
@required {request: map}
@returns(204) Customer registered
@errors {400: Email or password is invalid. Disposable email are refused., 409: Email already used, 500: Occurs when something goes wrong}

@endpoint POST /v2/public/security/lostpassword
@desc Lost password
@required {email: str(email) # Your email}
@returns(204) New password sent
@errors {400: Bad Request, 404: Email not found, 500: Occurs when something goes wrong, 502: Problem with SMTP service}

@endpoint GET /v2/public/channels/
@desc Get public channel index
@optional {If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
@returns(200) Channel list regrouped by country and links to list of values
@errors {304: The ETag sent in the http header If-None-Match did not change. So you are up to date !}

@endpoint GET /v2/public/channels/{countryIsoCode}
@desc The channel list for one country
@required {countryIsoCode: any # The country iso code alpha 3 based on this: https://en.wikipedia.org/wiki/ISO_3166-1_alpha-3#Decoding_table \ To know which country are available you have to use the operation: GetChannelsByCountry, Accept-Encoding: any # Allows the client to indicate whether it accepts a compressed encoding to reduce traffic size.}
@optional {If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
@returns(200) The channel list for one country
@errors {304: The ETag sent in the http header If-None-Match did not change. So you are up to date !, 404: Channel country not found}

@endpoint GET /v2/public/lov/
@desc Get all list names
@optional {If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
@returns(200) Get the list names
@errors {304: The ETag sent in the http header If-None-Match did not change. So you can keep your version.}

@endpoint GET /v2/public/lov/{listName}
@desc Get the list of values related to this list name
@required {listName: any # The list of value name your want to get}
@optional {Accept-Language: any # Indicates that the client accepts the following languages., If-None-Match: any # ETag value to identify the last known version of requested resource.\ To avoid useless exchange, we recommend you to indicate the ETag you previously got from this operation.\ If the ETag value does not match the response will be 200 to give you a new content, otherwise the response will be: 304 Not Modified, without any content.\ For more details go to this link: http://tools.ietf.org/html/rfc7232#section-2.3}
@returns(200) The list of values
@errors {304: The ETag sent in the http header If-None-Match did not change. So you can keep your version., 404: List not found}

@endgroup

