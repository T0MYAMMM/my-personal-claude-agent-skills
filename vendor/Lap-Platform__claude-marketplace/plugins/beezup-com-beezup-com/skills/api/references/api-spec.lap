@desc Get Order Invoice general settings
@returns(200) Settings successfully retrieved
@errors {403: The ownerId is not found or not authorized, 404: The order invoice general settings are not found}

@endpoint PUT /v2/user/marketplaces/orders/invoices/settings/design
@desc Save Order Invoice design settings
