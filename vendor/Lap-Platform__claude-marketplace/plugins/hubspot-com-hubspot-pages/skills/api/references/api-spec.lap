set the URL to be used in the rel=canonical link tag on the page., mabExperimentId: str # The ID of the MAB test (or dynamic test) associated with this page, if applicable, metaDescription: str # A description that goes in <meta> tag on the page., name: str # The internal name of the page., pageExpiryDate: int(int64) # The date at which this page should expire and begin redirecting to another url or page., pageExpiryEnabled: bool # Boolean describing if the page expiration feature is enabled for this page, pageExpiryRedirectId: int(int64) # The ID of another page this page's url should redirect to once this page expires. Should only set this or pageExpiryRedirectUrl., pageExpiryRedirectUrl: str # The URL this page's url should redirect to once this page expires. Should only set this or pageExpiryRedirectId., pageRedirected: bool # A generated Boolean describing whether or not this page is currently expired and being redirected., password: str # Set this to create a password protected page. Entering the password will be required to view the page., publicAccessRules: [map{}] # Rules for require member registration to access private content., publicAccessRulesEnabled: bool # Boolean to determine whether or not to respect publicAccessRules., publishDate: str(date-time) # The date (ISO8601 format) the page is to be published at., publishImmediately: bool # Set this to true if you want to be published immediately when the schedule publish endpoint is called, and to ignore the publish_date setting., slug: str # The path of the this page. This field is appended to the domain to construct the url of this page., state: str # An ENUM descibing the current state of this page., subcategory: str # Details the type of page this is. Should always be landing_page or site_page, templatePath: str # String detailing the path of the template used for this page., themeSettingsValues: map # A collection of settings specific to the theme applied to the page., translatedFromId: str # ID of the primary page this object was translated from., translations: map # A map of translations for the page, each associated with a specific language variation., updated: str(date-time) # The timestamp indicating when the page was last updated., updatedById: str # The ID of the user that updated this page., url: str # A generated field representing the URL of this page., useFeaturedImage: bool # Boolean to determine if this page should use a featuredImage., widgetContainers: map # A data structure containing the data for all the modules inside the containers for this page. This will only be populated if the page has widget containers., widgets: map # A data structure containing the data for all the modules for this page.}
@returns(200) successful operation
@returns(201) {abStatus: str, abTestId: str, archivedAt: str(date-time), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, pageRedirected: bool, password: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, slug: str, state: str, subcategory: str, templatePath: str, themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@endpoint POST /cms/v3/pages/landing-pages/ab-test/create-variation
@desc Create a new A/B test variation
@required {contentId: str # ID of the object to test., variationName: str # Name of A/B test variation.}
@returns(201) {abStatus: str, abTestId: str, archivedAt: str(date-time), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, pageRedirected: bool, password: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, slug: str, state: str, subcategory: str, templatePath: str, themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@endpoint POST /cms/v3/pages/landing-pages/ab-test/end
@desc End an active A/B test
@required {abTestId: str # The ID of the AB test associated with this page, if applicable, winnerId: str # ID of the object to designate as the test winner.}
@returns(204) No content

@endpoint POST /cms/v3/pages/landing-pages/ab-test/rerun
@desc Rerun a previous A/B test
@required {abTestId: str # The ID of the AB test associated with this page, if applicable, variationId: str # ID of the object to reactivate as a test variation.}
@returns(204) No content

@endpoint POST /cms/v3/pages/landing-pages/batch/archive
@desc Delete landing pages
@required {inputs: [str] # JSON nodes to input.}
@returns(204) No content

@endpoint POST /cms/v3/pages/landing-pages/batch/create
@desc Create landing pages
@required {inputs: [map{abStatus!: str, abTestId!: str, archivedAt!: str(date-time), archivedInDashboard!: bool, attachedStylesheets!: [map], authorName!: str, campaign!: str, categoryId!: int(int32), contentGroupId!: str, contentTypeCategory!: str, created!: str(date-time), createdById!: str, currentState!: str, currentlyPublished!: bool, domain!: str, dynamicPageDataSourceId!: str, dynamicPageDataSourceType!: int(int32), dynamicPageHubDbTableId!: str, enableDomainStylesheets!: bool, enableLayoutStylesheets!: bool, featuredImage!: str, featuredImageAltText!: str, folderId!: str, footerHtml!: str, headHtml!: str, htmlTitle!: str, id!: str, includeDefaultCustomCss!: bool, language!: str, layoutSections!: map, linkRelCanonicalUrl!: str, mabExperimentId!: str, metaDescription!: str, name!: str, pageExpiryDate!: int(int64), pageExpiryEnabled!: bool, pageExpiryRedirectId!: int(int64), pageExpiryRedirectUrl!: str, pageRedirected!: bool, password!: str, publicAccessRules!: [map], publicAccessRulesEnabled!: bool, publishDate!: str(date-time), publishImmediately!: bool, slug!: str, state!: str, subcategory!: str, templatePath!: str, themeSettingsValues!: map, translatedFromId!: str, translations!: map, updated!: str(date-time), updatedById!: str, url!: str, useFeaturedImage!: bool, widgetContainers!: map, widgets!: map}] # Pages to input.}
@returns(201) {completedAt: str(date-time), links: map, requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # successful operation
@returns(207) {completedAt: str(date-time), errors: [map], links: map, numErrors: int(int32), requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # multiple statuses

