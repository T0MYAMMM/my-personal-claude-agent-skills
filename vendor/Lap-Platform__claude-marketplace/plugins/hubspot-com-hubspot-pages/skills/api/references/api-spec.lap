@endpoint GET /cms/v3/pages/landing-pages/folders
@desc Get all landing page folders
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., archived: bool # Specifies whether to return deleted Folders. Defaults to `false`., createdAfter: str(date-time) # Only return Folders created after the specified time., createdAt: str(date-time) # Only return Folders created at exactly the specified time., createdBefore: str(date-time) # Only return Folders created before the specified time., limit: int(int32) # The maximum number of results to return. Default is 100., property: str # Specifies which properties of the landing page folders to include in the response., sort: [str] # Specifies which fields to use for sorting results. Valid fields are `name`, `createdAt`, `updatedAt`, `createdBy`, `updatedBy`. `createdAt` will be used by default., updatedAfter: str(date-time) # Only return Folders last updated after the specified time., updatedAt: str(date-time) # Only return Folders last updated at exactly the specified time., updatedBefore: str(date-time) # Only return Folders last updated before the specified time.}
@returns(200) {paging: map{next: map{after: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint POST /cms/v3/pages/landing-pages/folders
@desc Create a landing page folder
@required {category: int(int32) # The type of object this folder applies to. Should always be LANDING_PAGE., created: str(date-time) # The timestamp indicating when the content folder was created., deletedAt: str(date-time) # The timestamp (ISO8601 format) when this content folder was deleted., id: str # The unique ID of the content folder., name: str # The internal name of the page., parentFolderId: int(int64) # The ID of the content folder this folder is nested under, updated: str(date-time) # The timestamp indicating when the content folder was last updated.}
@returns(201) {category: int(int32), created: str(date-time), deletedAt: str(date-time), id: str, name: str, parentFolderId: int(int64), updated: str(date-time)} # successful operation

@endpoint POST /cms/v3/pages/landing-pages/folders/batch/archive
@desc Delete folders
@required {inputs: [str] # JSON nodes to input.}
@returns(204) No content

@endpoint POST /cms/v3/pages/landing-pages/folders/batch/create
@desc Create folders
@required {inputs: [map{category!: int(int32), created!: str(date-time), deletedAt!: str(date-time), id!: str, name!: str, parentFolderId!: int(int64), updated!: str(date-time)}] # JSON nodes to input.}
@returns(201) {completedAt: str(date-time), links: map, requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # successful operation
@returns(207) {completedAt: str(date-time), errors: [map], links: map, numErrors: int(int32), requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # multiple statuses

@endpoint POST /cms/v3/pages/landing-pages/folders/batch/read
@desc Retrieve folders
@required {inputs: [str] # JSON nodes to input.}
@optional {archived: bool # Specifies whether to return deleted Folders. Defaults to `false`.}
@returns(200) {completedAt: str(date-time), links: map, requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # successful operation
@returns(207) {completedAt: str(date-time), errors: [map], links: map, numErrors: int(int32), requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # multiple statuses

@endpoint POST /cms/v3/pages/landing-pages/folders/batch/update
@desc Update folders
@required {inputs: [map{}] # JSON nodes to input.}
@optional {archived: bool # Whether to return only results that have been archived.}
@returns(200) {completedAt: str(date-time), links: map, requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # successful operation
@returns(207) {completedAt: str(date-time), errors: [map], links: map, numErrors: int(int32), requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # multiple statuses

@endpoint GET /cms/v3/pages/landing-pages/folders/cursor
@optional {after: str, archived: bool, createdAfter: str(date-time), createdAt: str(date-time), createdBefore: str(date-time), limit: int(int32), property: str, sort: [str], updatedAfter: str(date-time), updatedAt: str(date-time), updatedBefore: str(date-time)}
@returns(200) successful operation

@endpoint GET /cms/v3/pages/landing-pages/folders/cursor/query
@optional {after: str, archived: bool, createdAfter: str(date-time), createdAt: str(date-time), createdBefore: str(date-time), limit: int(int32), property: str, sort: [str], updatedAfter: str(date-time), updatedAt: str(date-time), updatedBefore: str(date-time)}
@returns(200) successful operation

@endpoint GET /cms/v3/pages/landing-pages/folders/{objectId}
@desc Retrieve a landing page folder
@required {objectId: str # The ID of the landing page folder.}
@optional {archived: bool # Specifies whether to return deleted Folders. Defaults to `false`., property: str # Specifies which properties of the folder to include in the response.}
@returns(200) {category: int(int32), created: str(date-time), deletedAt: str(date-time), id: str, name: str, parentFolderId: int(int64), updated: str(date-time)} # successful operation

@endpoint DELETE /cms/v3/pages/landing-pages/folders/{objectId}
@desc Delete a landing page folder
@required {objectId: str # The ID of the landing page folder.}
@optional {archived: bool # Whether to return only results that have been archived.}
@returns(204) No content

@endpoint PATCH /cms/v3/pages/landing-pages/folders/{objectId}
@desc Update a landing page folder
@required {objectId: str # The ID of the landing page folder., category: int(int32) # The type of object this folder applies to. Should always be LANDING_PAGE., created: str(date-time) # The timestamp indicating when the content folder was created., deletedAt: str(date-time) # The timestamp (ISO8601 format) when this content folder was deleted., id: str # The unique ID of the content folder., name: str # The internal name of the page., parentFolderId: int(int64) # The ID of the content folder this folder is nested under, updated: str(date-time) # The timestamp indicating when the content folder was last updated.}
@optional {archived: bool # Specifies whether to update deleted Folders. Defaults to `false`.}
@returns(200) {category: int(int32), created: str(date-time), deletedAt: str(date-time), id: str, name: str, parentFolderId: int(int64), updated: str(date-time)} # successful operation

@endpoint GET /cms/v3/pages/landing-pages/folders/{objectId}/revisions
@desc Retrieves previous versions of a folder
@required {objectId: str # The ID of the folder.}
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., before: str # The cursor token value to retrieve the set of results before the specified cursor., limit: int(int32) # The maximum number of results to return. Default is 100.}
@returns(200) {paging: map{next: map{after: str, link: str}, prev: map{before: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint GET /cms/v3/pages/landing-pages/folders/{objectId}/revisions/{revisionId}
@desc Retrieve a previous version of a folder
@required {objectId: str # The Folder id., revisionId: str # The Folder version id.}
@returns(200) {id: str, object: map{category: int(int32), created: str(date-time), deletedAt: str(date-time), id: str, name: str, parentFolderId: int(int64), updated: str(date-time)}, updatedAt: str(date-time), user: map{email: str, fullName: str, id: str}} # successful operation

@endpoint POST /cms/v3/pages/landing-pages/folders/{objectId}/revisions/{revisionId}/restore
@desc Restore a previous version of a folder
@required {objectId: str # The Folder id., revisionId: str # The Folder version id to restore.}
@returns(200) {category: int(int32), created: str(date-time), deletedAt: str(date-time), id: str, name: str, parentFolderId: int(int64), updated: str(date-time)} # successful operation

