set the URL to be used in the rel=canonical link tag on the page., mabExperimentId: str # The ID of the MAB test (or dynamic test) associated with this page, if applicable, metaDescription: str # A description that goes in <meta> tag on the page., name: str # The internal name of the page., pageExpiryDate: int(int64) # The date at which this page should expire and begin redirecting to another url or page., pageExpiryEnabled: bool # Boolean describing if the page expiration feature is enabled for this page, pageExpiryRedirectId: int(int64) # The ID of another page this page's url should redirect to once this page expires. Should only set this or pageExpiryRedirectUrl., pageExpiryRedirectUrl: str # The URL this page's url should redirect to once this page expires. Should only set this or pageExpiryRedirectId., pageRedirected: bool # A generated Boolean describing whether or not this page is currently expired and being redirected., password: str # Set this to create a password protected page. Entering the password will be required to view the page., publicAccessRules: [map{}] # Rules for require member registration to access private content., publicAccessRulesEnabled: bool # Boolean to determine whether or not to respect publicAccessRules., publishDate: str(date-time) # The date (ISO8601 format) the page is to be published at., publishImmediately: bool # Set this to true if you want to be published immediately when the schedule publish endpoint is called, and to ignore the publish_date setting., slug: str # The path of the this page. This field is appended to the domain to construct the url of this page., state: str # An ENUM descibing the current state of this page., subcategory: str # Details the type of page this is. Should always be landing_page or site_page, templatePath: str # String detailing the path of the template used for this page., themeSettingsValues: map # A collection of settings specific to the theme applied to the page., translatedFromId: str # ID of 