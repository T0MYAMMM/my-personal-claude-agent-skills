@endpoint POST /cms/v3/pages/site-pages/{objectId}/draft/push-live
@desc Publish website page draft
@required {objectId: str # The ID of the website page.}
@returns(204) No content

@endpoint POST /cms/v3/pages/site-pages/{objectId}/draft/reset
@desc Reset the draft of a website page
@required {objectId: str # The ID of the website page to restore.}
@returns(204) No content

@endpoint GET /cms/v3/pages/site-pages/{objectId}/revisions
@desc Retrieve all previous versions of a website page
@required {objectId: str # The ID of the website page.}
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., before: str # The cursor token value to retrieve the set of results before the current page., limit: int(int32) # The maximum number of results to return. Default is 100.}
@returns(200) {paging: map{next: map{after: str, link: str}, prev: map{before: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint GET /cms/v3/pages/site-pages/{objectId}/revisions/{revisionId}
@desc Retrieve a previous version of a website page
@required {objectId: str # The ID of the website page., revisionId: str # The ID of the specific version to retrieve.}
@returns(200) {id: str, object: map{abStatus: str, abTestId: str, archivedAt: str(date-time), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, pageRedirected: bool, password: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, slug: str, state: str, subcategory: str, templatePath: str, themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map}, updatedAt: str(date-time), user: map{email: str, fullName: str, id: str}} # successful operation

@endpoint POST /cms/v3/pages/site-pages/{objectId}/revisions/{revisionId}/restore
@desc Restore a previous version of a website page
@required {objectId: str # The ID of the website page., revisionId: str # The ID of the specified version to restore.}
@returns(200) {abStatus: str, abTestId: str, archivedAt: str(date-time), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, pageRedirected: bool, password: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, slug: str, state: str, subcategory: str, templatePath: str, themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@endpoint POST /cms/v3/pages/site-pages/{objectId}/revisions/{revisionId}/restore-to-draft
@desc Restore a previous draft of a website page
@required {objectId: str # The ID of the website page., revisionId: int(int64) # The ID of the revision to restore.}
@returns(200) {abStatus: str, abTestId: str, archivedAt: str(date-time), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, pageRedirected: bool, password: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, slug: str, state: str, subcategory: str, templatePath: str, themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@end
