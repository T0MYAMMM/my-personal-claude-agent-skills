@endpoint POST /cms/v3/pages/landing-pages/{objectId}/draft/push-live
@desc Push Landing Page draft edits live
@required {objectId: str # The id of the Landing Page for which it's draft will be pushed live.}
@returns(204) No content

@endpoint POST /cms/v3/pages/landing-pages/{objectId}/draft/reset
@desc Reset a landing page draft
@required {objectId: str # The ID of the landing page to reset.}
@returns(204) No content

@endpoint GET /cms/v3/pages/landing-pages/{objectId}/revisions
@desc Retrieve all previous versions of a landing page
@required {objectId: str # The landing page ID.}
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., before: str # The cursor token value to retrieve the set of results before the current page., limit: int(int32) # The maximum number of results to return. Default is 100.}
@returns(200) {paging: map{next: map{after: str, link: str}, prev: map{before: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint GET /cms/v3/pages/landing-pages/{objectId}/revisions/{revisionId}
