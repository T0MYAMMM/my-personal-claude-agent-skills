@endpoint GET /cms/v3/pages/site-pages
@desc Retrieve all website pages
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., archived: bool # Specifies whether to return deleted Site Pages. Defaults to `false`., createdAfter: str(date-time) # Only return Site Pages created after the specified time., createdAt: str(date-time) # Only return Site Pages created at exactly the specified time., createdBefore: str(date-time) # Only return Site Pages created before the specified time., limit: int(int32) # The maximum number of results to return. Default is 100., property: str # Specifies which properties of the site pages to include in the response., sort: [str] # Specifies which fields to use for sorting results. Valid fields are `name`, `createdAt`, `updatedAt`, `createdBy`, `updatedBy`. `createdAt` will be used by default., updatedAfter: str(date-time) # Only return Site Pages last updated after the specified time., updatedAt: str(date-time) # Only return Site Pages last updated at exactly the specified time., updatedBefore: str(date-time) # Only return Site Pages last updated before the specified time.}
@returns(200) {paging: map{next: map{after: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint POST /cms/v3/pages/site-pages
