@returns(200) {EvaluationForm: EvaluationForm{EvaluationFormId: str, EvaluationFormVersion: int, Locked: bool, EvaluationFormArn: str, Title: str, Description: str?, Status: str, Items: [EvaluationFormItem], ScoringStrategy: EvaluationFormScoringStrategy?{Mode: str, Status: str}, CreatedTime: str(timestamp), CreatedBy: str, LastModifiedTime: str(timestamp), LastModifiedBy: str, Tags: map<str, str>?: any}}

