@optional {Description: str, ContactFlowId: str, Constraints: TaskTemplateConstraints, Defaults: TaskTemplateDefaults, Status: str, ClientToken: str}
@returns(200) {Id: str, Arn: str}

@endgroup

@group traffic-distribution-group
@endpoint PUT /traffic-distribution-group
@desc Creates a traffic distribution group given an Amazon Connect instance that has been replicated.   The SignInConfig distribution is available only on a default TrafficDistributionGroup (see the IsDefault parameter in the TrafficDistributionGroup data type). If you call UpdateTrafficDistribution with a modified SignInConfig and a non-default TrafficDistributionGroup, an InvalidRequestException is returned.  For more information about creating traffic distribution groups, see Set up traffic distribution groups in the Amazon Connect Administrator Guide.
@required {Name: str, InstanceId: str}
@optional {Description: str, ClientToken: str, Tags: map<str,str>}
@returns(200) {Id: str?, Arn: str?}

@endgroup

