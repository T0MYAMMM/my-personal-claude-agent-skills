@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Just Eat API
@base https://uk.api.just-eat.io
@version 1.0.0
@auth ApiKey Authorization in header | Bearer basic | Bearer bearer | openIdConnect | Bearer bearer
@endpoints 98
@hint download_for_search
@toc {tenant}(4), attempted-delivery-query-resolved(1), delivery-failed(1), checkout(3), orders(20), late-order-compensation-query(1), late-order-query(1), consumers(7), delivery-fees(1), delivery(12), acceptance-requested(1), order-accepted(1), order-cancelled(1), order-rejected(1), redelivery-requested(1), driver-assigned-to-delivery(1), driver-at-delivery-address(1), driver-at-restaurant(1), driver-has-delivered-order(1), driver-location(1), driver-on-their-way-to-delivery-address(1), order-is-ready-for-pickup(1), order-requires-delivery-acceptance(1), order-ready-for-preparation-async(1), order-ready-for-preparation-sync(1), send-to-pos-failed(1), restaurants(24), restaurant-offline-status(1), restaurant-online-status(1), order-eligible-for-restaurant-compensation(1), menu-ingestion-complete(1), order-time-updated(1), search(2)

@group {tenant}
@endpoint POST /{tenant}/orders/{orderId}/queries/attempteddelivery
@desc Delivery Attempt Failed
@required {tenant: str # Request tenant e.g. uk., orderId: str # Id for the order., Authorization: str # Containing a partner issued API key e.g. `JE-API-KEY ABCDE123456789`}
@optional {ReasonCode: str(problem_with_address/no_answer) # The reason the attempted delivery event was created}
@returns(200) OK
@errors {400: Bad Request - returned if providing invalid data such as an unacceptable reason code, 401: Unauthorized - consumer has not provided the necessary credentials, 404: Resource not found, 500: Internal server error}

@endpoint POST /{tenant}/orders/{orderId}/queries/attempteddelivery/resolution/redeliverorder
@desc Request Redelivery of the Order
@required {tenant: str # Request tenant e.g. uk., orderId: str # Id for the order., Authorization: str # Containing a partner issued API key e.g. `JE-API-KEY ABCDE123456789`}
@optional {Status: str(driver_at_address/repreparing) # The current status of the order, NewDueDate: str(date-time) # Updated due date for delivery of the order}
@returns(200) OK
@errors {400: Bad Request - returned if providing invalid data such as an unacceptable reason code, 401: Unauthorized - consumer has not provided the necessary credentials, 404: Resource not found, 500: Internal server error}

@endgroup

@group attempted-delivery-query-resolved
@endpoint PUT /attempted-delivery-query-resolved
@desc Attempted delivery query resolved
@optional {OrderId: str # The ID of the order for which an attempted delivery query has been resolved, Tenant: str(uk/dk/es/ie/it/no/au/nz) # The tenant of the restaurant the order was placed at, Resolution: map{Type: str, Cancellation: map{Reason: str}, Redelivery: map{Status: str, NewDueDate: str(date-time), CustomerTimeZone: str}} # Details of the resolution to the query}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group delivery-failed
@endpoint PUT /delivery-failed
@desc Delivery Attempt Failed
@optional {OrderId: str # The id of the order, RestaurantId: num # The id of the restaurant, Reason: str # The reason for creating the attempted delivery, Tenant: str # The tenant associated with the order}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group checkout
@endpoint GET /checkout/{tenant}/{checkoutId}
@desc Get Checkout
@required {tenant: str # A two-character country code.   The following countries are supported:   - United Kingdom (UK)   - Australia (AU)   - New Zealand (NZ), checkoutId: str # A unique identifier for a checkout. This is currently a Basket Id., User-Agent: str # Allows the server to identify the application making the request.}
@returns(200) {restaurant: map{id: str, availabilityId: str}, serviceType: str, customer: map{firstName: str?, lastName: str?, phoneNumber: str?}, fulfilment: map{time: map?{asap: bool, scheduled: map?{from: str, to: str}}, location: map?{address: map?{lines: [str], locality: str?, administrativeArea: str?, postalCode: str?}, geolocation: map?{latitude: num(decimal), longitude: num(decimal)}}}, isFulfillable: bool, issues: [map]} # OK : Request has succeeded.
@errors {400: BAD REQUEST : Cannot process the request due to error by client., 401: UNAUTHORIZED : Missing authentication credentials to access target resource., 403: FORBIDDEN : Not authorised to access target resource., 404: NOT FOUND : Target resource could not be found., 409: CONFLICT : Request not completed as it conflicts with target resource., 429: TOO MANY REQUESTS : Request not completed as server has received too many requests in a given amount of time., 500: INTERNAL SERVER ERROR : Error on server preventing request from being fulfilled., 503: SERVICE UNAVAILABLE : Server currently unable to fulfil the request. The request can be retried.}

@endpoint PATCH /checkout/{tenant}/{checkoutId}
@desc Update Checkout
@required {tenant: str # A two-character country code.   The following countries are supported:   - United Kingdom (UK)   - Australia (AU)   - New Zealand (NZ), checkoutId: str # A unique identifier for a checkout. This is currently a Basket Id., User-Agent: str # Allows the server to identify the application making the request.}
@returns(200) {isFulfillable: bool, issues: [map]} # OK : Request has succeeded.
@errors {400: BAD REQUEST : Cannot process the request due to error by client., 401: UNAUTHORIZED : Missing authentication credentials to access target resource., 403: FORBIDDEN : Not authorised to access target resource., 404: NOT FOUND : Target resource could not be found., 409: CONFLICT : Request not completed as it conflicts with target resource., 429: TOO MANY REQUESTS : Request not completed as server has received too many requests in a given amount of time., 500: INTERNAL SERVER ERROR : Error on server preventing request from being fulfilled., 503: SERVICE UNAVAILABLE : Server currently unable to fulfil the request. The request can be retried.}

@endpoint GET /checkout/{tenant}/{checkoutId}/fulfilment/availabletimes
@desc Get Available Fulfilment Times
@required {tenant: str # A two-character country code.   The following countries are supported:   - United Kingdom (UK)   - Australia (AU)   - New Zealand (NZ), checkoutId: str # A unique identifier for a checkout. This is currently a Basket Id., User-Agent: str # Allows the server to identify the application making the request.}
@returns(200) {times: [map], asapAvailable: bool} # OK : Request has succeeded.
@errors {400: BAD REQUEST : Cannot process the request due to error by client., 404: NOT FOUND : Target resource could not be found., 409: CONFLICT : Request not completed as it conflicts with target resource., 429: TOO MANY REQUESTS : Request not completed as server has received too many requests in a given amount of time., 500: INTERNAL SERVER ERROR : Error on server preventing request from being fulfilled., 503: SERVICE UNAVAILABLE : Server currently unable to fulfil the request. The request can be retried.}

@endgroup

@group orders
@endpoint POST /orders/{tenant}/{orderId}/consumerqueries/lateorder/restaurantresponse
@desc Response to Late Order Update Request
@required {tenant: str # Request tenant., orderId: str # Id for the order., Authorization: str # Containing a partner issued API key e.g. `JE-API-KEY ABCDE123456789`}
@optional {lateOrderStatus: str(Preparing/OnItsWay/Delivered) # The updated later order query status, additionalDeliveryTimeToAddMinutes: int # The amount of time to add to the current delivery estimate in minutes}
@returns(202) Accepted
@errors {400: Bad Request. Returned if the request is invalid i.e. missing a required parameters, 401: Unauthorized. Consumer is not authorized to modify the resource, 404: Not Found. Order query or Order not found, 409: Conflict. Query not in state to accept response, 500: Internal Server Error}
@example_request {"lateOrderStatus":"OnItsWay","additionalDeliveryTimeToAddMinutes":5}

@endpoint POST /orders/{tenant}/{orderId}/consumerqueries/lateordercompensation/restaurantresponse
@desc Update late order compensation request with Restaurant response
@required {tenant: str # Request tenant., orderId: str # Id for the order., Authorization: str # Containing a partner issued API key e.g. `JE-API-KEY ABCDE123456789`}
@optional {orderId: str # The ID of the late order compensation request that this response relates to., isAccepted: bool # Flag to indicate whether a compensation request has been accepted or rejected., acceptedAmount: int # The monetary amount of compensation granted, in cents/pence. Required when `isAccepted = true`., rejectedReasonCode: str(BadTraffic/BadWeather/BusierThanExpected/CompensatedWithItem/NoReason) # - `BadTraffic` : The driver was stuck in heavy traffic, sorry. - `BadWeather` : The bad weather was delaying our deliveries, sorry. - `BusierThanExpected` : Our restaurant was busier than we expected. - `CompensatedWithItem` : We gave you something from the menu free of charge to make up for it. - `NoReason` : We're really sorry your order was late. We hope you enjoyed your food.}
@returns(202) Accepted
@errors {400: Bad Request. Returned if the request is invalid - e.g. contains missing or invalid parameters., 401: Unauthorized. Consumer is not authorized to modify the resource, 404: Not Found. Order query or Order not found, 409: Conflict. Query not in state to accept response, 500: Internal Server Error}

@endgroup

@group late-order-compensation-query
@endpoint POST /late-order-compensation-query
@desc late order compensation query, restaurant response required
@optional {restaurantId: str # Just Eat restaurant identifier, orderId: str # Just Eat order identifier, tenant: str # Tenant (Country) of order restaurant., compensationOptions: [map{amount: num(decimal), isRecommended: bool}]}
@returns(200) Respond with a 200 status code to indicate that you have received the notification

@endgroup

@group late-order-query
@endpoint POST /late-order-query
@desc late order query, restaurant response required
@optional {restaurantId: str # Just Eat restaurant identifier, orderId: str # Just Eat order identifier, tenant: str # Tenant (Country) of order restaurant.}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group consumers
@endpoint POST /consumers/{tenant}
@desc Create consumer
@required {tenant: str # The identifier for the tenant. The only supported tenants are `uk`, `au` and `nz`, emailAddress: str(email) # The consumer's email address, firstName: str # The consumer's first name, lastName: str # The consumer's last name}
@optional {password: str # The consumer's password, registrationSource: str(Native/Guest)=Native # The registration source of the consumer. Australia and New Zealand only support Guest, marketingPreferences: [map{channelName: str, isSubscribed: bool, dateUpdated: str(date-time)}]}
@returns(201) {type: str, token: str} # Consumer created.
@errors {400: Bad request., 403: Forbidden., 404: The specified tenant does not exist., 409: The specified email already exists., 500: Internal Server Error}

@endpoint GET /consumers/{tenant}
@desc Get consumers details
@required {tenant: str # The identifier for the tenant., emailAddress: str # Email address of the consumer., accountType: str=registered # The account type of the consumer - currently only 'registered' accounts are supported., count: str # Returns the number of consumers that matches the `emailAddress` and `accountType`. The query value should be empty, e.g. `/consumers/uk/?emailAddress=someone@email.com&accountType=registered&count`.}
@returns(200) Success
@errors {400: Bad request., 404: The specified tenant does not exist., 500: Internal Server Error, 501: The operation has not been implemented}

@endpoint GET /consumers/{tenant}/me/communication-preferences
@desc Get communication preferences
@required {tenant: str # Request tenant.}
@returns(200) {marketing: map{isDefault: bool, subscribedChannels: [str]}} # Success
@errors {401: Unauthorized, 403: Forbidden, 404: Not Found, 500: Internal Server Error}

@endpoint GET /consumers/{tenant}/me/communication-preferences/{type}
@desc Get channel subscriptions for a given consumer's communication preference type
@required {tenant: str # Request tenant., type: str # The type of communication preferences.}
@returns(200) {isDefault: bool, subscribedChannels: [str]} # Success
@errors {401: Unauthorized, 403: Forbidden, 404: Not Found, 500: Internal Server Error}

@endpoint PUT /consumers/{tenant}/me/communication-preferences/{type}
@desc Set only the channel subscriptions for a given consumer's communication preference type
@required {tenant: str # Request tenant., type: str # The type of communication preferences.}
@optional {subscribedChannels: [str] # The list of channels that the consumer should only be subscribed to.}
@returns(204) Success
@errors {401: Unauthorized, 404: Not Found, 500: Internal Server Error}
@example_request {"subscribedChannels":["email","sms"]}

@endpoint POST /consumers/{tenant}/me/communication-preferences/{type}/subscribedChannels/{channel}
@desc Subscribe to a specific communication preference channel
@required {tenant: str # Request tenant., type: str # The type of communication preferences., channel: str # The channel.}
@returns(204) Success
@errors {401: Unauthorized, 403: Forbidden, 404: Not Found, 500: Internal Server Error}

@endpoint DELETE /consumers/{tenant}/me/communication-preferences/{type}/subscribedChannels/{channel}
@desc Remove subscription of a specific communication preference channel
@required {tenant: str # Request tenant., type: str # The type of communication preference., channel: str # The channel.}
@returns(204) Success
@errors {401: Unauthorized, 404: Not Found, 500: Internal Server Error}

@endgroup

@group delivery-fees
@endpoint GET /delivery-fees/{tenant}
@desc Get restaurant delivery fees
@required {tenant: str # Tenant containing the restaurants., restaurantIds: [str] # Restaurant IDs which fees are requested for. e.g. `?restaurantIds=1,2,3,4`, deliveryTime: str(date-time) # Delivery date/time when fees are required (ISO8601 format).}
@optional {zone: str # Postcode or other location name identifying the location to which delivery is required. For use when precise location is not available. This will be removed in future in favour of location., latlong: [num(double)] # Point to which delivery is required (latitude, longitude). Supply this where possible as support for zone-only based lookups will be removed in future.}
@returns(200) {restaurants: [map]} # Success
@errors {400: Bad request, 404: Not found}

@endgroup

@group delivery
@endpoint GET /delivery/pools
@desc Get your delivery pools
@returns(200) {delivery-pool-id: map{name: str, restaurants: [num(int32)]}} # OK
@errors {500: Internal Server Error}

@endpoint POST /delivery/pools
@desc Create a new delivery pool
@required {name: str # The name of the pool, used by operations teams, in reports, etc.}
@optional {restaurants: [num(int32)] # A list of Just Eat restaurant ids served by the delivery pool.}
@returns(201) Pool has been created.
@errors {400: There was something invalid in your request - check response body for details, 500: Internal Server Error}

@endpoint GET /delivery/pools/{deliveryPoolId}
@desc Get an individual delivery pool
@returns(200) {name: str, restaurants: [num(int32)]} # OK
@errors {404: The pool could not be found, 500: Internal Server Error}

@endpoint DELETE /delivery/pools/{deliveryPoolId}
@desc Delete a delivery pool
@returns(200) Pool deleted
@errors {404: The pool could not be found, 500: Internal Server Error}

@endpoint PATCH /delivery/pools/{deliveryPoolId}
@desc Modify a delivery pool
@optional {name: str # The name of the pool, used by operations teams, in reports, etc., restaurants: [num(int32)] # A list of Just Eat restaurant ids served by the delivery pool.}
@returns(202) {name: str, restaurants: [num(int32)]} # Pool has been updated
@errors {400: There was something invalid in your request - check response body for details, 404: The pool could not be found, 409: A restaurant in your request already belongs to another pool, 500: Internal Server Error}

@endpoint PUT /delivery/pools/{deliveryPoolId}
@desc Replace an existing delivery pool
@required {name: str # The name of the pool, used by operations teams, in reports, etc.}
@optional {restaurants: [num(int32)] # A list of Just Eat restaurant ids served by the delivery pool.}
@returns(202) {name: str, restaurants: [num(int32)]} # Pool has been replaced
@errors {400: There was something invalid in your request - check response body for details, 404: The pool could not be found, 409: A restaurant in your request already belongs to another pool, 500: Internal Server Error}

@endpoint GET /delivery/pools/{deliveryPoolId}/availability/relative
@desc Get availability for pickup
@returns(200) {bestGuess: str} # OK
@errors {404: The pool could not be found}

@endpoint PUT /delivery/pools/{deliveryPoolId}/availability/relative
@desc Set availability for pickup
@optional {bestGuess: str # Your best estimation (hh:mm:ss)}
@returns(202) Update will take effect shortly
@errors {404: The pool could not be found}

@endpoint PUT /delivery/pools/{deliveryPoolId}/hours
@desc Set the delivery pools daily start and end times
@required {monday: map{closed: bool, poolTimes!: [map{startTime!: str, endTime!: str}]}, tuesday: map{closed: bool, poolTimes!: [map{startTime!: str, endTime!: str}]}, wednesday: map{closed: bool, poolTimes!: [map{startTime!: str, endTime!: str}]}, thursday: map{closed: bool, poolTimes!: [map{startTime!: str, endTime!: str}]}, friday: map{closed: bool, poolTimes!: [map{startTime!: str, endTime!: str}]}, saturday: map{closed: bool, poolTimes!: [map{startTime!: str, endTime!: str}]}, sunday: map{closed: bool, poolTimes!: [map{startTime!: str, endTime!: str}]}}
@returns(200) Pool hours have been updated
@errors {404: The pool could not be found}

@endpoint PUT /delivery/pools/{deliveryPoolId}/restaurants
@desc Add restaurants to an existing delivery pool
@returns(200) {restaurants: [num(int32)]} # OK
@errors {400: There was something invalid in your request - check response body for details, 404: The pool could not be found, 409: The restaurants could not be added to the pool. Typically this is because they are already assigned to another pool}

@endpoint DELETE /delivery/pools/{deliveryPoolId}/restaurants
@desc Remove restaurants from a delivery pool
@optional {restaurants: [num(int32)] # A list of Just Eat restaurant ids served by the delivery pool.}
@returns(200) Pool has been updated
@errors {400: There was something invalid in your request - check response body for details, 404: The pool could not be found}

@endgroup

@group orders
@endpoint PUT /orders/{orderId}/accept
@desc Accept order
@required {orderId: str}
@optional {TimeAcceptedFor: str(date-time)}
@returns(200) OK
@errors {404: Order could not be found, 409: Conflict. This order has either already been accepted, rejected or ignored by restaurant or cancelled by ops}

@endpoint PUT /orders/{orderId}/cancel
@desc Cancel order
@required {orderId: str}
@optional {Message: str # Reason why this order is being cancelled.}
@returns(200) OK
@errors {404: Order could not be found, 409: Conflict. This order has already been cancelled}

@endpoint POST /orders/{orderId}/complete
@desc Complete order
@required {orderId: str # The ID of the order to mark as complete}
@returns(204) No content - status updated successfully
@errors {404: Not found - order could not be found, 409: Conflict - this order has already been marked as cancelled or complete, 500: Internal Server Error}

@endpoint PUT /orders/{orderId}/duedate
@desc Update order ETA
@required {orderId: str}
@optional {DueDate: str(date-time) # The updated ETA for the order}
@returns(200) OK
@errors {400: The due date is missing, or out of range (either in the past, or > 7 days in the future)., 404: The order could not be found.}

@endpoint PUT /orders/{orderId}/ignore
@desc Ignore order
@required {orderId: str}
@returns(200) OK
@errors {404: Order could not be found, 409: Conflict. This order has either already been accepted, rejected or ignored by restaurant or cancelled by ops}

@endpoint POST /orders/{orderId}/readyforcollection
@desc Mark order as ready for collection
@required {orderId: str # The ID of the order to mark as ready for collection}
@returns(204) No content - status updated successfully
@errors {400: Bad request - order cannot be marked as ready for collection because it is not a collection order, 404: Not found - order could not be found, 409: Conflict - this order is not in the accepted state, 500: Internal Server Error}

@endpoint PUT /orders/{orderId}/reject
@desc Reject order
@required {orderId: str}
@optional {Message: str # Reason why this order is being rejected.}
@returns(200) OK
@errors {404: Order could not be found, 409: Conflict. This order has either already been accepted, rejected or ignored by restaurant or cancelled by ops}

@endgroup

@group acceptance-requested
@endpoint POST /acceptance-requested
@desc Acceptance requested
@optional {OrderId: str, FriendlyOrderReference: str, Currency: str, TotalPrice: num(money), Fulfilment: map{Method: str, PhoneNumber: str, PhoneMaskingCode: str, CustomerDueDate: str(date-time), CustomerDueAsap: bool, PreparationTime: str(timespan), Address: map{Lines: [str], City: str, PostalCode: str, Geolocation: map}}, Payment: map{Lines: [map{Type: str, Value: num(money), Paid: bool}]}, Customer: map{Id: num, Name: str, PreviousRestaurantOrderCount: num, PreviousTotalOrderCount: num}, Restrictions: [map{Type: str}] # This is a list of types of restricted items contained in the order., Items: [map{Reference: str, Name: str, Quantity: num, UnitPrice: num(money), TotalPrice: num(money), Items: [map{Reference: str, Name: str, Quantity: num, UnitPrice: num(money), TotalPrice: num(money), Items: [map]}]}], PriceBreakdown: map{Discount: num(money), Tips: num(money), Taxes: num(money), Items: num(money), Fees: map{Delivery: num(money), ServiceCharge: num(money), Other: num(money)}}, PlacedDate: str(date-time), CustomerNotes: map, Restaurant: map{Id: str, Reference: str, Name: str, Address: map{Lines: [str], City: str, PostalCode: str, Geolocation: map}, TimeZone: str, PhoneNumber: str}, IsTest: bool}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group order-accepted
@endpoint POST /order-accepted
@desc Order accepted
@optional {OrderId: str, AcceptedFor: str(date-time), Event: str}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group order-cancelled
@endpoint POST /order-cancelled
@desc Order cancelled
@optional {OrderId: str, Event: str, Reason: str(cust_cancelled_changed_mind/cust_cancelled_delivery_too_long/cust_cancelled_made_mistake/cust_cancelled_other/delivery_partner_cancelled/rest_cancelled_customer_absent/rest_cancelled_customer_requested/rest_cancelled_declined/rest_cancelled_drivers_unavailable/rest_cancelled_fake_order/rest_cancelled_other/rest_cancelled_out_of_stock/rest_cancelled_too_busy/system_cancelled_other/system_cancelled_test_order) # The reason the order was cancelled.}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group order-rejected
@endpoint POST /order-rejected
@desc Order rejected
@optional {RejectedAt: str(date-time), RejectedBy: str, RejectedReason: str, Event: str}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group redelivery-requested
@endpoint PUT /redelivery-requested
@desc Customer Requested Redelivery
@optional {OrderId: str, Tenant: str, Update: str, Notes: str}
@returns(200) Respond with a 200 status code to indicate that you have received the notification.

@endgroup

@group delivery
@endpoint GET /delivery/estimate
@desc Get delivery estimate
@required {restaurantReference: str # The reference of the restaurant to estimate the delivery time from.}
@optional {toLat: str # The latitude of the position to estimate the delivery time to., toLon: str # The longitude of the position to estimate the delivery time to., toPostcode: str # The postcode to estimate the delivery time to.}
@returns(200) {RestaurantReference: str, DurationInMinutes: str} # OK

@endgroup

@group orders
@endpoint PUT /orders/{orderId}/deliverystate/atdeliveryaddress
@desc Update order with driver at delivery address details
@required {orderId: str # Just Eat order identifier}
@optional {Location: map{Latitude!: num(double), Longitude!: num(double), Speed: num(double), Heading: num(double), Accuracy: num(double)} # GeoLocation object containing latitude and longitude values., TimeStampWithUtcOffset: str(date-time) # This should represent the delivery detailed updated timestamp.}
@returns(200) OK

@endpoint PUT /orders/{orderId}/deliverystate/atrestaurant
@desc Update order with driver at restaurant details
@required {orderId: str # Just Eat order identifier}
@optional {EtaAtDeliveryAddress: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the delivery address., Location: map{Latitude!: num(double), Longitude!: num(double), Speed: num(double), Heading: num(double), Accuracy: num(double)} # GeoLocation object containing latitude and longitude values., TimeStampWithUtcOffset: str(date-time) # This should represent the Eta calculated timestamp.}
@returns(200) OK

@endpoint PUT /orders/{orderId}/deliverystate/atrestauranteta
@desc Update the driver's estimated time to arrive at the Restaurant
@required {orderId: str # Just Eat order identifier}
@optional {estimatedAt: str(date-time) # This is the time at which you are doing the estimation, bestGuess: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the restaurant.}
@returns(200) OK

@endpoint PUT /orders/{orderId}/deliverystate/delivered
@desc Update order with delivered details
@required {orderId: str # Just Eat order identifier}
@optional {Location: map{Latitude!: num(double), Longitude!: num(double), Speed: num(double), Heading: num(double), Accuracy: num(double)} # GeoLocation object containing latitude and longitude values., TimeStampWithUtcOffset: str(date-time) # This should represent the delivery detailed updated timestamp.}
@returns(200) OK

@endpoint PUT /orders/{orderId}/deliverystate/driverassigned
@desc Update order with driver assigned details
@required {orderId: str # Just Eat order identifier}
@optional {DriverName: str # This should represent the driver's name., DriverContactNumber: str # This should represent the driver's contact number., VehicleDetails: map{Vehicle: str, VehicleRegistration: str}, EtaAtRestaurant: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the restaurant. In other words, it should not just contain the pick-up time initially requested by Just Eat., EtaAtDeliveryAddress: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the delivery address., Location: map{Latitude!: num(double), Longitude!: num(double), Speed: num(double), Heading: num(double), Accuracy: num(double)} # GeoLocation object containing latitude and longitude values., TimeStampWithUtcOffset: str(date-time) # This should represent the driver assigned timestamp.}
@returns(200) OK

@endpoint PUT /orders/{orderId}/deliverystate/driverlocation
@desc Update the driver's current location
@required {orderId: str # Just Eat order identifier}
@optional {EtaAtDeliveryAddress: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the delivery address., EtaAtRestaurant: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the restaurant., Location: map{Latitude!: num(double), Longitude!: num(double), Speed: num(double), Heading: num(double), Accuracy: num(double)} # GeoLocation object containing latitude and longitude values., TimeStampWithUtcOffset: str(date-time) # This should represent the location updated timestamp.}
@returns(200) OK

@endpoint PUT /orders/{orderId}/deliverystate/driverunassigned
@desc Update order with driver unassigned details
@required {orderId: str # Just Eat order identifier}
@optional {Comment: str # This should represent the comment on the unassignment., DriverContactNumber: str # This should represent the driver's contact number., DriverName: str # This should represent the driver's name., EtaAtDeliveryAddress: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the delivery address., EtaAtRestaurant: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the restaurant. In other words, it should not just contain the pick-up time initially requested by Just Eat., Location:: map{Latitude!: num(double), Longitude!: num(double), Speed: num(double), Heading: num(double), Accuracy: num(double)} # GeoLocation object containing latitude and longitude values., Reason: str # This should represent the delivery partner's reason for unassigning themselves from the order., TimeStampWithUtcOffset: str(date-time) # This should represent the driver unassigned timestamp., UnassignedBy: str # This should represent the actor who triggered unassignment.}
@returns(200) OK
@errors {400: Bad Request.}

@endpoint PUT /orders/{orderId}/deliverystate/onitsway
@desc Update order with driver on its way details
@required {orderId: str}
@optional {EstimatedArrivalTime: str(date-time) # This should represent the delivery partner's best guess at when the driver will arrive at the customer's address. In other words, it should not just contain the delivery time initially requested by Just Eat., Location: map{Latitude!: num(double), Longitude!: num(double), Speed: num(double), Heading: num(double), Accuracy: num(double)} # GeoLocation object containing latitude and longitude values., TimeStampWithUtcOffset: str(date-time) # This should represent the driver on its ways timestamp.}
@returns(200) OK

@endpoint PUT /orders/deliverystate/driverlocation
@desc Update current driver locations (bulk upload)
@returns(200) OK

@endgroup

@group driver-assigned-to-delivery
@endpoint PUT /driver-assigned-to-delivery
