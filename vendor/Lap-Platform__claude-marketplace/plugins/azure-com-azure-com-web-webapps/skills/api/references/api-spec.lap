@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hybridconnection/{entityName}
@desc Creates a new hybrid connection configuration (PUT), or updates an existing one (PATCH).
@required {entityName: any # Name of the hybrid connection configuration., connectionEnvelope: map # Details of the hybrid connection configuration.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances
@desc Gets all scale-out instances of an app.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/extensions/MSDeploy
@desc Get the status of the last MSDeploy operation.
@required {instanceId: any # ID of web app instance.}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/extensions/MSDeploy
@desc Invoke the MSDeploy web app extension.
@required {instanceId: any # ID of web app instance., MSDeploy: map # Details of MSDeploy operation}
@returns(201) Deployment is scheduled.
@errors {409: Another deployment is in progress.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/extensions/MSDeploy/log
@desc Get the MSDeploy Log for the last MSDeploy operation.
@required {instanceId: any # ID of web app instance.}
@returns(200) MSDeploy log returned.
