@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/processes
@desc Get list of processes for a web site, or a deployment slot, or for a specific scaled-out instance in a web site.
@required {instanceId: any # ID of a specific scaled-out instance. This is the value of the name property in the JSON response from "GET api/sites/{siteName}/instances".}
@returns(200) Process terminated.
@errors {404: Process with the specified ID is not running.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/processes/{processId}
@desc Get process information by its ID for a specific scaled-out instance in a web site.
@required {processId: any # PID., instanceId: any # ID of a specific scaled-out instance. This is the value of the name property in the JSON response from "GET api/sites/{siteName}/instances".}
@returns(200) Process information returned.
@errors {404: Process with the specified ID is not running.}

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/processes/{processId}
@desc Terminate a process by its ID for a web site, or a deployment slot, or specific scaled-out instance in a web site.
@required {processId: any # PID., instanceId: any # ID of a specific scaled-out instance. This is the value of the name property in the JSON response from "GET api/sites/{siteName}/instances".}
@returns(204) Process terminated.
@errors {404: Process with the specified ID is not running.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/processes/{processId}/dump
@desc Get a memory dump of a process by its ID for a specific scaled-out instance in a web site.
@required {processId: any # PID., instanceId: any # ID of a specific scaled-out instance. This is the value of the name property in the JSON response from "GET api/sites/{siteName}/instances".}
@returns(200) OK
@errors {404: Process with the specified ID is not running.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/processes/{processId}/modules
@desc List module information for a process by its ID for a specific scaled-out instance in a web site.
@required {processId: any # PID., instanceId: any # ID of a specific scaled-out instance. This is the value of the name property in the JSON response from "GET api/sites/{siteName}/instances".}
@returns(200) Module information returned.
@errors {404: Process with the specified ID is not running.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/instances/{instanceId}/processes/{processId}/modules/{baseAddress}
@desc Get process information by its ID for a specific scaled-out instance in a web site.
@required {processId: any # PID., baseAddress: any # Module base address., instanceId: any # ID of a specific scaled-out instance. This is the value of the name property in the JSON response from "GET api/sites/{siteName}/instances".}
@returns(200) Module information returned.
