@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api WebApps API Client
@base https://management.azure.com
@version 2018-11-01
@auth OAuth2
@common_fields {subscriptionId: any # Your Azure subscription ID. This is a GUID-formatted string (e.g. 00000000-0000-0000-0000-000000000000)., api-version: any # API Version, resourceGroupName: any # Name of the resource group to which the resource belongs., name: any # Name of the app.}
@endpoints 349
@hint download_for_search
@toc subscriptions(349)

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Web/sites
@desc Get all apps for a subscription.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites
@desc Gets all web, mobile, and API apps in the specified resource group.
@optional {includeSlots: any # Specify <strong>true</strong> to include deployment slots in results. The default is false, which only gives you the production slot of all apps.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}
@desc Gets the details of a web, mobile, or API app.
@returns(200) OK.
@errors {404: Not found.}

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}
@desc Creates a new web, mobile, or API app in an existing resource group, or updates an existing app.
@required {siteEnvelope: any # A JSON representation of the app properties. See example.}
@returns(200) OK.
@returns(202) Asynchronous operation in progress.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}
@desc Deletes a web, mobile, or API app, or one of the deployment slots.
@optional {deleteMetrics: any # If true, web app metrics are also deleted., deleteEmptyServerFarm: any # Specify false if you want to keep empty App Service plan. By default, empty App Service plan is deleted.}
@returns(200) Successfully deleted web app.
@returns(204) Successfully deleted web app.
@errors {404: Web app not found.}

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}
@desc Creates a new web, mobile, or API app in an existing resource group, or updates an existing app.
@required {siteEnvelope: map # A JSON representation of the app properties. See example.}
@returns(200) OK.
@returns(202) Asynchronous operation in progress.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/analyzeCustomHostname
@desc Analyze a custom hostname.
@optional {hostName: any # Custom hostname.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/applySlotConfig
@desc Applies the configuration settings from the target slot onto the current slot.
@required {slotSwapEntity: map # JSON object that contains the target slot name. See example.}
@returns(200) OK.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/backup
@desc Creates a backup of an app.
@required {request: map # Backup configuration. You can use the JSON response from the POST action as input here.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/backups
@desc Gets existing backups of an app.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/backups/{backupId}
@desc Gets a backup of an app by its ID.
@required {backupId: any # ID of the backup.}
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/backups/{backupId}
@desc Deletes a backup of an app by its ID.
@required {backupId: any # ID of the backup.}
@returns(200) Successfully deleted web app backup item.
@errors {404: Web app backup item does not exist.}

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/backups/{backupId}/list
@desc Gets status of a web app backup that may be in progress, including secrets associated with the backup, such as the Azure Storage SAS URL. Also can be used to update the SAS URL for the backup if a new URL is passed in the request body.
@required {backupId: any # ID of backup., request: map # Information on backup request.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/backups/{backupId}/restore
@desc Restores a specific backup to another app (or deployment slot, if specified).
@required {backupId: any # ID of the backup., request: map # Information on restore request .}
@returns(202) Restore operation started.
@returns(200) Restore operation started.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config
@desc List the configurations of an app
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/appsettings
@desc Replaces the application settings of an app.
@required {appSettings: map # Application settings of the app.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/appsettings/list
@desc Gets the application settings of an app.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/authsettings
@desc Updates the Authentication / Authorization settings associated with web app.
@required {siteAuthSettings: map # Auth settings associated with web app.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/authsettings/list
@desc Gets the Authentication/Authorization settings of an app.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/azurestorageaccounts
@desc Updates the Azure storage account configurations of an app.
@required {azureStorageAccounts: map # Azure storage accounts of the app.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/azurestorageaccounts/list
@desc Gets the Azure storage account configurations of an app.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/backup
@desc Updates the backup configuration of an app.
@required {request: map # Edited backup configuration.}
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/backup
@desc Deletes the backup configuration of an app.
@returns(200) Successfully deleted backup configuration.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/backup/list
@desc Gets the backup configuration of an app.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/connectionstrings
@desc Replaces the connection strings of an app.
@required {connectionStrings: map # Connection strings of the app or deployment slot. See example.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/connectionstrings/list
@desc Gets the connection strings of an app.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/logs
@desc Gets the logging configuration of an app.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/logs
@desc Updates the logging configuration of an app.
@required {siteLogsConfig: map # A SiteLogsConfig JSON object that contains the logging configuration to change in the "properties" property.}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/metadata
@desc Replaces the metadata of an app.
@required {metadata: map # Edited metadata of the app or deployment slot. See example.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/metadata/list
@desc Gets the metadata of an app.
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/publishingcredentials/list
@desc Gets the Git/FTP publishing credentials of an app.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/pushsettings
@desc Updates the Push settings associated with web app.
@required {pushSettings: any # Push settings associated with web app.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/pushsettings/list
@desc Gets the Push settings associated with web app.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/slotConfigNames
@desc Gets the names of app settings and connection strings that stick to the slot (not swapped).
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/slotConfigNames
@desc Updates the names of application settings and connection string that remain with the slot during swap operation.
@required {slotConfigNames: map # Names of application settings and connection strings. See example.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/web
@desc Gets the configuration of an app, such as platform version and bitness, default documents, virtual applications, Always On, etc.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/web
@desc Updates the configuration of an app.
@required {siteConfig: map # JSON representation of a SiteConfig object. See example.}
@returns(200) OK

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/web
@desc Updates the configuration of an app.
@required {siteConfig: map # JSON representation of a SiteConfig object. See example.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/web/snapshots
@desc Gets a list of web app configuration snapshots identifiers. Each element of the list contains a timestamp and the ID of the snapshot.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/web/snapshots/{snapshotId}
@desc Gets a snapshot of the configuration of an app at a previous point in time.
@required {snapshotId: any # The ID of the snapshot to read.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/config/web/snapshots/{snapshotId}/recover
@desc Reverts the configuration of an app to a previous snapshot.
@required {snapshotId: any # The ID of the snapshot to read.}
@returns(204) No Content

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/containerlogs
@desc Gets the last lines of docker logs for the given site
@returns(204) No Content
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/containerlogs/zip/download
@desc Gets the ZIP archived docker log files for the given site
@returns(204) No Content
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/continuouswebjobs
@desc List continuous web jobs for an app, or a deployment slot.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/continuouswebjobs/{webJobName}
@desc Gets a continuous web job by its ID for an app, or a deployment slot.
@required {webJobName: any # Name of Web Job.}
@returns(200) Found continuous web job.
@errors {404: Continuous web job does not exist.}

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/continuouswebjobs/{webJobName}
@desc Delete a continuous web job by its ID for an app, or a deployment slot.
@required {webJobName: any # Name of Web Job.}
@returns(200) Successfully deleted continuous web job.
@returns(204) Continuous web job does not exist.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/continuouswebjobs/{webJobName}/start
@desc Start a continuous web job for an app, or a deployment slot.
@required {webJobName: any # Name of Web Job.}
@returns(200) Found continuous web job.
@errors {404: Continuous web job does not exist.}

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/continuouswebjobs/{webJobName}/stop
@desc Stop a continuous web job for an app, or a deployment slot.
@required {webJobName: any # Name of Web Job.}
@returns(200) Found continuous web job.
@errors {404: Continuous web job does not exist.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/deployments
@desc List deployments for an app, or a deployment slot.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/deployments/{id}
@desc Get a deployment by its ID for an app, or a deployment slot.
@required {id: any # Deployment ID.}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/deployments/{id}
@desc Create a deployment for an app, or a deployment slot.
@required {id: any # ID of an existing deployment., deployment: map # Deployment details.}
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/deployments/{id}
@desc Delete a deployment by its ID for an app, or a deployment slot.
@required {id: any # Deployment ID.}
@returns(200) Successfully deleted deployment.
@returns(204) Deployment does not exist.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/deployments/{id}/log
@desc List deployment log for specific deployment for an app, or a deployment slot.
@required {id: any # The ID of a specific deployment. This is the value of the name property in the JSON response from "GET /api/sites/{siteName}/deployments".}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/discoverbackup
@desc Discovers an existing app backup that can be restored from a blob in Azure storage. Use this to get information about the databases stored in a backup.
@required {request: map # A RestoreRequest object that includes Azure storage URL and blog name for discovery of backup.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/domainOwnershipIdentifiers
@desc Lists ownership identifiers for domain associated with web app.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/domainOwnershipIdentifiers/{domainOwnershipIdentifierName}
@desc Get domain ownership identifier for web app.
@required {domainOwnershipIdentifierName: any # Name of domain ownership identifier.}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/domainOwnershipIdentifiers/{domainOwnershipIdentifierName}
@desc Creates a domain ownership identifier for web app, or updates an existing ownership identifier.
@required {domainOwnershipIdentifierName: any # Name of domain ownership identifier., domainOwnershipIdentifier: any # A JSON representation of the domain ownership properties.}
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/domainOwnershipIdentifiers/{domainOwnershipIdentifierName}
@desc Deletes a domain ownership identifier for a web app.
@required {domainOwnershipIdentifierName: any # Name of domain ownership identifier.}
@returns(200) Successfully deleted domain ownership identifier.
@returns(204) Domain ownership identifier does not exist.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/domainOwnershipIdentifiers/{domainOwnershipIdentifierName}
@desc Creates a domain ownership identifier for web app, or updates an existing ownership identifier.
@required {domainOwnershipIdentifierName: any # Name of domain ownership identifier., domainOwnershipIdentifier: any # A JSON representation of the domain ownership properties.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/extensions/MSDeploy
@desc Get the status of the last MSDeploy operation.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/extensions/MSDeploy
@desc Invoke the MSDeploy web app extension.
@required {MSDeploy: map # Details of MSDeploy operation}
@returns(201) Deployment is scheduled.
@errors {409: Another deployment is in progress.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/extensions/MSDeploy/log
@desc Get the MSDeploy Log for the last MSDeploy operation.
@returns(200) MSDeploy log returned.
@errors {404: MSDeploy log not found.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/functions
@desc List the functions for a web site, or a deployment slot.
@returns(200) Function information returned.
@errors {404: Function with an ID of {functionName} is not running.}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/functions/admin/token
@desc Fetch a short lived token that can be exchanged for a master key.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/functions/{functionName}
@desc Get function information by its ID for web site, or a deployment slot.
@required {functionName: any # Function name.}
@returns(200) Function information returned.
@errors {404: Function with an name of {functionName} is not running.}

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/functions/{functionName}
@desc Create function for web site, or a deployment slot.
@required {functionName: any # Function name., function_envelope: map # Function details.}
@returns(201) Function created.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/functions/{functionName}
@desc Delete a function for web site, or a deployment slot.
@required {functionName: any # Function name.}
@returns(204) Function deleted.
@errors {404: Function does not exist.}

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/functions/{functionName}/listsecrets
@desc Get function secrets for a function in a web site, or a deployment slot.
@required {functionName: any # Function name.}
@returns(200) Function secrets returned.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hostNameBindings
@desc Get hostname bindings for an app or a deployment slot.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hostNameBindings/{hostName}
@desc Get the named hostname binding for an app (or deployment slot, if specified).
@required {hostName: any # Hostname in the hostname binding.}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hostNameBindings/{hostName}
@desc Creates a hostname binding for an app.
@required {hostName: any # Hostname in the hostname binding., hostNameBinding: map # Binding details. This is the JSON representation of a HostNameBinding object.}
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hostNameBindings/{hostName}
@desc Deletes a hostname binding for an app.
@required {hostName: any # Hostname in the hostname binding.}
@returns(200) Successfully deleted hostname binding.
@returns(204) Hostname binding does not exist.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hybridConnectionNamespaces/{namespaceName}/relays/{relayName}
@desc Retrieves a specific Service Bus Hybrid Connection used by this Web App.
@required {namespaceName: any # The namespace for this hybrid connection., relayName: any # The relay name for this hybrid connection.}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hybridConnectionNamespaces/{namespaceName}/relays/{relayName}
@desc Creates a new Hybrid Connection using a Service Bus relay.
@required {namespaceName: any # The namespace for this hybrid connection., relayName: any # The relay name for this hybrid connection., connectionEnvelope: any # The details of the hybrid connection.}
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hybridConnectionNamespaces/{namespaceName}/relays/{relayName}
@desc Removes a Hybrid Connection from this site.
@required {namespaceName: any # The namespace for this hybrid connection., relayName: any # The relay name for this hybrid connection.}
@returns(200) Successfully deleted hybrid connection.
@errors {404: Hybrid connection does not exist.}

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hybridConnectionNamespaces/{namespaceName}/relays/{relayName}
@desc Creates a new Hybrid Connection using a Service Bus relay.
@required {namespaceName: any # The namespace for this hybrid connection., relayName: any # The relay name for this hybrid connection., connectionEnvelope: any # The details of the hybrid connection.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hybridConnectionNamespaces/{namespaceName}/relays/{relayName}/listKeys
@desc Gets the send key name and value for a Hybrid Connection.
@required {namespaceName: any # The namespace for this hybrid connection., relayName: any # The relay name for this hybrid connection.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Web/sites/{name}/hybridConnectionRelays
@desc Retrieves all Service Bus Hybrid Connections used by this Web App.
