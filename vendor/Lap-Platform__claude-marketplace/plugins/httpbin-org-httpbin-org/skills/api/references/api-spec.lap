@endpoint PATCH /redirect-to
@desc 302/3XX Redirects to the given URL.
@errors {302: A redirection.}

@endpoint POST /redirect-to
@desc 302/3XX Redirects to the given URL.
@required {url: any}
@optional {status_code: any}
@errors {302: A redirection.}

@endpoint PUT /redirect-to
@desc 302/3XX Redirects to the given URL.
@required {url: any}
@optional {status_code: any}
@errors {302: A redirection.}

@endgroup

@group redirect
@endpoint GET /redirect/{n}
