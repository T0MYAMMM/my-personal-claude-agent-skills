@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Azure SQL Database
@base https://management.azure.com
@version 2014-04-01
@auth OAuth2
@endpoints 3
@toc subscriptions(3)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/recommendedElasticPools/{recommendedElasticPoolName}
@desc Gets a recommended elastic pool.
@required {serverName: any # The name of the server., recommendedElasticPoolName: any # The name of the recommended elastic pool to be retrieved.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/recommendedElasticPools
@desc Returns recommended elastic pools.
@required {serverName: any # The name of the server.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/recommendedElasticPools/{recommendedElasticPoolName}/metrics
@desc Returns recommended elastic pool metrics.
@required {serverName: any # The name of the server., recommendedElasticPoolName: any # The name of the recommended elastic pool to be retrieved.}
@returns(200) OK

@end
