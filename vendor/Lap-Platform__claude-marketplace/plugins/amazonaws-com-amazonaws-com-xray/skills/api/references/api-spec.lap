@endpoint POST /UpdateSamplingRule
@desc Modifies a sampling rule's configuration.
@required {SamplingRuleUpdate: SamplingRuleUpdate}
@returns(200) {SamplingRuleRecord: SamplingRuleRecord?{SamplingRule: SamplingRule?{RuleName: str?, RuleARN: str?, ResourceARN: str, Priority: int, FixedRate: num(f64), ReservoirSize: int, ServiceName: str, ServiceType: str, Host: str, HTTPMethod: str, URLPath: str, Version: int, Attributes: map<str, str>?: any}, CreatedAt: str(timestamp)?, ModifiedAt: str(timestamp)?}}

@endgroup

