@returns(201) The created patterns

@endpoint DELETE /apps/{appId}/versions/{versionId}/patternrules
@desc Deletes a list of patterns in a version of the application.
@required {appId: any # The application ID., versionId: any # The version ID., patternIds: [str(uuid)] # The patterns IDs.}
@returns(200) Successfully operation.

@endpoint PUT /apps/{appId}/versions/{versionId}/patternrules/{patternId}
@desc Updates a pattern in a version of the application.
@required {appId: any # The application ID., versionId: any # The version ID., patternId: any # The pattern ID., pattern: map # An object representing a pattern.}
@returns(200) The updated pattern

@endpoint DELETE /apps/{appId}/versions/{versionId}/patternrules/{patternId}
@desc Deletes the pattern with the specified ID from a version of the application..
@required {appId: any # The application ID., versionId: any # The version ID., patternId: any # The pattern ID.}
@returns(200) Successfully operation.

@endpoint GET /apps/{appId}/versions/{versionId}/intents/{intentId}/patternrules
@desc Returns patterns for the specific intent in a version of the application.
@required {appId: any # The application ID., versionId: any # The version ID., intentId: any # The intent classifier ID.}
@optional {skip: any # The number of entries to skip. Default value is 0., take: any # The number of entries to return. Maximum page size is 500. Default is 100.}
@returns(200) The retrieved patterns

@endpoint GET /apps/{appId}/versions/{versionId}/settings
@desc Gets the settings in a version of the application.
@required {appId: any # The application ID., versionId: any # The version ID.}
@returns(200) A list of the application version settings.

@endpoint PUT /apps/{appId}/versions/{versionId}/settings
@desc Updates the settings in a version of the application.
@required {appId: any # The application ID., versionId: any # The version ID., listOfAppVersionSettingObject: [map] # A list of the updated application version settings.}
@returns(200) Successful operation.

@endpoint POST /apps/{appId}/azureaccounts
@desc apps - Assign a LUIS Azure account to an application
@required {appId: any # The application ID., Authorization: any # The bearer authorization header to use; containing the user's ARM token used to validate Azure accounts information.}
@optional {ArmToken: any # The custom arm token header to use; containing the user's ARM token used to validate azure accounts information., azureAccountInfoObject: map # The Azure account information object.}
@returns(201) Successful operation.

@endpoint GET /apps/{appId}/azureaccounts
@desc apps - Get LUIS Azure accounts assigned to the application
@required {appId: any # The application ID., Authorization: any # The bearer authorization header to use; containing the user's ARM token used to validate Azure accounts information.}
@optional {ArmToken: any # The custom arm token header to use; containing the user's ARM token used to validate azure accounts information.}
@returns(200) A list of azure account information objects.

@endpoint DELETE /apps/{appId}/azureaccounts
@desc apps - Removes an assigned LUIS Azure account from an application
@required {appId: any # The application ID., Authorization: any # The bearer authorization header to use; containing the user's ARM token used to validate Azure accounts information.}
@optional {ArmToken: any # The custom arm token header to use; containing the user's ARM token used to validate azure accounts information., azureAccountInfoObject: map # The Azure account information object.}
@returns(200) Successful operation.

@endgroup

@group azureaccounts
@endpoint GET /azureaccounts
@desc user - Get LUIS Azure accounts
@required {Authorization: any # The bearer authorization header to use; containing the user's ARM token used to validate Azure accounts information.}
@optional {ArmToken: any # The custom arm token header to use; containing the user's ARM token used to validate azure accounts information.}
@returns(200) A list of Azure account information objects.

@endgroup

@group package
@endpoint GET /package/{appId}/slot/{slotName}/gzip
@desc package - Gets published LUIS application package in binary stream GZip format
@required {appId: any # The application ID., slotName: any # The publishing slot name.}
@returns(200) The GZip binary stream of the published application package.

@endpoint GET /package/{appId}/versions/{versionId}/gzip
@desc package - Gets trained LUIS application package in binary stream GZip format
@required {appId: any # The application ID., versionId: any # The version ID.}
@returns(200) The GZip binary stream of the trained application package.

@endgroup

@end
