@group institutions
@endpoint GET /institutions/
@desc List all institutions
@returns(200) OK

@endpoint GET /institutions/{institution_id}/
@desc Retrieve an institution
@required {institution_id: any # The unique identifier of the institution you wish to retrieve.}
@returns(200) OK

@endpoint GET /institutions/{institution_id}/users/
@desc List all affiliated users
@required {institution_id: any # The unique identifier of the institution you wish to retrieve.}
@returns(200) OK

@endpoint GET /institutions/{institution_id}/nodes/
@desc List all affiliated nodes
@required {institution_id: any # The unique identifier of the institution you wish to retrieve.}
@returns(200) OK

@endpoint GET /institutions/{institution_id}/registrations/
@desc List all affiliated registrations
@required {institution_id: any # The unique identifier of the institution you wish to retrieve.}
@returns(200) OK

@endpoint GET /institutions/{institution_id}/relationships/nodes/
@desc List nodes affiliated with an institution (relationship data)
@required {institution_id: any # The unique identifier of the institution.}
@returns(200) Successfully retrieved node relationships.
@errors {401: Authentication credentials were not provided or are invalid., 403: You do not have permission to view this institution's nodes., 404: Institution not found.}

@endpoint POST /institutions/{institution_id}/relationships/nodes/
@desc Add node relationships to an institution
@required {institution_id: any # The unique identifier of the institution., body: map # List of node relationships to add.}
@returns(201) Nodes successfully affiliated with institution.
@returns(204) No changes made (nodes already affiliated).
@errors {400: Invalid request payload., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to affiliate these nodes., 404: Institution not found.}

@endpoint DELETE /institutions/{institution_id}/relationships/nodes/
@desc Remove node relationships from an institution
@required {institution_id: any # The unique identifier of the institution., body: map # List of node relationships to remove.}
@returns(204) Nodes successfully removed from affiliation.
@errors {400: Invalid request payload., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to modify these nodes., 404: Institution not found.}

@endpoint GET /institutions/{institution_id}/relationships/registrations/
@desc List registrations affiliated with an institution (relationship data)
@required {institution_id: any # The unique identifier of the institution.}
@returns(200) Successfully retrieved registration relationships.
@errors {401: Authentication credentials were not provided or are invalid., 403: You do not have permission to view this institution's registrations., 404: Institution not found.}

@endpoint POST /institutions/{institution_id}/relationships/registrations/
@desc Add registration relationships to an institution
@required {institution_id: any # The unique identifier of the institution., body: map # List of registration relationships to add.}
@returns(201) Registrations successfully affiliated with institution.
@returns(204) No changes made (registrations already affiliated).
@errors {400: Invalid request payload., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to affiliate these registrations., 404: Institution not found.}

@endpoint DELETE /institutions/{institution_id}/relationships/registrations/
@desc Remove registration relationships from an institution
@required {institution_id: any # The unique identifier of the institution., body: map # List of registration relationships to remove.}
@returns(204) Registrations successfully removed from affiliation.
@errors {400: Invalid request payload., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to modify these registrations., 404: Institution not found.}

@endgroup

@group schemas
@endpoint GET /schemas/registrations/
@desc Retrieve a list of Registration Schemas
@returns(200) OK

@endpoint GET /schemas/registrations/{registration_schema_id}
@desc Retrieve a Registration Schema
@required {registration_schema_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`.}
@returns(200) OK

@endgroup

@group schema_responses
@endpoint GET /schema_responses/
@desc List all Schema Responses
@returns(200) OK

@endpoint POST /schema_responses/
@desc Create a new Schema Response
@required {body: map}
@returns(201) OK

@endpoint GET /schema_responses/{schema_response_id}
@desc Retrieve a Schema Response
@required {schema_response_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`.}
@returns(200) OK

@endpoint PATCH /schema_responses/{schema_response_id}
@desc Update a Registration's Schema Response
@required {schema_response_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`., body: map}
@returns(201) OK

@endpoint DELETE /schema_responses/{schema_response_id}
@desc Delete a Incomplete Schema Response
@required {schema_response_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`.}
@returns(204) No Content

@endpoint GET /schema_responses/{schema_response_id}/actions/
@desc Retrieve a list of Schema Response Actions for a Schema Response
@required {schema_response_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`.}
@returns(200) OK

@endpoint POST /schema_responses/{schema_response_id}/actions/
@desc Create a new Schema Response Action
@required {schema_response_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`.}
@returns(201) OK

@endpoint GET /schema_responses/{schema_response_id}/actions/{schema_response_action_id}
@desc A Schema Response Action from a Schema Response
@required {schema_response_id: any # The unique identifier of the Schema Response example `61b9cd62eb66180215222669`., schema_response_action_id: any # The unique identifier of the Schema Response Action example `61b9eae1a7d8ac025c4c46d3`.}
@returns(200) OK

@endpoint GET /schema_responses/{schema_response_id}/schema_blocks/
@desc Retrieve a list of Registration Schema Blocks for a Schema Response
@required {schema_response_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`.}
@returns(200) OK

@endpoint GET /schema_responses/{schema_response_id}/schema_blocks/{schema_response_block_id}
@desc Retrieve a Registration Schema Block
@required {schema_response_id: any # The unique identifier of the Registration Schema example `6176c9d45e01f100091d4f94`., schema_response_block_id: any # The unique identifier of the Schema Response Block example `61b79f9eadbb5701424a2d5e`.}
@returns(200) OK

@endgroup

