@endpoint GET /providers/registrations/{provider_id}/moderators/{moderator_id}/
@desc Retrieve Moderator Details
@required {provider_id: any # The unique identifier of the provider., moderator_id: any # The unique identifier of the moderator.}
@returns(200) Moderator details retrieved successfully.
@errors {403: Forbidden – insufficient permissions., 404: Not found – moderator does not exist.}

@endpoint PATCH /providers/registrations/{provider_id}/moderators/{moderator_id}/
@desc Update Moderator Permissions
@required {provider_id: any, moderator_id: any, body: map}
@returns(200) Moderator permissions updated successfully.
@errors {400: Invalid request – validation errors., 403: Forbidden – insufficient permissions.}

@endpoint DELETE /providers/registrations/{provider_id}/moderators/{moderator_id}/
@desc Remove Moderator
@required {provider_id: any, moderator_id: any}
@returns(204) Moderator removed successfully.
@errors {403: Forbidden – insufficient permissions., 404: Not found – moderator does not exist.}

@endgroup

