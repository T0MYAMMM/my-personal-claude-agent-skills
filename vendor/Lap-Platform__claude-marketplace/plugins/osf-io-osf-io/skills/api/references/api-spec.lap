@group requests
@endpoint GET /requests/{request_id}/
@desc Retrieve details for a specific request
@required {request_id: any # The unique identifier for the request (either NodeRequest or PreprintRequest).}
@returns(200) Successfully retrieved request details.
@errors {401: Authentication credentials were not provided or are invalid., 403: You do not have permission to view this request., 404: Request not found.}

@endpoint GET /requests/{request_id}/actions/
@desc List actions associated with a request
@required {request_id: any # The unique identifier for the request.}
@optional {filter: any # Filter actions by attributes.  Supported filters:   - `machine_state`: Filter by current state (e.g., `pending`, `accepted`, `rejected`)  Example:   - filter[machine_state]=pending}
@returns(200) Successfully retrieved actions for the request.
@errors {401: Authentication credentials were not provided or are invalid., 403: You do not have permission to view actions on this request., 404: Request not found or no actions are available for the given request.}

@endgroup

@group resources
@endpoint GET /resources/
@desc List resources
@returns(200) Successful retrieval of resource list
@errors {401: Authentication required., 403: Permission denied.}

@endpoint POST /resources/
@desc Create a new resource
@required {body: map # JSON:API-compliant resource creation payload.}
@returns(201) Successfully created a new resource.
@errors {400: Validation error or invalid data., 401: Authentication required., 403: Permission denied.}

@endpoint GET /resources/{resource_id}/
@desc Retrieve a resource
@required {resource_id: any # The unique identifier of the resource.}
@returns(200) Successful retrieval of the resource.
@errors {401: Authentication required., 403: Permission denied., 404: Resource not found.}

@endpoint PATCH /resources/{resource_id}/
@desc Update a resource
@required {resource_id: any # The unique identifier of the resource to update., body: map # A JSON:API compliant object describing the updates.}
@returns(200) Resource updated successfully.
@errors {400: Validation error or malformed request data., 401: Authentication required., 403: Permission denied., 404: Resource not found.}

@endpoint DELETE /resources/{resource_id}/
@desc Delete a resource
@required {resource_id: any # The unique identifier of the resource to delete.}
@returns(204) Resource deleted successfully. No content returned.
@errors {401: Authentication required., 403: Permission denied or resource cannot be deleted., 404: Resource not found.}

@endgroup

@group subjects
@endpoint GET /subjects/
@desc List available taxonomy subjects
@optional {filter[text]: any: any # Filter subjects by matching text., filter[parent]: any # Filter subjects by parent subject ID., page: any # Page number for paginated results., page_size: any # Number of results per page (no max page size).}
@returns(200) Successful retrieval of subjects.
@errors {400: Bad request (e.g., invalid filter or pagination parameters)}

@endpoint GET /subjects/{subject_id}/
@desc Retrieve a single taxonomy subject
@required {subject_id: any # The unique identifier of the subject.}
@returns(200) Successfully retrieved the subject.
@errors {404: Subject not found.}

@endpoint GET /subjects/{subject_id}/children/
@desc List child subjects for a given subject
@required {subject_id: any # The unique identifier of the parent taxonomy subject.}
@returns(200) Successful retrieval of child subjects.
@errors {404: Parent subject not found.}

@endgroup

@group guids
@endpoint GET /guids/{guid_id}/
@desc Retrieve a GUID resource or redirect to its referent resource
@required {guid_id: any # The unique identifier for the GUID.}
@optional {resolve: any # If true (default), redirect to the referent resource. If false, return a representation of the GUID resource.}
@returns(200) Successfully retrieved the GUID resource.
@errors {302: Redirects to the referent resource if `resolve=true` or omitted., 401: Authentication required., 403: You do not have permission to view this GUID., 404: GUID not found., 410: The GUID has been deleted.}

@endgroup

@group files
@endpoint POST /files/{file_id}/cedar_metadata_records/
@desc Create a CEDAR metadata record for a file
