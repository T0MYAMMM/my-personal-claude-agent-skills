@group regions
@endpoint GET /regions/
@desc List Regions
@returns(200) Successfully retrieved the list of regions.

@endpoint GET /regions/{region_id}/
@desc Region Detail
@required {region_id: any # The unique identifier for the region.}
@returns(200) Successfully retrieved region details.
@errors {404: Region not found.}

@endgroup

@group tokens
@endpoint GET /tokens/
@desc List Personal Access Tokens
@returns(200) Successful retrieval of personal access tokens.

@endpoint POST /tokens/
@desc Create Personal Access Token
@required {body: map}
@returns(201) Token successfully created.

@endpoint GET /tokens/{_id}/
@desc Personal Access Token Detail
@required {_id: any # The tokens's unique identifier.}
@returns(200) Successful retrieval of tokens details.
@errors {404: Token not found.}

@endpoint DELETE /tokens/{_id}/
@desc Deactivate Personal Access Token
@required {_id: any # The tokens's unique identifier.}
@returns(204) Token successfully deactivated.

@endpoint GET /tokens/{_id}/scopes/
@desc List Scopes of a Personal Access Token
@required {_id: any # The token's unique identifier.}
@returns(200) Successfully retrieved tokens scopes.
@errors {404: Token not found.}

@endgroup

@group applications
@endpoint GET /applications/
@desc List Registered Applications
@returns(200) Successfully retrieved list of applications.

@endpoint POST /applications/
@desc Create a New Application
@required {body: map # JSON:API payload representing the new OAuth2 Application.}
@returns(201) OAuth2 Application successfully created.

@endpoint GET /applications/{client_id}/
@desc Retrieve Application Details
@required {client_id: any # The application's `client_id`.}
@returns(200) Successfully retrieved application details.

@endpoint PATCH /applications/{client_id}/
@desc Update Application
@required {client_id: any, body: map # JSON:API payload with updated OAuth2 Application fields.}
@returns(200) Application successfully updated.

@endpoint DELETE /applications/{client_id}/
@desc Deactivate Application
@required {client_id: any}
@returns(204) Application successfully deactivated.

@endpoint POST /applications/{client_id}/reset/
@desc Reset Application Client Secret
@required {client_id: any}
@returns(201) Client secret successfully reset.
@errors {404: Application not found or unauthorized., 410: Endpoint deprecated and removed in v2.15.}

@endgroup

@group scopes
@endpoint GET /scopes/
@desc List OAuth Scopes
@returns(200) Successfully retrieved list of OAuth scopes.

@endpoint GET /scopes/{scope_id}/
@desc Retrieve OAuth Scope Detail
@required {scope_id: any # The unique identifier of the OAuth scope.}
@returns(200) Successfully retrieved OAuth scope details.
@errors {404: OAuth scope not found or inaccessible.}

@endgroup

@group actions
@endpoint GET /actions/reviews/
@desc List Review Actions
@optional {page: any # Page number of the results to fetch., per_page: any # Number of actions per page., filter[id]: any # Filter by the unique ID of the review action., filter[trigger]: any # Filter by the trigger that initiated the action., filter[from_state]: any # Filter by the previous state of the resource., filter[to_state]: any # Filter by the new state of the resource., filter[date_created]: any # Filter by the creation date of the action., filter[date_modified]: any # Filter by the last modification date of the action.}
@returns(200) Successful retrieval of review actions.
@errors {400: Bad request. Invalid filter or pagination parameters., 403: Forbidden. The user does not have permission to view these review actions.}

@endpoint POST /actions/requests/nodes/
@desc Create a Node Request Action
@required {body: map # A JSON:API compliant payload describing the Node Request Action to create.}
@returns(201) Node Request Action successfully created.
@errors {400: Invalid or incomplete request payload., 403: Forbidden. Insufficient permissions for requested trigger., 409: Conflict. Invalid trigger for the node request's current state.}

@endpoint POST /actions/requests/preprints/
@desc Create a Preprint Request Action
@required {body: map # A JSON:API compliant payload describing the Preprint Request Action to create.}
@returns(201) Preprint Request Action successfully created.
@errors {400: Invalid or incomplete request payload., 403: Forbidden. You do not have permission to perform this action., 409: Conflict. Trigger is invalid for the request's current state.}

@endpoint GET /actions/{action_id}/
@desc Retrieve an Action by ID
@required {action_id: any # Unique identifier for the action (e.g., `abc123`).}
@returns(200) Action retrieved successfully.
@errors {403: Permission denied. Insufficient privileges to access the requested action., 404: Action not found or inaccessible. Verify action ID and permissions.}

@endgroup

@group identifiers
@endpoint GET /identifiers/{identifier_id}/
@desc Retrieve a Specific Identifier
@required {identifier_id: any # The unique identifier for the identifier resource.}
@returns(200) Successful retrieval of the identifier.

@endpoint GET /identifiers/{node_id}/identifiers/
@desc List all identifiers
@required {node_id: any # The unique identifier of the node.}
@returns(200) OK

@endgroup

@end
