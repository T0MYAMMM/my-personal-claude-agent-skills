@returns(201) Successfully created a new CEDAR metadata record.
@errors {400: Validation error or invalid data., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to create metadata for this file., 404: File not found.}

@endgroup

@group nodes
@endpoint POST /nodes/{node_id}/cedar_metadata_records/
@desc Create a CEDAR metadata record for a node
@required {node_id: any # The unique identifier of the node., body: map # CEDAR metadata record object to be created.}
@returns(201) Successfully created a new CEDAR metadata record.
@errors {400: Validation error or invalid data., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to create metadata for this node., 404: Node not found.}

@endgroup

@group custom_file_metadata_records
@endpoint GET /custom_file_metadata_records/{file_id}/
@desc Retrieve custom file metadata for a file
@required {file_id: any # The unique identifier of the file.}
@returns(200) Successfully retrieved custom file metadata record.
@errors {401: Authentication credentials were not provided or are invalid., 403: You do not have permission to access this metadata record., 404: Metadata record not found.}

@endpoint PATCH /custom_file_metadata_records/{file_id}/
@desc Update custom file metadata for a file
@required {file_id: any # The unique identifier of the file., body: map # Custom file metadata record object.}
@returns(200) Successfully updated custom file metadata record.
@errors {400: Validation error or invalid data., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to modify this metadata record., 404: Metadata record not found.}

@endgroup

@group custom_item_metadata_records
@endpoint GET /custom_item_metadata_records/{guid_id}/
@desc Retrieve custom item metadata for a node or preprint
@required {guid_id: any # The unique identifier (GUID) of the node or preprint.}
@returns(200) Successfully retrieved custom item metadata record.
@errors {401: Authentication credentials were not provided or are invalid., 403: You do not have permission to access this metadata record., 404: Metadata record not found.}

@endpoint PATCH /custom_item_metadata_records/{guid_id}/
@desc Update custom item metadata for a node or preprint
@required {guid_id: any # The unique identifier (GUID) of the node or preprint., body: map # Custom item metadata record object.}
@returns(200) Successfully updated custom item metadata record.
@errors {400: Validation error or invalid data., 401: Authentication credentials were not provided or are invalid., 403: You do not have permission to modify this metadata record., 404: Metadata record not found.}

@endgroup

@group subscriptions
@endpoint GET /subscriptions/
@desc Retrieve a List of Notification Subscriptions
@optional {page: any # The page number of the paginated result set., filter[event_name]: any # Filter subscriptions by `event_name`.}
@returns(200) Successful retrieval of the user's notification subscriptions.
@errors {401: Unauthorized. Authentication is required., 403: Forbidden. You do not have permission to access these subscriptions., 404: Not Found. No subscriptions found for the user.}

@endpoint GET /subscriptions/{subscription_id}/
@desc Retrieve a Notification Subscription
@required {subscription_id: any # The unique identifier of the notification subscription.}
@returns(200) Successful retrieval of the subscription.
@errors {401: Unauthorized. Authentication is required., 403: Forbidden. You do not have permission to access this subscription., 404: Not Found. No subscription matches the given ID.}

@endpoint PATCH /subscriptions/{subscription_id}/
@desc Update a Notification Subscription
@required {subscription_id: any # The unique identifier of the notification subscription., body: map}
@returns(200) Subscription successfully updated.
@errors {400: Bad Request. Invalid input provided., 401: Unauthorized. Authentication is required., 403: Forbidden. You do not have permission to modify this subscription., 404: Not Found. No subscription matches the given ID.}

@endgroup

@group providers
@endpoint GET /providers/collections/{provider_id}/subscriptions/
@desc List Notification Subscriptions for a Collection Provider
@required {provider_id: any # The unique identifier of the collection provider.}
@returns(200) Successful response with a paginated list of subscriptions.
@errors {401: Unauthorized. Authentication is required., 403: Forbidden. The user does not have permission to access subscriptions for this provider., 404: Not Found. The specified collection provider does not exist or has no subscriptions for the user.}

@endpoint GET /providers/collections/{provider_id}/subscriptions/{subscription_id}/
