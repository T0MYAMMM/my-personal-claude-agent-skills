@group users
@endpoint GET /users/
@desc List all users
@returns(200) OK

@endpoint GET /users/{user_id}/
@desc Retrieve a user
@required {user_id: any # The unique identifier of the user.}
@returns(200) OK

@endpoint PATCH /users/{user_id}/
@desc Update a user
@required {user_id: any # The unique identifier of the user., body: map}
@returns(200) OK

@endpoint GET /users/{user_id}/institutions/
@desc List all institutions
@required {user_id: any # The unique identifier of the user.}
@returns(200) OK

@endpoint GET /users/{user_id}/nodes/
@desc List all nodes
@required {user_id: any # The unique identifier of the user.}
@returns(200) OK

@endpoint GET /users/{user_id}/preprints/
@desc List all preprints
@required {user_id: any # The unique identifier of the user.}
@returns(200) OK

@endpoint GET /users/{user_id}/registrations/
@desc List all registrations
@required {user_id: any # The unique identifier of the user.}
@returns(200) OK

@endpoint GET /users/{user_id}/addons/
@desc List all user addons
@required {user_id: any # The unique identifier of the user.}
@returns(200) OK

@endpoint GET /users/{user_id}/addons/{provider}/
@desc Retrieve a user addon
@required {user_id: any # The unique identifier of the user., provider: any # The unique identifier of the addon provider.}
@returns(200) OK

@endpoint GET /users/{user_id}/addons/{provider}/accounts/
@desc List all addon accounts
@required {user_id: any # The unique identifier of the user., provider: any # The unique identifier of the addon provider.}
@returns(200) OK

@endpoint GET /users/{user_id}/addons/{provider}/accounts/{account_id}/
@desc Retrieve an addon account
@required {user_id: any # The unique identifier of the user., provider: any # The unique identifier of the addon provider., account_id: any # The unique identifier of the addon account.}
@returns(200) OK

@endpoint POST /users/{user_id}/claim/
@desc Claim a User Account
@required {user_id: any # The unique identifier of the user you are trying to claim. Example: `abc123`, body: map # A JSON API representation of the claim request. You must provide at least a `record id`. Optionally, an `email` may be included if you are not authenticated.}
@returns(204) Successfully initiated the claim process. If the claimer is authenticated, they will receive an email confirming the claim. If not authenticated and an email is provided, the claim invitation will be sent to the specified email address.
@errors {400: Bad request. The request payload is invalid or missing required fields (such as `id`)., 403: Permission denied. You do not have permission to claim this user, or the user has already been claimed., 404: Not found. The specified user or record could not be found.}

@endpoint GET /users/{user_id}/draft_preprints/
@desc List a User's Draft Preprints
@required {user_id: any # The unique identifier of the user. Example: `abc123`}
@optional {page: any # Page number of results to view (pagination). Default is 1., filter[title]: any # Filter draft preprints by title.}
@returns(200) Successfully retrieved the list of draft preprints.
@errors {403: Permission denied. You do not have permission to view these draft preprints., 404: User not found.}

@endpoint GET /users/{user_id}/draft_registrations/
@desc List a User's Draft Registrations
@required {user_id: any # The unique identifier of the user. Example: `abc123`}
@optional {page: any # Page number of results to view (pagination). Default is 1., filter[title]: any # Filter draft registrations by title.}
@returns(200) Successfully retrieved the list of draft registrations.
@errors {403: Permission denied. You do not have permission to view these draft registrations., 404: User not found.}

@endpoint GET /users/{user_id}/relationships/institutions/
@desc Retrieve a User's Institution Relationships
@required {user_id: any # The unique identifier of the user. Example: `abc123`}
@returns(200) Successfully retrieved the user's affiliated institutions.
@errors {403: Permission denied. You do not have permission to view these institution relationships., 404: User not found.}

@endpoint DELETE /users/{user_id}/relationships/institutions/
@desc Remove Institutions from a User's Affiliations
@required {user_id: any # The unique identifier of the user. Example: `abc123`, body: map # List of institution relationships to remove.}
@returns(204) Successfully removed institutions from user's affiliations.
@errors {400: Bad request. Possible reasons include: - Institution `type` does not match `institutions`. - Institution ID is invalid or not affiliated with the user., 403: Permission denied. You do not have permission to modify these affiliations., 404: User not found.}

@endpoint GET /users/{user_id}/settings/
@desc Retrieve a User's Settings
@required {user_id: any # The unique identifier of the user. Example: `abc123`}
@returns(200) Successfully retrieved the user's settings.
@errors {403: Permission denied. You do not have permission to view these settings.}

@endpoint PATCH /users/{user_id}/settings/
@desc Update a User's Settings
@required {user_id: any # The unique identifier of the user. Example: `abc123`, body: map # JSON API representation of the updates to the user's settings.}
@returns(200) Successfully updated the user's settings.
@errors {400: Bad request. This can occur if the two-factor verification code is invalid, or subscription values are incorrect., 403: Permission denied. You do not have permission to update these settings., 404: User not found.}

@endpoint GET /users/{user_id}/settings/emails/
@desc List User Email Addresses
@required {user_id: any # The unique identifier of the user whose emails are being listed. Example: `abc123`}
@returns(200) A list of confirmed and unconfirmed email addresses for the user.
@errors {403: Permission denied. You do not have permission to view email addresses for this user.}

@endpoint POST /users/{user_id}/settings/emails/
@desc Add a New Email Address
@required {user_id: any # The unique identifier of the user to whom the email will be added. Example: `abc123`, body: map # A JSON API representation of the new email address to add. You must provide an `email_address` in the attributes object.}
@returns(201) The email address was successfully added and is pending confirmation.
@errors {400: Bad request. The email address is invalid or already exists on this user., 403: Permission denied. You do not have permission to add an email for this user., 429: Too many requests. You have exceeded the allowed number of email additions. Please wait and try again later.}

@endpoint GET /users/{user_id}/settings/emails/{email_id}/
@desc Retrieve a User's Email Address
@required {user_id: any # The unique identifier of the user. Example: `abc123`, email_id: any # The unique identifier of the email address (either a hashed ID or unconfirmed token). Example: `1a2b3c`}
@optional {resend_confirmation: any # If true, resend a confirmation email to the unconfirmed address (if applicable).}
@returns(200) Successfully retrieved the email address.
@errors {403: Permission denied. You do not have permission to view this email., 404: Email address not found.}

@endpoint PATCH /users/{user_id}/settings/emails/{email_id}/
@desc Update a User's Email Address
@required {user_id: any # The unique identifier of the user. Example: `abc123`, email_id: any # The unique identifier of the email address. Example: `1a2b3c`, body: map # JSON API representation of the updates to the email address.}
@returns(200) Successfully updated the email address.
@errors {400: Bad request. This can occur if trying to set an unconfirmed email as primary or verify an unconfirmed email., 403: Permission denied., 404: Email address not found.}

@endpoint DELETE /users/{user_id}/settings/emails/{email_id}/
@desc Remove a User's Email Address
@required {user_id: any # The unique identifier of the user. Example: `abc123`, email_id: any # The unique identifier of the email address. Example: `1a2b3c`}
@returns(204) Email address successfully removed.
@errors {400: Bad request. Cannot delete the primary email address., 403: Permission denied., 404: Email address not found.}

@endpoint POST /users/{user_id}/settings/export/
@desc Request User Account Export
@required {user_id: any # The unique identifier of the user requesting the export. Example: `abc123`, body: map # A JSON API representation of the export request. No additional attributes are required in the request payload.}
@returns(204) Export request successfully submitted. The user will receive confirmation once the export process is completed.
@errors {403: Permission denied. You do not have permission to request an export for this user., 429: Too many requests. You have exceeded the allowed number of export requests. Please wait and try again later.}

@endpoint GET /users/{user_id}/settings/identities/
@desc List User External Identities
@required {user_id: any # The unique identifier of the user whose external identities are being listed. Example: `abc123`}
@returns(200) A list of external identities associated with the user.
@errors {403: Permission denied. You do not have permission to view external identities for this user.}

@endpoint GET /users/{user_id}/settings/identities/{identity_id}
@desc Retrieve a User's External Identity
@required {user_id: any # The unique identifier of the user whose external identity is being retrieved. Example: `abc123`, identity_id: any # The unique identifier of the external identity to retrieve. Example: `orcid`}
@returns(200) A single external identity for the user.
@errors {403: Permission denied. You do not have permission to view external identities for this user., 404: External identity not found. No identity with the given ID exists for this user.}

@endpoint DELETE /users/{user_id}/settings/identities/{identity_id}
@desc Remove a User's External Identity
@required {user_id: any # The unique identifier of the user whose external identity is being deleted. Example: `abc123`, identity_id: any # The unique identifier of the external identity to delete. Example: `orcid`}
@returns(204) External identity successfully removed.
@errors {403: Permission denied. You do not have permission to remove external identities for this user., 404: External identity not found. No identity with the given ID exists for this user.}

@endpoint POST /users/{user_id}/settings/password/
@desc Change a User's Password
@required {user_id: any # The unique identifier of the user whose password is being changed. Example: `abc123`, body: map # A JSON API representation of the password change request. You must provide both the existing password and the new password.}
@returns(204) Password successfully changed. All sessions for the user will be logged out and must be re-authenticated.
@errors {400: Bad request. The existing password is incorrect, or the new password is invalid., 403: Permission denied. You do not have permission to change this user's password., 429: Too many failed attempts. Please wait before trying again.}

@endgroup

