@returns(201) Created

@endpoint GET /draft_registrations/{draft_id}/
@desc Retrieve a Draft Registration
@required {draft_id: any # The unique identifier of the draft registration.}
@returns(200) OK

@endpoint PATCH /draft_registrations/{draft_id}/
@desc Update a Draft Registration
@required {draft_id: any # The unique identifier of the draft registration., body: map}
@returns(200) OK

@endpoint DELETE /draft_registrations/{draft_id}/
@desc Delete a draft registration
