@required {provider_id: any # The unique identifier of the collection provider., subscription_id: any # The unique identifier of the notification subscription.}
@returns(200) Successful retrieval of the subscription.
@errors {401: Unauthorized. Authentication credentials are missing or invalid., 403: Forbidden. You do not have permission to access this subscription., 404: Not Found. No subscription matches the given ID or the collection provider does not exist.}

@endpoint PATCH /providers/collections/{provider_id}/subscriptions/{subscription_id}/
@desc Update a Collection Provider Notification Subscription
@required {provider_id: any # The unique identifier of the collection provider., subscription_id: any # The unique identifier of the notification subscription., body: map}
@returns(200) Subscription successfully updated.
@errors {400: Bad Request. Invalid input provided or missing required fields., 401: Unauthorized. Authentication credentials are missing or invalid., 403: Forbidden. You do not have permission to update this subscription., 404: Not Found. No subscription matches the given ID or the collection provider does not exist.}

@endpoint GET /providers/preprints/{provider_id}/subscriptions/
@desc List Preprint Provider Subscriptions
