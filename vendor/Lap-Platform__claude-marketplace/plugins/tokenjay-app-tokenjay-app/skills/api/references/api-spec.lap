@endgroup

@group createbabel
@endpoint GET /createbabel/{address}
@required {address: str, tokenId: str, ergAmount: int(int64), tokenAmount: int(int64)}
@returns(200) OK
@errors {401: Unauthorized, 400: Bad Request, 409: Conflict, 404: Not Found}

@endgroup

@group cancelbabel
@endpoint GET /cancelbabel/{boxId}
@required {boxId: str}
@returns(200) OK
@errors {401: Unauthorized, 400: Bad Request, 409: Conflict, 404: Not Found}

@endgroup

@group ageusd
@endpoint GET /ageusd/info
@desc Returns state of AgeUSD at this moment
@returns(200) OK
@errors {401: Unauthorized, 400: Bad Request, 409: Conflict, 404: Not Found}

@endgroup

@end
