@endpoint PUT /u/{username}/preferences/avatar/pick.json
@desc Update avatar
@required {username: str, upload_id: int, type: str(uploaded/custom/gravatar/system)}
@returns(200) {success: str} # avatar updated

@endpoint PUT /u/{username}/preferences/email.json
@desc Update email
@required {username: str, email: str(email)}
@returns(200) email updated

@endpoint PUT /u/{username}/preferences/username.json
@desc Update username
@required {username: str, new_username: str}
@returns(200) username updated

@endgroup

@group directory_items.json
@endpoint GET /directory_items.json
@desc Get a public list of users
@required {period: str(daily/weekly/monthly/quarterly/yearly/all), order: str(likes_received/likes_given/topic_count/post_count/topics_entered/posts_read/days_visited)}
@optional {asc: str, page: int}
@returns(200) {directory_items: [map], meta: map{last_updated_at: str?, total_rows_directory_items: int, load_more_directory_items: str}} # directory items response

@endgroup

@group admin
@endpoint GET /admin/users/{id}.json
@desc Get a user by id
@required {id: int}
@returns(200) {id: int, username: str, name: str?, avatar_template: str, active: bool, admin: bool, moderator: bool, last_seen_at: str?, last_emailed_at: str?, created_at: str, last_seen_age: num?, last_emailed_age: num?, created_at_age: num?, trust_level: int, manual_locked_trust_level: str?, title: str?, time_read: int, staged: bool, days_visited: int, posts_read_count: int, topics_entered: int, post_count: int, associated_accounts: [any], can_send_activation_email: bool, can_activate: bool, can_deactivate: bool, can_change_trust_level: bool, ip_address: str, registration_ip_address: str?, can_grant_admin: bool, can_revoke_admin: bool, can_grant_moderation: bool, can_revoke_moderation: bool, can_impersonate: bool, like_count: int, like_given_count: int, topic_count: int, flags_given_count: int, flags_received_count: int, private_topics_count: int, can_delete_all_posts: bool, can_be_deleted: bool, can_be_anonymized: bool, can_be_merged: bool, full_suspend_reason: str?, latest_export: map?, silence_reason: str?, post_edits_count: int?, primary_group_id: int?, badge_count: int, warnings_received_count: int, bounce_score: int?, reset_bounce_score_after: str?, can_view_action_logs: bool, can_disable_second_factor: bool, can_delete_sso_record: bool, api_key_count: int, similar_users_count: int, single_sign_on_record: str?, approved_by: map?, suspended_by: str?, silenced_by: str?, penalty_counts: map{silenced: int, suspended: int}, next_penalty: str, tl3_requirements: map{time_period: int, requirements_met: bool, requirements_lost: bool, trust_level_locked: bool, on_grace_period: bool, days_visited: int, min_days_visited: int, num_topics_replied_to: int, min_topics_replied_to: int, topics_viewed: int, min_topics_viewed: int, posts_read: int, min_posts_read: int, topics_viewed_all_time: int, min_topics_viewed_all_time: int, posts_read_all_time: int, min_posts_read_all_time: int, num_flagged_posts: int, max_flagged_posts: int, num_flagged_by_users: int, max_flagged_by_users: int, num_likes_given: int, min_likes_given: int, num_likes_received: int, min_likes_received: int, num_likes_received_days: int, min_likes_received_days: int, num_likes_received_users: int, min_likes_received_users: int, penalty_counts: map{silenced: int, suspended: int, total: int}}, groups: [map], external_ids: map, include_ip: bool} # response

@endpoint DELETE /admin/users/{id}.json
@desc Delete a user
@required {id: int}
@optional {delete_posts: bool, block_email: bool, block_urls: bool, block_ip: bool}
@returns(200) {deleted: bool} # response

@endpoint PUT /admin/users/{id}/activate.json
@desc Activate a user
@required {id: int}
@returns(200) {success: str} # response

@endpoint PUT /admin/users/{id}/deactivate.json
@desc Deactivate a user
@required {id: int}
@returns(200) {success: str} # response

@endpoint PUT /admin/users/{id}/suspend.json
@desc Suspend a user
@required {id: int, suspend_until: str, reason: str}
@optional {message: str # Will send an email with this message when present, post_action: str}
@returns(200) {suspension: map{suspend_reason: str, full_suspend_reason: str, suspended_till: str, suspended_at: str, suspended_by: map{id: int, username: str, name: str, avatar_template: str}}} # response

@endpoint PUT /admin/users/{id}/silence.json
@desc Silence a user
@required {id: int, silenced_till: str, reason: str}
@optional {message: str # Will send an email with this message when present, post_action: str}
@returns(200) {silence: map{silenced: bool, silence_reason: str, silenced_till: str, silenced_at: str, silenced_by: map{id: int, username: str, name: str, avatar_template: str}}} # response

@endpoint PUT /admin/users/{id}/anonymize.json
@desc Anonymize a user
@required {id: int}
@returns(200) {success: str, username: str} # response

@endpoint POST /admin/users/{id}/log_out.json
@desc Log a user out
@required {id: int}
@returns(200) {success: str} # response

@endgroup

@group user_avatar
@endpoint POST /user_avatar/{username}/refresh_gravatar.json
@desc Refresh gravatar
@required {username: str}
@returns(200) {gravatar_upload_id: int?, gravatar_avatar_template: str?} # response

@endgroup

@group admin
@endpoint GET /admin/users.json
@desc List users
@optional {order: str(created/last_emailed/seen/username/email/trust_level/days_visited/posts_read/topics_viewed/posts/read_time), asc: str, page: int, show_emails: bool # Include user email addresses in response. These requests will be logged in the staff action logs., stats: bool # Include user stats information, email: str # Filter to the user with this email address, ip: str # Filter to users with this IP address}
@returns(200) users response

@endpoint GET /admin/users/list/{flag}.json
@desc List users by flag
@required {flag: str(active/new/staff/suspended/blocked/suspect)}
@optional {order: str(created/last_emailed/seen/username/email/trust_level/days_visited/posts_read/topics_viewed/posts/read_time), asc: str, page: int, show_emails: bool # Include user email addresses in response. These requests will be logged in the staff action logs., stats: bool # Include user stats information, email: str # Filter to the user with this email address, ip: str # Filter to users with this IP address}
@returns(200) response

@endgroup

@group user_actions.json
@endpoint GET /user_actions.json
@desc Get a list of user actions
@required {offset: int, username: str, filter: str}
@returns(200) {user_actions: [map]} # response

@endgroup

@group session
@endpoint POST /session/forgot_password.json
@desc Send password reset email
@required {login: str}
@returns(200) {success: str, user_found: bool} # success response

@endgroup

@group users
@endpoint PUT /users/password-reset/{token}.json
@desc Change password
@required {token: str, username: str, password: str}
@returns(200) success response

@endgroup

@group u
@endpoint GET /u/{username}/emails.json
@desc Get email addresses belonging to a user
@required {username: str}
@returns(200) {email: str, secondary_emails: [any], unconfirmed_emails: [any], associated_accounts: [any]} # success response

@endgroup

@end
