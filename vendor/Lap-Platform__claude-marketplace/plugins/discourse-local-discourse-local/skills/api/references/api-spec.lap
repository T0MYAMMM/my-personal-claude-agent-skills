@group uploads.json
@endpoint POST /uploads.json
@desc Creates an upload
@returns(200) {id: int, url: str, original_filename: str, filesize: int, width: int, height: int, thumbnail_width: int, thumbnail_height: int, extension: str, short_url: str, short_path: str, retain_hours: str?, human_filesize: str, dominant_color: str?, thumbnail: map?, optimized_video: map?} # file uploaded

@endgroup

@group uploads
@endpoint POST /uploads/generate-presigned-put.json
@desc Initiates a direct external upload
@required {type: str(avatar/profile_background/card_background/custom_emoji/composer), file_name: str, file_size: int # File size should be represented in bytes.}
@optional {metadata: map{sha1-checksum: str}}
@returns(200) {key: str, url: str, signed_headers: map, unique_identifier: str} # external upload initialized

@endpoint POST /uploads/complete-external-upload.json
@desc Completes a direct external upload
@required {unique_identifier: str # The unique identifier returned in the original /generate-presigned-put request.}
@optional {for_private_message: str # Optionally set this to true if the upload is for a private message., for_site_setting: str # Optionally set this to true if the upload is for a site setting., pasted: str # Optionally set this to true if the upload was pasted into the upload area. This will convert PNG files to JPEG.}
@returns(200) {id: int, url: str, original_filename: str, filesize: int, width: int, height: int, thumbnail_width: int, thumbnail_height: int, extension: str, short_url: str, short_path: str, retain_hours: str?, human_filesize: str, dominant_color: str?, thumbnail: map?, optimized_video: map?} # external upload initialized

@endpoint POST /uploads/create-multipart.json
@desc Creates a multipart external upload
@required {upload_type: str(avatar/profile_background/card_background/custom_emoji/composer), file_name: str, file_size: int # File size should be represented in bytes.}
@optional {metadata: map{sha1-checksum: str}}
@returns(200) {key: str, external_upload_identifier: str, unique_identifier: str} # external upload initialized

@endpoint POST /uploads/batch-presign-multipart-parts.json
@desc Generates batches of presigned URLs for multipart parts
@required {part_numbers: [any] # The part numbers to generate the presigned URLs for, must be between 1 and 10000., unique_identifier: str # The unique identifier returned in the original /create-multipart request.}
@returns(200) {presigned_urls: map} # external upload initialized

@endpoint POST /uploads/abort-multipart.json
@desc Abort multipart upload
@required {external_upload_identifier: str # The identifier of the multipart upload in the external storage provider. This is the multipart upload_id in AWS S3.}
@returns(200) {success: str} # external upload initialized

@endpoint POST /uploads/complete-multipart.json
@desc Complete multipart upload
@required {unique_identifier: str # The unique identifier returned in the original /create-multipart request., parts: [any] # All of the part numbers and their corresponding ETags that have been uploaded must be provided.}
@returns(200) {id: int, url: str, original_filename: str, filesize: int, width: int, height: int, thumbnail_width: int, thumbnail_height: int, extension: str, short_url: str, short_path: str, retain_hours: str?, human_filesize: str, dominant_color: str?, thumbnail: map?, optimized_video: map?} # external upload initialized

@endgroup

