@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api HDInsightManagementClient
@base https://management.azure.com
@version 2018-06-01-preview
@auth OAuth2
@common_fields {subscriptionId: any # The subscription credentials which uniquely identify Microsoft Azure subscription. The subscription ID forms part of the URI for every service call., resourceGroupName: any # The name of the resource group., clusterName: any # The name of the cluster., api-version: any # The HDInsight client API Version.}
@endpoints 10
@toc subscriptions(10)

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/clustermonitoring
@desc Enables the Operations Management Suite (OMS) on the HDInsight cluster.
@required {parameters: any # The Operations Management Suite (OMS) workspace parameters.}
@returns(200) Ok response definition.
@returns(202) Accepted response definition.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/clustermonitoring
@desc Gets the status of Operations Management Suite (OMS) on the HDInsight cluster.
@returns(200) OK. The request has succeeded.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/clustermonitoring
@desc Disables the Operations Management Suite (OMS) on the HDInsight cluster.
@returns(200) Ok response definition.
@returns(202) OK response definition.
@returns(204) No Content response definition.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/azureMonitor
@desc Enables the Azure Monitor on the HDInsight cluster.
@required {parameters: any # The Log Analytics workspace parameters.}
@returns(200) Ok response definition.
@returns(202) Accepted response definition.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/azureMonitor
@desc Gets the status of Azure Monitor on the HDInsight cluster.
@returns(200) OK. The request has succeeded.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/azureMonitor
@desc Disables the Azure Monitor on the HDInsight cluster.
@returns(200) Ok response definition.
@returns(202) OK response definition.
@returns(204) No Content response definition.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/{extensionName}
@desc Creates an HDInsight cluster extension.
@required {extensionName: any # The name of the cluster extension., parameters: any # The cluster extensions create request.}
@returns(200) Ok response definition.
@returns(202) Accepted response definition.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/{extensionName}
@desc Gets the extension properties for the specified HDInsight cluster extension.
@required {extensionName: any # The name of the cluster extension.}
@returns(200) OK. The request has succeeded.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/{extensionName}
@desc Deletes the specified extension for HDInsight cluster.
@required {extensionName: any # The name of the cluster extension.}
@returns(200) Ok response definition.
@returns(202) Accepted response definition.
@returns(204) No Content response definition.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.HDInsight/clusters/{clusterName}/extensions/{extensionName}/azureAsyncOperations/{operationId}
@desc Gets the async operation status.
@required {extensionName: any # The name of the cluster extension., operationId: any # The long running operation id.}
@returns(200) OK response definition.

@end
