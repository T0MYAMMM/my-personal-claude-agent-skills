@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api IPQualityScore API
@base https://ipqualityscore.com/api
@auth Basic username:password
@endpoints 3
@toc json(3)

@endpoint GET /json/email/{YOUR_API_KEY_HERE}/{USER_EMAIL_HERE}
@desc Email Validation
@required {YOUR_API_KEY_HERE: str # (Required) YOUR_API_KEY_HERE, USER_EMAIL_HERE: str # (Required) USER_EMAIL_HERE}
@returns(200) {message: str, success: bool, valid: bool, disposable: bool, smtp_score: int, overall_score: int, first_name: str, generic: bool, common: bool, dns_valid: bool, honeypot: bool, deliverability: str, frequent_complainer: bool, spam_trap_score: str, catch_all: bool, timed_out: bool, suspect: bool, recent_abuse: bool, fraud_score: int, suggested_domain: str, leaked: bool, domain_age: map{human: str, timestamp: int, iso: str}, first_seen: map{human: str, timestamp: int, iso: str}, sanitized_email: str, domain_velocity: str, user_activity: str, associated_names: map{status: str, names: [str]}, associated_phone_numbers: map{status: str, phone_numbers: [str]}, request_id: str} # Successful response
@errors {400: Bad Request, 500: Internal Server error, 500: Unexpected error}

@endpoint GET /json/phone/{YOUR_API_KEY_HERE}/{USER_PHONE_HERE}
@desc Phone Validation
@required {YOUR_API_KEY_HERE: str # (Required) YOUR_API_KEY_HERE, USER_PHONE_HERE: str # (Required) USER_PHONE_HERE, country: str # country, country: str # country}
@returns(200) {message: str, success: bool, formatted: str, local_format: str, valid: bool, fraud_score: int, recent_abuse: bool, VOIP: bool, prepaid: str, risky: bool, active: bool, carrier: str, line_type: str, country: str, city: str, zip_code: str, region: str, dialing_code: int, active_status: str, sms_domain: str, associated_email_addresses: map{status: str, emails: [str]}, user_activity: str, mnc: str, mcc: str, leaked: bool, spammer: bool, request_id: str, name: str, timezone: str, do_not_call: bool, sms_email: str} # Successful response
@errors {400: Bad Request, 500: Internal Server error, 500: Unexpected error}

@endpoint GET /json/url/{YOUR_API_KEY_HERE}/{URL_HERE}
@desc Malicious URL Scanner
@required {YOUR_API_KEY_HERE: str # (Required) YOUR_API_KEY_HERE, URL_HERE: str # (Required) URL_HERE}
@returns(200) {message: str, success: bool, unsafe: bool, domain: str, ip_address: str, server: str, content_type: str, status_code: int, page_size: int, domain_rank: int, dns_valid: bool, parking: bool, spamming: bool, malware: bool, phishing: bool, suspicious: bool, adult: bool, risk_score: int, domain_age: map{human: str, timestamp: int, iso: str}, category: str, request_id: str} # Successful response
@errors {400: Bad Request, 500: Internal Server error, 500: Unexpected error}

@end
