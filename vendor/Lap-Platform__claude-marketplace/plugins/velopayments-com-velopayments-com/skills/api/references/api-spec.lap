@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Velo Payments APIs
@base https://api.sandbox.velopayments.com/
@version 2.38.183
@auth OAuth2 | Bearer basic | OAuth2
@endpoints 109
@hint download_for_search
@toc authenticate(1), logout(1), password(1), validate(1), users(17), payors(6), payorLinks(2), payees(27), sourceAccounts(11), fundingAccounts(3), deltas(2), fundings(1), transactions(3), paymentaudit(14), payments(2), payouts(8), paymentChannelRules(1), supportedCountries(2), currencies(1), webhooks(5)

@group authenticate
@endpoint POST /v1/authenticate
@desc Authentication endpoint
@optional {grant_type: str=client_credentials # OAuth grant type. Should use 'client_credentials'}
@returns(200) {access_token: str, token_type: str, expires_in: num, refresh_token: str, scope: str, entityIds: [str]} # Valid Authenication response

@endgroup

@group logout
@endpoint POST /v1/logout
@desc Logout
@returns(204) User has been logged out
@errors {401: Invalid access token. May be expired or invalid, 403: The authentication does not have permissions to access the resource This usually occurs when there is a valid authentication instance (client or user) but they do not have the required permissions}

@endgroup

@group password
@endpoint POST /v1/password/reset
@desc Reset password
@required {email: str(email) # the email address of the user requesting the reset password}
@returns(204) the request was accepted
@errors {400: Invalid request. See Error message payload for details of failure}

@endgroup

@group validate
@endpoint POST /v1/validate
@desc validate
@required {otp: str # an OTP either sent via sms or generated by a registered MFA device}
@optional {Authorization: str # Bearer token authorization leg of validate}
@returns(200) {access_token: str, token_type: str, refresh_token: str, expires_in: int, scope: str, user_info: map{user_id: str(uuid), userType: str, mfa_details: map{mfa_type: str?, verified: bool}}, entityIds: [str]} # User request has been validated
@errors {401: Invalid access token. May be expired or invalid, 403: The authentication does not have permissions to access the resource This usually occurs when there is a valid authentication instance (client or user) but they do not have the required permissions}

@endgroup

@group users
@endpoint GET /v2/users
@desc List Users
@optional {type: str # The Type of the User., status: str # The status of the User., entityId: str(uuid) # The entityId of the User., payeeType: str # The Type of the Payee entity. Either COMPANY or INDIVIDUAL., page: int(int32)=1 # Page number. Default is 1., pageSize: int(int32)=25 # The number of results to return in a page, sort: str=email:asc # List of sort fields (e.g. ?sort=email:asc,lastName:asc) Default is email:asc 'name' The supported sort fields are - email, lastNmae.}
@returns(200) {page: any, links: [any], content: [map]} # Paginated list of Users filtered by query parameters
@errors {400: Invalid request. See Error message payload for details of failure, 401: Invalid access token. May be expired or invalid, 403: The authentication does not have permissions to access the resource This usually occurs when there is a valid authentication instance (client or user) but they do not have the required permissions}

