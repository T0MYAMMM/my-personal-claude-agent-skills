@group addresses
@endpoint PUT /v1/addresses/recognize
@desc Parse an address
@required {text: str # The unstructured text that contains address-related entities}
@optional {address: any # You can optionally provide any already-known address values. For example, you may already know the recipient's name, city, and country, and only want to parse the street address into separate lines.}
@returns(200) {score: num(double), address: any, entities: [map]} # Returns the parsed address, as well as a confidence score and a list of all the entities that were recognized in the text.
@errors {400: The request contained errors., 500: An error occurred on ShipEngine's side.  > This error will automatically be reported to our engineers.}
@example_request {"text":"Margie McMiller at 3800 North Lamar suite 200 in austin, tx.  The zip code there is 78652."}

@endpoint POST /v1/addresses/validate
@desc Validate An Address
@returns(200) The request was a success.
@errors {400: The request contained errors., 500: An error occurred on ShipEngine's side.  > This error will automatically be reported to our engineers.}
@example_request [{"name":"Mickey and Minnie Mouse","phone":"714-781-4565","company_name":"The Walt Disney Company","address_line1":"500 South Buena Vista Street","city_locality":"Burbank","state_province":"CA","postal_code":91521,"country_code":"US"}]

@endgroup

