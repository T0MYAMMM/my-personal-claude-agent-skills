@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2015-05-01-preview
@auth OAuth2
@common_fields {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., serverName: any # The name of the server containing the failover group., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@endpoints 7
@toc subscriptions(7)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/failoverGroups/{failoverGroupName}
@desc Gets a failover group.
@required {failoverGroupName: any # The name of the failover group.}
@returns(200) Successfully retrieved the specified failover group.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/failoverGroups/{failoverGroupName}
@desc Creates or updates a failover group.
@required {failoverGroupName: any # The name of the failover group., parameters: map # The failover group parameters.}
@returns(200) Successfully updated the failover group.
@returns(202) Accepted
@returns(201) Successfully created the failover group.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/failoverGroups/{failoverGroupName}
@desc Deletes a failover group.
@required {failoverGroupName: any # The name of the failover group.}
@returns(200) Successfully deleted the failover group.
@returns(202) Accepted
@returns(204) The specified failover group does not exist.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/failoverGroups/{failoverGroupName}
@desc Updates a failover group.
@required {failoverGroupName: any # The name of the failover group., parameters: map # The failover group parameters.}
@returns(200) Successfully updated the failover group.
@returns(202) Accepted

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/failoverGroups
@desc Lists the failover groups in a server.
@returns(200) Successfully retrieved the failover groups.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/failoverGroups/{failoverGroupName}/failover
@desc Fails over from the current primary server to this server.
@required {failoverGroupName: any # The name of the failover group.}
@returns(200) Successfully failed over.
@returns(202) Accepted

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/failoverGroups/{failoverGroupName}/forceFailoverAllowDataLoss
@desc Fails over from the current primary server to this server. This operation might result in data loss.
@required {failoverGroupName: any # The name of the failover group.}
@returns(200) Successfully failed over.
@returns(202) Accepted

@end
