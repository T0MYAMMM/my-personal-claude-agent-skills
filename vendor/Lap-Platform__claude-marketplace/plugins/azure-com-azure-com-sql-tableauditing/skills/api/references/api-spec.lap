@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2014-04-01
@auth OAuth2
@common_fields {serverName: any # The name of the server.}
@endpoints 8
@toc subscriptions(8)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/auditingPolicies/{tableAuditingPolicyName}
@desc Gets a server's table auditing policy. Table auditing is deprecated, use blob auditing instead.
@required {tableAuditingPolicyName: any # The name of the table auditing policy.}
@returns(200) Successfully retrieved the server table auditing policy.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/auditingPolicies/{tableAuditingPolicyName}
@desc Creates or updates a server's table auditing policy. Table auditing is deprecated, use blob auditing instead.
@required {tableAuditingPolicyName: any # The name of the table auditing policy., parameters: map # The server table auditing policy.}
@returns(200) Successfully set the server table auditing policy.
@returns(201) Successfully created the server table auditing policy.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/auditingPolicies
@desc Lists a server's table auditing policies. Table auditing is deprecated, use blob auditing instead.
@returns(200) Successfully retrieved the server table auditing policies.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/auditingPolicies/{tableAuditingPolicyName}
@desc Gets a database's table auditing policy. Table auditing is deprecated, use blob auditing instead.
@required {databaseName: any # The name of the database for which the table audit policy is defined., tableAuditingPolicyName: any # The name of the table auditing policy.}
@returns(200) Successfully retrieved the database table auditing policy.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/auditingPolicies/{tableAuditingPolicyName}
@desc Creates or updates a database's table auditing policy. Table auditing is deprecated, use blob auditing instead.
@required {databaseName: any # The name of the database for which the table auditing policy will be defined., tableAuditingPolicyName: any # The name of the table auditing policy., parameters: map # The database table auditing policy.}
@returns(200) Successfully set the database table auditing policy.
@returns(201) Successfully created the database table auditing policy.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/auditingPolicies
@desc Lists a database's table auditing policies. Table auditing is deprecated, use blob auditing instead.
@required {databaseName: any # The name of the database for which the table audit policy is defined.}
@returns(200) Successfully retrieved the database table auditing policies.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/connectionPolicies/{connectionPolicyName}
@desc Gets a database's connection policy, which is used with table auditing. Table auditing is deprecated, use blob auditing instead.
@required {databaseName: any # The name of the database for which the connection policy is defined., connectionPolicyName: any # The name of the connection policy.}
@returns(200) Successfully retrieved the database connection policy.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/connectionPolicies/{connectionPolicyName}
@desc Creates or updates a database's connection policy, which is used with table auditing. Table auditing is deprecated, use blob auditing instead.
@required {databaseName: any # The name of the database for which the connection policy will be defined., connectionPolicyName: any # The name of the connection policy., parameters: map # The database connection policy.}
@returns(200) Successfully set the database connection policy.
@returns(201) Successfully created the database connection policy.

@end
