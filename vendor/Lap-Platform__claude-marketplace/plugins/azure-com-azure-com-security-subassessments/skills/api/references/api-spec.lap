@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Microsoft Defender for Cloud
@base https://management.azure.com
@version 2019-01-01-preview
@auth OAuth2
@endpoints 3
@toc {scope}(3)

@endpoint GET /{scope}/providers/Microsoft.Security/subAssessments
@desc Get security sub-assessments on all your scanned resources inside a subscription scope
@returns(200) OK

@endpoint GET /{scope}/providers/Microsoft.Security/assessments/{assessmentName}/subAssessments
@desc Get security sub-assessments on all your scanned resources inside a scope
@required {assessmentName: any # The Assessment Key - Unique key for the assessment type}
@returns(200) OK

@endpoint GET /{scope}/providers/Microsoft.Security/assessments/{assessmentName}/subAssessments/{subAssessmentName}
@desc Get a security sub-assessment on your scanned resource
@required {assessmentName: any # The Assessment Key - Unique key for the assessment type, subAssessmentName: any # The Sub-Assessment Key - Unique key for the sub-assessment type}
@returns(200) OK

@end
