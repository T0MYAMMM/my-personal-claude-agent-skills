@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api App Center Client
@base https://api.appcenter.ms/
@version v0.1
@auth ApiKey X-API-Token in header | basic
@endpoints 265
@hint download_for_search
@toc v0.1(265)

@endpoint POST /v0.1/users/{user_id}/devices/register
@desc Registers a user for an existing device
@required {user_id: any # The ID of the user, body: any # The device info.}
@returns(200) Success
@errors {404:<b>not_found</b>: The user or the device can't be found.}

@endpoint GET /v0.1/user/notifications/emailSettings
@desc Get Default email notification settings for the user
@returns(200) Success

@endpoint GET /v0.1/user/metadata/optimizely
@returns(200) Success

@endpoint POST /v0.1/user/invitations/orgs/{invitation_token}/reject
@desc Rejects a pending organization invitation
@required {invitation_token: any # The app invitation token that was sent to the user}
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(204) Success

@endpoint POST /v0.1/user/invitations/orgs/{invitation_token}/accept
@desc Accepts a pending organization invitation for the specified user
@required {invitation_token: any # The app invitation token that was sent to the user}
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(204) Success

@endpoint POST /v0.1/user/invitations/distribution_groups/accept
@desc Accepts all pending invitations to distribution groups for the specified user
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(204) Success

@endpoint POST /v0.1/user/invitations/apps/{invitation_token}/reject
@desc Rejects a pending invitation for the specified user
@required {invitation_token: any # The app invitation token that was sent to the user}
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(204) Success

@endpoint POST /v0.1/user/invitations/apps/{invitation_token}/accept
@desc Accepts a pending invitation for the specified user
@required {invitation_token: any # The app invitation token that was sent to the user}
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(204) Success

@endpoint GET /v0.1/user/export/serviceConnections
@desc Gets all service connections of the service type for GDPR export.
@returns(200) Success

@endpoint POST /v0.1/user/dsr/export/{token}/cancel
@required {token: any # Unique request ID (GUID)}
@returns(202) Data subject right cancel export request has been accepted.
@errors {503: Cancel export request cannot be processed yet.}

@endpoint GET /v0.1/user/dsr/export/{token}
@required {token: any # Unique request ID (GUID)}
@returns(200) Data subject right export request status successfully retrieved.

@endpoint POST /v0.1/user/dsr/export
@returns(202) Data subject right export request has been accepted.

@endpoint POST /v0.1/user/dsr/delete/{token}/cancel
@required {token: any # Unique request ID (GUID)}
@optional {email: map}
@returns(202) Data subject right cancel delete request has been accepted.
@errors {503: Cancel delete request cannot be processed yet.}

@endpoint GET /v0.1/user/dsr/delete/{token}
@required {token: any # Unique request ID (GUID), email: any # Email used for delete with x-authz-bypass headers}
@returns(200) Data subject right delete request status successfully retrieved.

@endpoint POST /v0.1/user/dsr/delete
@returns(202) Data subject right delete request has been accepted.

@endpoint GET /v0.1/user/devices/{device_udid}
@desc Returns the device details.
@required {device_udid: any # The UDID of the device}
@returns(200) Success
@errors {400:<b>bad_request</b>: Devices information can only be requested for iOS apps., 403:<b>forbidden</b>: The user is not allowed to view someone else's device., 404:<b>not_found</b>: The user or device can't be found.}

@endpoint DELETE /v0.1/user/devices/{device_udid}
@desc Removes an existing device from a user
@required {device_udid: any # The UDID of the device}
@returns(200) Success
@errors {403:<b>forbidden</b>: The user is not allowed to delete someone else's device., 404:<b>not_found</b>: The user or the device can't be found.}

@endpoint GET /v0.1/user/devices
@desc Returns all devices associated with the given user.
@returns(200) Success
@errors {400:<b>bad_request</b>: Devices information can only be requested for iOS apps., 403:<b>forbidden</b>: The user is not allowed to view someone else's devices.}

@endpoint GET /v0.1/user
@desc Returns the user profile data
@returns(200) Success

@endpoint PATCH /v0.1/user
@desc Updates the user profile and returns the updated user data
@required {user: any # The data for the created user}
@returns(200) Success

@endpoint GET /v0.1/sdk/apps/{app_secret}/releases/{release_hash}
@desc If 'latest' is not specified then it will return the specified release if it's enabled. If 'latest' is specified, regardless of whether a release hash is provided, the latest enabled release is returned.
@required {app_secret: any # The secret of the target application, release_hash: any # The hash of the release or 'latest' to get the latest release from all the distribution groups assigned to the current user.}
@optional {udid: any # When passing `udid` in the query string, a provisioning check for the given device ID will be done. Will be ignored for non-iOS platforms.}
@returns(200) If called with a specific `release_hash` return the app's 'display_name'' and 'buildIdentifier'. If 'release_hash' is 'latest' return the full release details of the latest release that was distributed to the current user (from all the distribution groups).
@errors {404: Error codes: - `not_found` - A release or an app can't be found. - `no_releases_for_user` - No releases available for that user (will only be returned when `release_hash` is `latest`)}

@endpoint GET /v0.1/sdk/apps/{app_secret}/releases/private/latest
@desc Get the latest release distributed to a private group the given user is a member of for the given app.
@required {app_secret: any # The secret of the target application}
@optional {udid: any # When passing `udid` in the query string, a provisioning check for the given device ID will be done. Will be ignored for non-iOS platforms.}
@returns(200) Return the full release details of the latest release that was distributed to the current user (from all the private distribution groups).
@errors {404: Error codes: - `not_found` - A release or an app can't be found. - `no_releases_for_user` - No releases available for that user.}

@endpoint GET /v0.1/public/sparkle/apps/{app_secret}
@desc Gets the sparkle feed of the releases that are distributed to all the public distribution groups.
@required {app_secret: any # The secret of the application.}
@returns(200) The RSS feed of releases.

@endpoint GET /v0.1/public/sdk/apps/{app_secret}/releases/{release_hash}/public_distribution_groups
@desc Get all public distribution groups that a given release has been distributed to
@required {app_secret: any # The secret of the target application, release_hash: any # The hash of the release}
@returns(200) The public distribution groups that the release has been distributed to
@errors {404: Error Codes: - `not_found` - The app doesn't exist}

@endpoint GET /v0.1/public/sdk/apps/{app_secret}/releases/latest
@desc Get the latest public release for the given app.
@required {app_secret: any # The secret of the target application}
@returns(200) The full release details of the latest release that was distributed to a public group.
@errors {404: Error Codes: - `not_found` - The app doesn't exist - `no_releases_for_app` - The app has no public releases.}

@endpoint GET /v0.1/public/sdk/apps/{app_secret}/distribution_groups/{distribution_group_id}/releases/latest
@desc Get a release with 'latest' for the given public group.
@required {app_secret: any # The secret of the target application, distribution_group_id: any # the id for destination}
@optional {is_install_page: any # The check if the request is from Install page}
@returns(200) The full release details of the latest release that was distributed from the given public group.
@errors {403: Error Codes: - `forbidden` - Unauthorized to access private distribution group, 404: Error Codes: - `not_found` - Distribution group or the app doesn't exist - `no_releases_for_app` - App has no releases.}

@endpoint POST /v0.1/public/apps/{owner_name}/{app_name}/install_analytics
@desc Notify download(s) for the provided distribution release(s).
@required {owner_name: any # The name of the app owner, app_name: any # The name of the app, body: any # The install analytics request payload}
@returns(204) Install Analytics Notification Sent Successfully.

@endpoint GET /v0.1/public/apps/{app_id}/releases/{release_id}/ios_manifest
@desc Returns the manifest.plist in XML format for installing the release on a device. Only available for iOS.
@required {app_id: any # The ID of the application, release_id: any # The release_id, token: any # A hash that authorizes the download if it matches the release info.}
@returns(200) Success
@errors {400: The app's OS is not iOS., 403: Forbidden - The token provided doesn't match the release's token., 404: The app or release can't be found.}

@endpoint GET /v0.1/orgs/{org_name}/users/{user_name}/apps
@desc Get a user apps information from an organization by name
@required {org_name: any # The organization's name, user_name: any # The slug name of the user}
@returns(200) Success

@endpoint PATCH /v0.1/orgs/{org_name}/users/{user_name}
@desc Updates the given organization user
@required {org_name: any # The organization's name, user_name: any # The slug name of the user, organization_user: any}
@returns(200) Success

@endpoint DELETE /v0.1/orgs/{org_name}/users/{user_name}
@desc Removes a user from an organization.
@required {org_name: any # The organization's name, user_name: any # The slug name of the user}
@returns(204) Success

@endpoint GET /v0.1/orgs/{org_name}/users/{user_name}
@desc Get a user information from an organization by name - if there is explicit permission return it, if not if not return highest implicit permission
@required {org_name: any # The organization's name, user_name: any # The slug name of the user}
@returns(200) Success

@endpoint GET /v0.1/orgs/{org_name}/users
@desc Returns a list of users that belong to an organization
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint GET /v0.1/orgs/{org_name}/testers
@desc Returns a unique list of users including the whole organization members plus testers in any shared group of that org
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint DELETE /v0.1/orgs/{org_name}/teams/{team_name}/users/{user_name}
@desc Removes a user from a team that is owned by an organization
@required {org_name: any # The organization's name, team_name: any # The team's name, user_name: any # The slug name of the user}
@returns(204) Success

@endpoint GET /v0.1/orgs/{org_name}/teams/{team_name}/users
@desc Returns the users of a team which is owned by an organization
@required {org_name: any # The organization's name, team_name: any # The team's name}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/teams/{team_name}/users
@desc Adds a new user to a team that is owned by an organization
@required {org_name: any # The organization's name, team_name: any # The team's name, user_email: any # The email of the user to add to the team}
@returns(201) Success

@endpoint PATCH /v0.1/orgs/{org_name}/teams/{team_name}/apps/{app_name}
@desc Updates the permissions the team has to the app
@required {org_name: any # The organization's name, team_name: any # The team's name, app_name: any # The name of the application, team: any}
@returns(200) Success

@endpoint DELETE /v0.1/orgs/{org_name}/teams/{team_name}/apps/{app_name}
@desc Removes an app from a team
@required {org_name: any # The organization's name, team_name: any # The team's name, app_name: any # The name of the application}
@returns(204) Success

@endpoint POST /v0.1/orgs/{org_name}/teams/{team_name}/apps
@desc Adds an app to a team
@required {org_name: any # The organization's name, team_name: any # The team's name, app: any # The name of the app to be added to the team. The app has to be owned by the organization.}
@returns(201) Success

@endpoint GET /v0.1/orgs/{org_name}/teams/{team_name}/apps
@desc Returns the apps a team has access to
@required {org_name: any # The organization's name, team_name: any # The team's name}
@returns(200) Success

@endpoint GET /v0.1/orgs/{org_name}/teams/{team_name}
@desc Returns the details of a single team
@required {org_name: any # The organization's name, team_name: any # The team's name}
@returns(200) Success

@endpoint DELETE /v0.1/orgs/{org_name}/teams/{team_name}
@desc Deletes a single team
@required {org_name: any # The organization's name, team_name: any # The team's name}
@returns(204) Success

@endpoint PATCH /v0.1/orgs/{org_name}/teams/{team_name}
@desc Updates a single team
@required {org_name: any # The organization's name, team_name: any # The team's name, team: any # The information used to update the team}
@returns(200) Success

@endpoint GET /v0.1/orgs/{org_name}/teams
@desc Returns the list of all teams in this org
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/teams
@desc Creates a team and returns it
@required {org_name: any # The organization's name, team: any # The information used to create the team}
@returns(201) Success

@endpoint POST /v0.1/orgs/{org_name}/invitations/{email}/revoke
@desc Removes a user's invitation to an organization
@required {org_name: any # The organization's name, email: any # The email address of the user to send the password reset mail to.}
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(204) Success

@endpoint POST /v0.1/orgs/{org_name}/invitations/{email}/resend
@desc Cancels an existing organization invitation for the user and sends a new one
@required {org_name: any # The organization's name, email: any # The email address of the user to send the password reset mail to.}
@optional {role: any # The role of the user to be added}
@returns(204) Success

@endpoint PATCH /v0.1/orgs/{org_name}/invitations/{email}
@desc Allows the role of an invited user to be changed
@required {org_name: any # The organization's name, email: any # The email address of the user to send the password reset mail to., user_role: any # The new role of the user}
@returns(204) Success

@endpoint POST /v0.1/orgs/{org_name}/invitations
@desc Invites a new or existing user to an organization
@required {org_name: any # The organization's name, user_email: any # The email of the user to invite}
@returns(204) Success

@endpoint DELETE /v0.1/orgs/{org_name}/invitations
@desc Removes a user's invitation to an organization
@required {org_name: any # The organization's name, user_email: any # The email of the user whose invitation should be removed}
@returns(204) Success

@endpoint GET /v0.1/orgs/{org_name}/invitations
@desc Gets the pending invitations for the organization
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint GET /v0.1/orgs/{org_name}/distribution_groups_details
@desc Returns a list of distribution groups with details for an organization
@required {org_name: any # The organization's name}
@optional {apps_limit: any # The max number of apps to include in the response}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}/resend_invite
@desc Resend shared distribution group invite notification to previously invited testers
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group, members: any # The list of members to add}
@returns(204) Success

@endpoint POST /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}/members/bulk_delete
@desc Delete testers from distribution group in an org
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group, members: any # The list of members to add}
@returns(204) Success

@endpoint GET /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}/members
@desc Returns a list of member in the distribution group specified
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}/members
@desc Accepts an array of user email addresses to get added to the specified group
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group, member_emails: any # list of user email addresses that should get added as members to the specified group}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}/apps/bulk_delete
@desc Delete apps from distribution group in an org
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group, apps: any # The name of the apps to be deleted from the distribution group. The apps have to be owned by the organization.}
@returns(204) Success

@endpoint GET /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}/apps
@desc Get apps from a distribution group in an org
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}/apps
@desc Add apps to distribution group in an org
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group, apps: any # The name of the apps to be added to the distribution group. The apps have to be owned by the organization.}
@returns(204) Success

@endpoint GET /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}
@desc Returns a single distribution group in org for a given distribution group name
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group}
@returns(200) Success

@endpoint PATCH /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}
@desc Update one given distribution group name in an org
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group}
@optional {distribution_group_for_org: any # The attributes to update for the distribution group}
@returns(200) Success

@endpoint DELETE /v0.1/orgs/{org_name}/distribution_groups/{distribution_group_name}
@desc Deletes a single distribution group from an org with a given distribution group name
@required {org_name: any # The organization's name, distribution_group_name: any # The name of the distribution group}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/distribution_groups
@desc Creates a disribution goup which can be shared across apps under an organization
@required {org_name: any # The organization's name, distribution_group: any # The attributes to update for the distribution group}
@returns(201) Success

@endpoint GET /v0.1/orgs/{org_name}/distribution_groups
@desc Returns a list of distribution groups in the org specified
@required {org_name: any # The organization's name}
@returns(201) Success

@endpoint GET /v0.1/orgs/{org_name}/azure_subscriptions
@desc Returns a list of azure subscriptions for the organization
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/avatar
@desc Sets the organization avatar
@required {org_name: any # The organization's name}
@optional {avatar: any # The image for an Organization avatar to upload.}
@returns(200) Success

@endpoint DELETE /v0.1/orgs/{org_name}/avatar
@desc Deletes the uploaded organization avatar
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint POST /v0.1/orgs/{org_name}/apps
@desc Creates a new app for the organization and returns it to the caller
@required {org_name: any # The organization's name, app: any # The data for the app}
@returns(200) Success
@returns(201) Success

@endpoint GET /v0.1/orgs/{org_name}/apps
@desc Returns a list of apps for the organization
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint GET /v0.1/orgs/{org_name}
@desc Returns the details of a single organization
@required {org_name: any # The organization's name}
@returns(200) Success

@endpoint PATCH /v0.1/orgs/{org_name}
@desc Returns a list of organizations the requesting user has access to
@required {org_name: any # The organization's name, org: any # The data for the org}
@returns(200) Success

@endpoint DELETE /v0.1/orgs/{org_name}
@desc Deletes a single organization
@required {org_name: any # The organization's name}
@returns(204) Success

@endpoint POST /v0.1/orgs
@desc Creates a new organization and returns it to the caller
@required {organization: any # The organization data}
@returns(201) Created

@endpoint GET /v0.1/orgs
@desc Returns a list of organizations the requesting user has access to
@returns(200) Success

@endpoint GET /v0.1/invitations/sent
@desc Returns all invitations sent by the caller
@returns(200) Success

@endpoint GET /v0.1/azure_subscriptions
@desc Returns a list of azure subscriptions for the user
@returns(200) Success

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/webhooks
@desc Get web hooks configured for a particular app
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/versions
@desc Gets a list of application versions.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success

@endpoint DELETE /v0.1/apps/{owner_name}/{app_name}/users/{user_email}
@desc Removes the user from the app
@required {owner_name: any # The name of the owner, app_name: any # The name of the application, user_email: any # The user email of the user to delete}
@returns(204) Success

@endpoint PATCH /v0.1/apps/{owner_name}/{app_name}/users/{user_email}
@desc Update user permission for the app
@required {owner_name: any # The name of the owner, app_name: any # The name of the application, user_email: any # The user email of the user to patch, user_app_permissions_data: any # The value to update the user permission for the app.}
@returns(204) Success

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/users
@desc Returns the users associated with the app specified with the given app name which belongs to the given owner.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/uploads/releases/{upload_id}
@desc Get the current status of the release upload.
@required {upload_id: any # The ID of the release upload, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success
@errors {400: The request contained invalid properties., 404: Error codes: - `not_found` - The app or upload doesn't exist.}

@endpoint PATCH /v0.1/apps/{owner_name}/{app_name}/uploads/releases/{upload_id}
@desc Update the current status of the release upload.
@required {upload_id: any # The ID of the release upload, body: any # The release upload status information., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {extract: any # A flag that indicates to extract release or not, true by default}
@returns(200) Success
@errors {400: The request contained invalid properties., 404: Error codes: - `not_found` - The app or upload doesn't exist.}

@endpoint POST /v0.1/apps/{owner_name}/{app_name}/uploads/releases
@desc Initiate a new release upload. This API is part of multi-step upload process.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {body: any # Optional parameters to create releases with user defined metadata}
@returns(201) Created
@errors {400: The request contained invalid properties., 404: Error codes: - `not_found` - The app doesn't exist.}

@endpoint POST /v0.1/apps/{owner_name}/{app_name}/transfer_to_org
@desc Transfers ownership of an app to a new organization
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(200) Success

@endpoint POST /v0.1/apps/{owner_name}/{app_name}/transfer/{destination_owner_name}
@desc Transfers ownership of an app to a different user or organization
@required {owner_name: any # The name of the owner, app_name: any # The name of the application, destination_owner_name: any # The name of the owner (user or organization) to which the app is being transferred}
@optional {empty_body: map # allow empty body for custom http-client lib}
@returns(200) Success

@endpoint DELETE /v0.1/apps/{owner_name}/{app_name}/testers/{tester_id}
@desc Delete the given tester from the all releases
@required {tester_id: any # The id of the tester, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success
@errors {404: Tester can't be found}

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/testers
@desc Returns the testers associated with the app specified with the given app name which belongs to the given owner.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/teams
@desc Returns the details of all teams that have access to the app.
@required {app_name: any # The name of the application, owner_name: any # The name of the owner}
@returns(200) Success

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/symbols/{symbol_id}/status
@desc Returns a particular symbol by id (uuid) for the provided application
@required {symbol_id: any # The ID of the symbol (uuid of the symbol), owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success
@errors {403: Unauthorized, 404: Not found, 500: Internal error}

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/symbols/{symbol_id}/location
@desc Gets the URL to download the symbol
@required {symbol_id: any # The ID of the symbol (uuid of the symbol), owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success
@errors {403: Unauthorized, 404: Not found, 500: Internal error}

@endpoint POST /v0.1/apps/{owner_name}/{app_name}/symbols/{symbol_id}/ignore
@desc Marks a symbol by id (uuid) as ignored
@required {symbol_id: any # The ID of the symbol (uuid of the symbol), owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success
@errors {403: Unauthorized, 404: Not found, 500: Internal error}

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/symbols/{symbol_id}
