@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {start: any # Start date time in data in ISO 8601 date time format. It must be within the current day in the UTC timezone. The default value is the start time of the current day in UTC timezone.}
@returns(200) List of logs for the requested time range.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/languages
@desc Languages in the time range.
@required {start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., $top: any # The maximum number of results to return. (0 will fetch all results), versions: any # To select specific application versions}
@returns(200) Languages with count during the time range in descending order.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/generic_log_flow
@desc Logs received between the specified start time and the current time. The API will return a maximum of 100 logs per call.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {start: any # Start date time in data in ISO 8601 date time format. It must be within the current day in the UTC timezone. The default value is the start time of the current day in UTC timezone.}
@returns(200) List of logs for the requested time range.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/events/{event_name}/properties/{event_property_name}/counts
@desc Event properties value counts during the time range in descending order.
@required {event_name: any # The id of the event., event_property_name: any # The id of the event property., start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions, $top: any # The number of property values to return. Set to 0 in order to fetch all results available.}
@returns(200) Event properties value counts during the time range in descending order.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/events/{event_name}/properties
@desc Event properties.
@required {event_name: any # The id of the event., owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Event properties.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/events/{event_name}/event_count
@desc Count of events by interval in the time range.
@required {event_name: any # The id of the event., start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions}
@returns(200) Count of events by interval in the time range.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/events/{event_name}/device_count
@desc Count of devices for an event by interval in the time range.
@required {event_name: any # The id of the event., start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions}
@returns(200) Count of devices for an event by interval in the time range.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/events/{event_name}/count_per_session
@desc Count of events per session by interval in the time range.
@required {event_name: any # The id of the event., start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions}
@returns(200) Count of events per session by interval in the time range.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/events/{event_name}/count_per_device
@desc Count of events per device by interval in the time range.
@required {event_name: any # The id of the event., start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions}
@returns(200) Count of events per device by interval in the time range.

@endpoint DELETE /v0.1/apps/{owner_name}/{app_name}/analytics/events/{event_name}
@desc Delete the set of Events with the specified event names.
@required {event_name: any # The id of the event., owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Event successfully deleted.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/events
@desc Count of active events in the time range ordered by event.
@required {start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions, event_name: any # To select the specific events., $top: any # The maximum number of results to return. (0 will fetch all results), $skip: any # The offset (starting at 0) of the first result to return. This parameter along with limit is used to perform pagination., $inlinecount: any # Controls whether or not to include a count of all the items across all pages., $orderby: any # controls the sorting order and sorting based on which column}
@returns(200) Count of active events in the time range ordered by event.

@endpoint DELETE /v0.1/apps/{owner_name}/{app_name}/analytics/event_logs/{event_name}
@desc Delete the set of Events with the specified event names.
@required {event_name: any # The id of the event., owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Event successfully deleted.

@endpoint POST /v0.1/apps/{owner_name}/{app_name}/analytics/distribution/release_counts
@desc Count of total downloads for the provided distribution releases.
@required {releases: map # The releases to retrieve., owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Count of total downloads for the provided distribution release(s).

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/crashfree_device_percentages
@desc Percentage of crash-free device by day in the time range based on the selected versions. Api will return -1 if crash devices is greater than active devices.
@required {start: any # Start date time in data in ISO 8601 date time format., version: any, owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format.}
@returns(200) Percentage of crash-free devices by day in the time range and overall percentage of the time range.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/crash_groups/{crash_group_id}/overall
@desc Available for UWP apps only.
@required {crash_group_id: any # The id of the crash group., version: any, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Overall crashes and affected users count.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/crash_groups/{crash_group_id}/operating_systems
@desc Available for UWP apps only.
@required {crash_group_id: any # The id of the crash group., version: any, owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {$top: any # The maximum number of results to return. (0 will fetch all results)}
@returns(200) Top OSes with percentage in descending order.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/crash_groups/{crash_group_id}/models
@desc Available for UWP apps only.
@required {crash_group_id: any # The id of the crash group., version: any, owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {$top: any # The maximum number of results to return. (0 will fetch all results)}
@returns(200) Top models with percentage in descending order.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/crash_groups/{crash_group_id}/crash_counts
@desc Available for UWP apps only.
@required {crash_group_id: any # The id of the crash group., version: any, start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format.}
@returns(200) Count of crashes by day in the time range and total crashes over the time range.

@endpoint POST /v0.1/apps/{owner_name}/{app_name}/analytics/crash_groups
@desc Overall crashes and affected users count of the selected crash groups with selected versions.
@required {crash_groups: map, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Overall crashes and affected users count for all selected crash groups.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/crash_counts
@desc Available for UWP apps only.
@required {start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions}
@returns(200) Count of crashes by day in the time range and total crashes over the time range.

@endpoint HEAD /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/{audience_name}
@desc Returns whether audience definition exists.
@required {audience_name: any # The name of the audience, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(204) Audiences exists.
@errors {404: Audiences does not exist.}

@endpoint DELETE /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/{audience_name}
@desc Deletes audience definition.
@required {audience_name: any # The name of the audience, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(204) Audiences exists.
@errors {404: Audiences does not exist.}

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/{audience_name}
@desc Gets audience definition.
@required {audience_name: any # The name of the audience, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Audiences definition.

@endpoint PUT /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/{audience_name}
@desc Creates or updates audience definition.
@required {audience_name: any # The name of the audience, audience: map # Audience definition, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Updated audiences definition.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/metadata/device_properties/{property_name}/values
@desc Get list of device property values.
@required {property_name: any # Device property, owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {contains: any # Contains string}
@returns(200) List of supported device property values.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/metadata/device_properties
@desc Get list of device properties.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) List of device properties.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/metadata/custom_properties
@desc Get list of custom properties.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) List of device properties.

@endpoint POST /v0.1/apps/{owner_name}/{app_name}/analytics/audiences/definition/test
@desc Tests audience definition.
@required {audience: map # Audience definition, owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Tests audience definition.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/audiences
@desc Get list of audiences.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {include_disabled: any # Include disabled audience definitions}
@returns(200) List of audiences.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}/analytics/active_device_counts
@desc Count of active devices by interval in the time range.
@required {start: any # Start date time in data in ISO 8601 date time format., owner_name: any # The name of the owner, app_name: any # The name of the application}
@optional {end: any # Last date time in data in ISO 8601 date time format., versions: any # To select specific application versions, app_build: any # Application build number. If build number is specified than multiple versions are not allowed.}
@returns(200) Count of active devices by interval in the time range.

@endpoint GET /v0.1/apps/{owner_name}/{app_name}
@desc Return a specific app with the given app name which belongs to the given owner.
@required {owner_name: any # The name of the owner, app_name: any # The name of the application}
@returns(200) Success

@endpoint PATCH /v0.1/apps/{owner_name}/{app_name}
@desc Partially updates a single app
@required {app_name: any # The name of the application, owner_name: any # The name of the owner}
@optional {app: any # The partial data for the app}
@returns(200) Success

@endpoint DELETE /v0.1/apps/{owner_name}/{app_name}
@desc Delete an app
@required {app_name: any # The name of the application, owner_name: any # The name of the owner}
@returns(204) Success

@endpoint POST /v0.1/apps
@desc Creates a new app and returns it to the caller
@required {app: any # The data for the app}
@returns(201) Success

@endpoint GET /v0.1/apps
@desc Returns a list of apps
@optional {$orderBy: any # The name of the attribute by which to order the response by. By default, apps are in order of creation. All results are ordered in ascending order.}
@returns(200) Success

@endpoint DELETE /v0.1/api_tokens/{api_token_id}
@desc Delete the user api_token object with the specific id
@required {api_token_id: any # The unique ID (UUID) of the api token}
@returns(204) Success
@errors {400: Error, 401: Unauthorized, 404: NotFound}

@endpoint GET /v0.1/api_tokens
@desc Returns api tokens for the authenticated user
@returns(200) Success
@errors {400: Error, 401: Unauthorized}

@endpoint POST /v0.1/api_tokens
@desc Creates a new User API token
@optional {description: any # Description of the token}
@returns(201) Success
@errors {400: Error, 401: Unauthorized}

@endpoint GET /v0.1/administeredOrgs
@desc Returns a list organizations in which the requesting user is an admin
@returns(200) Success

@end
