@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Azure SQL Server API spec
@base https://management.azure.com
@version 2014-04-01
@auth OAuth2
@endpoints 2
@toc subscriptions(2)

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/connectionPolicies/{connectionPolicyName}
@desc Creates or updates the server's connection policy.
@required {serverName: any # The name of the server., connectionPolicyName: any # The name of the connection policy., parameters: any # The required parameters for updating a secure connection policy.}
@returns(200) OK
@returns(201) Created

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/connectionPolicies/{connectionPolicyName}
@desc Gets the server's secure connection policy.
@required {serverName: any # The name of the server., connectionPolicyName: any # The name of the connection policy.}
@returns(200) OK

@end
