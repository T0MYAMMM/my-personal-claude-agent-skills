@returns(200) {text: str, abuse: [map], sentiment_expressions: [map]} # Abuse detection incl. snippets
@returns(200) {text: str, topics: [str]} # Extract topics (native standard)
@returns(200) {text: str, topics: [str]} # Extract topics (IAB standard)
@returns(200) {text: str, topics: [str], sentiment_expressions: [map], entities_summary: [map]} # Adverse media monitoring in fintech
@returns(200) {text: str, topics: [str], sentence_list: [map]} # Tokenize a Japanese sentence
@returns(200) {text: str, topics: [any], abuse: [map], sentence_list: [map]} # Parse alias w/ sentence structure
@returns(200) {text: str, topics: [str], abuse: [map], sentence_list: [map]} # Parse hashtag and output words

@endgroup

