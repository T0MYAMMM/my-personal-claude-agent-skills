@group lm
@endpoint GET /lm/inflections
@desc List inflected forms
@required {language: str # (Required) The language code, lexeme: str # (Required) The lexeme to inspect, family: str # (Required) The family to inspect}
@optional {Ocp-Apim-Subscription-Key: str # {{apiKeyDescription}}}
@returns(200) {features: [map], text: str} # Inflected forms of "buy" in English
