@returns(200) {languages: [map]} # Breakdown of languages segmenting by line

@endgroup

@group transform
@endpoint POST /transform
@desc Translate text
@optional {Ocp-Apim-Subscription-Key: str # {{apiKeyDescription}}}
@returns(200) Translate a Japanese sentence
