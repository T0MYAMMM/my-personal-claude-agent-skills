@group users
@endpoint GET /users
@desc Retrieve all users
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail., includeRole: bool=False # Whether to include the user's role or not., projectId: str}
@returns(200) {data: [map], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized}

@endpoint POST /users
@desc Create multiple users
@returns(200) {user: map{id: str, email: str, inviteAcceptUrl: str, emailSent: bool}, error: str} # Operation successful.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /users/{id}
@desc Get user by ID/Email
@required {id: str(identifier) # The ID or email of the user.}
@optional {includeRole: bool=False # Whether to include the user's role or not.}
@returns(200) {id: str, email: str(email), firstName: str, lastName: str, isPending: bool, createdAt: str(date-time), updatedAt: str(date-time), role: str} # Operation successful.
@errors {401: Unauthorized}

@endpoint DELETE /users/{id}
@desc Delete a user
@required {id: str(identifier) # The ID or email of the user.}
@returns(204) Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endpoint PATCH /users/{id}/role
@desc Change a user's global role
@required {id: str(identifier) # The ID or email of the user., newRoleName: str}
@returns(200) Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endgroup

@group source-control
@endpoint POST /source-control/pull
@desc Pull changes from the remote repository
@optional {force: bool, autoPublish: str(none/all/published)=none # Controls automatic workflow publishing after import: - `none`: Keep workflows in their local published state (default) - `all`: Publish all imported workflows - `published`: Publish only workflows that were published locally before import, variables: map}
@returns(200) {variables: map{added: [str], changed: [str]}, credentials: [map], workflows: [map], tags: map{tags: [map], mappings: [map]}} # Import result
@errors {400: The request is invalid or provides malformed data., 409: Conflict}

@endgroup

@group variables
@endpoint POST /variables
@desc Create a variable
@required {key: str, value: str}
@optional {id: str, type: str, projectId: str}
@returns(201) Operation successful.
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized}

@endpoint GET /variables
@desc Retrieve variables
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail., projectId: str, state: str}
@returns(200) {data: [map], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized}

@endpoint DELETE /variables/{id}
@desc Delete a variable
@required {id: str # The ID of the variable.}
@returns(204) Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint PUT /variables/{id}
@desc Update a variable
@required {id: str # The ID of the variable., key: str, value: str}
@optional {id: str, type: str, projectId: str}
@returns(204) Operation successful.
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endgroup

@group data-tables
@endpoint GET /data-tables
@desc List all data tables
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail., filter: str(jsonString) # JSON string of filter conditions, sortBy: str # Sort format: field:asc or field:desc}
@returns(200) {data: [map], nextCursor: str?} # Successfully retrieved data tables
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized}

@endpoint POST /data-tables
@desc Create a new data table
@required {name: str # Name of the data table, columns: [map{name!: str, type!: str}] # Column definitions for the table}
@returns(201) {id: str, name: str, columns: [map], projectId: str, createdAt: str(date-time), updatedAt: str(date-time)} # Data table created successfully
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 409: Conflict}
@example_request {"name":"customers","columns":[{"name":"email","type":"string"},{"name":"status","type":"string"},{"name":"age","type":"number"}]}

@endpoint GET /data-tables/{dataTableId}
@desc Get a data table
@required {dataTableId: str(nanoid) # The ID of the data table}
@returns(200) {id: str, name: str, columns: [map], projectId: str, createdAt: str(date-time), updatedAt: str(date-time)} # Successfully retrieved data table
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint PATCH /data-tables/{dataTableId}
@desc Update a data table
@required {dataTableId: str(nanoid) # The ID of the data table, name: str # New name for the data table}
@returns(200) {id: str, name: str, columns: [map], projectId: str, createdAt: str(date-time), updatedAt: str(date-time)} # Data table updated successfully
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found., 409: Conflict}
@example_request {"name":"updated-customers"}

@endpoint DELETE /data-tables/{dataTableId}
@desc Delete a data table
@required {dataTableId: str(nanoid) # The ID of the data table}
@returns(204) Data table deleted successfully
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint GET /data-tables/{dataTableId}/rows
@desc Retrieve rows from a data table
@required {dataTableId: str(nanoid) # The ID of the data table}
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail., filter: str(jsonString) # JSON string of filter conditions, sortBy: str # Sort format: columnName:asc or columnName:desc, search: str # Search text across all string columns}
@returns(200) {data: [map], nextCursor: str?} # Successfully retrieved rows
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}

@endpoint POST /data-tables/{dataTableId}/rows
@desc Insert rows into a data table
@required {dataTableId: str(nanoid) # The ID of the data table, data: [map] # Array of rows to insert. Each row is an object with column names as keys.}
@optional {returnType: str(count/id/all)=count # - count: Return only the number of rows inserted - id: Return an array of inserted row IDs - all: Return the full row data for all inserted rows}
@returns(200) Rows inserted successfully
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}
@example_request {"data":[{"name":"John Doe","email":"john@example.com","age":30},{"name":"Jane Smith","email":"jane@example.com","age":25}],"returnType":"all"}

@endpoint PATCH /data-tables/{dataTableId}/rows/update
@desc Update rows in a data table
@required {dataTableId: str(nanoid) # The ID of the data table, filter: map{type: str, filters!: [map{columnName!: str, condition!: str, value!: any}]} # Filter conditions to match rows for update, data: map # Column values to update}
@optional {returnData: bool=False # If true, return the updated rows; if false, return true on success, dryRun: bool=False # If true, preview changes without persisting them}
@returns(200) Rows updated successfully
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}
@example_request {"filter":{"type":"and","filters":[{"columnName":"status","condition":"eq","value":"pending"}]},"data":{"status":"completed","updatedBy":"admin"},"returnData":false,"dryRun":false}

@endpoint POST /data-tables/{dataTableId}/rows/upsert
@desc Upsert a row in a data table
@required {dataTableId: str(nanoid) # The ID of the data table, filter: map{type: str, filters!: [map{columnName!: str, condition!: str, value!: any}]} # Filter conditions to match existing row. If no row matches, a new row is inserted., data: map # Column values for the row}
@optional {returnData: bool=False # If true, return the upserted row; if false, return true on success, dryRun: bool=False # If true, preview changes without persisting them}
@returns(200) Row upserted successfully
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}
@example_request {"filter":{"type":"and","filters":[{"columnName":"email","condition":"eq","value":"user@example.com"}]},"data":{"email":"user@example.com","name":"Updated Name","status":"active"},"returnData":true,"dryRun":false}

@endpoint DELETE /data-tables/{dataTableId}/rows/delete
@desc Delete rows from a data table
@required {dataTableId: str(nanoid) # The ID of the data table, filter: str(jsonString) # JSON string of filter conditions. Required to prevent accidental deletion of all data.}
@optional {returnData: bool=False # If true, return the deleted rows; if false, return true on success, dryRun: bool=False # If true, preview which rows would be deleted without actually deleting them}
@returns(200) Rows deleted successfully
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}

@endgroup

@group projects
@endpoint POST /projects
@desc Create a project
@required {name: str}
@optional {id: str, type: str}
@returns(201) Operation successful.
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized}

@endpoint GET /projects
@desc Retrieve projects
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail.}
@returns(200) {data: [map], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized}

@endpoint DELETE /projects/{projectId}
@desc Delete a project
@required {projectId: str # The ID of the project.}
@returns(204) Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endpoint PUT /projects/{projectId}
@desc Update a project
@required {projectId: str # The ID of the project., name: str}
@optional {id: str, type: str}
@returns(204) Operation successful.
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endpoint GET /projects/{projectId}/users
@desc List project members
@required {projectId: str # The ID of the project.}
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail.}
@returns(200) {data: [map], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endpoint POST /projects/{projectId}/users
@desc Add one or more users to a project
@required {projectId: str # The ID of the project., relations: [map{userId!: str, role!: str}] # A list of userIds and roles to add to the project.}
@returns(201) Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endpoint DELETE /projects/{projectId}/users/{userId}
@desc Delete a user from a project
@required {projectId: str # The ID of the project., userId: str # The ID of the user.}
@returns(204) Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endpoint PATCH /projects/{projectId}/users/{userId}
@desc Change a user's role in a project
@required {projectId: str # The ID of the project., userId: str # The ID of the user., role: str # The role assigned to the user in the project.}
@returns(204) Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endgroup

@end
