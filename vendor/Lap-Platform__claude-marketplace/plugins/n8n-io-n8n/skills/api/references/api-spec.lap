@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api n8n Public API
@base /api/v1
@version 1.1.1
@auth ApiKey X-N8N-API-KEY in header
@endpoints 59
@hint download_for_search
@toc audit(1), credentials(6), executions(8), tags(5), workflows(11), users(5), source-control(1), variables(4), data-tables(10), projects(8)

@group audit
@endpoint POST /audit
@desc Generate an audit
@optional {additionalOptions: map{daysAbandonedWorkflow: int, categories: [str]}}
@returns(200) {Credentials Risk Report: map, Database Risk Report: map, Filesystem Risk Report: map, Nodes Risk Report: map, Instance Risk Report: map} # Operation successful.
@errors {401: Unauthorized, 500: Internal server error.}

@endgroup

@group credentials
@endpoint GET /credentials
@desc List credentials
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail.}
@returns(200) {data: [any], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized}

@endpoint POST /credentials
@desc Create a credential
@required {name: str, type: str, data: map}
@optional {id: str, isResolvable: bool # Whether this credential has resolvable fields, createdAt: str(date-time), updatedAt: str(date-time)}
@returns(200) {id: str, name: str, type: str, createdAt: str(date-time), updatedAt: str(date-time)} # Operation successful.
@errors {400: Bad request - invalid credential type or data., 401: Unauthorized, 415: Unsupported media type.}

@endpoint PATCH /credentials/{id}
@desc Update credential by ID
@required {id: str # The credential ID that needs to be updated}
@optional {name: str # The name of the credential, type: str # The credential type. If changing type, data must also be provided., data: map # The credential data. Required when changing credential type., isGlobal: bool # Whether this credential is available globally, isResolvable: bool # Whether this credential has resolvable fields, isPartialData: bool=False # If true, unredacts and merges existing credential data with the provided data. If false, replaces the entire data object.}
@returns(200) {id: str, name: str, type: str, createdAt: str(date-time), updatedAt: str(date-time)} # Operation successful.
@errors {400: Bad request - invalid credential type or data., 401: Unauthorized, 404: The specified resource was not found.}

@endpoint DELETE /credentials/{id}
@desc Delete credential by ID
@required {id: str # The credential ID that needs to be deleted}
@returns(200) {id: str, name: str, type: str, data: map, isResolvable: bool, createdAt: str(date-time), updatedAt: str(date-time)} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint GET /credentials/schema/{credentialTypeName}
@desc Show credential data schema
@required {credentialTypeName: str # The credential type name that you want to get the schema for}
@returns(200) Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint PUT /credentials/{id}/transfer
@desc Transfer a credential to another project.
@required {id: str # The ID of the credential., destinationProjectId: str # The ID of the project to transfer the credential to.}
@returns(200) Operation successful.
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}

@endgroup

@group executions
@endpoint GET /executions
@desc Retrieve all executions
@optional {includeData: bool # Whether or not to include the execution's detailed data., status: str(canceled/error/running/success/waiting) # Status to filter the executions by., workflowId: str # Workflow to filter the executions by., projectId: str, limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail.}
@returns(200) {data: [map], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint GET /executions/{id}
@desc Retrieve an execution
@required {id: num # The ID of the execution.}
@optional {includeData: bool # Whether or not to include the execution's detailed data.}
@returns(200) {id: num, data: map, finished: bool, mode: str, retryOf: num?, retrySuccessId: num?, startedAt: str(date-time), stoppedAt: str(date-time)?, workflowId: num, waitTill: str(date-time)?, customData: map, status: str} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint DELETE /executions/{id}
@desc Delete an execution
@required {id: num # The ID of the execution.}
@returns(200) {id: num, data: map, finished: bool, mode: str, retryOf: num?, retrySuccessId: num?, startedAt: str(date-time), stoppedAt: str(date-time)?, workflowId: num, waitTill: str(date-time)?, customData: map, status: str} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint POST /executions/{id}/retry
@desc Retry an execution
@required {id: num # The ID of the execution.}
@optional {loadWorkflow: bool # Whether to load the currently saved workflow to execute instead of the one saved at the time of the execution. If set to true, it will retry with the latest version of the workflow.}
@returns(200) {id: num, data: map, finished: bool, mode: str, retryOf: num?, retrySuccessId: num?, startedAt: str(date-time), stoppedAt: str(date-time)?, workflowId: num, waitTill: str(date-time)?, customData: map, status: str} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found., 409: Conflict}

@endpoint POST /executions/{id}/stop
@desc Stop an execution
@required {id: num # The ID of the execution.}
@returns(200) {id: num, data: map, finished: bool, mode: str, retryOf: num?, retrySuccessId: num?, startedAt: str(date-time), stoppedAt: str(date-time)?, workflowId: num, waitTill: str(date-time)?, customData: map, status: str} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint POST /executions/stop
@desc Stop multiple executions
@required {status: [str] # Array of execution statuses to stop. Must include at least one status.}
@optional {workflowId: str # Optional workflow ID to filter executions. If not provided, will stop executions across all accessible workflows., startedAfter: str(date-time) # Only stop executions that started after this time., startedBefore: str(date-time) # Only stop executions that started before this time.}
@returns(200) {stopped: num} # Operation successful.
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized}

@endpoint GET /executions/{id}/tags
@desc Get execution tags
@required {id: num # The ID of the execution.}
@returns(200) List of annotation tags
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint PUT /executions/{id}/tags
@desc Update tags of an execution
@required {id: num # The ID of the execution.}
@returns(200) List of tags after updating
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}

@endgroup

@group tags
@endpoint POST /tags
@desc Create a tag
@required {name: str}
@optional {id: str, createdAt: str(date-time), updatedAt: str(date-time)}
@returns(201) {id: str, name: str, createdAt: str(date-time), updatedAt: str(date-time)} # A tag object
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 409: Conflict}

@endpoint GET /tags
@desc Retrieve all tags
@optional {limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail.}
@returns(200) {data: [map], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized}

@endpoint GET /tags/{id}
@desc Retrieves a tag
@required {id: str # The ID of the tag.}
@returns(200) {id: str, name: str, createdAt: str(date-time), updatedAt: str(date-time)} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint DELETE /tags/{id}
@desc Delete a tag
@required {id: str # The ID of the tag.}
@returns(200) {id: str, name: str, createdAt: str(date-time), updatedAt: str(date-time)} # Operation successful.
@errors {401: Unauthorized, 403: Forbidden, 404: The specified resource was not found.}

@endpoint PUT /tags/{id}
@desc Update a tag
@required {id: str # The ID of the tag., name: str}
@optional {id: str, createdAt: str(date-time), updatedAt: str(date-time)}
@returns(200) {id: str, name: str, createdAt: str(date-time), updatedAt: str(date-time)} # Tag object
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found., 409: Conflict}

@endgroup

@group workflows
@endpoint POST /workflows
@desc Create a workflow
@required {name: str, nodes: [map{id: str, name: str, webhookId: str, disabled: bool, notesInFlow: bool, notes: str, type: str, typeVersion: num, executeOnce: bool, alwaysOutputData: bool, retryOnFail: bool, maxTries: num, waitBetweenTries: num, continueOnFail: bool, onError: str, position: [num], parameters: map, credentials: map, createdAt: str(date-time), updatedAt: str(date-time)}], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}}
@optional {id: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), staticData: any, tags: [map{id: str, name!: str, createdAt: str(date-time), updatedAt: str(date-time)}], shared: [map{role: str, workflowId: str, projectId: str, project: map{id: str, name: str, type: str}, createdAt: str(date-time), updatedAt: str(date-time)}], activeVersion: map{versionId: str, workflowId: str, nodes: [map{id: str, name: str, webhookId: str, disabled: bool, notesInFlow: bool, notes: str, type: str, typeVersion: num, executeOnce: bool, alwaysOutputData: bool, retryOnFail: bool, maxTries: num, waitBetweenTries: num, continueOnFail: bool, onError: str, position: [num], parameters: map, credentials: map, createdAt: str(date-time), updatedAt: str(date-time)}], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}}
@returns(200) {id: str, name: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), nodes: [map], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}, staticData: any, tags: [map], shared: [map], activeVersion: map?{versionId: str, workflowId: str, nodes: [map], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}} # A workflow object
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized}

@endpoint GET /workflows
@desc Retrieve all workflows
@optional {active: bool, tags: str, name: str, projectId: str, excludePinnedData: bool # Set this to avoid retrieving pinned data, limit: num=100 # The maximum number of items to return., cursor: str # Paginate by setting the cursor parameter to the nextCursor attribute returned by the previous request's response. Default value fetches the first "page" of the collection. See pagination for more detail.}
@returns(200) {data: [map], nextCursor: str?} # Operation successful.
@errors {401: Unauthorized}

@endpoint GET /workflows/{id}
@desc Retrieve a workflow
@required {id: str # The ID of the workflow.}
@optional {excludePinnedData: bool # Set this to avoid retrieving pinned data}
@returns(200) {id: str, name: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), nodes: [map], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}, staticData: any, tags: [map], shared: [map], activeVersion: map?{versionId: str, workflowId: str, nodes: [map], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint DELETE /workflows/{id}
@desc Delete a workflow
@required {id: str # The ID of the workflow.}
@returns(200) {id: str, name: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), nodes: [map], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}, staticData: any, tags: [map], shared: [map], activeVersion: map?{versionId: str, workflowId: str, nodes: [map], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint PUT /workflows/{id}
@desc Update a workflow
@required {id: str # The ID of the workflow., name: str, nodes: [map{id: str, name: str, webhookId: str, disabled: bool, notesInFlow: bool, notes: str, type: str, typeVersion: num, executeOnce: bool, alwaysOutputData: bool, retryOnFail: bool, maxTries: num, waitBetweenTries: num, continueOnFail: bool, onError: str, position: [num], parameters: map, credentials: map, createdAt: str(date-time), updatedAt: str(date-time)}], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}}
@optional {id: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), staticData: any, tags: [map{id: str, name!: str, createdAt: str(date-time), updatedAt: str(date-time)}], shared: [map{role: str, workflowId: str, projectId: str, project: map{id: str, name: str, type: str}, createdAt: str(date-time), updatedAt: str(date-time)}], activeVersion: map{versionId: str, workflowId: str, nodes: [map{id: str, name: str, webhookId: str, disabled: bool, notesInFlow: bool, notes: str, type: str, typeVersion: num, executeOnce: bool, alwaysOutputData: bool, retryOnFail: bool, maxTries: num, waitBetweenTries: num, continueOnFail: bool, onError: str, position: [num], parameters: map, credentials: map, createdAt: str(date-time), updatedAt: str(date-time)}], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}}
@returns(200) {id: str, name: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), nodes: [map], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}, staticData: any, tags: [map], shared: [map], activeVersion: map?{versionId: str, workflowId: str, nodes: [map], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}} # Workflow object
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}

@endpoint GET /workflows/{id}/{versionId}
@desc Retrieves a specific version of a workflow
@required {id: str # The ID of the workflow., versionId: str # The version ID to retrieve}
@returns(200) {versionId: str, workflowId: str, nodes: [map], connections: map, authors: str, name: str?, description: str?, createdAt: str(date-time), updatedAt: str(date-time)} # Operation successful.
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint POST /workflows/{id}/activate
@desc Publish a workflow
@required {id: str # The ID of the workflow.}
@optional {versionId: str # The specific version ID to activate or publish. If not provided, the latest version is used., name: str # Optional name for the workflow version during activation., description: str # Optional description for the workflow version during activation.}
@returns(200) {id: str, name: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), nodes: [map], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}, staticData: any, tags: [map], shared: [map], activeVersion: map?{versionId: str, workflowId: str, nodes: [map], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}} # Workflow object
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}

@endpoint POST /workflows/{id}/deactivate
@desc Deactivate a workflow
@required {id: str # The ID of the workflow.}
@returns(200) {id: str, name: str, active: bool, createdAt: str(date-time), updatedAt: str(date-time), nodes: [map], connections: map, settings: map{saveExecutionProgress: bool, saveManualExecutions: bool, saveDataErrorExecution: str, saveDataSuccessExecution: str, executionTimeout: num, errorWorkflow: str, timezone: str, executionOrder: str, callerPolicy: str, callerIds: str, timeSavedPerExecution: num, availableInMCP: bool}, staticData: any, tags: [map], shared: [map], activeVersion: map?{versionId: str, workflowId: str, nodes: [map], connections: map, authors: str, createdAt: str(date-time), updatedAt: str(date-time)}} # Workflow object
@errors {401: Unauthorized, 404: The specified resource was not found.}

@endpoint PUT /workflows/{id}/transfer
@desc Transfer a workflow to another project
@required {id: str # The ID of the workflow., destinationProjectId: str # The ID of the project to transfer the workflow to.}
@returns(200) Operation successful.
@errors {400: The request is invalid or provides malformed data., 401: Unauthorized, 404: The specified resource was not found.}

@endpoint GET /workflows/{id}/tags
@desc Get workflow tags
@required {id: str # The ID of the workflow.}
@returns(200) List of tags
