@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Security Center
@base https://management.azure.com
@version 2017-08-01-preview
@auth OAuth2
@endpoints 3
@toc subscriptions(3)

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/autoProvisioningSettings
@desc Exposes the auto provisioning settings of the subscriptions
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/autoProvisioningSettings/{settingName}
@desc Details of a specific setting
@required {settingName: any # Auto provisioning setting key}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/providers/Microsoft.Security/autoProvisioningSettings/{settingName}
@desc Details of a specific setting
@required {settingName: any # Auto provisioning setting key, setting: map # Auto provisioning setting key}
@returns(200) OK

@end
