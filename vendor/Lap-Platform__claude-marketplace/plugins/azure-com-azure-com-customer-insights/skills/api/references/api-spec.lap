@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api CustomerInsightsManagementClient
@base https://management.azure.com
@version 2017-04-26
@auth OAuth2
@common_fields {api-version: any # Client Api Version., resourceGroupName: any # The name of the resource group., hubName: any # The name of the Hub., subscriptionId: any # Gets subscription credentials which uniquely identify Microsoft Azure subscription. The subscription ID forms part of the URI for every service call.}
@endpoints 66
@hint download_for_search
@toc providers(1), subscriptions(65)

@group providers
@endpoint GET /providers/Microsoft.CustomerInsights/operations
@desc Lists all of the available Customer Insights REST API operations.
@returns(200) OK. The request has succeeded.

@endgroup

@group subscriptions
@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}
@desc Creates a hub, or updates an existing hub.
@required {parameters: any # Parameters supplied to the CreateOrUpdate Hub operation.}
@returns(201) Created. A new hub is created.
@returns(200) OK. An existing hub is updated.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}
@desc Updates a Hub.
@required {parameters: any # Parameters supplied to the Update Hub operation.}
@returns(200) OK. The hub is updated.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}
@desc Deletes the specified hub.
@returns(200) OK. The hub is deleted.
@returns(202) Accepted. The delete operation is accepted.
@returns(204) NoContent. Successfully requested delete operation, but the response is intentionally empty.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}
@desc Gets information about the specified hub.
@returns(200) OK. Successfully get the hub.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs
@desc Gets all the hubs in a resource group.
@returns(200) OK. Successfully get all the hubs in the resource group.

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.CustomerInsights/hubs
@desc Gets all hubs in the specified subscription.
@returns(200) OK. Successfully get all the hubs in the subscription.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}/profiles/{profileName}
@desc Creates a profile within a Hub, or updates an existing profile.
@required {profileName: any # The name of the profile., parameters: any # Parameters supplied to the create/delete Profile type operation}
@returns(200) OK. Successfully created the profile.
@returns(202) Accepted. The create profile operation is accepted.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}/profiles/{profileName}
@desc Gets information about the specified profile.
@required {profileName: any # The name of the profile.}
@optional {locale-code: any # Locale of profile to retrieve, default is en-us.}
@returns(200) OK. Successfully get the profile.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}/profiles/{profileName}
@desc Deletes a profile within a hub
@required {profileName: any # The name of the profile.}
@optional {locale-code: any # Locale of profile to retrieve, default is en-us.}
@returns(200) OK. The profile is deleted.
@returns(202) Accepted. The delete operation is accepted.
@returns(204) NoContent. Successfully requested delete operation, but the response is intentionally empty.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}/profiles
@desc Gets all profile in the hub.
@optional {locale-code: any # Locale of profile to retrieve, default is en-us.}
@returns(200) OK. Successfully get all the profiles in the hub.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}/profiles/{profileName}/getEnrichingKpis
@desc Gets the KPIs that enrich the profile Type identified by the supplied name. Enrichment happens through participants of the Interaction on an Interaction KPI and through Relationships for Profile KPIs.
@required {profileName: any # The name of the profile.}
@returns(200) OK. Successfully get the enriching KPIs.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}/interactions/{interactionName}
@desc Creates an interaction or updates an existing interaction within a hub.
@required {interactionName: any # The name of the interaction., parameters: any # Parameters supplied to the CreateOrUpdate Interaction operation.}
@returns(200) OK. Successfully created the interaction.
@returns(202) Accepted. The create interaction operation is accepted.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.CustomerInsights/hubs/{hubName}/interactions/{interactionName}
