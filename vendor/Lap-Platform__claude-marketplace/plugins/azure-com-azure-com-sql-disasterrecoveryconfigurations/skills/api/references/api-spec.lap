@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Azure SQL Database disaster recovery configurations
@base https://management.azure.com
@version 2014-04-01
@auth OAuth2
@common_fields {serverName: any # The name of the server.}
@endpoints 6
@toc subscriptions(6)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/disasterRecoveryConfiguration
@desc Lists a server's disaster recovery configuration.
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/disasterRecoveryConfiguration/{disasterRecoveryConfigurationName}
@desc Deletes a disaster recovery configuration.
@required {disasterRecoveryConfigurationName: any # The name of the disaster recovery configuration to be deleted.}
@returns(200) OK
@returns(202) Accepted
@returns(204) NoContent

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/disasterRecoveryConfiguration/{disasterRecoveryConfigurationName}
@desc Creates or updates a disaster recovery configuration.
@required {disasterRecoveryConfigurationName: any # The name of the disaster recovery configuration to be created/updated.}
@returns(202) Accepted
@returns(201) Created
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/disasterRecoveryConfiguration/{disasterRecoveryConfigurationName}
@desc Gets a disaster recovery configuration.
@required {disasterRecoveryConfigurationName: any # The name of the disaster recovery configuration.}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/disasterRecoveryConfiguration/{disasterRecoveryConfigurationName}/failover
@desc Fails over from the current primary server to this server.
@required {disasterRecoveryConfigurationName: any # The name of the disaster recovery configuration to failover.}
@returns(204) No Content
@returns(202) Accepted

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/disasterRecoveryConfiguration/{disasterRecoveryConfigurationName}/forceFailoverAllowDataLoss
@desc Fails over from the current primary server to this server. This operation might result in data loss.
@required {disasterRecoveryConfigurationName: any # The name of the disaster recovery configuration to failover forcefully.}
@returns(204) No Content
@returns(202) Accepted

@end
