@returns(201) {size: int(int64), hash: str} # Created
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found, 406: Not Acceptable, 507: Insufficient Storage}

@endpoint DELETE /v4/uploads/{token}
