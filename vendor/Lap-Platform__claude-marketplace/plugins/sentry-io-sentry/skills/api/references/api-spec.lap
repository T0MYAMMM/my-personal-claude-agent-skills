@endpoint GET /api/0/organizations/{organization_id_or_slug}/releases/{version}/files/
@desc Return a list of files for a given release.
@required {version: str # The version identifier of the release.}
@optional {cursor: str # A pointer to the last object fetched and its sort order; used to retrieve the next or previous results.}
@returns(200) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint POST /api/0/organizations/{organization_id_or_slug}/releases/{version}/files/
@desc Upload a new file for the given release.
@required {version: str # The version identifier of the release.}
@returns(201) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint GET /api/0/projects/{organization_id_or_slug}/{project_id_or_slug}/releases/{version}/files/
@desc Return a list of files for a given release.
@required {project_id_or_slug: str # The ID or slug of the project., version: str # The version identifier of the release.}
@optional {cursor: str # A pointer to the last object fetched and its sort order; used to retrieve the next or previous results.}
@returns(200) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint POST /api/0/projects/{organization_id_or_slug}/{project_id_or_slug}/releases/{version}/files/
@desc Upload a new file for the given release.
@required {project_id_or_slug: str # The ID or slug of the project., version: str # The version identifier of the release.}
@returns(201) {sha1: str, dist: str?, name: str, dateCreated: str(date-time), headers: map{Content-Type: str}, id: str, size: int} # Success
@errors {403: Forbidden, 404: Not Found}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/releases/{version}/files/{file_id}/
@desc Retrieve a file for a given release.
@required {version: str # The version identifier of the release., file_id: str # The ID of the file to retrieve.}
@optional {download: bool # If this is set to true, then the response payload will be the raw file contents. Otherwise, the response will be the file metadata as JSON.}
@returns(200) {sha1: str, dist: str?, name: str, dateCreated: str(date-time), headers: map{Content-Type: str}, id: str, size: int} # Success
@errors {403: Forbidden, 404: Not Found}

@endpoint PUT /api/0/organizations/{organization_id_or_slug}/releases/{version}/files/{file_id}/
@desc Update an organization release file.
@required {version: str # The version identifier of the release., file_id: str # The ID of the file to retrieve.}
@optional {name: str # The new name (full path) of the file., dist: str # The new name of the dist.}
@returns(200) {sha1: str, dist: str?, name: str, dateCreated: str(date-time), headers: map{Content-Type: str}, id: str, size: int} # Success
@errors {403: Forbidden, 404: Not Found}
@example_request {"name":"/demo/goodbye.txt"}

@endpoint DELETE /api/0/organizations/{organization_id_or_slug}/releases/{version}/files/{file_id}/
@desc Delete a file for a given release.
@required {version: str # The version identifier of the release., file_id: str # The ID of the file to delete.}
@returns(204) Success
@errors {403: Forbidden, 404: Not Found}

