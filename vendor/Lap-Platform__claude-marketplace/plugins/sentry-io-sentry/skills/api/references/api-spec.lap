@returns(200) {sha1: str, dist: str?, name: str, dateCreated: str(date-time), headers: map{Content-Type: str}, id: str, size: int} # Success
@errors {403: Forbidden, 404: Not Found}

@endpoint PUT /api/0/projects/{organization_id_or_slug}/{project_id_or_slug}/releases/{version}/files/{file_id}/
@desc Update a project release file.
@required {project_id_or_slug: str # The ID or slug of the project., version: str # The version identifier of the release., file_id: str # The ID of the file to retrieve.}
@optional {name: str # The new name (full path) of the file., dist: str # The new name of the dist.}
@returns(200) {sha1: str, dist: str?, name: str, dateCreated: str(date-time), headers: map{Content-Type: str}, id: str, size: int} # Success
@errors {403: Forbidden, 404: Not Found}
@example_request {"name":"/demo/goodbye.txt"}

@endpoint DELETE /api/0/projects/{organization_id_or_slug}/{project_id_or_slug}/releases/{version}/files/{file_id}/
@desc Delete a file for a given release.
@required {project_id_or_slug: str # The ID or slug of the project., version: str # The version identifier of the release., file_id: str # The ID of the file to delete.}
@returns(204) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/releases/{version}/commits/
@desc List an organization release's commits.
@required {version: str # The version identifier of the release.}
@optional {cursor: str # A pointer to the last object fetched and its sort order; used to retrieve the next or previous results.}
@returns(200) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint GET /api/0/projects/{organization_id_or_slug}/{project_id_or_slug}/releases/{version}/commits/
@desc List a project release's commits.
@required {project_id_or_slug: str # The ID or slug of the project the release belongs to., version: str # The version identifier of the release.}
@optional {cursor: str # A pointer to the last object fetched and its sort order; used to retrieve the next or previous results.}
@returns(200) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/releases/{version}/commitfiles/
@desc Retrieve files changed in a release's commits
@required {version: str # The version identifier of the release.}
@returns(200) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/sentry-app-installations/
@desc Return a list of integration platform installations for a given organization.
@optional {cursor: str # A pointer to the last object fetched and its sort order; used to retrieve the next or previous results.}
@returns(200) Success
@errors {403: Forbidden, 404: Not Found}

@endpoint POST /api/0/sentry-app-installations/{uuid}/external-issues/
@desc Create or update an external issue from an integration platform integration.
@required {uuid: str # The uuid of the integration platform integration., issueId: int # The ID of the Sentry issue to link the external issue to., webUrl: str # The URL of the external service to link the issue to., project: str # The external service's project., identifier: str # A unique identifier of the external issue.}
@returns(200) {id: str, issueId: str, serviceType: str, displayName: str, webUrl: str} # Success
@errors {403: Forbidden, 404: Not Found}
@example_request {"issueId":1,"webUrl":"https://somerandom.io/project/issue-id","project":"ExternalProj","identifier":"issue-1"}

@endpoint DELETE /api/0/sentry-app-installations/{uuid}/external-issues/{external_issue_id}/
@desc Delete an external issue.
@required {uuid: str # The uuid of the integration platform integration., external_issue_id: str # The ID of the external issue.}
@returns(204) Success
@errors {403: Forbidden, 404: External issue not found}

@endpoint POST /api/0/organizations/{organization_id_or_slug}/spike-protections/
@desc Enables Spike Protection feature for some of the projects within the organization.
@required {projects: [str] # Slugs of projects to enable Spike Protection for. Set to `$all` to enable Spike Protection for all the projects in the organization.}
@returns(201) Success
@errors {400: Bad Request, 403: Forbidden}

@endpoint DELETE /api/0/organizations/{organization_id_or_slug}/spike-protections/
@desc Disables Spike Protection feature for some of the projects within the organization.
@required {projects: [str] # Slugs of projects to disable Spike Protection for. Set to `$all` to disable Spike Protection for all the projects in the organization.}
@returns(200) Success
@errors {400: Bad Request, 403: Forbidden}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/issues/{issue_id}/autofix/
@desc Retrieve the current detailed state of an issue fix process for a specific issue including:
@required {issue_id: int # The ID of the issue you'd like to query.}
@returns(200) {autofix: map?}
@errors {401: Unauthorized, 403: Forbidden, 404: Not Found}

@endpoint POST /api/0/organizations/{organization_id_or_slug}/issues/{issue_id}/autofix/
@desc Trigger a Seer Issue Fix run for a specific issue.
@required {issue_id: int # The ID of the issue you'd like to query.}
@optional {event_id: str # Run issue fix on a specific event. If not provided, the recommended event for the issue will be used., instruction: str # Optional custom instruction to guide the issue fix process., pr_to_comment_on_url: str(uri) # URL of a pull request where the issue fix should add comments., stopping_point: str(root_cause/solution/code_changes/open_pr) # Where the issue fix process should stop. If not provided, will run to root cause.  * `root_cause` * `solution` * `code_changes` * `open_pr`}
@returns(202) {run_id: int}
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/issues/{issue_id}/events/
@desc Return a list of error events bound to an issue
@required {issue_id: int # The ID of the issue you'd like to query.}
@optional {start: str(date-time) # The start of the period of time for the query, expected in ISO-8601 format. For example, `2001-12-14T12:34:56.7890`., end: str(date-time) # The end of the period of time for the query, expected in ISO-8601 format. For example, `2001-12-14T12:34:56.7890`., statsPeriod: str # The period of time for the query, will override the start & end parameters, a number followed by one of: - `d` for days - `h` for hours - `m` for minutes - `s` for seconds - `w` for weeks  For example, `24h`, to mean query data starting from 24 hours ago to now., environment: [str] # The name of environments to filter by., full: bool=false # Specify true to include the full event body, including the stacktrace, in the event payload., sample: bool=false # Return events in pseudo-random order. This is deterministic so an identical query will always return the same events in the same order., query: str # An optional search query for filtering events. See [search syntax](https://docs.sentry.io/concepts/search/) and queryable event properties at [Sentry Search Documentation](https://docs.sentry.io/concepts/search/searchable-properties/events/) for more information. An example query might be `query=transaction:foo AND release:abc`, cursor: str # A pointer to the last object fetched and its sort order; used to retrieve the next or previous results.}
@returns(200)
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/issues/{issue_id}/events/{event_id}/
@desc Retrieves the details of an issue event.
@required {issue_id: int # The ID of the issue you'd like to query., event_id: str(latest/oldest/recommended) # The ID of the event to retrieve, or 'latest', 'oldest', or 'recommended'.}
@optional {environment: [str] # The name of environments to filter by.}
@returns(200) {id: str, groupID: str?, eventID: str, projectID: str, message: str?, title: str, location: str?, user: map?{id: str?, email: str?, username: str?, ip_address: str?, name: str?, geo: map?, data: map?}, tags: [map], platform: str, dateReceived: str(date-time)?, contexts: map?, size: int?, entries: [any], dist: str?, sdk: map, context: map?, packages: map, type: str, metadata: any, errors: [any], occurrence: any, _meta: map, crashFile: str?, culprit: str?, dateCreated: str(date-time), fingerprints: [str], groupingConfig: any, startTimestamp: str(date-time), endTimestamp: str(date-time), measurements: any, breakdowns: any, release: map?{id: int, commitCount: int, data: map, dateCreated: str(date-time), dateReleased: str(date-time)?, deployCount: int, ref: str?, lastCommit: map?, lastDeploy: map?{dateStarted: str?, url: str?, id: str, environment: str, dateFinished: str, name: str}, status: str, url: str?, userAgent: str?, version: str?, versionInfo: map?{description: str, package: str?, version: map, buildHash: str?}}, userReport: map?{id: str, eventID: str, name: str?, email: str?, comments: str, dateCreated: str, user: map?{id: str, username: str?, email: str?, name: str?, ipAddress: str?, avatarUrl: str?}, event: map{id: str, eventID: str}}, sdkUpdates: [map], resolvedWith: [str], nextEventID: str?, previousEventID: str?}
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found}

@endpoint GET /api/0/organizations/{organization_id_or_slug}/issues/{issue_id}/external-issues/
@desc Retrieve custom integration issue links for the given Sentry issue
@required {issue_id: int # The ID of the issue you'd like to query.}
@returns(200)

@endpoint GET /api/0/organizations/{organization_id_or_slug}/issues/{issue_id}/tags/{key}/
@desc Return a list of values associated with this key for an issue. When paginated can return at most 1000 values.
@required {issue_id: int # The ID of the issue you'd like to query., key: str # The tag key to look the values up for.}
@optional {environment: [str] # The name of environments to filter by.}
@returns(200) {uniqueValues: int?, totalValues: int?, topValues: [map]?, key: str, name: str}
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found}

@end
