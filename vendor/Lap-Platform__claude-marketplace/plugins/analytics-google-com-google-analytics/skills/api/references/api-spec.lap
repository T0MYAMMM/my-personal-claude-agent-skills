@returns(200) {entity: map{accountRef: map{href: str, id: str, kind: str, name: str}, profileRef: map{accountId: str, href: str, id: str, internalWebPropertyId: str, kind: str, name: str, webPropertyId: str}, webPropertyRef: map{accountId: str, href: str, id: str, internalWebPropertyId: str, kind: str, name: str}}, id: str, kind: str, permissions: map{effective: [str], local: [str]}, selfLink: str, userRef: map{email: str, id: str, kind: str}} # Successful response

