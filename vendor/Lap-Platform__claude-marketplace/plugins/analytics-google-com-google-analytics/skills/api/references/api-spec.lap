@optional {max-results: int # The maximum number of profile-user links to include in this response., start-index: int # An index of the first profile-user link to retrieve. Use this parameter as a pagination mechanism along with the max-results parameter.}
@returns(200) {items: [map], itemsPerPage: int(int32), kind: str, nextLink: str, previousLink: str, startIndex: int(int32), totalResults: int(int32)} # Successful response

