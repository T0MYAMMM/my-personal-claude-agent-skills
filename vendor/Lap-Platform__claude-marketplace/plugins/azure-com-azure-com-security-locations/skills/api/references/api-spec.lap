@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Microsoft Defender for Cloud
@base https://management.azure.com
@version 2015-06-01-preview
@auth OAuth2
@endpoints 2
@toc subscriptions(2)

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/locations
@desc The location of the responsible ASC of the specific subscription (home region). For each subscription there is only one responsible location. The location in the response should be used to read or write other resources in ASC according to their ID.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/locations/{ascLocation}
@desc Details of a specific location
@returns(200) OK

@end
