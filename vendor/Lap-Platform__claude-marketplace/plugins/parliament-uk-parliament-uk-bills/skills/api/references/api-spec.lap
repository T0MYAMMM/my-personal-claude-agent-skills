@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Bills API
@version v1
@endpoints 21
@hint download_for_search
@toc api(21)

@endpoint GET /api/v1/Bills/{billId}/Stages/{billStageId}/Amendments
@desc Returns a list of amendments.
@required {billId: int(int32) # Amendments relating to a Bill with Bill ID specified, billStageId: int(int32) # Amendments relating to a Bill stage with Bill stage ID specified}
@optional {SearchTerm: str, AmendmentNumber: str, Decision: str, MemberId: int(int32), Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/Bills/{billId}/Stages/{billStageId}/Amendments/{amendmentId}
@desc Returns an amendment.
@required {billId: int(int32) # Amendment relating to a bill with bill ID specified, billStageId: int(int32) # Amendment relating to a bill stage with bill stage ID specified, amendmentId: int(int32) # Amendment with amendment ID specified}
@returns(200) {id: int(int32), billId: int(int32), billStageId: int(int32), statusIndicator: str?, decision: str, decisionExplanation: str?, sponsors: [map]?, amendmentId: int(int32), amendmentType: str, clause: int(int32)?, schedule: int(int32)?, pageNumber: int(int32)?, lineNumber: int(int32)?, amendmentPosition: str?, marshalledListText: str?, dNum: str?, amendmentLines: [map]?, explanatoryTextPrefix: str?, explanatoryText: str?, amendmentNote: str?, amendmentLocation: str?, mainHeader: str?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/Bills/{billId}/NewsArticles
@desc Returns a list of news articles for a Bill.
@required {billId: int(int32)}
@optional {Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/BillTypes
@desc Returns a list of Bill types.
@optional {Category: str, Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {400: Bad Request}

@endpoint GET /api/v1/Bills
@desc Returns a list of Bills.
@optional {SearchTerm: str, Session: int(int32), CurrentHouse: str, OriginatingHouse: str, MemberId: int(int32), DepartmentId: int(int32), BillStage: [int(int32)], BillStagesExcluded: [int(int32)], IsDefeated: bool, IsWithdrawn: bool, BillType: [int(int32)], SortOrder: str, BillIds: [int(int32)], IsInAmendableStage: bool, Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {400: Bad Request}

@endpoint GET /api/v1/Bills/{billId}
@desc Return a Bill.
@required {billId: int(int32) # Bill with ID specified}
@returns(200) {billId: int(int32), shortTitle: str?, formerShortTitle: str?, currentHouse: str, originatingHouse: str, lastUpdate: str(date-time), billWithdrawn: str(date-time)?, isDefeated: bool, billTypeId: int(int32), introducedSessionId: int(int32), includedSessionIds: [int(int32)]?, isAct: bool, currentStage: map{id: int(int32), stageId: int(int32), sessionId: int(int32), description: str?, abbreviation: str?, house: str, stageSittings: [map]?, sortOrder: int(int32)}, longTitle: str?, summary: str?, sponsors: [map]?, promoters: [map]?, petitioningPeriod: str?, petitionInformation: str?, agent: map{name: str?, address: str?, phoneNo: str?, email: str?, website: str?}} # OK
@errors {400: Bad Request, 404: Not Found}

@endpoint GET /api/v1/Bills/{billId}/Stages/{billStageId}
@desc Returns a Bill stage.
@required {billId: int(int32) # Bill stage relating to Bill with Bill ID specified, billStageId: int(int32) # Bill stage with ID specified}
@returns(200) {id: int(int32), stageId: int(int32), sessionId: int(int32), description: str?, abbreviation: str?, house: str, stageSittings: [map]?, sortOrder: int(int32), committee: map{id: int(int32), name: str?, category: str?, house: str, url: str?}, nextStageBillStageId: int(int32)?, previousStageBillStageId: int(int32)?, lastUpdate: str(date-time), hasMotions: bool} # OK
@errors {400: Bad Request, 404: Not Found}

@endpoint GET /api/v1/Bills/{billId}/Stages
@desc Returns all Bill stages.
@required {billId: int(int32) # Stages relating to a Bill with Bill ID specified}
@optional {Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {400: Bad Request, 404: Not Found}

@endpoint GET /api/v1/Publications/{publicationId}/Documents/{documentId}
@desc Return information on a document.
@required {publicationId: int(int32) # Document with publication Id specified, documentId: int(int32) # Document with Id specified}
@returns(200) {id: int(int32), filename: str?, contentType: str?, contentLength: int(int32)} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/Publications/{publicationId}/Documents/{documentId}/Download
@desc Return a document.
@required {publicationId: int(int32) # Document with publication Id specified, documentId: int(int32) # Document with Id specified}
@returns(200) OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/Bills/{billId}/Stages/{billStageId}/PingPongItems
@desc Returns a list of motions or amendments.
@required {billId: int(int32) # Motions or amendments relating to a Bill with Bill ID specified, billStageId: int(int32) # Motions or amendments relating to a Bill stage with Bill stage ID specified}
@optional {SearchTerm: str, AmendmentNumber: str, Decision: str, MemberId: int(int32), Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/Bills/{billId}/Stages/{billStageId}/PingPongItems/{pingPongItemId}
@desc Returns amendment or motion detail.
@required {billId: int(int32) # Motions or amendments relating to a bill with bill ID specified, billStageId: int(int32) # Motions or amendments relating to a bill stage with bill stage ID specified, pingPongItemId: int(int32) # Motions or amendments with ping pong item ID specified}
@returns(200) {type: str, amendment: map{id: int(int32), billId: int(int32), billStageId: int(int32), statusIndicator: str?, decision: str, decisionExplanation: str?, sponsors: [map]?, type: str, number: str?, summary: str?, amendmentGroups: [map]?}, motion: map{id: int(int32), billId: int(int32), billStageId: int(int32), statusIndicator: str?, decision: str, decisionExplanation: str?, sponsors: [map]?, type: str, number: str?, summary: str?, motionGroups: [map]?}} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/PublicationTypes
@desc Returns a list of publication types.
@optional {Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {400: Bad Request}

@endpoint GET /api/v1/Bills/{billId}/Publications
@desc Return a list of Bill publications.
@required {billId: int(int32) # Publications relating to Bill with Bill ID specified}
@returns(200) {billId: int(int32), publications: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/Bills/{billId}/Stages/{stageId}/Publications
@desc Return a list of Bill stage publications.
@required {billId: int(int32), stageId: int(int32)}
@returns(200) {billStageId: int(int32), publications: [map]?, sittings: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/v1/Rss/allbills.rss
@desc Returns an Rss feed of all Bills.
@returns(200) OK

@endpoint GET /api/v1/Rss/publicbills.rss
@desc Returns an Rss feed of public Bills.
@returns(200) OK

@endpoint GET /api/v1/Rss/privatebills.rss
@desc Returns an Rss feed of private Bills.
@returns(200) OK

@endpoint GET /api/v1/Rss/Bills/{id}.rss
@desc Returns an Rss feed of a certain Bill.
@required {id: int(int32) # Id of Bill}
@returns(200) OK
@errors {400: Bad Request, 404: Not Found}

@endpoint GET /api/v1/Sittings
@desc Returns a list of Sittings.
@optional {House: str, DateFrom: str(date-time), DateTo: str(date-time), Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {400: Bad Request}

@endpoint GET /api/v1/Stages
@desc Returns a list of Bill stages.
@optional {Skip: int(int32), Take: int(int32)}
@returns(200) {items: [map]?, totalResults: int(int32), itemsPerPage: int(int32)} # OK
@errors {400: Bad Request}

@end
