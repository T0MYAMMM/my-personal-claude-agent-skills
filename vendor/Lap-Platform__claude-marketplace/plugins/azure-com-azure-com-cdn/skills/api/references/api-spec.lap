@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api CdnManagementClient
@base https://management.azure.com
@version 2019-06-15-preview
@auth OAuth2
@common_fields {api-version: any # Version of the API to be used with the client request. Current version is 2017-04-02.}
@endpoints 35
@hint download_for_search
@toc subscriptions(32), providers(3)

@group subscriptions
@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Cdn/profiles
@desc Lists all of the CDN profiles within an Azure subscription.
@required {subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles
@desc Lists all of the CDN profiles within a resource group.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}
@desc Gets a CDN profile with the specified profile name under the specified subscription and resource group.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}
@desc Creates a new CDN profile with a profile name under the specified subscription and resource group.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., profile: map # Profile properties needed to create a new profile., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(201) Created. The request has been fulfilled and a new profile has been created.
@returns(202) Accepted. The request has been accepted for processing and the operation will complete asynchronously.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}
@desc Updates an existing CDN profile with the specified profile name under the specified subscription and resource group.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., profileUpdateParameters: map # Profile properties needed to update an existing profile., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted. The request has been accepted for processing and the operation will complete asynchronously.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}
@desc Deletes an existing CDN profile with the specified parameters. Deleting a profile will result in the deletion of all of the sub-resources including endpoints, origins and custom domains.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., subscriptionId: any # Azure Subscription ID.}
@returns(202) Accepted. The request has been accepted for processing and the operation will complete asynchronously.
@returns(204) No Content. The request has been accepted but the profile was not found.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/generateSsoUri
@desc Generates a dynamic SSO URI used to sign in to the CDN supplemental portal. Supplemental portal is used to configure advanced feature capabilities that are not yet available in the Azure portal, such as core reports in a standard profile; rules engine, advanced HTTP reports, and real-time stats and alerts in a premium profile. The SSO URI changes approximately every 10 minutes.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/getSupportedOptimizationTypes
@desc Gets the supported optimization types for the current profile. A user can create an endpoint with an optimization type from the listed values.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/checkResourceUsage
@desc Checks the quota and actual usage of endpoints under the given CDN profile.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints
@desc Lists existing CDN endpoints.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}
@desc Gets an existing CDN endpoint with the specified endpoint name under the specified subscription, resource group and profile.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}
@desc Creates a new CDN endpoint with the specified endpoint name under the specified subscription, resource group and profile.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., endpoint: map # Endpoint properties, subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(201) Created. The request has been fulfilled and a new endpoint has been created.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}
@desc Updates an existing CDN endpoint with the specified endpoint name under the specified subscription, resource group and profile. Only tags and Origin HostHeader can be updated after creating an endpoint. To update origins, use the Update Origin operation. To update custom domains, use the Update Custom Domain operation.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., endpointUpdateProperties: map # Endpoint update properties, subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}
@desc Deletes an existing CDN endpoint with the specified endpoint name under the specified subscription, resource group and profile.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., subscriptionId: any # Azure Subscription ID.}
@returns(202) Accepted and the operation will complete asynchronously.
@returns(204) No Content. The request has been accepted but the endpoint was not found.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/start
@desc Starts an existing CDN endpoint that is on a stopped state.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/stop
@desc Stops an existing running CDN endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/purge
@desc Removes a content from CDN.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., contentFilePaths: map # The path to the content to be purged. Path can be a full URL, e.g. '/pictures/city.png' which removes a single file, or a directory with a wildcard, e.g. '/pictures/*' which removes all folders and files in the directory., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/load
@desc Pre-loads a content to CDN. Available for Verizon Profiles.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., contentFilePaths: map # The path to the content to be loaded. Path should be a full URL, e.g. ‘/pictures/city.png' which loads a single file, subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/validateCustomDomain
@desc Validates the custom domain mapping to ensure it maps to the correct CDN endpoint in DNS.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., customDomainProperties: map # Custom domain to be validated., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/checkResourceUsage
@desc Checks the quota and usage of geo filters and custom domains under the given endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/origins
@desc Lists all of the existing origins within an endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/origins/{originName}
@desc Gets an existing origin within an endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., originName: any # Name of the origin which is unique within the endpoint., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/origins/{originName}
@desc Updates an existing origin within an endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., originName: any # Name of the origin which is unique within the endpoint., originUpdateProperties: map # Origin properties, subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/customDomains
@desc Lists all of the existing custom domains within an endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/customDomains/{customDomainName}
@desc Gets an existing custom domain within an endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., customDomainName: any # Name of the custom domain within an endpoint., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/customDomains/{customDomainName}
@desc Creates a new custom domain within an endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., customDomainName: any # Name of the custom domain within an endpoint., customDomainProperties: map # Properties required to create a new custom domain., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(201) Created. The request has been fulfilled and a new custom domain has been created.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/customDomains/{customDomainName}
@desc Deletes an existing custom domain within an endpoint.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., customDomainName: any # Name of the custom domain within an endpoint., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.
@returns(204) No Content. The request has been accepted but the custom domain was not found

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/customDomains/{customDomainName}/disableCustomHttps
@desc Disable https delivery of the custom domain.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., customDomainName: any # Name of the custom domain within an endpoint., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Cdn/profiles/{profileName}/endpoints/{endpointName}/customDomains/{customDomainName}/enableCustomHttps
@desc Enable https delivery of the custom domain.
@required {resourceGroupName: any # Name of the Resource group within the Azure subscription., profileName: any # Name of the CDN profile which is unique within the resource group., endpointName: any # Name of the endpoint under the profile which is unique globally., customDomainName: any # Name of the custom domain within an endpoint., subscriptionId: any # Azure Subscription ID.}
@optional {customDomainHttpsParameters: any # The configuration specifying how to enable HTTPS for the custom domain - using CDN managed certificate or user's own certificate. If not specified, enabling ssl uses CDN managed certificate by default.}
@returns(200) OK. The request has succeeded.
@returns(202) Accepted and the operation will complete asynchronously.

@endgroup

@group providers
@endpoint POST /providers/Microsoft.Cdn/checkNameAvailability
@desc Check the availability of a resource name. This is needed for resources where name is globally unique, such as a CDN endpoint.
@required {checkNameAvailabilityInput: map # Input to check.}
@returns(200) OK. The request has succeeded.

@endgroup

@group subscriptions
@endpoint POST /subscriptions/{subscriptionId}/providers/Microsoft.Cdn/checkNameAvailability
@desc Check the availability of a resource name. This is needed for resources where name is globally unique, such as a CDN endpoint.
@required {checkNameAvailabilityInput: map # Input to check., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint POST /subscriptions/{subscriptionId}/providers/Microsoft.Cdn/validateProbe
@desc Check if the probe path is a valid path and the file can be accessed. Probe path is the path to a file hosted on the origin server to help accelerate the delivery of dynamic content via the CDN endpoint. This path is relative to the origin path specified in the endpoint configuration.
@required {validateProbeInput: map # Input to check., subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endpoint POST /subscriptions/{subscriptionId}/providers/Microsoft.Cdn/checkResourceUsage
@desc Check the quota and actual usage of the CDN profiles under the given subscription.
@required {subscriptionId: any # Azure Subscription ID.}
@returns(200) OK. The request has succeeded.

@endgroup

@group providers
@endpoint GET /providers/Microsoft.Cdn/operations
@desc Lists all of the available CDN REST API operations.
@returns(200) OK. The request has succeeded.

@endpoint GET /providers/Microsoft.Cdn/edgenodes
@desc Edgenodes are the global Point of Presence (POP) locations used to deliver CDN content to end users.
@returns(200) OK. The request has succeeded.

@endgroup

@end
