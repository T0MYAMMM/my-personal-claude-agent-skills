@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api OnSched API Utility
@base https://sandbox-api.onsched.com/
@version v1
@auth OAuth2
@endpoints 2
@toc utility(2)

@endpoint GET /utility/v1/health/heartbeat
@returns(200) Success

@endpoint GET /utility/v1/health/threadinfo
@returns(200) {availableCompletionThreads: int(int32), availableWorkerThreads: int(int32), minCompletionThreads: int(int32), minWorkerThreads: int(int32), maxCompletionThreads: int(int32), maxWorkerThreads: int(int32), occupiedCompletionThreads: int(int32), occupiedWorkerThreads: int(int32)} # Success

@end
