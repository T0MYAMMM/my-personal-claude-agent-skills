@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api AWS Migration Hub Config
@version 2019-06-30
@auth AWS SigV4
@endpoints 4
@toc root(4)

@endpoint POST /
@desc This API sets up the home region for the calling account only.
@required {HomeRegion: str, Target: Target}
@optional {DryRun: bool}
@returns(200) {HomeRegionControl: HomeRegionControl?{ControlId: str?, HomeRegion: str?, Target: Target?{Type: str, Id: str?}, RequestedTime: str(timestamp)?}}

@endpoint POST /
@desc This operation deletes the home region configuration for the calling account. The operation does not delete discovery or migration tracking data in the home region.
@required {ControlId: str}

@endpoint POST /
@desc This API permits filtering on the ControlId and HomeRegion fields.
@optional {ControlId: str, HomeRegion: str, Target: Target, MaxResults: int, NextToken: str}
@returns(200) {HomeRegionControls: [HomeRegionControl]?, NextToken: str?}

@endpoint POST /
@desc Returns the calling account’s home region, if configured. This API is used by other AWS services to determine the regional endpoint for calling AWS Application Discovery Service and Migration Hub. You must call GetHomeRegion at least once before you call any other AWS Application Discovery Service and AWS Migration Hub APIs, to obtain the account's Migration Hub home region.
@returns(200) {HomeRegion: str?}

@end
