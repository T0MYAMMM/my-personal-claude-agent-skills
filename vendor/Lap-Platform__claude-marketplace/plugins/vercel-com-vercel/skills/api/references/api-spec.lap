@group artifacts
@endpoint POST /v8/artifacts/events
@desc Record an artifacts cache usage event
@optional {x-artifact-client-ci: str # The continuous integration or delivery environment where this artifact is downloaded., x-artifact-client-interactive: int # 1 if the client is an interactive shell. Otherwise 0, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) Success. Event recorded.
@errors {400: One of the provided values in the request body is invalid. One of the provided values in the headers is invalid, 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: The customer has reached their spend cap limit and has been paused. An owner can disable the cap or raise the limit in settings. The Remote Caching usage limit has been reached for this account for this billing cycle. Remote Caching has been disabled for this team or user. An owner can enable it in the billing settings. You do not have permission to access this resource.}

@endpoint GET /v8/artifacts/status
@desc Get status of Remote Caching for this principal
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {status: str}
@errors {400, 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: You do not have permission to access this resource.}

@endpoint PUT /v8/artifacts/{hash}
@desc Upload a cache artifact
@required {Content-Length: num # The artifact size in bytes, hash: str # The artifact hash}
@optional {x-artifact-duration: num # The time taken to generate the uploaded artifact in milliseconds., x-artifact-client-ci: str # The continuous integration or delivery environment where this artifact was generated., x-artifact-client-interactive: int # 1 if the client is an interactive shell. Otherwise 0, x-artifact-tag: str # The base64 encoded tag for this artifact. The value is sent back to clients when the artifact is downloaded as the header `x-artifact-tag`, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(202) {urls: [str]} # File successfully uploaded
@errors {400: One of the provided values in the request query is invalid. One of the provided values in the headers is invalid File size is not valid, 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: The customer has reached their spend cap limit and has been paused. An owner can disable the cap or raise the limit in settings. The Remote Caching usage limit has been reached for this account for this billing cycle. Remote Caching has been disabled for this team or user. An owner can enable it in the billing settings. You do not have permission to access this resource.}

@endpoint GET /v8/artifacts/{hash}
@desc Download a cache artifact
@required {hash: str # The artifact hash}
@optional {x-artifact-client-ci: str # The continuous integration or delivery environment where this artifact is downloaded., x-artifact-client-interactive: int # 1 if the client is an interactive shell. Otherwise 0, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) The artifact was found and is downloaded as a stream. Content-Length should be verified.
@errors {400: One of the provided values in the request query is invalid. One of the provided values in the headers is invalid, 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: The customer has reached their spend cap limit and has been paused. An owner can disable the cap or raise the limit in settings. The Remote Caching usage limit has been reached for this account for this billing cycle. Remote Caching has been disabled for this team or user. An owner can enable it in the billing settings. You do not have permission to access this resource., 404: The artifact was not found}

@endpoint HEAD /v8/artifacts/{hash}
@desc Check if a cache artifact exists
@required {hash: str # The artifact hash}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) The artifact was found and headers are returned
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: The customer has reached their spend cap limit and has been paused. An owner can disable the cap or raise the limit in settings. The Remote Caching usage limit has been reached for this account for this billing cycle. Remote Caching has been disabled for this team or user. An owner can enable it in the billing settings. You do not have permission to access this resource., 404: The artifact was not found}

@endpoint POST /v8/artifacts
@desc Query information about an artifact
@required {hashes: [str] # artifact hashes}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200)
@errors {400: One of the provided values in the request body is invalid., 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: The customer has reached their spend cap limit and has been paused. An owner can disable the cap or raise the limit in settings. The Remote Caching usage limit has been reached for this account for this billing cycle. Remote Caching has been disabled for this team or user. An owner can enable it in the billing settings. You do not have permission to access this resource.}

@endgroup

