@returns(200) {user: any} # Successful response.
@errors {302, 400, 401: The request is not authorized., 403: You do not have permission to access this resource., 409}

@endpoint DELETE /v1/user
@desc Delete User Account
@optional {reasons: [map{slug!: str, description!: str}] # Optional array of objects that describe the reason why the User account is being deleted.}
@returns(202) {id: str, email: str, message: str} # Response indicating that the User deletion process has been initiated, and a confirmation email has been sent.
@errors {400: One of the provided values in the request body is invalid., 401, 402, 403: You do not have permission to access this resource.}

@endgroup

@group webhooks
@endpoint POST /v1/webhooks
@desc Creates a webhook
@required {url: str(uri), events: [str]}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., projectIds: [str]}
@returns(200) {secret: str, events: [str], id: str, url: str, ownerId: str, createdAt: num, updatedAt: num, projectIds: [str]}
@errors {400: One of the provided values in the request body is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource.}

@endpoint GET /v1/webhooks
@desc Get a list of webhooks
@optional {projectId: str, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200)
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource.}

@endpoint GET /v1/webhooks/{id}
@desc Get a webhook
@required {id: str}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {events: [str], id: str, url: str, ownerId: str, createdAt: num, updatedAt: num, projectIds: [str]}
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource.}

@endpoint DELETE /v1/webhooks/{id}
@desc Deletes a webhook
@required {id: str}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(204)
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource.}

@endgroup

@group deployments
@endpoint GET /v2/deployments/{id}/aliases
@desc List Deployment Aliases
@required {id: str # The ID of the deployment the aliases should be listed for}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {aliases: [map]} # The list of aliases assigned to the deployment
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404: The deployment was not found}

@endpoint POST /v2/deployments/{id}/aliases
@desc Assign an Alias
@required {id: any # The ID of the deployment the aliases should be listed for}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., alias: str # The alias we want to assign to the deployment defined in the URL, redirect: str # The redirect property will take precedence over the deployment id from the URL and consists of a hostname (like test.com) to which the alias should redirect using status code 307}
@returns(200) {uid: str, alias: str, created: str(date-time), oldDeploymentId: str?} # The alias was successfully assigned to the deployment
@errors {400: One of the provided values in the request body is invalid. One of the provided values in the request query is invalid. The cert for the provided alias is not ready The deployment is not READY and can not be aliased The supplied alias is invalid, 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: You do not have permission to access this resource. If no .vercel.app alias exists then we fail (nothing to mirror), 404: The domain used for the alias was not found The deployment was not found, 409: The provided alias is already assigned to the given deployment The domain is not allowed to be used}

@endgroup

@group aliases
@endpoint GET /v4/aliases
@desc List aliases
@optional {domain: any # Get only aliases of the given domain name, from: num # Get only aliases created after the provided timestamp, limit: num # Maximum number of aliases to list from a request, projectId: str # Filter aliases from the given `projectId`, since: num # Get aliases created after this JavaScript timestamp, until: num # Get aliases created before this JavaScript timestamp, rollbackDeploymentId: str # Get aliases that would be rolled back for the given deployment, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {aliases: [map], pagination: map{count: num, next: num?, prev: num?}} # The paginated list of aliases
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404}

@endpoint GET /v4/aliases/{idOrAlias}
@desc Get an Alias
@required {idOrAlias: str # The alias or alias ID to be retrieved}
@optional {from: num # Get the alias only if it was created after the provided timestamp, projectId: str # Get the alias only if it is assigned to the provided project ID, since: num # Get the alias only if it was created after this JavaScript timestamp, until: num # Get the alias only if it was created before this JavaScript timestamp, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {alias: str, created: str(date-time), createdAt: num?, creator: map{uid: str, email: str, username: str}, deletedAt: num?, deployment: map{id: str, url: str, meta: str}, deploymentId: str?, projectId: str?, redirect: str?, redirectStatusCode: num?, uid: str, updatedAt: num?, protectionBypass: map, microfrontends: map{defaultApp: map{projectId: str}, applications: any}} # The alias information
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404: The alias was not found}

@endpoint DELETE /v2/aliases/{aliasId}
@desc Delete an Alias
@required {aliasId: any # The ID or alias that will be removed}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {status: str} # The alias was successfully removed
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404: The alias was not found}

@endpoint PATCH /aliases/{id}/protection-bypass
@desc Update the protection bypass for a URL
@required {id: str # The alias or deployment ID}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200)
@errors {400: One of the provided values in the request body is invalid. One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404, 409, 428}

@endgroup

@group certs
@endpoint GET /v8/certs/{id}
@desc Get cert by id
@required {id: str # The cert id}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {id: str, createdAt: num, expiresAt: num, autoRenew: bool, cns: [str]}
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404}

@endpoint DELETE /v8/certs/{id}
@desc Remove cert
@required {id: str # The cert id to remove}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200)
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404}

@endpoint POST /v8/certs
@desc Issue a new cert
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., cns: [str] # The common names the cert should be issued for}
@returns(200) {id: str, createdAt: num, expiresAt: num, autoRenew: bool, cns: [str]}
@errors {400: One of the provided values in the request body is invalid., 401: The request is not authorized., 402: The account was soft-blocked for an unhandled reason. The account is missing a payment so payment method must be updated, 403: You do not have permission to access this resource., 404, 449, 500}

@endpoint PUT /v8/certs
@desc Upload a cert
@required {ca: str # The certificate authority, key: str # The certificate key, cert: str # The certificate}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., skipValidation: bool # Skip validation of the certificate}
@returns(200) {id: str, createdAt: num, expiresAt: num, autoRenew: bool, cns: [str]}
@errors {400: One of the provided values in the request body is invalid., 401: The request is not authorized., 402: This feature is only available for Enterprise customers., 403: You do not have permission to access this resource.}

@endgroup

@group deployments
@endpoint GET /v6/deployments/{id}/files
@desc List Deployment Files
@required {id: str # The unique deployment identifier}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) Retrieved the file tree successfully
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404: File tree not found Deployment not found}

@endpoint GET /v8/deployments/{id}/files/{fileId}
@desc Get Deployment File Contents
@required {id: str # The unique deployment identifier, fileId: str # The unique file identifier}
@optional {path: str # Path to the file to fetch (only for Git deployments), teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404: File not found Deployment not found, 410: Invalid API version.}

@endpoint GET /v6/deployments
@desc List deployments
@optional {app: str # Name of the deployment., from: num # Gets the deployment created after this Date timestamp. (default: current time), limit: num # Maximum number of deployments to list from a request., projectId: str # Filter deployments from the given ID or name., projectIds: [str] # Filter deployments from the given project IDs. Cannot be used when projectId is specified., target: str # Filter deployments based on the environment., to: num # Gets the deployment created before this Date timestamp. (default: current time), users: str # Filter out deployments based on users who have created the deployment., since: num # Get Deployments created after this JavaScript timestamp., until: num # Get Deployments created before this JavaScript timestamp., state: str # Filter deployments based on their state (`BUILDING`, `ERROR`, `INITIALIZING`, `QUEUED`, `READY`, `CANCELED`), rollbackCandidate: bool # Filter deployments based on their rollback candidacy, branch: str # Filter deployments based on the branch name, sha: str # Filter deployments based on the SHA, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {pagination: map{count: num, next: num?, prev: num?}, deployments: [map]}
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404, 422}

@endpoint DELETE /v13/deployments/{id}
@desc Delete a Deployment
@required {id: str # The ID of the deployment to be deleted}
@optional {url: str # A Deployment or Alias URL. In case it is passed, the ID will be ignored, teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {uid: str, state: str} # The deployment was successfully deleted
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404: The deployment was not found}

@endgroup

@end
