@returns(200) {sandbox: map{id: str, memory: num, vcpus: num, region: str, runtime: str, timeout: num, status: str, requestedAt: num, startedAt: num, cwd: str, requestedStopAt: num, stoppedAt: num, abortedAt: num, duration: num, sourceSnapshotId: str, snapshottedAt: num, createdAt: num, updatedAt: num, networkPolicy: map{mode: str, allowedDomains: [str], allowedCIDRs: [str], deniedCIDRs: [str], injectionRules: [map]}}} # The sandbox timeout was extended successfully.
