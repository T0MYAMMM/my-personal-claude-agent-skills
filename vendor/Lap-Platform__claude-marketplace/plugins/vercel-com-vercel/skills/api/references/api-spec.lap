@group bulk-redirects
@endpoint PUT /v1/bulk-redirects
@desc Stages new redirects for a project.
@required {projectId: str, teamId: str}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., overwrite: bool, name: str, redirects: [map{source!: str, destination!: str, statusCode: any, permanent: bool, caseSensitive: bool, query: bool, preserveQueryParams: bool}]=[]}
@returns(200) {alias: str?, version: map{id: str, key: str, lastModified: num, createdBy: str, name: str, isStaging: bool, isLive: bool, redirectCount: num, alias: str}}
@errors {400: One of the provided values in the request body is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 500}

@endpoint GET /v1/bulk-redirects
@desc Gets project-level redirects.
@required {projectId: str}
@optional {versionId: str, q: str, diff: any, page: int, per_page: int, sort_by: str(source/destination/statusCode), sort_order: str(asc/desc), teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200)
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404}

@endpoint DELETE /v1/bulk-redirects
@desc Delete project-level redirects.
@required {projectId: str, redirects: [str] # The redirects to delete. The source of the redirect is used to match the redirect to delete.}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., name: str}
@returns(200)
@errors {400: One of the provided values in the request body is invalid. One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404, 500}

@endpoint PATCH /v1/bulk-redirects
@desc Edit a project-level redirect.
@required {projectId: str, redirect: map{source!: str, destination: str, statusCode: num, permanent: bool, caseSensitive: bool, query: bool, preserveQueryParams: bool} # The redirect object to edit. The source field is used to match the redirect to modify.}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., name: str, restore: bool # If true, restores the redirect from the latest production version to staging.}
@returns(200) {alias: str?, version: map{id: str, key: str, lastModified: num, createdBy: str, name: str, isStaging: bool, isLive: bool, redirectCount: num, alias: str}}
@errors {400: One of the provided values in the request body is invalid. One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404, 500}

@endpoint POST /v1/bulk-redirects/restore
@desc Restore staged project-level redirects to their production version.
@required {projectId: str, redirects: [str] # The redirects to restore. The source of the redirect is used to match the redirect to restore.}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of., name: str}
@returns(200) {version: map{id: str, key: str, lastModified: num, createdBy: str, name: str, isStaging: bool, isLive: bool, redirectCount: num, alias: str}, restored: [str], failedToRestore: [str]}
@errors {400: One of the provided values in the request body is invalid. One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404, 500}

@endpoint GET /v1/bulk-redirects/versions
@desc Get the version history for a project's redirects.
