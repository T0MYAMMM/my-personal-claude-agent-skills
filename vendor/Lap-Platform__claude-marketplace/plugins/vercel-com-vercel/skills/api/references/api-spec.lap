@returns(200)
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 404}

@endpoint GET /v1/sandboxes/{sandboxId}
@desc Get a sandbox
@required {sandboxId: str # The unique identifier of the sandbox to retrieve.}
@optional {teamId: str # The Team identifier to perform the request on behalf of., slug: str # The Team slug to perform the request on behalf of.}
@returns(200) {sandbox: map{id: str, memory: num, vcpus: num, region: str, runtime: str, timeout: num, status: str, requestedAt: num, startedAt: num, cwd: str, requestedStopAt: num, stoppedAt: num, abortedAt: num, duration: num, sourceSnapshotId: str, snapshottedAt: num, createdAt: num, updatedAt: num, networkPolicy: map{mode: str, allowedDomains: [str], allowedCIDRs: [str], deniedCIDRs: [str], injectionRules: [map]}}, routes: [map]}
@errors {400: One of the provided values in the request query is invalid., 401: The request is not authorized., 403: You do not have permission to access this resource., 410: The Sandbox has stopped execution and is no longer available., 422: The Sandbox is creating a snapshot and will be stopped shortly. The Sandbox is stopping and is no longer available., 429}

@endpoint GET /v1/sandboxes/{sandboxId}/cmd
@desc List commands
