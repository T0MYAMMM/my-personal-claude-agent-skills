@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api DnsManagementClient
@base https://management.azure.com
@version 2018-05-01
@auth OAuth2
@common_fields {api-version: any # Specifies the API version., subscriptionId: any # Specifies the Azure subscription ID, which uniquely identifies the Microsoft Azure subscription.}
@endpoints 14
@toc subscriptions(14)

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}/{recordType}/{relativeRecordSetName}
@desc Updates a record set within a DNS zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot)., relativeRecordSetName: any # The name of the record set, relative to the name of the zone., recordType: any # The type of DNS record in this record set., parameters: any # Parameters supplied to the Update operation.}
@optional {If-Match: any # The etag of the record set. Omit this value to always overwrite the current record set. Specify the last-seen etag value to prevent accidentally overwriting concurrent changes.}
@returns(200) The record set has been updated.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}/{recordType}/{relativeRecordSetName}
@desc Creates or updates a record set within a DNS zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot)., relativeRecordSetName: any # The name of the record set, relative to the name of the zone., recordType: any # The type of DNS record in this record set. Record sets of type SOA can be updated but not created (they are created when the DNS zone is created)., parameters: any # Parameters supplied to the CreateOrUpdate operation.}
@optional {If-Match: any # The etag of the record set. Omit this value to always overwrite the current record set. Specify the last-seen etag value to prevent accidentally overwriting any concurrent changes., If-None-Match: any # Set to '*' to allow a new record set to be created, but to prevent updating an existing record set. Other values will be ignored.}
@returns(201) The record set has been created.
@returns(200) The record set has been updated.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}/{recordType}/{relativeRecordSetName}
@desc Deletes a record set from a DNS zone. This operation cannot be undone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot)., relativeRecordSetName: any # The name of the record set, relative to the name of the zone., recordType: any # The type of DNS record in this record set. Record sets of type SOA cannot be deleted (they are deleted when the DNS zone is deleted).}
@optional {If-Match: any # The etag of the record set. Omit this value to always delete the current record set. Specify the last-seen etag value to prevent accidentally deleting any concurrent changes.}
@returns(204) The record set was not found.
@returns(200) The record set has been deleted.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}/{recordType}/{relativeRecordSetName}
@desc Gets a record set.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot)., relativeRecordSetName: any # The name of the record set, relative to the name of the zone., recordType: any # The type of DNS record in this record set.}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}/{recordType}
@desc Lists the record sets of a specified type in a DNS zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot)., recordType: any # The type of record sets to enumerate.}
@optional {$top: any # The maximum number of record sets to return. If not specified, returns up to 100 record sets., $recordsetnamesuffix: any # The suffix label of the record set name that has to be used to filter the record set enumerations. If this parameter is specified, Enumeration will return only records that end with .<recordSetNameSuffix>}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}/recordsets
@desc Lists all record sets in a DNS zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot).}
@optional {$top: any # The maximum number of record sets to return. If not specified, returns up to 100 record sets., $recordsetnamesuffix: any # The suffix label of the record set name that has to be used to filter the record set enumerations. If this parameter is specified, Enumeration will return only records that end with .<recordSetNameSuffix>}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}/all
@desc Lists all record sets in a DNS zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot).}
@optional {$top: any # The maximum number of record sets to return. If not specified, returns up to 100 record sets., $recordsetnamesuffix: any # The suffix label of the record set name that has to be used to filter the record set enumerations. If this parameter is specified, Enumeration will return only records that end with .<recordSetNameSuffix>}
@returns(200) Success.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}
@desc Creates or updates a DNS zone. Does not modify DNS records within the zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot)., parameters: any # Parameters supplied to the CreateOrUpdate operation.}
@optional {If-Match: any # The etag of the DNS zone. Omit this value to always overwrite the current zone. Specify the last-seen etag value to prevent accidentally overwriting any concurrent changes., If-None-Match: any # Set to '*' to allow a new DNS zone to be created, but to prevent updating an existing zone. Other values will be ignored.}
@returns(200) The DNS zone has been updated.
@returns(201) The DNS zone has been created.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}
@desc Deletes a DNS zone. WARNING: All DNS records in the zone will also be deleted. This operation cannot be undone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot).}
@optional {If-Match: any # The etag of the DNS zone. Omit this value to always delete the current zone. Specify the last-seen etag value to prevent accidentally deleting any concurrent changes.}
@returns(204) The DNS zone was not found.
@returns(202) The DNS zone delete operation has been accepted and will complete asynchronously.
@returns(200) The DNS zone has been deleted.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}
@desc Gets a DNS zone. Retrieves the zone properties, but not the record sets within the zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot).}
@returns(200) Success.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones/{zoneName}
@desc Updates a DNS zone. Does not modify DNS records within the zone.
@required {resourceGroupName: any # The name of the resource group., zoneName: any # The name of the DNS zone (without a terminating dot)., parameters: any # Parameters supplied to the Update operation.}
@optional {If-Match: any # The etag of the DNS zone. Omit this value to always overwrite the current zone. Specify the last-seen etag value to prevent accidentally overwriting any concurrent changes.}
@returns(200) The DNS zone has been updated.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/dnsZones
@desc Lists the DNS zones within a resource group.
@required {resourceGroupName: any # The name of the resource group.}
@optional {$top: any # The maximum number of record sets to return. If not specified, returns up to 100 record sets.}
@returns(200) Success.

@endpoint POST /subscriptions/{subscriptionId}/providers/Microsoft.Network/getDnsResourceReference
@desc Returns the DNS records specified by the referencing targetResourceIds.
@required {parameters: any # Properties for dns resource reference request.}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Network/dnszones
@desc Lists the DNS zones in all resource groups in a subscription.
@optional {$top: any # The maximum number of DNS zones to return. If not specified, returns up to 100 zones.}
@returns(200) Success.

@end
