@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Security Center
@base https://management.azure.com
@version 2019-01-01
@auth OAuth2
@endpoints 10
@toc subscriptions(10)

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/alerts
@desc List all the alerts that are associated with the subscription
@optional {$filter: any # OData filter. Optional., $select: any # OData select. Optional., $expand: any # OData expand. Optional., autoDismissRuleName: any # The name of an existing auto dismiss rule. Use it to simulate the rule on existing alerts and get the alerts that would have been dismissed if the rule was enabled when the alert was created}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Security/alerts
@desc List all the alerts that are associated with the resource group
@optional {$filter: any # OData filter. Optional., $select: any # OData select. Optional., $expand: any # OData expand. Optional., autoDismissRuleName: any # The name of an existing auto dismiss rule. Use it to simulate the rule on existing alerts and get the alerts that would have been dismissed if the rule was enabled when the alert was created}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/locations/{ascLocation}/alerts
@desc List all the alerts that are associated with the subscription that are stored in a specific location
@optional {$filter: any # OData filter. Optional., $select: any # OData select. Optional., $expand: any # OData expand. Optional., autoDismissRuleName: any # The name of an existing auto dismiss rule. Use it to simulate the rule on existing alerts and get the alerts that would have been dismissed if the rule was enabled when the alert was created}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Security/locations/{ascLocation}/alerts
@desc List all the alerts that are associated with the resource group that are stored in a specific location
@optional {$filter: any # OData filter. Optional., $select: any # OData select. Optional., $expand: any # OData expand. Optional., autoDismissRuleName: any # The name of an existing auto dismiss rule. Use it to simulate the rule on existing alerts and get the alerts that would have been dismissed if the rule was enabled when the alert was created}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/locations/{ascLocation}/alerts/{alertName}
@desc Get an alert that is associated with a subscription
@required {alertName: any # Name of the alert object}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Security/locations/{ascLocation}/alerts/{alertName}
@desc Get an alert that is associated a resource group or a resource in a resource group
@required {alertName: any # Name of the alert object}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/providers/Microsoft.Security/locations/{ascLocation}/alerts/{alertName}/dismiss
@desc Update the alert's state
@required {alertName: any # Name of the alert object}
@returns(204) No Content

@endpoint POST /subscriptions/{subscriptionId}/providers/Microsoft.Security/locations/{ascLocation}/alerts/{alertName}/reactivate
@desc Update the alert's state
@required {alertName: any # Name of the alert object}
@returns(204) No Content

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Security/locations/{ascLocation}/alerts/{alertName}/dismiss
@desc Update the alert's state
@required {alertName: any # Name of the alert object}
@returns(204) No Content

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Security/locations/{ascLocation}/alerts/{alertName}/reactivate
@desc Update the alert's state
@required {alertName: any # Name of the alert object}
@returns(204) No Content

@end
