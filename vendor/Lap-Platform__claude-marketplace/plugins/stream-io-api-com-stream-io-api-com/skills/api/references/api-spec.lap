@desc Upload file
@returns(201) {duration: str, file: str, thumb_url: str} # Successful response
@errors {400: Bad request, 429: Too many requests}

@endpoint DELETE /uploads/image
@desc Delete image
@optional {url: str}
@returns(200) {duration: str} # Response
@errors {400: Bad request, 429: Too many requests}

