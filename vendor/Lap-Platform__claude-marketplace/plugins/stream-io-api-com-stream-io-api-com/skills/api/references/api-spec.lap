@desc Search user groups
@required {query: str}
@optional {limit: int(int32), name_gt: str, id_gt: str, team_id: str}
@returns(200) {duration: str, user_groups: [map]} # SearchUserGroupsResponse
@errors {400: Bad request, 429: Too many requests}

@endgroup

