@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api koomalooma Partner API
@base https://api.koomalooma.com/api
@version 1.0
@auth ApiKey X-KoomaLooma-JWT in header
@endpoints 2
@toc users(2)

@endpoint POST /users
@desc Create a User
@returns(201) Created
@errors {400: Bad Request, 403: Forbidden}

@endpoint POST /users/{user_id}/commitments
@desc Assign points to a User
@required {user_id: any # user_id of the user to assign points to, commitmentRequest: map}
@returns(201) Created
@errors {400: Bad Request, 403: Forbidden}

@end
