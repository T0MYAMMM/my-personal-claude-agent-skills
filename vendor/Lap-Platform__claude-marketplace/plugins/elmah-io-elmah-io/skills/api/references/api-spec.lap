@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api elmah.io API
@version v3
@auth ApiKey api_key in query
@endpoints 24
@hint download_for_search
@toc deployments(4), heartbeats(1), installations(1), logs(7), messages(9), sourcemaps(1), uptimechecks(1)

@group deployments
@endpoint GET /v3/deployments
@desc Fetch a list of deployments.
@returns(200) Request for deployments successful.
@errors {401: API key not valid or no access to resource., 402: Tried to call the deployment API without deployment tracking enabled or trial expired., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/deployments
@desc Create a new deployment.
@optional {body: map # The deployment object to create.}
@returns(201) Deployment was created.
@errors {400: Model not valid., 401: API key not valid or no access to resource., 402: Tried to call the deployment API without deployment tracking enabled or trial expired., 404: Specified log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint GET /v3/deployments/{id}
@desc Fetch a deployment by its ID.
@required {id: any # The ID of the deployment to fetch.}
@returns(200) Request for deployment successful.
@errors {400: Id not specified., 401: API key not valid or no access to resource., 402: Deployment with specified id not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint DELETE /v3/deployments/{id}
@desc Delete a deployment by its ID.
@required {id: any # The ID of the deployment to delete.}
@returns(204) Deployment was deleted.
@errors {400: Id not specified., 401: API key not valid or no access to resource., 402: Tried to call the deployment API without deployment tracking enabled or trial expired., 404: Deployment with specified id not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endgroup

@group heartbeats
@endpoint POST /v3/heartbeats/{logId}/{id}
@desc Create a new heartbeat.
@required {id: any # The ID of the heartbeat check., logId: any # The ID of the log containing the heartbeat check.}
@optional {body: map # The details of the heartbeat.}
@returns(200) Heartbeat was created.
@errors {400: Model not valid., 401: API key not valid or no access to resource., 402: Tried to call the heartbeats API without heartbeats enabled or trial expired., 404: The specified log or heartbeat was not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endgroup

@group installations
@endpoint POST /v3/installations/{logId}
@desc Create a new installation.
@required {logId: any # The ID of the log containing the installation.}
@optional {body: map # The installation object to create.}
@returns(200) Installation was created.
@errors {400: Model not valid., 401: API key not valid or no access to resource., 404: Specified log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endgroup

@group logs
@endpoint GET /v3/logs
@desc Fetch a list of logs.
@returns(200) Request for logs successful.
@errors {401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/logs
@desc Create a new log.
@optional {body: map # The log object to create.}
@returns(201) Log where successfully created.
@errors {400: Something wrong with the parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint GET /v3/logs/{id}
@desc Fetch a log by its ID.
@required {id: any # The ID of the log to fetch.}
@returns(200) Request for log successful.
@errors {401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint DELETE /v3/logs/{id}
@desc Delete a log by its ID.
@required {id: any # The ID of the log to delete.}
@returns(204) Log was deleted.
@errors {400: Id not specified., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 409: Log contains data and cannot be deleted., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/logs/{id}/_disable
@desc Disable a log by its ID.
@required {id: any # The ID of the log to disable.}
@returns(200) Log was disabled.
@errors {401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/logs/{id}/_enable
@desc Enable a log by its ID.
@required {id: any # The ID of the log to enable.}
@returns(200) Log was enabled.
@errors {401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint GET /v3/logs/{id}/_diagnose
@desc Help diagnose logging problems.
@required {id: any # The ID of the log to diagnose.}
@returns(200) Log was diagnosed.
@errors {401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endgroup

@group messages
@endpoint GET /v3/messages/{logId}
@desc Fetch messages from a log.
@required {logId: any # The ID of the log containing the messages.}
@optional {pageIndex: any # The page number of the result. When using pageIndex and pageSize only 10,000 messages can be returned. For example, if setting pageSize to 100 and pageIndex to 100, no log messages will be returned. To request more than 10,000 log messages you should use the searchAfter property instead., pageSize: any # The number of messages to load (max 100) or 15 if not set., query: any # A full-text or Lucene query to limit the messages by., from: any # A start date and time to search from (not included)., to: any # An end date and time to search to (not included)., includeHeaders: any # Include headers like server variables and cookies in the result (slower)., searchAfter: any # Search after is an alternative to using pageIndex that will let you get more than 10,000 messages. Each search result contains a searchAfter property that should be set on future requests to continue from the end of the previous request, but only until the returned list of log messages is empty. When using searchAfter any value in the pageIndex property will be ignored.}
@returns(200) Log found and may contain messages.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint DELETE /v3/messages/{logId}
@desc Deletes a list of messages by logid and query.
@required {logId: any # The ID of the log containing the message.}
@optional {body: map # A search object containing query, time filters etc.}
@returns(200) Messages where deleted.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/messages/{logId}
@desc Create a new message.
@required {logId: any # The ID of the log which should contain the new message.}
@optional {body: map # The message object to create.}
@returns(200) Message was not created.
@returns(201) Message was successfully created.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 413: Message too large. Messages must not exceed 256 kb. As additional information, some fields are trimmed down when processed on the backend., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint GET /v3/messages/{logId}/{id}
@desc Fetch a message by its ID.
@required {id: any # The ID of the message to fetch., logId: any # The ID of the log containing the message.}
@returns(200) Message found.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Message not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint DELETE /v3/messages/{logId}/{id}
@desc Delete a message by its ID.
@required {id: any # The ID of the message to delete., logId: any # The ID of the log containing the message.}
@returns(200) Message where deleted.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log or message not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/messages/{logId}/_fix
@desc Mark a list of messages as fixed by logid and query.
@required {logId: any # The ID of the log containing the messages.}
@optional {body: map # A search object containing query, time filters etc.}
@returns(200) Messages where marked as fixed.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/messages/{logId}/{id}/_hide
@desc Hide a message by its ID.
@required {id: any # The ID of the message to hide., logId: any # The ID of the log containing the message.}
@returns(200) Message was hidden.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Message not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/messages/{logId}/{id}/_fix
@desc Fix a message by its ID.
@required {id: any # The ID of the message to fix., logId: any # The ID of the log containing the message.}
@optional {markAllAsFixed: any # If set to true, all instances of the log message are set to fixed.}
@returns(200) Message was fixed.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Message not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endpoint POST /v3/messages/{logId}/_bulk
@desc Create one or more new messages.
@required {logId: any # The ID of the log which should contain the new messages.}
@optional {body: [map] # The messages to create.}
@returns(200) Zero or more messages where successfully created. Check the response body for details.
@errors {400: Something wrong with the query parameters., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endgroup

@group sourcemaps
@endpoint POST /v3/sourcemaps/{logId}
@desc Create or update a translation between a minified JavaScript path to the minified JavaScript and source map files.
@required {logId: any # The ID of the log which should contain the minified JavaScript and source map., Path: any # An URL to the online minified JavaScript file. The URL can be absolute or relative but will always be converted to a relative path (no protocol, domain, and query parameters). elmah.io uses this path to lookup any lines in a JS stack trace that will need de-minification., SourceMap: any # The source map file. Only files with an extension of .map and content type of application/json will be accepted., MinifiedJavaScript: any # The minified JavaScript file. Only files with an extension of .js and content type of text/javascript will be accepted.}
@returns(200) Source map was successfully created.
@errors {400: Something wrong with the query parameters or form., 401: API key not valid or no access to resource., 402: Tried to call the logs API but the trial expired., 404: Log not found., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endgroup

@group uptimechecks
@endpoint GET /v3/uptimechecks
@desc Fetch a list of uptime checks. Currently in closed beta. Get in contact to get access to this endpoint.
@returns(200) Request for uptime checks successful.
@errors {401: API key not valid or no access to resource., 402: Tried to call the uptime checks API but the trial expired., 429: A maximum of 500 requests per minute and 3600 requests per hour are permitted}

@endgroup

@end
