@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api CircleCI API
@base https://circleci.com/api/v2
@version v2
@auth ApiKey Circle-Token in header | Basic | ApiKey circle-token in query
@endpoints 111
@hint download_for_search
@toc insights(10), jobs(1), me(2), organization(7), pipeline(6), project(24), schedule(3), user(1), webhook(5), workflow(5), org(6), owner(9), context(10), organizations(6), projects(11), deploy(5)

@group insights
@endpoint GET /insights/pages/{project-slug}/summary
@desc Get summary metrics and trends for a project across it's workflows and branches
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@optional {reporting-window: str(last-7-days/last-90-days/last-24-hours/last-30-days/last-60-days) # The time window used to calculate summary metrics. If not provided, defaults to last-90-days, branches: map # The names of VCS branches to include in branch-level workflow metrics., workflow-names: map # The names of workflows to include in workflow-level metrics.}
@returns(200) {org_id: any, project_id: any, project_data: map{metrics: map{total_runs: int(int64), total_duration_secs: int(int64), total_credits_used: int(int64), success_rate: num(float), throughput: num(float)}, trends: map{total_runs: num(float), total_duration_secs: num(float), total_credits_used: num(float), success_rate: num(float), throughput: num(float)}}, project_workflow_data: [map], project_workflow_branch_data: [map], all_branches: [str], all_workflows: [str]} # Aggregated summary metrics and trends by workflow and branches

@endpoint GET /insights/time-series/{project-slug}/workflows/{workflow-name}/jobs
@desc Job timeseries data
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., workflow-name: str # The name of the workflow.}
@optional {branch: str # The name of a vcs branch. If not passed we will scope the API call to the default branch., granularity: str(daily/hourly) # The granularity for which to query timeseries data., start-date: str(date-time) # Include only executions that started at or after this date. This must be specified if an end-date is provided., end-date: str(date-time) # Include only executions that started before this date. This date can be at most 90 days after the start-date.}
@returns(200) {next_page_token: str, items: [map]} # An array of timeseries data, one entry per job.

@endpoint GET /insights/{org-slug}/summary
@desc Get summary metrics with trends for the entire org, and for each project.
@required {org-slug: str # Org slug in the form `vcs-slug/org-name`. The `/` characters may be URL-escaped.}
@optional {reporting-window: str(last-7-days/last-90-days/last-24-hours/last-30-days/last-60-days) # The time window used to calculate summary metrics. If not provided, defaults to last-90-days, project-names: map # List of project names.}
@returns(200) {org_data: map{metrics: map{total_runs: int(int64), total_duration_secs: int(int64), total_credits_used: int(int64), success_rate: num(float), throughput: num(float)}, trends: map{total_runs: num(float), total_duration_secs: num(float), total_credits_used: num(float), success_rate: num(float), throughput: num(float)}}, org_project_data: [map], all_projects: [str]} # summary metrics with trends for an entire org and it's projects.

@endpoint GET /insights/{project-slug}/branches
@desc Get all branches for a project
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@optional {workflow-name: str # The name of a workflow. If not passed we will scope the API call to the project.}
@returns(200) {org_id: any, project_id: any, branches: [str]} # A list of branches for a project

@endpoint GET /insights/{project-slug}/flaky-tests
@desc Get flaky tests for a project
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@returns(200) {flaky-tests: [map], total-flaky-tests: num(double)} # A list of flaky tests for a project

@endpoint GET /insights/{project-slug}/workflows
@desc Get summary metrics for a project's workflows
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@optional {page-token: str # A token to retrieve the next page of results., all-branches: bool # Whether to retrieve data for all branches combined. Use either this parameter OR the branch name parameter., branch: str # The name of a vcs branch. If not passed we will scope the API call to the default branch., reporting-window: str(last-7-days/last-90-days/last-24-hours/last-30-days/last-60-days) # The time window used to calculate summary metrics. If not provided, defaults to last-90-days}
@returns(200) {items: [map], next_page_token: str} # A paginated list of summary metrics by workflow

@endpoint GET /insights/{project-slug}/workflows/{workflow-name}
@desc Get recent runs of a workflow
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., workflow-name: str # The name of the workflow.}
@optional {all-branches: bool # Whether to retrieve data for all branches combined. Use either this parameter OR the branch name parameter., branch: str # The name of a vcs branch. If not passed we will scope the API call to the default branch., page-token: str # A token to retrieve the next page of results., start-date: str(date-time) # Include only executions that started at or after this date. This must be specified if an end-date is provided., end-date: str(date-time) # Include only executions that started before this date. This date can be at most 90 days after the start-date.}
@returns(200) {items: [map], next_page_token: str} # A paginated list of recent workflow runs

@endpoint GET /insights/{project-slug}/workflows/{workflow-name}/jobs
@desc Get summary metrics for a project workflow's jobs.
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., workflow-name: str # The name of the workflow.}
@optional {page-token: str # A token to retrieve the next page of results., all-branches: bool # Whether to retrieve data for all branches combined. Use either this parameter OR the branch name parameter., branch: str # The name of a vcs branch. If not passed we will scope the API call to the default branch., reporting-window: str(last-7-days/last-90-days/last-24-hours/last-30-days/last-60-days) # The time window used to calculate summary metrics. If not provided, defaults to last-90-days, job-name: str # The name of the jobs you would like to filter from your workflow. If not specified, all workflow jobs will be returned. The job name can either be the full job name or just a substring of the job name.}
@returns(200) {items: [map], next_page_token: str} # A paginated list of summary metrics by workflow job.

@endpoint GET /insights/{project-slug}/workflows/{workflow-name}/summary
@desc Get metrics and trends for workflows
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., workflow-name: str # The name of the workflow.}
@optional {all-branches: bool # Whether to retrieve data for all branches combined. Use either this parameter OR the branch name parameter., branch: str # The name of a vcs branch. If not passed we will scope the API call to the default branch.}
@returns(200) {metrics: map{total_runs: int(int64), successful_runs: int(int64), mttr: int(int64), total_credits_used: int(int64), failed_runs: int(int64), success_rate: num(float), completed_runs: int(int64), window_start: str(date-time), duration_metrics: map{min: int(int64), mean: int(int64), median: int(int64), p95: int(int64), max: int(int64), standard_deviation: num(float)}, window_end: str(date-time), throughput: num(float)}, trends: map{total_runs: num(float), failed_runs: num(float), success_rate: num(float), p95_duration_secs: num(float), median_duration_secs: num(float), total_credits_used: num(float), mttr: num(float), throughput: num(float)}, workflow_names: [str]} # Metrics and trends for a workflow

@endpoint GET /insights/{project-slug}/workflows/{workflow-name}/test-metrics
@desc Get test metrics for a project's workflows
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., workflow-name: str # The name of the workflow.}
@optional {branch: str # The name of a vcs branch. If not passed we will scope the API call to the default branch., all-branches: bool # Whether to retrieve data for all branches combined. Use either this parameter OR the branch name parameter.}
@returns(200) {average_test_count: int(int64), most_failed_tests: [map], most_failed_tests_extra: int(int64), slowest_tests: [map], slowest_tests_extra: int(int64), total_test_runs: int(int64), test_runs: [map]} # A list of test metrics by workflow

@endgroup

@group jobs
@endpoint POST /jobs/{job-id}/cancel
@desc Cancel job by job ID
@required {job-id: str(uuid) # The unique ID of the job.}
@returns(200) {message: str} # Job cancelled successfully.
@errors {400: Bad request error., 401: Unauthorized error., 403: Forbidden error., 404: Job not found error.}

@endgroup

@group me
@endpoint GET /me
@desc User Information
@returns(200) {avatar_url: str, id: str(uuid), login: str, name: str} # User login information.

@endpoint GET /me/collaborations
@desc Collaborations
@returns(200) Collaborations

@endgroup

@group organization
@endpoint POST /organization
@desc Create a new organization
@required {name: str # The name of the organization., vcs_type: str(github/bitbucket/circleci) # The version control system type for the organization.}
@returns(201) {id: str, name: str, slug: str, vcs_type: str} # The newly created organization

@endpoint DELETE /organization/{org-slug-or-id}
@desc Delete an organization
@required {org-slug-or-id: str # Org UUID or slug in the form `vcs-slug/org-name`. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug` and replace the `org-name` with the organization ID (found in Organization Settings).}
@returns(202) {message: str} # A confirmation message.

@endpoint GET /organization/{org-slug-or-id}
@desc Get an organization
@required {org-slug-or-id: str # Org UUID or slug in the form `vcs-slug/org-name`. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug` and replace the `org-name` with the organization ID (found in Organization Settings).}
@returns(200) {id: str, name: str, slug: str, vcs_type: str} # An organization object

@endpoint POST /organization/{org-slug-or-id}/project
@desc Create a new project
@required {org-slug-or-id: str # Org UUID or slug in the form `vcs-slug/org-name`. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug` and replace the `org-name` with the organization ID (found in Organization Settings)., name: str # The name of the project}
@returns(200) {slug: str, name: str, id: str(uuid), organization_name: str, organization_slug: str, organization_id: str(uuid), vcs_info: map{vcs_url: str, provider: str, default_branch: str}} # The new project

@endpoint POST /organization/{org-slug-or-id}/url-orb-allow-list
@desc Create a new URL Orb allow-list entry
@required {org-slug-or-id: str # Org UUID or slug in the form `vcs-slug/org-name`. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug` and replace the `org-name` with the organization ID (found in Organization Settings)., name: str # Name of the URL orb allow-list entry., prefix: any # URL prefix. URL orb references that start with this prefix will be allowed by this allow-list entry., auth: str(github-oauth/none/bitbucket-oauth/github-app) # An authentication method to use for fetching URL orb references that match this allow-list entry's prefix. Allowed values are "bitbucket-oauth", "github-oauth", "github-app", or "none".}
@returns(200) {id: str, message: str} # The ID of the new URL Orb allow-list entry

@endpoint GET /organization/{org-slug-or-id}/url-orb-allow-list
@desc List the entries in the org's URL Orb allow-list
@required {org-slug-or-id: str # Org UUID or slug in the form `vcs-slug/org-name`. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug` and replace the `org-name` with the organization ID (found in Organization Settings).}
@returns(200) {items: [map]} # URL Orb allow-list entries

@endpoint DELETE /organization/{org-slug-or-id}/url-orb-allow-list/{allow-list-entry-id}
@desc Remove an entry from the org's URL orb allow-list
@required {org-slug-or-id: str # Org UUID or slug in the form `vcs-slug/org-name`. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug` and replace the `org-name` with the organization ID (found in Organization Settings)., allow-list-entry-id: str # URL orb allow-list entry UUID.}
@returns(200) {id: str, message: str} # The ID of the removed URL Orb allow-list entry

@endgroup

@group pipeline
@endpoint GET /pipeline
@desc Get a list of pipelines
@optional {org-slug: str # Org slug in the form `vcs-slug/org-name`. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug` and replace the `org-name` with the organization ID (found in Organization Settings)., page-token: str # A token to retrieve the next page of results., mine: bool # Only include entries created by your user.}
@returns(200) {items: [map], next_page_token: str} # A sequence of pipelines.

@endpoint POST /pipeline/continue
@desc Continue a pipeline
@required {continuation-key: str # A pipeline continuation key., configuration: str # A configuration string for the pipeline.}
@optional {parameters: map # An object containing pipeline parameters and their values. Pipeline parameters have the following size limits: 100 max entries, 128 maximum key length, 512 maximum value length.}
@returns(200) {message: str} # A confirmation message.

@endpoint GET /pipeline/{pipeline-id}
@desc Get a pipeline by ID
@required {pipeline-id: str(uuid) # The unique ID of the pipeline.}
@returns(200) {id: str(uuid), errors: [map], project_slug: str, updated_at: str(date-time), number: int(int64), trigger_parameters: map, state: str, created_at: str(date-time), trigger: map{type: str, received_at: str(date-time), actor: map{login: str, avatar_url: str}}, vcs: map{provider_name: str, target_repository_url: str, branch: str, review_id: str, review_url: str, revision: str, tag: str, commit: map{subject: str, body: str}, origin_repository_url: str}} # A pipeline object.

@endpoint GET /pipeline/{pipeline-id}/config
@desc Get a pipeline's configuration
@required {pipeline-id: str(uuid) # The unique ID of the pipeline.}
@returns(200) {source: str, compiled: str, setup-config: str, compiled-setup-config: str} # The configuration strings for the pipeline.

@endpoint GET /pipeline/{pipeline-id}/values
@desc Get pipeline values for a pipeline
@required {pipeline-id: str(uuid) # The unique ID of the pipeline.}
@returns(200) A JSON object of pipeline values

@endpoint GET /pipeline/{pipeline-id}/workflow
@desc Get a pipeline's workflows
@required {pipeline-id: str(uuid) # The unique ID of the pipeline.}
@optional {page-token: str # A token to retrieve the next page of results.}
@returns(200) {items: [map], next_page_token: str} # A paginated list of workflow objects.

@endgroup

@group project
@endpoint DELETE /project/{project-slug}
@desc Delete a project
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@returns(200) {message: str} # A confirmation message.

@endpoint GET /project/{project-slug}
@desc Get a project
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@returns(200) {slug: str, name: str, id: str(uuid), organization_name: str, organization_slug: str, organization_id: str(uuid), vcs_info: map{vcs_url: str, provider: str, default_branch: str}} # A project object

@endpoint POST /project/{project-slug}/checkout-key
@desc Create a new checkout key
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., type: str(user-key/deploy-key) # The type of checkout key to create. This may be either `deploy-key` or `user-key`.}
@returns(201) {public-key: str, type: str, fingerprint: str, preferred: bool, created-at: str(date-time)} # The checkout key.

@endpoint GET /project/{project-slug}/checkout-key
@desc Get all checkout keys
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@optional {digest: str(sha256/md5) # The fingerprint digest type to return. This may be either `md5` or `sha256`. If not passed, defaults to `md5`.}
@returns(200) {items: [map], next_page_token: str} # A sequence of checkout keys.

@endpoint DELETE /project/{project-slug}/checkout-key/{fingerprint}
@desc Delete a checkout key
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., fingerprint: str # An SSH key fingerprint.}
@returns(200) {message: str} # A confirmation message.

@endpoint GET /project/{project-slug}/checkout-key/{fingerprint}
@desc Get a checkout key
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., fingerprint: str # An SSH key fingerprint.}
@returns(200) {public-key: str, type: str, fingerprint: str, preferred: bool, created-at: str(date-time)} # The checkout key.

@endpoint POST /project/{project-slug}/envvar
@desc Create an environment variable
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., name: str # The name of the environment variable., value: str # The value of the environment variable.}
@returns(201) {name: str, value: str, created-at: any} # The environment variable.

@endpoint GET /project/{project-slug}/envvar
@desc List all environment variables
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@returns(200) {items: [map], next_page_token: str} # A sequence of environment variables.

@endpoint DELETE /project/{project-slug}/envvar/{name}
@desc Delete an environment variable
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., name: str # The name of the environment variable.}
@returns(200) {message: str} # A confirmation message.

@endpoint GET /project/{project-slug}/envvar/{name}
@desc Get a masked environment variable
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings)., name: str # The name of the environment variable.}
@returns(200) {name: str, value: str, created-at: any} # The environment variable.

@endpoint GET /project/{project-slug}/job/{job-number}
@desc Get job details
@required {job-number: any # The number of the job., project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@returns(200) {web_url: str, project: map{id: str(uuid), slug: str, name: str, external_url: str}, parallel_runs: [map], started_at: str(date-time), latest_workflow: map{id: str(uuid), name: str}, name: str, executor: map{resource_class: str, type: str}, parallelism: int(int64), status: str, number: int(int64), pipeline: map{id: str(uuid)}, duration: int(int64), created_at: str(date-time), messages: [map], contexts: [map], organization: map{name: str}, queued_at: str(date-time), stopped_at: str(date-time)} # Job details.

@endpoint POST /project/{project-slug}/job/{job-number}/cancel
@desc Cancel job by job number
@required {job-number: any # The number of the job., project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@returns(200) {message: str}

@endpoint GET /project/{project-slug}/pipeline
@desc Get all pipelines
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@optional {branch: str # The name of a vcs branch., page-token: str # A token to retrieve the next page of results.}
@returns(200) {items: [map], next_page_token: str} # A sequence of pipelines.

@endpoint POST /project/{project-slug}/pipeline
@desc Trigger a new pipeline
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@optional {branch: str # The branch where the pipeline ran. The HEAD commit on this branch was used for the pipeline. Note that `branch` and `tag` are mutually exclusive. To trigger a pipeline for a PR by number use `pull//head` for the PR ref or `pull//merge` for the merge ref (GitHub only)., tag: str # The tag used by the pipeline. The commit that this tag points to was used for the pipeline. Note that `branch` and `tag` are mutually exclusive., parameters: map # An object containing pipeline parameters and their values. Pipeline parameters have the following size limits: 100 max entries, 128 maximum key length, 512 maximum value length.}
@returns(201) {id: str(uuid), state: str, number: int(int64), created_at: str(date-time)} # The created pipeline.

@endpoint GET /project/{project-slug}/pipeline/mine
@desc Get your pipelines
@required {project-slug: str # Project slug in the form `vcs-slug/org-name/repo-name`. The `/` characters may be URL-escaped. For projects that use GitLab or GitHub App, use `circleci` as the `vcs-slug`, replace `org-name` with the organization ID (found in Organization Settings), and replace `repo-name` with the project ID (found in Project Settings).}
@optional {page-token: str # A token to retrieve the next page of results.}
@returns(200) {items: [map], next_page_token: str} # A sequence of pipelines.

@endpoint GET /project/{project-slug}/pipeline/{pipeline-number}
