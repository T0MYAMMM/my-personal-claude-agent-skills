@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2017-10-01-preview
@auth OAuth2
@common_fields {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., serverName: any # The name of the server., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@endpoints 10
@toc subscriptions(10)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases
@desc Gets a list of databases.
@returns(200) Successfully retrieved the list of databases.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}
@desc Gets a database.
@required {databaseName: any # The name of the database.}
@returns(200) Successfully retrieved the specified database.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}
@desc Creates a new database or updates an existing database.
@required {databaseName: any # The name of the database., parameters: map # The requested database resource state.}
@returns(200) Successfully updated the database.
@returns(202) Creating or updating the database is in progress.
@returns(201) Successfully created the database.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}
@desc Deletes the database.
@required {databaseName: any # The name of the database.}
@returns(200) Successfully deleted the database.
@returns(202) Deleting the database is in progress.
@returns(204) The specified database does not exist.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}
@desc Updates an existing database.
@required {databaseName: any # The name of the database., parameters: map # The requested database resource state.}
@returns(200) Successfully updated the database.
@returns(202) Updating the database is in progress.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/elasticPools/{elasticPoolName}/databases
@desc Gets a list of databases in an elastic pool.
@required {elasticPoolName: any # The name of the elastic pool.}
@returns(200) Successfully retrieved a list of databases in an elastic pool.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/pause
@desc Pauses a database.
@required {databaseName: any # The name of the database to be paused.}
@returns(200) Successfully paused the database.
@returns(202) Pausing the database is in progress.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/resume
@desc Resumes a database.
@required {databaseName: any # The name of the database to be resumed.}
@returns(200) Successfully resumed the database.
@returns(202) Resuming the database is in progress.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/upgradeDataWarehouse
@desc Upgrades a data warehouse.
@required {databaseName: any # The name of the database to be upgraded.}
@returns(200) Successfully upgraded the data warehouse.
@returns(202) Upgrading the data warehouse is in progress.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/move
@desc Renames a database.
@required {databaseName: any # The name of the database to rename., parameters: map # The resource move definition for renaming this database.}
@returns(200) Successfully renamed the database.

@end
