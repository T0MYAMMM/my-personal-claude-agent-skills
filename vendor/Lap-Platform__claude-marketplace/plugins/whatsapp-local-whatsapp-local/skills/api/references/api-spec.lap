@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api WhatsApp Business API
@base http://example.com/v1
@version 1.0
@auth Bearer basic | Bearer bearer
@endpoints 55
@hint download_for_search
@toc users(6), settings(17), account(3), contacts(1), messages(2), groups(13), health(1), media(3), stats(2), metrics(1), support(1), certificates(5)

@group users
@endpoint POST /users/login
@desc Login-User
@required {new_password: str}
@returns(200) OK

@endpoint POST /users
@desc Create-User
@required {username: str # password, password: str # username}
@returns(200)
@example_request {"username":"{{UserUsername}}","password":"{{UserPassword}}"}

@endpoint GET /users/{UserUsername}
@desc Get-User
@required {UserUsername: str}
@returns(200)

@endpoint PUT /users/{UserUsername}
@desc Update-User
@required {UserUsername: str, password: str # password}
@returns(200)
@example_request {"password":"<New Password>"}

@endpoint DELETE /users/{UserUsername}
@desc Delete-User
@required {UserUsername: str}
@returns(200)

@endpoint POST /users/logout
@desc Logout-User
@returns(200)

@endgroup

@group settings
@endpoint GET /settings/application
@desc Get-Application-Settings
@returns(200) {callback_backoff_delay_ms: str, max_callback_backoff_delay_ms: str, callback_persist: bool, media: map{auto_download: [str]}, webhooks: map{url: str, max_concurrent_requests: int(int32)}, on_call_pager: str, pass_through: bool, sent_status: bool, unhealthy_interval: int, heartbeat_interval: int}

@endpoint DELETE /settings/application
@desc Reset-Application-Settings
@returns(200)

@endpoint PATCH /settings/application
@desc Update-Application-Settings
@optional {callback_backoff_delay_ms: str=3000 # Backoff delay for a failed callback in milliseconds This setting is used to configure the amount of time the backoff delays before retrying a failed callback. The backoff delay increases linearly by this value each time a callback fails to get a HTTPS 200 OK response. The backoff delay is capped by the max_callback_backoff_delay_ms setting., max_callback_backoff_delay_ms: str=900000 # Maximum delay for a failed callback in milliseconds, callback_persist: bool=True # Stores callbacks on disk until they are successfully acknowledged by the Webhook or not. Restart required., media: map{auto_download!: [str]}, webhooks: map{url: str, max_concurrent_requests: int(int32)}, on_call_pager: str # Set to valid WhatsApp Group with users who wish to see alerts for critical errors and messages., pass_through: bool=True # When true, removes messages from the local database after they are delivered to or read by the recipient. When false, saves all messages on local storage until they are explicitly deleted. When messages are sent, they are stored in a local database. This database is used as the application's history. Since the business keeps its own history, you can specify whether you want message pass_through or not. Restart required., sent_status: bool=False # Receive a notification that a message is sent to server. When true, you will receive a message indicating that a message has been sent. If false (default), you will not receive notification., unhealthy_interval: int=30 # Multiconnect: Maximum amount of seconds a Master node waits for a Coreapp node to respond to a heartbeat before considering it unhealthy and starting the failover process., heartbeat_interval: int=5 # Multiconnect: Interval of the Master node monitoring of Coreapp nodes in seconds}
@returns(200) {meta: map{version: str, api_status: str}, errors: [map]}
@example_request {"webhooks":{"url":"<Webhook URL, https>"}}

@endgroup

@group account
@endpoint POST /account/shards
@desc Set-Shards
@required {cc: str, phone_number: str, shards: int(int32)(1/2/4/8/16/32), pin: str}
@returns(200)
@example_request {"cc":"<Country Code>","phone_number":"<Phone Number>","shards":32,"pin":"<Two-Step PIN>"}

@endgroup

@group settings
@endpoint GET /settings/application/media/providers
@desc Get-Media-Providers
@returns(200)

@endpoint POST /settings/application/media/providers
@desc Update-Media-Providers
@returns(200)
@example_request [{"name":"<Provider Name>","type":"www","config":{"bearer":"<Bearer Auth Token>"}}]

@endpoint DELETE /settings/application/media/providers/{ProviderName}
@desc Delete-Media-Providers
@required {ProviderName: str # Provider Name}
@returns(200)

@endpoint POST /settings/backup
@desc Backup-Settings
@required {password: str # Used to encrypt backup data for security}
@returns(200) {settings: map{data: str}}
@example_request {"password":"<Password for Backup>"}

@endpoint POST /settings/restore
@desc Restore-Settings
@required {password: str # The password you used in the /v1/settings/backup API call to encrypt the backup data, data: str # The data that was returned by the /v1/settings/backup API call}
@returns(200)
@example_request {"password":"<Password for Backup>","data":"<Data to Restore, from Backup API>"}

@endpoint GET /settings/business/profile
@desc Get-Business-Profile
@returns(200)

@endpoint POST /settings/business/profile
@desc Update-Business-Profile
@required {address: str # Address of the business Maximum of 256 characters, description: str # Description of the business Maximum of 256 characters, email: str # Email address to contact the business Maximum of 128 characters, vertical: str # Industry of the business Maximum of 128 characters, websites: [str] # URLs associated with business (e.g., website, Facebook page, Instagram) Maximum of 2 websites with a maximum of 256 characters each}
@returns(200)
@example_request {"address":"<Business Profile Address>","description":"<Business Profile Description>","email":"<Business Profile Email>","vertical":"<Business Profile Vertical>","websites":["https://www.whatsapp.com","https://www.facebook.com"]}

@endpoint GET /settings/profile/about
@desc Get-Profile-About
@returns(200) {settings: map{profile: map{about: map{text: str}}}}

@endpoint PATCH /settings/profile/about
@desc Update-Profile-About
@required {text: str # Text to display in your profile's About section The max length for the string is 139 characters.}
@returns(200)
@example_request {"text":"<About Profile>"}

@endpoint POST /settings/account/two-step
@desc Enable-Two-Step
@required {pin: str}
@returns(200)
@example_request {"pin":"<Two-Step Verification PIN>"}

@endpoint DELETE /settings/account/two-step
@desc Disable-Two-Step
@returns(200)

@endgroup

@group account
@endpoint POST /account/verify
@desc Register-Account
@required {code: str}
@returns(200)
@example_request {"code":"<Registration Code Received via SMS/Voice>"}

@endgroup

@group contacts
@endpoint POST /contacts
@desc Check-Contact
@required {contacts: [str] # Array of contact phone numbers. The numbers can be in any standard telephone number format.}
@optional {blocking: str(no_wait/wait)=no_wait # Blocking determines whether the request should wait for the processing to complete (synchronous) or not (asynchronous).}
@returns(200)
@example_request {"blocking":"wait","contacts":["{{Recipient-WA-ID}}"]}

@endgroup

@group messages
@endpoint POST /messages
@desc Send-Message
@required {to: str # When recipient_type is individual, this field is the WhatsApp ID (phone number) returned from contacts endpoint. When recipient_type is group, this field is the WhatsApp group ID.}
@optional {type: str(audio/contacts/document/hsm/image/location/text/video/voice/unknown)=text # type of the message, recipient_type: str(individual/group)=individual # Determines whether the recipient is an individual or a group Specifying recipient_type in the request is optional when the value is individual. However, recipient_type is required when using group. If sending a text message to a group, see the Sending Group Messages documentation., text: map{body!: str}, audio: map # The media object containing audio, image: map # The media object containing an image, document: map # The media object containing a document, video: map # The media object containing a video, hsm: map{namespace!: str, element_name!: str, language!: map{policy!: str, code!: str}, localizable_params!: [map{default!: str, currency: map, date_time: map}]} # The containing element for the message content — Indicates that the message is highly structured. Parameters contained within provide the structure., ttl: map, contacts: [map{addresses: [map{city!: str, country!: str, country_code!: str, state!: str, street!: str, type!: str, zip!: str}], birthday: str, emails: [map{email!: str, type!: str}], ims: [str], name: map{first_name: str, formatted_name!: str, last_name: str, suffix: str, prefix: str}, org: map{company!: str, department: str, title: str}, phones: [map{phone: str, type: str, wa_id: str}], urls: [map{url: str, type: str}]}], location: map{longitude!: str, latitude!: str, name!: str, address!: str}, preview_url: bool # Specifying preview_url in the request is optional when not including a URL in your message. To include a URL preview, set preview_url to true in the message body and make sure the URL begins with http:// or https://. For more information, see the Sending URLs in Text Messages section.}
@returns(200)
@example_request {"to":"{{Recipient-WA-ID}}","type":"text","recipient_type":"individual","text":{"body":"<Message Text>"}}

@endpoint PUT /messages/{MessageID}
@desc Mark-Message-As-Read
@required {MessageID: str # Message ID from Webhook, status: str=read}
@returns(200)
@example_request {"status":"read"}

@endgroup

@group groups
@endpoint GET /groups
@desc Get-All-Groups
@returns(200)

@endpoint POST /groups
@desc Create-Group
@required {subject: str}
@returns(200)
@example_request {"subject":"<Group Subject>"}

@endpoint GET /groups/{GroupId}
@desc Get-Group-Info
@required {GroupId: str}
@returns(200)

@endpoint PUT /groups/{GroupId}
@desc Update-Group-Info
@required {GroupId: str, subject: str}
@returns(200)
@example_request {"subject":"<New Group Subject>"}

@endpoint GET /groups/{GroupId}/invite
@desc Get-Group-Invite
@required {GroupId: str}
@returns(200)

@endpoint DELETE /groups/{GroupId}/invite
@desc Delete-Group-Invite
@required {GroupId: str}
@returns(200)

@endpoint DELETE /groups/{GroupId}/participants
@desc Remove-Group-Participant
@required {GroupId: str, wa_ids: [str]}
@returns(200)
@example_request {"wa_ids":["{{Recipient-WA-ID}}"]}

@endpoint POST /groups/{GroupId}/leave
@desc Leave-Group
@required {GroupId: str}
@returns(200)

@endpoint GET /groups/{GroupId}/icon
@desc Get-Group-Icon-Binary
@required {GroupId: str}
@returns(200)

@endpoint POST /groups/{GroupId}/icon
@desc Set-Group-Icon
@required {GroupId: str}
@returns(200)

@endpoint DELETE /groups/{GroupId}/icon
@desc Delete-Group-Icon
@required {GroupId: str}
@returns(200)

@endpoint DELETE /groups/{GroupId}/admins
@desc Demote-Group-Admin
@required {GroupId: str, wa_ids: [str] # The WhatsApp IDs of the people to be added or removed as group admins}
@returns(200)
@example_request {"wa_ids":["<Recipient WA-ID, from Contacts API>"]}

@endpoint PATCH /groups/{GroupId}/admins
@desc Promote-To-Group-Admin
@required {GroupId: str, wa_ids: [str] # The WhatsApp IDs of the people to be added or removed as group admins}
@returns(200)
@example_request {"wa_ids":["<Recipient WA-ID, from Contacts API>"]}

@endgroup

@group health
@endpoint GET /health
@desc Check-Health
@returns(200)

@endgroup

@group settings
@endpoint GET /settings/profile/photo
@desc Get-Profile-Photo
@optional {format: str}
@returns(200) {settings: map{profile: map{photo: map{link: str}}}}

@endpoint POST /settings/profile/photo
@desc Update-Profile-Photo
@returns(200)

@endpoint DELETE /settings/profile/photo
@desc Delete-Profile-Photo
@returns(200)

@endgroup

@group account
@endpoint POST /account
@desc Request-Code
@required {cc: str # Numerical country code for the phone number you are registering, phone_number: str # Phone number you are registering, without the country code or plus symbol (+), method: str(sms/voice) # Method of receiving your registration code, cert: str # Base64-encoded Verified Name certificate}
@optional {pin: str # Existing 6-digit PIN — This is only required when two-factor verification is enabled on this account.}
@returns(201) Created: the account already exists. You are already registered, so you do not need to do anything else.
@returns(202) {account: [map]} # Created: the account does not exist. Depending on the method selected in the request, check your SMS or voice number for the registration code.
@example_request {"cc":"<Country Code>","phone_number":"<Phone Number>","method":"sms","cert":"<Valid Cert from Business Manager>","pin":"<Two-Step Verification PIN"}

@endgroup

@group media
@endpoint POST /media
@desc Upload-Media
@returns(200)

@endpoint GET /media/{MediaId}
@desc Download-Media
@required {MediaId: str}
@returns(200)

@endpoint DELETE /media/{MediaId}
@desc Delete-Media
@required {MediaId: str}
@returns(200)

@endgroup

@group stats
@endpoint GET /stats/app
@desc Get-App-Stats
@optional {format: str}
@returns(200)

@endpoint GET /stats/db
@desc Get-DB-Stats
@optional {format: str}
@returns(200)

@endgroup

@group metrics
@endpoint GET /metrics
@desc Get-Metrics (since v2.21.3)
@optional {format: str}
@returns(200)

@endgroup

@group support
@endpoint GET /support
@desc Get-Support-Info
@returns(200)

@endgroup

@group certificates
@endpoint GET /certificates/external/ca
@desc Download-CA-Certificate
@returns(200)

@endpoint POST /certificates/external
@desc Upload-Certificate
@returns(200)

@endpoint GET /certificates/webhooks/ca
@desc Download Webhook CA Certificate
@returns(200)

@endpoint POST /certificates/webhooks/ca
@desc Upload Webhook CA Certificate
@returns(200)

@endpoint DELETE /certificates/webhooks/ca
@desc Delete Webhook CA Certificate
@returns(200)

@endgroup

@end
