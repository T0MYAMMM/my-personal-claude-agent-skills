@returns(200) {EngineDefaults: EngineDefaults?{DBParameterGroupFamily: str?, Marker: str?, Parameters: [Parameter]?}}

@endpoint POST /
@desc Displays a list of categories for all event source types, or, if specified, for a specified source type.
@optional {SourceType: str, Filters: [Filter]}
@returns(200) {EventCategoriesMapList: [EventCategoriesMap]?}

@endpoint POST /
@desc Lists all the subscription descriptions for a customer account. The description for a subscription includes SubscriptionName, SNSTopicARN, CustomerID, SourceType, SourceID, CreationTime, and Status. If you specify a SubscriptionName, lists the description for that subscription.
@optional {SubscriptionName: str, Filters: [Filter], MaxRecords: int, Marker: str}
@returns(200) {Marker: str?, EventSubscriptionsList: [EventSubscription]?}

@endpoint POST /
@desc Returns events related to instances, security groups, snapshots, and DB parameter groups for the past 14 days. You can obtain events specific to a particular DB instance, security group, snapshot, or parameter group by providing the name as a parameter. By default, the events of the past hour are returned.
@optional {SourceIdentifier: str, SourceType: str, StartTime: str(timestamp), EndTime: str(timestamp), Duration: int, EventCategories: [str], Filters: [Filter], MaxRecords: int, Marker: str}
@returns(200) {Marker: str?, Events: [Event]?}

