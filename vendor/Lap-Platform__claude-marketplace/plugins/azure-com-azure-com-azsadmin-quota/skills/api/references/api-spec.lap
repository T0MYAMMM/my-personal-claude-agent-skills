@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SubscriptionsManagementClient
@base https://management.azure.com
@version 2015-11-01
@auth OAuth2
@endpoints 2
@toc subscriptions(2)

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Subscriptions.Admin/locations/{location}/quotas
@desc Get the list of quotas at a location.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Subscriptions.Admin/locations/{location}/quotas/{quota}
@desc Gets a quota by name.
@required {quota: any # Name of the quota.}
@returns(200) OK

@end
