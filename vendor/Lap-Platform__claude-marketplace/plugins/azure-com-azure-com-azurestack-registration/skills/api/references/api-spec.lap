@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Azure Stack Azure Bridge Client
@base https://management.azure.com
@version 2017-06-01
@auth OAuth2
@endpoints 8
@toc subscriptions(8)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroup}/providers/Microsoft.AzureStack/registrations
@desc Returns a list of all registrations.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.AzureStack/registrations
@desc Returns a list of all registrations under current subscription.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroup}/providers/Microsoft.AzureStack/registrations/{registrationName}
@desc Returns the properties of an Azure Stack registration.
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroup}/providers/Microsoft.AzureStack/registrations/{registrationName}
@desc Delete the requested Azure Stack registration.
@returns(200) OK
@returns(204) NO CONTENT

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroup}/providers/Microsoft.AzureStack/registrations/{registrationName}
@desc Create or update an Azure Stack registration.
@required {token: map # Registration token}
@returns(200) OK
@returns(201) CREATED

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroup}/providers/Microsoft.AzureStack/registrations/{registrationName}
@desc Patch an Azure Stack registration.
@required {token: map # Registration token}
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroup}/providers/Microsoft.AzureStack/registrations/{registrationName}/getactivationkey
@desc Returns Azure Stack Activation Key.
@returns(200) OK

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroup}/providers/Microsoft.AzureStack/registrations/{registrationName}/enableRemoteManagement
@desc Enables remote management for device under the Azure Stack registration.
@returns(200) OK

@end
