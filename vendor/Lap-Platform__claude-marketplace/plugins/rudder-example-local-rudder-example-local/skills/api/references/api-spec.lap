@endpoint POST /nodes/{nodeId}/fetchData/{datasourceId}
@desc Update properties for one node from a data source
@required {nodeId: str(uuid (or "root")) # Id of the target node, datasourceId: str # Id of the data source}
@returns(200) {result: str, action: str, data: str} # Data sources reloaded

@endpoint GET /nodes/{nodeId}/inheritedProperties
@desc Get inherited node properties for a node
@required {nodeId: str(uuid (or "root")) # Id of the target node}
@returns(200) {result: str, action: str, data: [map]} # Node

