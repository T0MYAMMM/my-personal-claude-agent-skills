@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Rudder API
@base https://{rudderServer}/rudder/api/latest
@version 22
@auth ApiKey X-API-Token in header
@endpoints 176
@hint download_for_search
@toc api(1), apiaccounts(7), archives(2), branding(3), campaigns(10), changeRequests(4), compliance(9), cve(9), datasources(7), directives(7), groups(11), info(3), inventories(4), methods(2), nodes(14), openscap(1), parameters(5), plugins(3), rules(10), scaleoutrelay(2), secret(5), securitytags(2), settings(6), status(1), system(13), systemUpdate(5), techniques(13), tenants(4), usermanagement(10), users(1), validatedUsers(2)

@group api
@endpoint GET /api/changeRequests
@desc List all change requests
@returns(200) {result: str, action: str, data: [map]} # Change requests information

@endgroup

@group apiaccounts
@endpoint GET /apiaccounts
@desc List all API accounts
@returns(200) {result: str, action: str, data: map{accounts: [map]}} # Directives information

@endpoint POST /apiaccounts
@desc Create an API account
@optional {id: str # An optional ID for that account. It needs to match [a-zA-Z0-9_-]+, name: str # Human readable name of the API account, description: str # One line API account description, status: str(enabled/disabled) # Status of that API account, generateToken: bool # Optionally specify if the token need to be generated (default true), expirationPolicy: str(never/datetime) # Optionally specify the expiration policy of the API account. Default: never, expirationDate: str(rfc3339) # Optional expiration date of the API account, tenants: str # a comma separated list of tenants allowed for that account. See tenant documentation for syntax., authorizationType: str(rw/ro/acl) # Authorization type for that account:  - ro: read-only (GET) access to all APIs - rw: read (GET) and write (other verbs) access to all APIs - acl: access control list based permission for API (need api-authorization plugin), acl: [map{path: str, actions: [str]}] # in case of ACL authorization type, the actual ACL}
@returns(200) {result: str, id: str(uuid), action: str, data: map{accounts: [map]}} # Information about request

@endpoint GET /apiaccounts/${apiAccountId}
@desc Get an API account details
@required {apiAccountId: str(uuid) # Id of the API account}
@returns(200) {result: str, id: str, action: str, data: map{accounts: [map]}} # API account information

@endpoint DELETE /apiaccounts/${apiAccountId}
@desc Delete an API account
@required {apiAccountId: str(uuid) # Id of the API account}
@returns(200) {result: str, id: str, action: str, data: map{accounts: [map]}} # API account information

@endpoint POST /apiaccounts/${apiAccountId}
@desc Update an API account details
@required {apiAccountId: str(uuid) # Id of the API account}
@optional {name: str # Human readable name of the API account, description: str # One line API account description, status: str(enabled/disabled) # Status of that API account, expirationPolicy: str(never/datetime) # Optionally specify the expiration policy of the API account. Default: never, expirationDate: str(rfc3339) # Optional expiration date of the API account, tenants: str # a comma separated list of tenants allowed for that account. See tenant documentation for syntax., authorizationType: str(rw/ro/acl) # Authorization type for that account:  - ro: read-only (GET) access to all APIs - rw: read (GET) and write (other verbs) access to all APIs - acl: access control list based permission for API (need api-authorization plugin), acl: [map{path: str, actions: [str]}] # in case of ACL authorization type, the actual ACL}
@returns(200) {result: str, action: str, data: map{accounts: [map]}} # Directives information

@endpoint POST /apiaccounts/${apiAccountId}/regenerate
@desc Regenerate the token of an API account
@required {apiAccountId: str(uuid) # Id of the API account}
@returns(200) {result: str, id: str, action: str, data: map{accounts: [map]}} # API account information

@endpoint GET /apiaccounts/token
@desc Get API account for the currently identified token
@returns(200) {result: str, id: str, action: str, data: map{accounts: [map]}} # API account information

@endgroup

@group archives
@endpoint GET /archives/export
@desc Get a ZIP archive of the requested items and their dependencies
@optional {rules: [str] # IDs (optionally with revision, '+' need to be escaped as '%2B') of rules to include.  The special key-word 'all' can be use to mean "all non-system rules", directives: [str] # IDs (optionally with revision, '+' need to be escaped as '%2B') of directives to include The special key-word 'all' can be use to mean "all non-system directives", techniques: [str] # IDs, ie technique name/technique version (optionally with revision, '+' need to be escaped as '%2B') of techniques to include The special key-word 'all' can be use to mean "all non-system techniques", groups: [str] # IDs (optionally with revision, '+' need to be escaped as '%2B') of groups to include The special key-word 'all' can be use to mean "all non-system groups", include: [str] # Scope of dependencies to include in archive, where rule as directives and groups dependencies, directives have techniques dependencies, and techniques and groups don't have dependencies. 'none' means no dependencies will be include, 'all' means that the whole tree will,  'directives' and 'groups' means to include them specifically, 'techniques' means to include both directives and techniques.}
@returns(200) A zip archive with the queried content.

@endpoint POST /archives/import
@desc Import a ZIP archive of policies into Rudder
@returns(200) {result: str, action: str, data: map{archiveImported: bool}} # Archive imported

@endgroup

@group branding
@endpoint GET /branding
@desc Get branding configuration
@returns(200) {result: str, action: str, data: map{branding: map{displayBar: bool, displayLabel: bool, labelText: str, barColor: map{red: num, blue: num, green: num, alpha: num}, labelColor: map{red: num, blue: num, green: num, alpha: num}, wideLogo: map{enable: bool}, smallLogo: map{enable: bool}, displayBarLogin: bool, displayMotd: bool, motd: str}}} # Branding configuration

@endpoint POST /branding
@desc Update web interface customization
@required {displayBar: bool # Whether header bar is displayed or not, displayLabel: bool # Whether header bar's label is displayed or not, labelText: str # The header bar's label title, barColor: map{red!: num, blue!: num, green!: num, alpha!: num}, labelColor: map{red!: num, blue!: num, green!: num, alpha!: num}, wideLogo: map{enable!: bool}, smallLogo: map{enable!: bool}, displayBarLogin: bool # Whether header bar is displayed in login page or not, displayMotd: bool # Whether the message of the day is displayed in login page or not, motd: str # Message of the day in login page}
@returns(200) {result: str, action: str, data: map{branding: map{displayBar: bool, displayLabel: bool, labelText: str, barColor: map{red: num, blue: num, green: num, alpha: num}, labelColor: map{red: num, blue: num, green: num, alpha: num}, wideLogo: map{enable: bool}, smallLogo: map{enable: bool}, displayBarLogin: bool, displayMotd: bool, motd: str}}} # Updated

@endpoint POST /branding/reload
@desc Reload branding file
@returns(200) {result: str, action: str, data: map{branding: map{displayBar: bool, displayLabel: bool, labelText: str, barColor: map{red: num, blue: num, green: num, alpha: num}, labelColor: map{red: num, blue: num, green: num, alpha: num}, wideLogo: map{enable: bool}, smallLogo: map{enable: bool}, displayBarLogin: bool, displayMotd: bool, motd: str}}} # Branding configuration

@endgroup

@group campaigns
@endpoint GET /campaigns
@desc Get all campaigns details
@optional {campaignType: str(system-update/software-update) # Type of the campaigns we want, status: str(enabled/disabled/archived) # Status of the campaigns we want}
@returns(200) {result: str, action: str, data: map{campaigns: [map]}} # Campaign details result

@endpoint POST /campaigns
@desc Save a campaign
@optional {info: map{id: str(uuid), name: str, description: str, status: any, schedule: any} # common data about campaign, campaignType: str(system-update/software-update) # Type of campaign (with version determine what kind of campaign you handle and the details object), version: int # Version of campaign (with type determine what kind of campaign you handle and the details object), details: any}
@returns(200) {result: str, action: str, data: map{campaigns: [map]}} # Campaign details result

@endpoint GET /campaigns/events
@desc Get all campaign events
@optional {campaignType: str(system-update/software-update) # Type of the campaigns we want, state: str(scheduled/running/finished/skipped) # Status of the campaign events we want, campaignId: str # id of a specific campaign, limit: int # Max number of elements in response, offset: int # Offset of data in response (skip X elements), before: str(date-time), after: str(date-time), order: str(start/startDate/end/endDate), asc: str(asc/desc)}
@returns(200) {result: str, action: str, data: map{campaignEvents: [map]}} # Campaign event details result

@endpoint GET /campaigns/events/{id}
@desc Get a campaign event details
@required {id: str(uuid) # Id of the campaign event}
@returns(200) {result: str, action: str, data: map{campaignEvents: [map]}} # Campaign details result

@endpoint POST /campaigns/events/{id}
@desc Update an existing event
@required {id: str(uuid) # Id of the campaign event}
@returns(200) {result: str, action: str, data: map{campaignEvents: [map]}} # Campaign event details result

@endpoint DELETE /campaigns/events/{id}
@desc Delete a campaign event details
@required {id: str(uuid) # Id of the campaign event}
@returns(200) {result: str, action: str, data: map{campaignEvents: [map]}} # Campaign event details result

@endpoint GET /campaigns/{id}
@desc Get a campaign details
@required {id: str(uuid) # Id of the campaign}
@returns(200) {result: str, action: str, data: map{campaigns: [map]}} # Campaign details result

@endpoint DELETE /campaigns/{id}
@desc Delete a campaign
@required {id: str(uuid) # Id of the campaign}
@returns(200) {result: str, action: str, data: map{campaigns: [map]}} # Campaign details result

@endpoint GET /campaigns/{id}/events
@desc Get campaign events for a campaign
@required {id: str(uuid) # Id of the campaign}
@optional {campaignType: str(system-update/software-update) # Type of the campaigns we want, state: str(scheduled/running/finished/skipped) # Status of the campaign events we want, limit: int # Max number of elements in response, offset: int # Offset of data in response (skip X elements), before: str(date-time), after: str(date-time), order: str(start/startDate/end/endDate), asc: str(asc/desc)}
@returns(200) {result: str, action: str, data: map{campaignEvents: [map]}} # Campaign details result

@endpoint POST /campaigns/{id}/schedule
@desc Schedule a campaign event for a campaign
@required {id: str(uuid) # Id of the campaign}
@returns(200) {result: str, action: str, data: map{campaignEvents: [map]}} # Campaign events details result

@endgroup

@group changeRequests
@endpoint GET /changeRequests/{changeRequestId}
@desc Get a change request details
@required {changeRequestId: int}
@returns(200) {result: str, action: str, data: map{changeRequests: [map]}} # Change requests information

@endpoint DELETE /changeRequests/{changeRequestId}
@desc Decline a request details
@required {changeRequestId: int}
@returns(200) {result: str, action: str, data: map{changeRequests: [map]}} # Change requests information

@endpoint POST /changeRequests/{changeRequestId}
@desc Update a request details
@required {changeRequestId: int}
@optional {name: str # Change request name, description: str # Change request description}
@returns(200) {result: str, action: str, data: map{changeRequests: [map]}} # Change requests information

@endpoint POST /changeRequests/{changeRequestId}/accept
@desc Accept a request details
@required {changeRequestId: int}
@optional {status: str(pending deployment/deployed) # New status of the change request}
@returns(200) {result: str, action: str, data: map{changeRequests: [map]}} # Change requests information

@endgroup

@group compliance
@endpoint GET /compliance
@desc Global compliance
@optional {precision: int=2 # Number of digits after comma in compliance percent figures}
@returns(200) {result: str, action: str, data: map{globalCompliance: map{compliance: num(integer), complianceDetails: map{successAlreadyOK: num(float), noReport: num(float), successNotApplicable: num(float), unexpectedMissingComponent: num(float), error: num(float), unexpectedUnknownComponent: num(float), successRepaired: num(float)}}}} # Success

@endpoint GET /compliance/directives
@desc Compliance details for all directives
@returns(200) {result: str, action: str, data: map{directivesCompliance: map{id: str(uuid), name: str, mode: str, compliance: num(float), complianceDetails: map{successAlreadyOK: num(float), noReport: num(float), successNotApplicable: num(float), unexpectedMissingComponent: num(float), error: num(float), unexpectedUnknownComponent: num(float), successRepaired: num(float)}, rules: map{id: str(uuid), name: str, mode: str, compliance: num(float), complianceDetails: map, components: [map]}, nodes: map{id: str(uuid), name: str, compliance: num(float), complianceDetails: map, rules: map}}}} # Success

@endpoint GET /compliance/directives/{directiveId}
@desc Compliance details by directive
@required {directiveId: str(uuid) # Id of the directive}
@optional {format: str(csv/json)=json # format of export}
@returns(200) Success

@endpoint GET /compliance/groups/{targetOrNodeGroupId}
@desc Compliance details by group (global)
@required {targetOrNodeGroupId: any # Id of the node group or rule target}
@optional {level: int=10 # Number of depth level of compliance objects to display (1:rules, 2:directives, 3:components, 4:nodes, 5:values, 6:reports), precision: int=2 # Number of digits after comma in compliance percent figures}
@returns(200) {result: str, action: str, data: map{nodeGroups: [map]}} # Success

@endpoint GET /compliance/groups/{targetOrNodeGroupId}/target
@desc Compliance details by group (targeted)
@required {targetOrNodeGroupId: any # Id of the node group or rule target}
@optional {level: int=10 # Number of depth level of compliance objects to display (1:rules, 2:directives, 3:components, 4:nodes, 5:values, 6:reports), precision: int=2 # Number of digits after comma in compliance percent figures}
@returns(200) {result: str, action: str, data: map{nodeGroups: [map]}} # Success

@endpoint GET /compliance/nodes
@desc Compliance details for all nodes
@optional {level: int=10 # Number of depth level of compliance objects to display (1:rules, 2:directives, 3:components, 4:nodes, 5:values, 6:reports), precision: int=2 # Number of digits after comma in compliance percent figures}
@returns(200) {result: str, action: str, data: map{nodes: [map]}} # Success

@endpoint GET /compliance/nodes/{nodeId}
@desc Compliance details by node
@required {nodeId: str(uuid (or "root")) # Id of the target node}
@optional {level: int=10 # Number of depth level of compliance objects to display (1:rules, 2:directives, 3:components, 4:nodes, 5:values, 6:reports), precision: int=2 # Number of digits after comma in compliance percent figures}
@returns(200) {result: str, action: str, data: map{nodes: [map]}} # Success

@endpoint GET /compliance/rules
@desc Compliance details for all rules
@optional {level: int=10 # Number of depth level of compliance objects to display (1:rules, 2:directives, 3:components, 4:nodes, 5:values, 6:reports), precision: int=2 # Number of digits after comma in compliance percent figures}
@returns(200) {result: str, action: str, data: map{rules: [map]}} # Success

@endpoint GET /compliance/rules/{ruleId}
@desc Compliance details by rule
@required {ruleId: str(uuid) # Id of the target rule}
@optional {level: int=10 # Number of depth level of compliance objects to display (1:rules, 2:directives, 3:components, 4:nodes, 5:values, 6:reports), precision: int=2 # Number of digits after comma in compliance percent figures}
@returns(200) {result: str, action: str, data: map{rules: [map]}} # Success

@endgroup

@group cve
@endpoint GET /cve
@desc Get all CVE details
@returns(200) {result: str, action: str, data: map{CVEs: [map]}} # CVE details result

@endpoint POST /cve/check
@desc Trigger a CVE check
@returns(200) {result: str, action: str, data: map{cveChecks: [map]}} # CVE check result

@endpoint GET /cve/check/config
@desc Get CVE check config
@returns(200) {result: str, action: str, data: map{url: str, apiKey: str}} # CVE check config

@endpoint POST /cve/check/config
@desc Update cve check config
@optional {url: str # Url used to check CVE, apiKey: str # Token used by to contact the API to check CVE}
@returns(200) {result: str, action: str, data: map{url: str, apiKey: str}} # new CVE check config

@endpoint GET /cve/check/last
@desc Get last CVE check result
@optional {groupId: str # Id of node groups you want to get from last CVE check, nodeId: str # Id of nodes you want to get from last CVE check, cveId: str # Id of CVE you want to get from last CVE check, package: str # Name of packages you want to get from last CVE check, severity: str(critical/high/medium/low/none/unknown) # Severity of the CVE you want to get from last CVE check}
@returns(200) {result: str, action: str, data: map{CVEChecks: [map]}} # Last CVE check

@endpoint POST /cve/list
@desc Get a list of CVE details
@optional {cveIds: [str], onlyScore: bool=False # Only send score of the cve, and not the whole detailed list, minScore: num(A score between 0 and 10 as a float) # Only send CVE with a score higher than the value, maxScore: num(A score between 0 and 10 as a float) # Only send CVE with a score lower than the value, publishedDate: str(date-time) # Only send CVE with a publication date more recent than the value}
@returns(200) {result: str, action: str, data: map{CVEs: [map]}} # CVE list

@endpoint POST /cve/update
@desc Update CVE database from remote source
@optional {url: str # Url used to update CVE, will default to one set in config, years: [str]}
@returns(200) {result: str, action: str, data: map{CVEs: int}} # updated CVE count

@endpoint POST /cve/update/fs
@desc Update CVE database from file system
@returns(200) {result: str, action: str, data: map{CVEs: int}} # updated CVE count

@endpoint GET /cve/{cveId}
@desc Get a CVE details
@required {cveId: str(CVE ID) # Id of the CVE}
@returns(200) {result: str, action: str, data: map{CVEs: [map]}} # CVE details result

@endgroup

@group datasources
@endpoint GET /datasources
@desc List all data sources
@returns(200) {result: str, action: str, data: map{datasources: [map]}} # Data sources information

@endpoint PUT /datasources
@desc Create a data source
@optional {id: str # Unique identifier of the data source to create., name: str # The human readable name of the data source to create., description: str # Description of the goal of the data source to create., enabled: bool # Enable or disable data source., updateTimeout: int # Duration in seconds before aborting data source update. The main goal is to prevent never ending requests. If a periodicity if configured, you should set that timeout at a lower value., runParameters: map{onGeneration: bool, onNewNode: bool, schedule: map{type: str}} # Parameters to configure when the data source is fetched to update node properties., type: map{name: str, parameters: map{url: str, requestMethod: str, headers: [map], path: str, checkSsl: bool, requestTimeout: int, requestMode: map}} # Define and configure data source type.}
@returns(200) {result: str, action: str, data: map{datasources: [map]}} # Created

@endpoint POST /datasources/reload
@desc Update properties from data sources
@returns(200) {result: str, action: str, data: str} # Data source reloaded

@endpoint POST /datasources/reload/{datasourceId}
@desc Update properties from data sources
@required {datasourceId: str # Id of the data source}
@returns(200) {result: str, action: str, data: str} # Data source reloaded

@endpoint GET /datasources/{datasourceId}
@desc Get data source configuration
@required {datasourceId: str # Id of the data source}
@returns(200) {result: str, action: str, data: map{datasources: [map]}} # Data source information

@endpoint POST /datasources/{datasourceId}
@desc Update a data source configuration
@required {datasourceId: str # Id of the data source}
@optional {id: str # Unique identifier of the data source to create., name: str # The human readable name of the data source to create., description: str # Description of the goal of the data source to create., enabled: bool # Enable or disable data source., updateTimeout: int # Duration in seconds before aborting data source update. The main goal is to prevent never ending requests. If a periodicity if configured, you should set that timeout at a lower value., runParameters: map{onGeneration: bool, onNewNode: bool, schedule: map{type: str}} # Parameters to configure when the data source is fetched to update node properties., type: map{name: str, parameters: map{url: str, requestMethod: str, headers: [map], path: str, checkSsl: bool, requestTimeout: int, requestMode: map}} # Define and configure data source type.}
@returns(200) {result: str, action: str, data: map{datasources: [map]}} # Data source information

@endpoint DELETE /datasources/{datasourceId}
@desc Delete a data source
@required {datasourceId: str # Id of the data source}
@returns(200) {result: str, action: str, data: map{datasources: [map]}} # Data source information

@endgroup

@group directives
@endpoint GET /directives
@desc List all directives
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Directives information

@endpoint PUT /directives
@desc Create a directive
@optional {source: str(uuid) # The id of the directive the clone will be based onto. If this parameter if provided,  the new directive will be a clone of this source. Other value will override values from the source., id: str(uuid) # Directive id, displayName: str # Human readable name of the directive, shortDescription: str # One line directive description, longDescription: str(markdown) # Description of the technique (rendered as markdown), techniqueName: str # Directive id, techniqueVersion: str # Directive id, priority: int # Directive priority. `0` has highest priority., enabled: bool # Is the directive enabled, system: bool # If true it is an internal Rudder directive, tags: [map], parameters: map # Directive parameters (depends on the source technique)}
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Directives information

@endpoint GET /directives/tree
@desc Get directive tree
@optional {includeSystem: bool=False # Should we include system techniques and categories in the tree or not., includeSystem: bool # Should we include system techniques and categories in the tree or not.}
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Directives tree

@endpoint GET /directives/{directiveId}
@desc Get directive details
@required {directiveId: str(uuid) # Id of the directive}
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Directives information

@endpoint DELETE /directives/{directiveId}
@desc Delete a directive
@required {directiveId: str(uuid) # Id of the directive}
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Directives information

@endpoint POST /directives/{directiveId}
@desc Update a directive details
@required {directiveId: str(uuid) # Id of the directive}
@optional {id: str(uuid) # Directive id, displayName: str # Human readable name of the directive, shortDescription: str # One line directive description, longDescription: str(markdown) # Description of the technique (rendered as markdown), techniqueName: str # Directive id, techniqueVersion: str # Directive id, priority: int # Directive priority. `0` has highest priority., enabled: bool # Is the directive enabled, system: bool # If true it is an internal Rudder directive, policyMode: str(enforce/audit) # Policy mode of the directive, tags: [map], parameters: map # Directive parameters (depends on the source technique)}
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Directives information

@endpoint POST /directives/{directiveId}/check
@desc Check that update on a directive is valid
@required {directiveId: str(uuid) # Id of the directive}
@optional {id: str(uuid) # Directive id, displayName: str # Human readable name of the directive, shortDescription: str # One line directive description, longDescription: str(markdown) # Description of the technique (rendered as markdown), techniqueName: str # Directive id, techniqueVersion: str # Directive id, priority: int # Directive priority. `0` has highest priority., enabled: bool # Is the directive enabled, system: bool # If true it is an internal Rudder directive, policyMode: str(enforce/audit) # Policy mode of the directive, tags: [map], parameters: map # Directive parameters (depends on the source technique)}
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Directives information

@endgroup

@group groups
@endpoint GET /groups
@desc List all groups
@returns(200) {result: str, action: str, data: map{groups: [map]}} # Groups information

@endpoint PUT /groups
@desc Create a group
@required {category: str(uuid) # Id of the new group's category, displayName: str # Name of the group}
@optional {source: str(uuid) # The id of the group the clone will be based onto. If this parameter if provided,  the new group will be a clone of this source. Other value will override values from the source., id: str(uuid)={autogenerated} # Group id, only provide it when needed., description: str # Group description, query: map{select: str, composition: str, where: [map{objectType: str, attribute: str, comparator: str, value: str}]} # The criteria defining the group. If not provided, the group will be empty., dynamic: bool=True # Should the group be dynamically refreshed (if not, it is a static group), enabled: bool=True # Enable or disable the group, properties: [map{name!: str, value!: any}] # Group properties}
@returns(200) {result: str, action: str, data: map{groups: [map]}} # Group information

@endpoint PUT /groups/categories
@desc Create a group category
@required {parent: str(uuid) # The parent category of the groups, name: str # Name of the group category}
@optional {id: str(uuid)={autogenerated} # Group category id, only provide it when needed., description: str # Group category description}
@returns(200) {result: str, action: str, data: map{groupCategories: [map]}} # Groups category information

@endpoint GET /groups/categories/{groupCategoryId}
@desc Get group category details
@required {groupCategoryId: str(uuid)}
@returns(200) {result: str, action: str, data: map{groupCategories: [map]}} # Groups category information

@endpoint DELETE /groups/categories/{groupCategoryId}
@desc Delete group category
@required {groupCategoryId: str(uuid)}
@returns(200) {result: str, action: str, data: map{groupCategories: [map]}} # Groups category information

@endpoint POST /groups/categories/{groupCategoryId}
@desc Update group category details
@required {groupCategoryId: str(uuid), parent: str(uuid) # The parent category of the groups, name: str # Name of the group category}
@optional {description: str # Group category description}
@returns(200) {result: str, action: str, data: map{groupCategories: [map]}} # Groups category information

@endpoint GET /groups/tree
@desc Get groups tree
@optional {includeSystem: bool=False # Whether to include system categories and groups in results.}
@returns(200) {result: str, action: str, data: map{groupCategories: map}} # Groups information

@endpoint GET /groups/{groupId}
@desc Get group details
@required {groupId: str(uuid) # Id of the group}
@returns(200) {result: str, action: str, data: map{groups: [map]}} # Groups information

@endpoint POST /groups/{groupId}
@desc Update group details
@required {groupId: str(uuid) # Id of the group}
@optional {category: str(uuid) # Id of the new group's category, displayName: str # Name of the group, description: str # Group description, query: map{select: str, composition: str, where: [map{objectType: str, attribute: str, comparator: str, value: str}]} # The criteria defining the group. If not provided, the group will be empty., dynamic: bool=True # Should the group be dynamically refreshed (if not, it is a static group), enabled: bool=True # Enable or disable the group}
@returns(200) {result: str, action: str, data: map{groups: [map]}} # Groups information

