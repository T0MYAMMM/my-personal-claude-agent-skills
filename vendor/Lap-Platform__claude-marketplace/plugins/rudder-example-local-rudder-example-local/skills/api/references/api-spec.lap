@endpoint POST /techniques/{techniqueId}/{techniqueVersion}
@desc Update technique
@required {techniqueId: str # Technique ID, techniqueVersion: str # Technique version}
@returns(200) {result: str, action: str, data: map{techniques: map{technique: map{id: str, name: str, version: str, category: str, description: str, source: str, parameters: [map], resources: [map], calls: [any]}}}} # Versions information

@endpoint DELETE /techniques/{techniqueId}/{techniqueVersion}
@desc Delete technique
@required {techniqueId: str # Technique ID, techniqueVersion: str # Technique version}
@returns(200) {result: str, action: str, data: map{techniques: [map]}} # Deletion information

@endpoint GET /techniques/{techniqueId}/{techniqueVersion}
@desc Technique metadata by version and ID
@required {techniqueId: str # Technique ID, techniqueVersion: str # Technique version}
@returns(200) {result: str, action: str, data: map{techniques: [map]}} # Techniques information

@endpoint GET /techniques/{techniqueId}/{techniqueVersion}/directives
@desc List all directives based on a version of a technique
@required {techniqueId: str # Technique ID, techniqueVersion: str # Technique version}
@returns(200) {result: str, action: str, data: map{directives: [map]}} # Techniques information

@endpoint GET /techniques/{techniqueId}/{techniqueVersion}/resources
@desc Technique's resources
@required {techniqueId: str # Technique ID, techniqueVersion: str # Technique version}
@returns(200) {result: str, action: str, data: map{resources: [map]}} # Resources information

@endpoint GET /techniques/{techniqueId}/{techniqueVersion}/revisions
@desc Technique's revisions
@required {techniqueId: str # Technique ID, techniqueVersion: str # Technique version}
@returns(200) {result: str, action: str, data: map{techniques: [map]}} # Versions information

@endgroup

@group tenants
@endpoint GET /tenants
@desc Get the list of all tenants.
@returns(200) {result: str, action: str, data: map{tenants: [map]}} # The list of tenants with their documentation information

@endpoint POST /tenants
@desc Add one or more tenants
@returns(200) {result: str, action: str, data: map{tenants: [map]}} # List of actually added/updated tenants

@endpoint DELETE /tenants
@desc Delete a list of tenants
@returns(200) {result: str, action: str, data: map{tenants: [str]}} # The list of tenants actually deleted. Already missing tenants are ignored.

@endpoint GET /tenants/{id}
@desc Get tenant details
@required {id: str(string matching ^(\p{Alnum}[\p{Alnum}-_]*)$) # Id of the tenant}
@returns(200) {result: str, action: str, data: map{tenants: [map]}} # Tenant information

@endgroup

@group usermanagement
@endpoint POST /usermanagement
@desc Add user
@required {username: str # A new username, password: str # This password will be hashed for you if the `isPreHashed` is set on false, permissions: [str] # Roles or authorizations, isPreHashed: bool(false/true) # If you want to provide hashed password set this property to `true` otherwise we will hash the plain password and store the hash}
@optional {name: str, email: str, otherInfo: map}
@returns(200) {result: str, action: str, data: map{addedUser: map{username: str, password: str, permissions: [str], name: str, email: str, otherInfo: map}}} # Updated

@endpoint POST /usermanagement/coverage/{username}
@desc Compute the role coverage
@required {username: str # Username of an user (unique and must not contain whitespace), permissions: [str] # List of roles, authz: [str] # List of authorizations}
@returns(200) {action: str, result: str, data: map{coverage: map{permissions: [str], custom: [str]}}} # Roles coverage

@endpoint GET /usermanagement/roles
@desc List all roles
@returns(200) {result: str, action: str, data: [map]} # Roles information

@endpoint PUT /usermanagement/status/activate/{username}
@desc Activate user
@required {username: str # Username of an user (unique and must not contain whitespace)}
@returns(200) {action: str, id: str, result: str, data: map{status: str}} # User was activated
@errors {500: User activation was an error}

@endpoint PUT /usermanagement/status/disable/{username}
@desc Disable user
@required {username: str # Username of an user (unique and must not contain whitespace)}
@returns(200) {action: str, id: str, result: str, data: map{status: str}} # User was disabled
@errors {500: User disabling was an error}

@endpoint POST /usermanagement/update/info/{username}
@desc Update user information
@required {username: str # Username of an user (unique and must not contain whitespace)}
@optional {name: str, email: str, otherInfo: map}
@returns(200) {result: str, action: str, data: map{updatedUser: map{name: str, email: str, otherInfo: map}}} # Updated

@endpoint POST /usermanagement/update/{username}
@desc Update user access to Rudder
@required {username: str # Username of an user (unique and must not contain whitespace), username: str # A new username or an empty string to ignore the update of username., password: str # This password will be hashed for you if the `isPreHashed` is set on false. Empty string means that no update is requested., permissions: [str] # Roles or authorizations, isPreHashed: bool(false/true) # If you want to provide hashed password set this property to `true` otherwise we will hash the plain password and store the hash}
@returns(200) {result: str, action: str, data: map{updatedUser: map{username: str, password: str, permissions: [str]}}} # Updated

@endpoint GET /usermanagement/users
@desc List all users
@returns(200) {result: str, action: str, data: map{roleListOverride: str, authenticationBackends: [str], providerProperties: map, users: [map], digest: str, tenantsEnabled: bool}} # Users information

@endpoint POST /usermanagement/users/reload
@desc Reload users
@returns(200) {result: str, action: str, data: map{reload: map{status: str}}} # Reload information

@endpoint DELETE /usermanagement/{username}
@desc Delete an user
@required {username: str # Username of an user (unique and must not contain whitespace)}
@returns(200) {result: str, action: str, data: map{deletedUser: map{username: str}}} # Deleted user

@endgroup

@group users
@endpoint GET /users
@desc List user
@returns(200) {result: str, action: str, data: [map]} # List users

@endgroup

@group validatedUsers
@endpoint POST /validatedUsers
@desc Update validated user list
@required {validatedUsers: [str] # list of user to put in validated list}
@returns(200) {result: str, action: str, data: map{username: str, isValidated: bool, userExists: bool}} # Updated

@endpoint DELETE /validatedUsers/{username}
@desc Remove an user from validated user list
@required {username: str # Username of an user (unique and must not contain whitespace)}
@returns(200) {result: str, action: str, data: str} # Removed user

@endgroup

@end
