@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Runscope API
@base https://api.runscope.com/
@version 1.0.0
@auth OAuth2
@endpoints 29
@hint download_for_search
@toc account(1), teams(3), buckets(25)

@group account
@endpoint GET /account
@desc Account Resource
@returns(200) Account owner and team information.

@endgroup

@group teams
@endpoint GET /teams/{teamId}/people
@desc Teams Resource
@required {teamId: any # Unique identifier for team}
@returns(200) List of people associated with the team.

@endpoint GET /teams/{teamId}/integrations
@desc Team integrations list
@required {teamId: any # Unique identifier for team}
@returns(200) List of integrations associated with the team.

@endpoint GET /teams/{teamId}/agents
@desc Team agents list
@required {teamId: any # Unique identifier for team}
@returns(200) List of the team’s currently connected agents.

@endgroup

@group buckets
@endpoint GET /buckets
@desc Returns a list of buckets.
@returns(200) List of buckets associated with this authenticated account.

@endpoint POST /buckets
@desc Create a new bucket
@required {NewBucket: any}
@returns(200) Bucket details.

@endpoint GET /buckets/{bucketKey}
@desc Returns a single bucket resource.
@required {bucketKey: any # Unique identifier for a bucket}
@returns(200) Bucket details.

@endpoint DELETE /buckets/{bucketKey}
@desc Delete a single bucket resource.
@required {bucketKey: any # Unique identifier for a bucket}
@returns(204) No content with no body.

@endpoint GET /buckets/{bucketKey}/messages
@desc Retrieve a list of messages in a bucket
@required {bucketKey: any # Unique identifier for a bucket}
@optional {count: any # Maxiumum number of messages to return. Default 50, max 1000., since: any # Only return messages after the given Unix timestamp, before: any # Only return messages before the given Unix timestamp}
@returns(200) List of messages in a bucket

@endpoint DELETE /buckets/{bucketKey}/messages
@desc Clear a bucket (remove all messages).
@required {bucketKey: any # Unique identifier for a bucket}
@returns(204) No content with no body.

@endpoint POST /buckets/{bucketKey}/messages
@desc Create a message
@required {bucketKey: any # Unique identifier for a bucket, NewMessage: any}
@returns(200) The response includes a list of result objects for the message(s) submitted. It will always return an array, even if only one message was created. The order of the result objects corresponds to the order of messages submitted.

@endpoint GET /buckets/{bucketKey}/errors
@desc Retrieve a list of error messages in a bucket
@required {bucketKey: any # Unique identifier for a bucket}
@optional {count: any # Maxiumum number of messages to return. Default 50, max 1000., since: any # Only return messages after the given Unix timestamp, before: any # Only return messages before the given Unix timestamp}
@returns(200) List of error messages in a bucket

@endpoint GET /buckets/{bucketKey}/messages/{messageId}
@desc Retrieve the details for a single message.
@required {bucketKey: any # Unique identifier for a bucket, messageId: any # The unique identifier for this message}
@returns(200) List of messages in a bucket

@endpoint GET /buckets/{bucketKey}/tests
@desc Returns a list of tests.
@required {bucketKey: any # Unique identifier for a bucket}
@returns(200) List of tests for this bucket

@endpoint POST /buckets/{bucketKey}/tests
@desc Create a test.
@required {bucketKey: any # Unique identifier for a bucket, NewTest: any}
@returns(200) List of tests for this bucket

@endpoint GET /buckets/{bucketKey}/tests/{testId}
@desc Retrieve the details of a given test by ID.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test}
@returns(200) Returns an object with the details of the given test.

@endpoint PUT /buckets/{bucketKey}/tests/{testId}
@desc Modify a test's name, description, default environment and its steps. To modify other individual properties of a test, make requests to the steps, environments, and schedules subresources of the test.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test}
@returns(201) Returns 201 and the updated test's JSON description if the test is successfully updated.

@endpoint DELETE /buckets/{bucketKey}/tests/{testId}
@desc Delete a test, including all steps, schedules, test-specific environments and results.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test}
@returns(204) No content with no body.

@endpoint GET /buckets/{bucketKey}/tests/{testId}/steps
@desc List test steps for a test.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test}
@returns(200) List of test steps for a test

@endpoint POST /buckets/{bucketKey}/tests/{testId}/steps
@desc Add new test step.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test, TestStep: any}
@returns(201) Details of the new test step.
@errors {400: Must send valid JSON object to create a new test step}

@endpoint PUT /buckets/{bucketKey}/tests/{testId}/steps/{stepId}
@desc Update the details of a single test step.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test, stepId: any # Unique identifier for a test step, TestStep: any}
@returns(200) List of test steps for a test
@errors {400: Unable to update template '{stepId}' for test '{testId}'}

@endpoint DELETE /buckets/{bucketKey}/tests/{testId}/steps/{stepId}
@desc Delete a step from a test.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test, stepId: any # Unique identifier for a test step}
@returns(204) No content with no body.

@endpoint GET /buckets/{bucketKey}/tests/{testId}/environments
@desc Return details of the test's environments (only those that belong to the specified test)
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test}
@returns(200) List of environments belonging to this test.

@endpoint POST /buckets/{bucketKey}/tests/{testId}/environments
@desc Create new test environment.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test, NewEnvironment: map}
@returns(201) Details of the new test environment.

@endpoint PUT /buckets/{bucketKey}/tests/{testId}/environments/{environmentId}
@desc Update the details of a test environment.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test, environmentId: any # Unique identifier for a test environment, ModifiedEnvironment: map}
@returns(201) Details of the modified test environment.

@endpoint GET /buckets/{bucketKey}/tests/{testId}/metrics
@desc Return details of the test metrics for the specified timeframe.
@required {bucketKey: any # Unique identifier for a bucket, testId: any # Unique identifier for a test}
@returns(200) List of average response times and additional performance metrics belonging to this test.

@endpoint GET /buckets/{bucketKey}/environments
@desc Returns list of shared environments for a specified bucket.
@required {bucketKey: any # Unique identifier for a bucket}
@returns(200) List of shared environments belonging to this bucket.

@endpoint POST /buckets/{bucketKey}/environments
@desc Create new shared environment.
@required {bucketKey: any # Unique identifier for a bucket, NewEnvironment: map}
@returns(201) Details of the new test environment.

@endpoint PUT /buckets/{bucketKey}/environments/{environmentId}
@desc Update the details of a shared environment.
@required {bucketKey: any # Unique identifier for a bucket, environmentId: any # Unique identifier for a test environment, ModifiedEnvironment: map}
@returns(201) Details of the modified test environment.

@endgroup

@end
