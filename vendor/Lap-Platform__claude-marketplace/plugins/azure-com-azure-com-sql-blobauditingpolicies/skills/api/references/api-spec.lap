@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2015-05-01-preview
@auth OAuth2
@endpoints 2
@toc subscriptions(2)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/auditingSettings/{blobAuditingPolicyName}
@desc Gets a database's blob auditing policy.
@required {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., serverName: any # The name of the server., databaseName: any # The name of the database for which the blob audit policy is defined., blobAuditingPolicyName: any # The name of the blob auditing policy., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@returns(200) Successfully retrieved the database blob auditing policy.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/auditingSettings/{blobAuditingPolicyName}
@desc Creates or updates a database's blob auditing policy.
@required {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., serverName: any # The name of the server., databaseName: any # The name of the database for which the blob auditing policy will be defined., blobAuditingPolicyName: any # The name of the blob auditing policy., parameters: map # The database blob auditing policy., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@returns(200) Successfully set the database blob auditing policy.
@returns(201) Successfully created the database blob auditing policy.

@end
