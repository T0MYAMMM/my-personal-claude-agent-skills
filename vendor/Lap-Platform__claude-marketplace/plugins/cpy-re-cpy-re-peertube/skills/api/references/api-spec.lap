@returns(200) {watchedWordsList: map{id: int}} # successful operation

@endpoint PUT /api/v1/watched-words/server/lists/{listId}
@desc Update server watched words
@required {listId: str # list of watched words to update}
@optional {listName: str, words: [str]}
@returns(204) successful operation

@endpoint DELETE /api/v1/watched-words/server/lists/{listId}
@desc Delete server watched words
@required {listId: str # list of watched words to delete}
@returns(204) successful operation

