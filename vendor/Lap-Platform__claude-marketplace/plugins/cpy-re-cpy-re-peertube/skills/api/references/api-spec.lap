@returns(204) successful operation

@endpoint GET /api/v1/video-channels/{channelHandle}/collaborators
@desc *List channel collaborators
@required {channelHandle: str # The video channel handle}
@returns(200) {total: int, data: [map]} # successful operation

@endpoint POST /api/v1/video-channels/{channelHandle}/collaborators/invite
@desc Invite a collaborator
@required {channelHandle: str # The video channel handle}
@optional {accountHandle: str # Local user username to invite}
@returns(200) {collaborator: map{id: int, account: any, state: map{id: int, label: str}, createdAt: str(date-time), updatedAt: str(date-time)}} # Collaborator invited

@endpoint POST /api/v1/video-channels/{channelHandle}/collaborators/{collaboratorId}/accept
@desc Accept a collaboration invitation
@required {channelHandle: str # The video channel handle, collaboratorId: int # The collaborator id}
@returns(204) Collaboration accepted

@endpoint POST /api/v1/video-channels/{channelHandle}/collaborators/{collaboratorId}/reject
@desc Reject a collaboration invitation
@required {channelHandle: str # The video channel handle, collaboratorId: int # The collaborator id}
@returns(204) Collaboration rejected

@endpoint DELETE /api/v1/video-channels/{channelHandle}/collaborators/{collaboratorId}
@desc Remove a channel collaborator
@required {channelHandle: str # The video channel handle, collaboratorId: int # The collaborator id}
@returns(204) successful operation

@endgroup

