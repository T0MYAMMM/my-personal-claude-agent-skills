@desc Get server available auto tags
@returns(200) {available: [map]} # successful operation

@endpoint GET /api/v1/watched-words/accounts/{accountName}/lists
@desc List account watched words
@required {accountName: str # account name to list watched words}
@returns(200) {total: int, data: [any]} # successful operation

@endpoint POST /api/v1/watched-words/accounts/{accountName}/lists
