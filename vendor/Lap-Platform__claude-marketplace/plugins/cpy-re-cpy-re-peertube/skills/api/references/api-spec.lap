@endpoint GET /api/v1/search/videos
@desc Search videos
@required {search: str # String to search. If the user can make a remote URI search, and the string is an URI then the PeerTube instance will fetch the remote object and add it to its database. Then, you can use the REST API to fetch the complete video information and interact with it.}
@optional {uuids: any # Find elements with specific UUIDs, searchTarget: str(local/search-index) # If the administrator enabled search index support, you can override the default search target.  **Warning**: If you choose to make an index search, PeerTube will get results from a third party service. It means the instance may not yet know the objects you fetched. If you want to load video/channel information:   * If the current user has the ability to make a remote URI search (this information is available in the config endpoint),   then reuse the search API to make a search using the object URI so PeerTube instance fetches the remote object and fill its database.   After that, you can use the classic REST API endpoints to fetch the complete object or interact with it   * If the current user doesn't have the ability to make a remote URI search, then redirect the user on the origin instance or fetch   the data from the origin instance API, start: int # Offset used to paginate results, count: int=15 # Number of items to return, skipCount: str(true/false)=false # if you don't need the `total` in the response, sort: str(name/-duration/-createdAt/-publishedAt/-views/-likes/-comments/-trending/-hot/-best), nsfw: str(true/false) # whether to include nsfw videos, if any, nsfwFlagsIncluded: int, nsfwFlagsExcluded: int, isLive: bool # whether or not the video is a live, includeScheduledLive: bool # whether or not include live that are scheduled for later, categoryOneOf: any # category id of the video (see [/videos/categories](#operation/getCategories)), licenceOneOf: any # licence id of the video (see [/videos/licences](#operation/getLicences)), languageOneOf: any # language id of the video (see [/videos/languages](#operation/getLanguages)). Use `_unknown` to filter on videos that don't have a video language, tagsOneOf: any # tag(s) of the video, tagsAllOf: any # tag(s) of the video, where all should be present in the video, isLocal: bool # **PeerTube >= 4.0** Display only local or remote objects, include: int(0/1/2/4/8/16/32) # **Only administrators and moderators can use this parameter**  Include additional videos in results (can be combined using bitwise or operator) - `0` NONE - `1` NOT_PUBLISHED_STATE - `2` BLACKLISTED - `4` BLOCKED_OWNER - `8` FILES - `16` CAPTIONS - `32` VIDEO SOURCE, hasHLSFiles: bool # **PeerTube >= 4.0** Display only videos that have HLS files, hasWebVideoFiles: bool # **PeerTube >= 6.0** Display only videos that have Web Video files, host: str # Find elements owned by this host, autoTagOneOf: any # **PeerTube >= 6.2** **Admins and moderators only** filter on videos that contain one of these automatic tags, privacyOneOf: int # **PeerTube >= 4.0** Display only videos in this specific privacy/privacies, excludeAlreadyWatched: bool # Whether or not to exclude videos that are in the user's video history, startDate: str(date-time) # Get videos that are published after this date, endDate: str(date-time) # Get videos that are published before this date, originallyPublishedStartDate: str(date-time) # Get videos that are originally published after this date, originallyPublishedEndDate: str(date-time) # Get videos that are originally published before this date, durationMin: int # Get videos that have this minimum duration, durationMax: int # Get videos that have this maximum duration}
@returns(200) {total: int, data: [any]} # successful operation
@errors {500: search index unavailable}

@endpoint GET /api/v1/search/video-channels
@desc Search channels
@required {search: str # String to search. If the user can make a remote URI search, and the string is an URI then the PeerTube instance will fetch the remote object and add it to its database. Then, you can use the REST API to fetch the complete channel information and interact with it.}
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, searchTarget: str(local/search-index) # If the administrator enabled search index support, you can override the default search target.  **Warning**: If you choose to make an index search, PeerTube will get results from a third party service. It means the instance may not yet know the objects you fetched. If you want to load video/channel information:   * If the current user has the ability to make a remote URI search (this information is available in the config endpoint),   then reuse the search API to make a search using the object URI so PeerTube instance fetches the remote object and fill its database.   After that, you can use the classic REST API endpoints to fetch the complete object or interact with it   * If the current user doesn't have the ability to make a remote URI search, then redirect the user on the origin instance or fetch   the data from the origin instance API, sort: str # Sort column, host: str # Find elements owned by this host, handles: any # Find elements with these handles}
@returns(200) {total: int, data: [any]} # successful operation
@errors {500: search index unavailable}

@endpoint GET /api/v1/search/video-playlists
@desc Search playlists
@required {search: str # String to search. If the user can make a remote URI search, and the string is an URI then the PeerTube instance will fetch the remote object and add it to its database. Then, you can use the REST API to fetch the complete playlist information and interact with it.}
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, searchTarget: str(local/search-index) # If the administrator enabled search index support, you can override the default search target.  **Warning**: If you choose to make an index search, PeerTube will get results from a third party service. It means the instance may not yet know the objects you fetched. If you want to load video/channel information:   * If the current user has the ability to make a remote URI search (this information is available in the config endpoint),   then reuse the search API to make a search using the object URI so PeerTube instance fetches the remote object and fill its database.   After that, you can use the classic REST API endpoints to fetch the complete object or interact with it   * If the current user doesn't have the ability to make a remote URI search, then redirect the user on the origin instance or fetch   the data from the origin instance API, sort: str # Sort column, host: str # Find elements owned by this host, uuids: any # Find elements with specific UUIDs}
@returns(200) {total: int, data: [any]} # successful operation
@errors {500: search index unavailable}

@endpoint GET /api/v1/blocklist/status
@desc Get block status of accounts/hosts
@optional {accounts: [str] # Check if these accounts are blocked, hosts: [str] # Check if these hosts are blocked}
@returns(200) {accounts: map, hosts: map} # successful operation

@endpoint GET /api/v1/server/blocklist/accounts
@desc List account blocks
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str # Sort column}
@returns(200) successful operation

@endpoint POST /api/v1/server/blocklist/accounts
@desc Block an account
@required {accountName: str # account to block, in the form `username@domain`}
@returns(200) successful operation
@errors {409: self-blocking forbidden}

@endpoint DELETE /api/v1/server/blocklist/accounts/{accountName}
@desc Unblock an account by its handle
@required {accountName: str # account to unblock, in the form `username@domain`}
@returns(201) successful operation
@errors {404: account or account block does not exist}

@endpoint GET /api/v1/server/blocklist/servers
@desc List server blocks
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str # Sort column}
@returns(200) successful operation

@endpoint POST /api/v1/server/blocklist/servers
@desc Block a server
@required {host: str(hostname) # server domain to block}
@returns(204) successful operation
@errors {409: self-blocking forbidden}

@endpoint DELETE /api/v1/server/blocklist/servers/{host}
@desc Unblock a server by its domain
@required {host: str(hostname) # server domain to unblock}
@returns(204) successful operation
@errors {404: account block does not exist}

@endpoint PUT /api/v1/server/redundancy/{host}
@desc Update a server redundancy policy
@required {host: str(hostname) # server domain to mirror, redundancyAllowed: bool # allow mirroring of the host's local videos}
@returns(204) successful operation
@errors {404: server is not already known}

@endpoint GET /api/v1/server/redundancy/videos
@desc List videos being mirrored
@required {target: str(my-videos/remote-videos) # direction of the mirror}
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str # Sort abuses by criteria}
@returns(200) successful operation

@endpoint POST /api/v1/server/redundancy/videos
@desc Mirror a video
@required {videoId: any # object id for the video}
@returns(204) successful operation
@errors {400: cannot mirror a local video, 404: video does not exist, 409: video is already mirrored}

@endpoint DELETE /api/v1/server/redundancy/videos/{redundancyId}
@desc Delete a mirror done on a video
@required {redundancyId: str # id of an existing redundancy on a video}
@returns(204) successful operation
@errors {404: video redundancy not found}

@endpoint GET /api/v1/server/stats
@desc Get instance stats
@returns(200) {totalUsers: num, totalDailyActiveUsers: num, totalWeeklyActiveUsers: num, totalMonthlyActiveUsers: num, totalModerators: num, totalAdmins: num, totalLocalVideos: num, totalLocalVideoViews: num, totalLocalVideoComments: num, totalLocalVideoFilesSize: num, totalVideos: num, totalVideoComments: num, totalLocalVideoChannels: num, totalLocalDailyActiveVideoChannels: num, totalLocalWeeklyActiveVideoChannels: num, totalLocalMonthlyActiveVideoChannels: num, totalLocalPlaylists: num, totalInstanceFollowers: num, totalInstanceFollowing: num, videosRedundancy: [map], totalActivityPubMessagesProcessed: num, totalActivityPubMessagesSuccesses: num, totalActivityPubMessagesErrors: num, activityPubMessagesProcessedPerSecond: num, totalActivityPubMessagesWaiting: num, averageRegistrationRequestResponseTimeMs: num, totalRegistrationRequestsProcessed: num, totalRegistrationRequests: num, averageAbuseResponseTimeMs: num, totalAbusesProcessed: num, totalAbuses: num} # successful operation

@endpoint POST /api/v1/server/logs/client
@desc Send client log
@required {message: str, url: str # URL of the current user page, level: any(error/warn)}
@optional {stackTrace: str # Stack trace of the error if there is one, userAgent: str # User agent of the web browser that sends the message, meta: str # Additional information regarding this log}
@returns(204) successful operation

@endpoint GET /api/v1/server/logs
@desc Get instance logs
@returns(200) successful operation

@endpoint GET /api/v1/server/audit-logs
@desc Get instance audit logs
@returns(200) successful operation

@endpoint GET /api/v1/plugins
@desc List plugins
@optional {pluginType: int, uninstalled: bool, start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str # Sort column}
@returns(200) {total: int, data: [any]} # successful operation

@endpoint GET /api/v1/plugins/available
@desc List available plugins
@optional {search: str, pluginType: int, currentPeerTubeEngine: str, start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str # Sort column}
@returns(200) {total: int, data: [any]} # successful operation
@errors {503: plugin index unavailable}

@endpoint POST /api/v1/plugins/install
@desc Install a plugin
@returns(204) successful operation
@errors {400: should have either `npmName` or `path` set}

@endpoint POST /api/v1/plugins/update
@desc Update a plugin
@returns(204) successful operation
@errors {400: should have either `npmName` or `path` set, 404: existing plugin not found}

@endpoint POST /api/v1/plugins/uninstall
@desc Uninstall a plugin
@required {npmName: str # name of the plugin/theme in its package.json}
@returns(204) successful operation
@errors {404: existing plugin not found}

@endpoint GET /api/v1/plugins/{npmName}
@desc Get a plugin
@required {npmName: str # name of the plugin/theme on npmjs.com or in its package.json}
@returns(200) {name: str, type: int, latestVersion: str, version: str, enabled: bool, uninstalled: bool, peertubeEngine: str, description: str, homepage: str(url), settings: map, createdAt: str(date-time), updatedAt: str(date-time)} # successful operation
@errors {404: plugin not found}

@endpoint PUT /api/v1/plugins/{npmName}/settings
@desc Set a plugin's settings
@required {npmName: str # name of the plugin/theme on npmjs.com or in its package.json}
@optional {settings: map}
@returns(204) successful operation
@errors {404: plugin not found}

@endpoint GET /api/v1/plugins/{npmName}/public-settings
@desc Get a plugin's public settings
@required {npmName: str # name of the plugin/theme on npmjs.com or in its package.json}
@returns(200) successful operation
@errors {404: plugin not found}

@endpoint GET /api/v1/plugins/{npmName}/registered-settings
@desc Get a plugin's registered settings
@required {npmName: str # name of the plugin/theme on npmjs.com or in its package.json}
@returns(200) successful operation
@errors {404: plugin not found}

@endpoint POST /api/v1/metrics/playback
@desc Create playback metrics
@required {playerMode: str(p2p-media-loader/web-video), p2pEnabled: bool, resolutionChanges: num # How many resolution changes occurred since the last metric creation, errors: num # How many errors occurred since the last metric creation, downloadedBytesP2P: num # How many bytes were downloaded with P2P since the last metric creation, downloadedBytesHTTP: num # How many bytes were downloaded with HTTP since the last metric creation, uploadedBytesP2P: num # How many bytes were uploaded with P2P since the last metric creation, videoId: any}
@optional {resolution: num # Current player video resolution, fps: num # Current player video fps, p2pPeers: num # P2P peers connected (doesn't include WebSeed peers), bufferStalled: num # How many times buffer has been stalled since the last metric creation}
@returns(204) successful operation

@endpoint POST /api/v1/runners/registration-tokens/generate
@desc Generate registration token
@returns(204) successful operation

@endpoint DELETE /api/v1/runners/registration-tokens/{registrationTokenId}
@desc Remove registration token
@required {registrationTokenId: int}
@returns(204) successful operation

@endpoint GET /api/v1/runners/registration-tokens
@desc List registration tokens
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str # Sort registration tokens by criteria}
@returns(200) {total: int, data: [any]} # successful operation

@endpoint POST /api/v1/runners/register
@desc Register a new runner
@required {registrationToken: str, name: str}
@optional {description: str}
@returns(200) {id: int, runnerToken: str} # successful operation

@endpoint POST /api/v1/runners/unregister
@desc Unregister a runner
@required {runnerToken: str}
@returns(204) successful operation

@endpoint DELETE /api/v1/runners/{runnerId}
@desc Delete a runner
@required {runnerId: int, runnerToken: str}
@returns(204) successful operation

@endpoint GET /api/v1/runners
@desc List runners
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str # Sort runners by criteria}
@returns(200) {total: int, data: [any]} # successful operation

@endpoint POST /api/v1/runners/jobs/request
@desc Request a new job
@required {runnerToken: str}
@optional {jobTypes: [str] # Filter jobs depending on their types}
@returns(200) {availableJobs: [map]} # successful operation

@endpoint POST /api/v1/runners/jobs/{jobUUID}/accept
@desc Accept job
@required {jobUUID: str(uuid), runnerToken: str}
@returns(200) {job: any} # successful operation

@endpoint POST /api/v1/runners/jobs/{jobUUID}/abort
@desc Abort job
@required {jobUUID: str(uuid), runnerToken: str, jobToken: str, reason: str # Why the runner aborts this job}
@returns(204) successful operation

@endpoint POST /api/v1/runners/jobs/{jobUUID}/update
@desc Update job
@required {jobUUID: str(uuid), runnerToken: str, jobToken: str}
@optional {progress: int # Update job progression percentage (optional), payload: any}
@returns(204) successful operation

@endpoint POST /api/v1/runners/jobs/{jobUUID}/error
@desc Post job error
@required {jobUUID: str(uuid), runnerToken: str, jobToken: str, message: str # Why the runner failed to process this job}
@returns(204) successful operation

@endpoint POST /api/v1/runners/jobs/{jobUUID}/success
@desc Post job success
@required {jobUUID: str(uuid), runnerToken: str, jobToken: str, payload: any}
@returns(204) successful operation

@endpoint GET /api/v1/runners/jobs/{jobUUID}/cancel
@desc Cancel a job
@required {jobUUID: str(uuid)}
@returns(204) successful operation

@endpoint DELETE /api/v1/runners/jobs/{jobUUID}
@desc Delete a job
@required {jobUUID: str(uuid)}
@returns(204) successful operation

@endpoint GET /api/v1/runners/jobs
@desc List jobs
@optional {start: int # Offset used to paginate results, count: int=15 # Number of items to return, sort: str(updatedAt/createdAt/priority/state/progress) # Sort runner jobs by criteria, search: str # Plain text search, applied to various parts of the model depending on endpoint, stateOneOf: [int]}
@returns(200) {total: int, data: [any]} # successful operation

@endpoint GET /api/v1/automatic-tags/policies/accounts/{accountName}/comments
@desc Get account auto tag policies on comments
@required {accountName: str # account name to get auto tag policies}
@returns(200) {review: [str]} # successful operation

@endpoint PUT /api/v1/automatic-tags/policies/accounts/{accountName}/comments
@desc Update account auto tag policies on comments
@required {accountName: str # account name to update auto tag policies}
@optional {review: [str] # Auto tags that automatically set the comment in review state}
