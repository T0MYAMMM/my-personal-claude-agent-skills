alues, or a sum of multiple values: - `0` NONE - `1` WEB - `2` EMAIL, newPluginVersion: int # Notification type. One of the following values, or a sum of multiple values: - `0` NONE - `1` WEB - `2` EMAIL, myVideoStudioEditionFinished: int # Notification type. One of the following values, or a sum of multiple values: - `0` NONE - `1` WEB - `2` EMAIL, myVideoTranscriptionGenerated: int # Notification type. One of the following values, or a sum of multiple values: - `0` NONE - `1` WEB - `2` EMAIL}
