@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2015-05-01-preview
@auth OAuth2
@common_fields {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., serverName: any # The name of the server on which the sync agent is hosted., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@endpoints 6
@toc subscriptions(6)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/syncAgents/{syncAgentName}
@desc Gets a sync agent.
@required {syncAgentName: any # The name of the sync agent.}
@returns(200) Successfully retrieved the specified sync agent.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/syncAgents/{syncAgentName}
@desc Creates or updates a sync agent.
@required {syncAgentName: any # The name of the sync agent., parameters: map # The requested sync agent resource state.}
@returns(200) Successfully updated the sync agent.
@returns(202) Creating or updating the sync agent is in progress.
@returns(201) Successfully created the sync agent.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/syncAgents/{syncAgentName}
@desc Deletes a sync agent.
@required {syncAgentName: any # The name of the sync agent.}
@returns(200) Successfully deleted the sync agent.
@returns(202) Deleting the sync agent is in progress.
@returns(204) The specified sync agent does not exist.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/syncAgents
@desc Lists sync agents in a server.
@returns(200) Successfully retrieved the list of sync agents.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/syncAgents/{syncAgentName}/generateKey
@desc Generates a sync agent key.
@required {syncAgentName: any # The name of the sync agent.}
@returns(200) Successfully generate a sync agent key.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/syncAgents/{syncAgentName}/linkedDatabases
@desc Lists databases linked to a sync agent.
@required {syncAgentName: any # The name of the sync agent.}
@returns(200) Successfully retrieved sync agent linked SQL server databases.

@end
