@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api OnSched Consumer API
@base https://sandbox-api.onsched.com/
@version v1
@auth OAuth2
@endpoints 38
@hint download_for_search
@toc consumer(38)

@endpoint GET /consumer/v1/appointments
@desc Get Appointments
@optional {locationId: str # id of business location, email: str # Filter by email address, lastname: str # Filter by lastname or part of it, phone: str # Filter by phone number or part of it, serviceId: str # Filter by service, calendarId: str # Filter by calendar, resourceId: str # Filter by resource, customerId: str # Filter by customer, serviceAllocationId: str # Filter by service allocation, startDate: str(date-time) # Format YYYY-MM-DD. Filter by on/after startDate, endDate: str(date-time) # Format YYYY-MM-DD. Filter on/before endDate, status: str # Filter by status: IN, BK, CN, RE, RS, bookedBy: str # Filter by the email of who booked, offset: int(int32) # Starting row of page, default 0, limit: int(int32) # Page limit, default 20, max 100}
@returns(200) {object: str?, url: str?, hasMore: bool, count: int(int32), total: int(int32), data: [map]?} # Success

