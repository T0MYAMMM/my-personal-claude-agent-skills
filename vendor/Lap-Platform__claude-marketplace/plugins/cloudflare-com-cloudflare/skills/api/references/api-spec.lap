@optional {ai_config: map{summarization: map{summary_type: str, text_format: str, word_limit: int}, transcription: map{keywords: [str], language: str, profanity_filter: bool}} # The AI Config allows you to customize the behavior of meeting transcriptions and summaries, live_stream_on_start: bool=False # Specifies if the meeting should start getting livestreamed on start., persist_chat: bool=False # If a meeting is set to persist_chat, meeting chat would remain for a week within the meeting space., record_on_start: bool=False # Specifies if the meeting should start getting recorded as soon as someone joins the meeting., recording_config: map{audio_config: map{channel: str, codec: str, export_file: bool}, file_name_prefix: str, live_streaming_config: map{rtmp_url: str(uri)}, max_seconds: num, realtimekit_bucket_config: map{enabled!: bool}, storage_config: map{access_key: str, auth_method: str, bucket: str, host: str, password: str, path: str, port: num, private_key: str, region: str, secret: str, type!: str, username: str}, video_config: map{codec: str, export_file: bool, height: int, watermark: map, width: int}} # Recording Configurations to be used for this meeting. This level of configs takes higher preference over App level configs on the RealtimeKit developer portal., session_keep_alive_time_in_secs: num=60 # Time in seconds, for which a session remains active, after the last participant has left the meeting., summarize_on_end: bool=False # Automatically generate summary of meetings using transcripts. Requires Transcriptions to be enabled, and can be retrieved via Webhooks or summary API., title: str # Title of the meeting}
