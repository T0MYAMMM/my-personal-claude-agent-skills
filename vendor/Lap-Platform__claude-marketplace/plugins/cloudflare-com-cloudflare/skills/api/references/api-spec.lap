@optional {x-magic-new-hc-target: bool # If true, the health check target in the response body will be presented using the new object format. Defaults to false.}
@returns(200) Delete GRE Tunnel response
@errors {4XX: Delete GRE Tunnel response failure}

@endpoint GET /accounts/{account_id}/magic/gre_tunnels/{gre_tunnel_id}
