@endpoint GET /accounts/{account_id}/abuse-reports
@desc List abuse reports
@required {account_id: str # Cloudflare Account ID}
@optional {page: int # Where in pagination to start listing abuse reports, per_page: int # How many abuse reports per page to list, sort: str # A property to sort by, followed by the order (id, cdate, domain, type, status), domain: str # Filter by domain name related to the abuse report, created_before: str # Returns reports created before the specified date, created_after: str # Returns reports created after the specified date, status: str # Filter by the status of the report., type: str # Filter by the type of the report., mitigation_status: str # Filter reports that have any mitigations in the given status.}
@returns(200) {errors: [map], messages: [map], result: map{reports: [map]}, result_info: map{count: num, page: num, per_page: num, total_count: num, total_pages: num}, success: bool} # Abuse report list successful
@errors {500: Failed to retrieve abuse reports}

@endpoint GET /accounts/{account_id}/abuse-reports/{report_id}/emails
@desc List abuse report emails
@required {account_id: str # Cloudflare Account ID, report_id: str # Abuse Report ID}
@optional {page: int # Page number to retrieve (default 1), per_page: int # Number of emails per page (default 20, max 100)}
@returns(200) {errors: [map], messages: [map], result: map{emails: [map]}, result_info: map{count: num, page: num, per_page: num, total_count: num, total_pages: num}, success: bool} # List abuse report emails successful
@errors {400: Bad request - invalid parameters or report not found, 500: Failed to list abuse report emails}

@endpoint GET /accounts/{account_id}/abuse-reports/{report_id}/mitigations
@desc List abuse report mitigations
@required {account_id: str # Cloudflare Account ID, report_id: str # Abuse Report ID}
@optional {page: int # Where in pagination to start listing abuse reports, per_page: int # How many abuse reports per page to list, sort: str(type,asc/type,desc/effective_date,asc/effective_date,desc/status,asc/status,desc/entity_type,asc/entity_type,desc) # A property to sort by, followed by the order, type: str # Filter by the type of mitigation. This filter parameter can be specified multiple times to include multiple types of mitigations in the result set, e.g. ?type=rate_limit_cache&type=legal_block., effective_before: str # Returns mitigations that were dispatched before the given date, effective_after: str # Returns mitigation that were dispatched after the given date, status: str # Filter by the status of the mitigation., entity_type: str # Filter by the type of entity the mitigation impacts.}
@returns(200) {errors: [map], messages: [map], result: map{mitigations: [map]}, result_info: map{count: num, page: num, per_page: num, total_count: num, total_pages: num}, success: bool} # List abuse report mitigations successful
@errors {500: Failed to list abuse report mitigations}

@endpoint POST /accounts/{account_id}/abuse-reports/{report_id}/mitigations/appeal
@desc Request review on mitigations
@required {account_id: str # Cloudflare Account ID, report_id: str # Abuse Report ID, appeals: [map{id!: str, reason!: str}] # List of mitigations to appeal.}
@returns(200) {errors: [map], messages: [map], result: [map], result_info: map{count: num, page: num, per_page: num, total_count: num, total_pages: num}, success: bool} # Mitigation appeals received
@errors {500: Failed to request review on delayed action.}

@endpoint GET /accounts/{account_id}/abuse-reports/{report_param}
@desc Abuse Report Details
@required {account_id: str # Cloudflare Account ID, report_param: str # Identifier of the abuse report}
@returns(200) {errors: [map], messages: [map], result: map{cdate: str, domain: str, id: str, justification: str, mitigation_summary: map{accepted_url_count: int, active_count: int, external_host_notified: bool, in_review_count: int, pending_count: int}, original_work: str, status: str, submitter: map{company: str, email: str, name: str, telephone: str}, type: str, urls: [str]}, success: bool} # Report submitted successfully
@errors {400: Report submitted with an error, 500: Report submitted with an error}

@endpoint POST /accounts/{account_id}/abuse-reports/{report_param}
@desc Submit an abuse report
@required {account_id: str # Cloudflare Account ID, report_param: str # The report type to be submitted. Example: abuse_general}
@returns(200) {abuse_rand: str, request: map{act: str}, result: str} # Report submitted successfully
@errors {400: Report submitted with an error, 500: Report submitted with an error}

