@desc Add a OAuth provider
@required {id: str(google/github/microsoft/vercel)}
@optional {client_id: str, client_secret: str, microsoft_tenant_id: str}
@returns(200) {id: str, type: str, client_id: str, client_secret: str} # The OAuth provider has been added to the project

@endpoint GET /projects/{project_id}/branches/{branch_id}/auth/oauth_providers
@desc List OAuth providers for neon auth for a branch
@returns(200) {providers: [map]} # Returns the OAuth providers for the Neon Auth

@endpoint POST /projects/{project_id}/branches/{branch_id}/auth/oauth_providers
@desc Add a OAuth provider
@required {id: str(google/github/microsoft/vercel)}
@optional {client_id: str, client_secret: str, microsoft_tenant_id: str}
@returns(200) {id: str, type: str, client_id: str, client_secret: str} # The OAuth provider has been added to the project

