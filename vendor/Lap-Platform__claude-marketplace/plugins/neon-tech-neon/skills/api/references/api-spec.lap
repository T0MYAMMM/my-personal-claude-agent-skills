@desc Get email server configuration
@returns(200) Returns the email server configuration for the Neon Auth

@endpoint PATCH /projects/{project_id}/auth/email_server
@desc Update email server configuration
@returns(200) The OAuth provider has been added to the project

@endpoint POST /projects/{project_id}/branches/{branch_id}/auth/send_test_email
@desc Send test email
@returns(200) {success: bool, error_message: str} # Response with the result of the test email send

@endpoint GET /projects/{project_id}/branches/{branch_id}/auth/email_and_password
@desc Get email and password configuration
@returns(200) {enabled: bool, email_verification_method: str, require_email_verification: bool, auto_sign_in_after_verification: bool, send_verification_email_on_sign_up: bool, send_verification_email_on_sign_in: bool, disable_sign_up: bool} # Returns the email and password configuration for Neon Auth

@endpoint PATCH /projects/{project_id}/branches/{branch_id}/auth/email_and_password
@desc Update email and password configuration
@optional {enabled: bool # Whether email and password authentication is enabled, email_verification_method: str(link/otp) # The email verification method to use. - `link`: Sends a verification link via email - `otp`: Sends a one-time password (OTP) via email, require_email_verification: bool # Whether email verification is required before users can sign in, auto_sign_in_after_verification: bool # Whether users are automatically signed in after verifying their email, send_verification_email_on_sign_up: bool # Whether to send a verification email when users sign up, send_verification_email_on_sign_in: bool # Whether to send a verification email when users sign in, disable_sign_up: bool # Whether to disable new user sign ups}
@returns(200) {enabled: bool, email_verification_method: str, require_email_verification: bool, auto_sign_in_after_verification: bool, send_verification_email_on_sign_up: bool, send_verification_email_on_sign_in: bool, disable_sign_up: bool} # The email and password configuration has been updated

@endpoint GET /projects/{project_id}/branches/{branch_id}/auth/email_provider
@desc Get email provider configuration
@returns(200) Returns the email provider configuration for the Neon Auth

@endpoint PATCH /projects/{project_id}/branches/{branch_id}/auth/email_provider
@desc Update email provider configuration
@returns(200) The email provider configuration has been updated

@endpoint DELETE /projects/{project_id}/auth/integration/{auth_provider}
@desc Delete integration with auth provider
@required {project_id: str # The Neon project ID, auth_provider: str # The authentication provider name}
@optional {delete_data: bool=False # If true, deletes the `neon_auth` schema from the database}
@returns(200) Delete the integration with the authentication provider

@endpoint GET /projects/{project_id}/connection_uri
@desc Retrieve connection URI
@required {project_id: str # The Neon project ID, database_name: str # The database name, role_name: str # The role name}
@optional {branch_id: str # The branch ID. Defaults to your project's default `branch_id` if not specified., endpoint_id: str # The endpoint ID. Defaults to the read-write `endpoint_id` associated with the `branch_id` if not specified., pooled: bool # Adds the `-pooler` option to the connection URI when set to `true`, creating a pooled connection URI.}
@returns(200) {uri: str} # Returned the connection URI

@endpoint GET /projects/{project_id}/branches/{branch_id}/auth/allow_localhost
@desc Get allow localhost
@returns(200) {allow_localhost: bool} # The allow localhost configuration

@endpoint PATCH /projects/{project_id}/branches/{branch_id}/auth/allow_localhost
@desc Update allow localhost
@required {allow_localhost: bool # Whether to allow localhost connections}
@returns(200) {allow_localhost: bool} # Updated the allow localhost configuration

@endpoint GET /projects/{project_id}/branches/{branch_id}/auth/plugins
@desc Get all plugin configurations
@returns(200) {organization: map{enabled: bool, organization_limit: int(int32), allow_user_to_create_organization: bool, creator_role: str}, email_provider: map, email_and_password: map{enabled: bool, email_verification_method: str, require_email_verification: bool, auto_sign_in_after_verification: bool, send_verification_email_on_sign_up: bool, send_verification_email_on_sign_in: bool, disable_sign_up: bool}, oauth_providers: [map], allow_localhost: bool} # Returns all plugin configurations

@endpoint PATCH /projects/{project_id}/branches/{branch_id}/auth/plugins/organization
@desc Update organization plugin configuration
@optional {enabled: bool # Whether the organization plugin is enabled, organization_limit: int(int32) # Maximum number of organizations a user can create, allow_user_to_create_organization: bool # Whether users are allowed to create organizations, creator_role: str(admin/owner) # The role assigned to the user who creates an organization}
@returns(200) {enabled: bool, organization_limit: int(int32), allow_user_to_create_organization: bool, creator_role: str} # The organization plugin configuration has been updated

@endpoint GET /projects/{project_id}/branches/{branch_id}/auth/webhooks
@desc Get webhook configuration for Neon Auth
@returns(200) {enabled: bool, webhook_url: str, enabled_events: [str], timeout_seconds: int} # Returns webhook configuration for Neon Auth

@endpoint PUT /projects/{project_id}/branches/{branch_id}/auth/webhooks
@desc Update webhook configuration for Neon Auth
@required {enabled: bool}
@optional {webhook_url: str, enabled_events: [str], timeout_seconds: int=5}
@returns(200) {enabled: bool, webhook_url: str, enabled_events: [str], timeout_seconds: int} # Returns the updated webhook configuration

@endpoint POST /projects/{project_id}/branches
@desc Create branch
@returns(201) Created a branch. An endpoint is only created if it was specified in the request.
@example_request {"branch":{"parent_id":"br-aged-salad-637688","name":"mybranch"}}

@endpoint GET /projects/{project_id}/branches
@desc List branches
@optional {search: str # Search by branch `name` or `id`. You can specify partial `name` or `id` values to filter results., sort_by: str(name/created_at/updated_at)=updated_at # Sort the branches by sort_field. If not provided, branches will be sorted by updated_at descending order, cursor: str # A cursor to use in pagination. A cursor defines your place in the data list. Include `response.pagination.next` in subsequent API calls to fetch next page of the list., sort_order: str(asc/desc)=desc # Defines the sorting order of entities., limit: int # The maximum number of records to be returned in the response}
@returns(200) Returned a list of branches for the specified project

@endpoint POST /projects/{project_id}/branch_anonymized
@desc Create anonymized branch
@returns(201) Created a branch. An endpoint is only created if it was specified in the request.

@endpoint GET /projects/{project_id}/branches/count
@desc Retrieve number of branches
@optional {search: str # Count branches matching the `name` in search query}
@returns(200) Returned a count of branches for the specified project

@endpoint GET /projects/{project_id}/branches/{branch_id}
@desc Retrieve branch details
@returns(200) Returned information about the specified branch

@endpoint DELETE /projects/{project_id}/branches/{branch_id}
@desc Delete branch
@returns(200) Deleted the specified branch
@returns(204) Returned if the branch doesn't exist or has already been deleted

@endpoint PATCH /projects/{project_id}/branches/{branch_id}
@desc Update branch
@required {branch: map{name: str, protected: bool, expires_at: str(date-time)}}
@returns(200) Updated the specified branch
@example_request {"branch":{"name":"mybranch"}}

@endpoint POST /projects/{project_id}/branches/{branch_id}/restore
@desc Restore branch
@required {project_id: str # The Neon project ID, branch_id: str # The branch ID, source_branch_id: str # The `branch_id` of the restore source branch. If `source_timestamp` and `source_lsn` are omitted, the branch will be restored to head. If `source_branch_id` is equal to the branch's id, `source_timestamp` or `source_lsn` is required.}
@optional {source_lsn: str # A Log Sequence Number (LSN) on the source branch. The branch will be restored with data from this LSN., source_timestamp: str(date-time) # A timestamp identifying a point in time on the source branch. The branch will be restored with data starting from this point in time. The timestamp must be provided in ISO 8601 format; for example: `2024-02-26T12:00:00Z`., preserve_under_name: str # If not empty, the previous state of the branch will be saved to a branch with this name. If the branch has children or the `source_branch_id` is equal to the branch id, this field is required. All existing child branches will be moved to the newly created branch under the name `preserve_under_name`.}
@returns(200) Updated the specified branch

@endpoint GET /projects/{project_id}/branches/{branch_id}/schema
@desc Retrieve database schema
@required {project_id: str # The Neon project ID, branch_id: str # The branch ID, db_name: str # Name of the database for which the schema is retrieved}
@optional {lsn: str # The Log Sequence Number (LSN) for which the schema is retrieved, timestamp: str(date-time) # The point in time for which the schema is retrieved, format: str # The format of the schema to retrieve. Possible values: - `sql` (default) - `json`}
@returns(200) {sql: str, json: map{tables: [map]}} # Schema definition

@endpoint GET /projects/{project_id}/branches/{branch_id}/compare_schema
@desc Compare database schema
@required {project_id: str # The Neon project ID, branch_id: str # The branch ID, db_name: str # Name of the database for which the schema is retrieved}
@optional {base_branch_id: str # The branch ID to compare the schema with, lsn: str # The Log Sequence Number (LSN) for which the schema is retrieved, timestamp: str(date-time) # The point in time for which the schema is retrieved, base_lsn: str # The Log Sequence Number (LSN) for the base branch schema, base_timestamp: str(date-time) # The point in time for the base branch schema}
@returns(200) {diff: str} # Difference between the schemas

@endpoint GET /projects/{project_id}/branches/{branch_id}/masking_rules
@desc Get masking rules
@returns(200) {masking_rules: [map]} # Masking rules retrieved successfully

@endpoint PATCH /projects/{project_id}/branches/{branch_id}/masking_rules
@desc Update masking rules
@required {masking_rules: [map{database_name!: str, schema_name!: str, table_name!: str, column_name!: str, masking_function: str, masking_value: str}] # List of masking rules to apply to the branch. This will replace all existing masking rules for the branch.}
@returns(200) {masking_rules: [map]} # Masking rules updated successfully

@endpoint GET /projects/{project_id}/branches/{branch_id}/anonymized_status
@desc Get anonymized branch status
@returns(200) {project_id: str, branch_id: str, state: str, status_message: str, created_at: str(date-time), updated_at: str(date-time), failed_at: str(date-time), last_run: map{started_at: str(date-time), completed_at: str(date-time), triggered_by: str(uuid), triggered_by_username: str, masked_columns: int}} # Anonymized branch status retrieved successfully

@endpoint POST /projects/{project_id}/branches/{branch_id}/anonymize
@desc Start anonymization
@returns(200) {project_id: str, branch_id: str, state: str, status_message: str, created_at: str(date-time), updated_at: str(date-time), failed_at: str(date-time), last_run: map{started_at: str(date-time), completed_at: str(date-time), triggered_by: str(uuid), triggered_by_username: str, masked_columns: int}} # Anonymization started successfully

@endpoint POST /projects/{project_id}/branches/{branch_id}/set_as_default
@desc Set branch as default
@returns(200) Updated the specified branch

@endpoint POST /projects/{project_id}/branches/{branch_id}/finalize_restore
@desc Finalize restore
@optional {name: str # used to rename the existing branch when it is replaced. if omitted, a default name is generated and used}
@returns(200) {operations: [map]} # OK

@endpoint GET /projects/{project_id}/branches/{branch_id}/endpoints
@desc List branch endpoints
@returns(200) {endpoints: [map]} # Returned a list of endpoints for the specified branch

@endpoint GET /projects/{project_id}/branches/{branch_id}/databases
@desc List databases
@returns(200) {databases: [map]} # Returned a list of databases of the specified branch

@endpoint POST /projects/{project_id}/branches/{branch_id}/databases
