@endpoint POST /projects/{project_id}/endpoints
@desc Create compute endpoint
@required {endpoint: map{branch_id!: str, region_id: str, type!: str, settings: map{pg_settings: map, pgbouncer_settings: map, preload_libraries: map}, autoscaling_limit_min_cu: num, autoscaling_limit_max_cu: num, provisioner: str, pooler_enabled: bool, pooler_mode: str, disabled: bool, passwordless_access: bool, suspend_timeout_seconds: int(int64), name: str}}
@returns(201) Created a compute endpoint
@example_request {"endpoint":{"branch_id":"br-floral-mountain-251143","type":"read_write"}}

@endpoint GET /projects/{project_id}/endpoints
