@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api DataLakeAnalyticsJobManagementClient
@version 2017-09-01-preview
@common_fields {api-version: any # Client Api Version.}
@endpoints 13
@toc jobs(8), buildJob(1), pipelines(2), recurrences(2)

@group jobs
@endpoint GET /jobs
@desc Lists the jobs, if any, associated with the specified Data Lake Analytics account. The response includes a link to the next page of results, if any.
@optional {$filter: any # OData filter. Optional., $top: any # The number of items to return. Optional., $skip: any # The number of items to skip over before returning elements. Optional., $select: any # OData Select statement. Limits the properties on each entry to just those requested, e.g. Categories?$select=CategoryName,Description. Optional., $orderby: any # OrderBy clause. One or more comma-separated expressions with an optional "asc" (the default) or "desc" depending on the order you'd like the values sorted, e.g. Categories?$orderby=CategoryName desc. Optional., $count: any # The Boolean value of true or false to request a count of the matching resources included with the resources in the response, e.g. Categories?$count=true. Optional.}
@returns(200) Successfully retrieved the list of jobs.

@endpoint PUT /jobs/{jobIdentity}
@desc Submits a job to the specified Data Lake Analytics account.
@required {jobIdentity: any # Job identifier. Uniquely identifies the job across all jobs submitted to the service., parameters: any # The parameters to submit a job.}
@returns(200) Successfully submitted the job.

@endpoint GET /jobs/{jobIdentity}
@desc Gets the job information for the specified job ID.
@required {jobIdentity: any # JobInfo ID.}
@returns(200) Successfully retrieved details of the specified job.

@endpoint PATCH /jobs/{jobIdentity}
@desc Updates the job information for the specified job ID. (Only for use internally with Scope job type.)
@required {jobIdentity: any # Job identifier. Uniquely identifies the job across all jobs submitted to the service.}
@optional {parameters: any # The parameters to update a job.}
@returns(200) Successfully updated the details of the specified job.
@returns(201) Successfully initiated an update of the specified job.
@returns(202) Successfully initiated an update of the specified job.

@endpoint GET /jobs/{jobIdentity}/GetStatistics
@desc Gets statistics of the specified job.
@required {jobIdentity: any # Job Information ID.}
@returns(200) Successfully retrieved job statistics of the specified job.

@endpoint GET /jobs/{jobIdentity}/GetDebugDataPath
@desc Gets the job debug data information specified by the job ID.
@required {jobIdentity: any # Job identifier. Uniquely identifies the job across all jobs submitted to the service.}
@returns(200) Successfully retrieved debug data paths of the specified job.

@endpoint POST /jobs/{jobIdentity}/CancelJob
@desc Cancels the running job specified by the job ID.
@required {jobIdentity: any # Job identifier. Uniquely identifies the job across all jobs submitted to the service.}
@returns(200) Successfully cancelled the job.
@returns(202) Successfully initiated the cancellation of the specified job.
@returns(204) The specified job was not found.

@endpoint POST /jobs/{jobIdentity}/YieldJob
@desc Pauses the specified job and places it back in the job queue, behind other jobs of equal or higher importance, based on priority. (Only for use internally with Scope job type.)
@required {jobIdentity: any # Job identifier. Uniquely identifies the job across all jobs submitted to the service.}
@returns(200) Successfully yielded the specified job.
@returns(202) Successfully initiated the yielding of the specified job.
@returns(204) The specified job was not found.

@endgroup

@group buildJob
@endpoint POST /buildJob
@desc Builds (compiles) the specified job in the specified Data Lake Analytics account for job correctness and validation.
@required {parameters: any # The parameters to build a job.}
@returns(200) Successfully built the job script.

@endgroup

@group pipelines
@endpoint GET /pipelines
@desc Lists all pipelines.
@optional {startDateTime: any # The start date for when to get the list of pipelines. The startDateTime and endDateTime can be no more than 30 days apart., endDateTime: any # The end date for when to get the list of pipelines. The startDateTime and endDateTime can be no more than 30 days apart.}
@returns(200) Successfully retrieved the list of pipelines.

@endpoint GET /pipelines/{pipelineIdentity}
@desc Gets the Pipeline information for the specified pipeline ID.
@required {pipelineIdentity: any # Pipeline ID.}
@optional {startDateTime: any # The start date for when to get the pipeline and aggregate its data. The startDateTime and endDateTime can be no more than 30 days apart., endDateTime: any # The end date for when to get the pipeline and aggregate its data. The startDateTime and endDateTime can be no more than 30 days apart.}
@returns(200) Successfully retrieved details of the specified pipeline.

@endgroup

@group recurrences
@endpoint GET /recurrences
@desc Lists all recurrences.
@optional {startDateTime: any # The start date for when to get the list of recurrences. The startDateTime and endDateTime can be no more than 30 days apart., endDateTime: any # The end date for when to get the list of recurrences. The startDateTime and endDateTime can be no more than 30 days apart.}
@returns(200) Successfully retrieved the list of recurrences.

@endpoint GET /recurrences/{recurrenceIdentity}
@desc Gets the recurrence information for the specified recurrence ID.
@required {recurrenceIdentity: any # Recurrence ID.}
@optional {startDateTime: any # The start date for when to get the recurrence and aggregate its data. The startDateTime and endDateTime can be no more than 30 days apart., endDateTime: any # The end date for when to get recurrence and aggregate its data. The startDateTime and endDateTime can be no more than 30 days apart.}
@returns(200) Successfully retrieved details of the specified pipeline.

@endgroup

@end
