@endpoint GET /Users/{userId}/Items/{itemId}/Intros
@desc Gets intros to play before the main media item plays.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32)} # Intros returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Users/{userId}/Items/{itemId}/LocalTrailers
@desc Gets local trailers for an item.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@returns(200) An Microsoft.AspNetCore.Mvc.OkResult containing the item's local trailers.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Users/{userId}/Items/{itemId}/Rating
@desc Deletes a user's saved personal rating for an item.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@returns(200) {Rating: num(double)?, PlayedPercentage: num(double)?, UnplayedItemCount: int(int32)?, PlaybackPositionTicks: int(int64), PlayCount: int(int32), IsFavorite: bool, Likes: bool?, LastPlayedDate: str(date-time)?, Played: bool, Key: str?, ItemId: str?} # Personal rating removed.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Users/{userId}/Items/{itemId}/Rating
@desc Updates a user's rating for an item.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@optional {likes: bool # Whether this M:Jellyfin.Api.Controllers.UserLibraryController.UpdateUserItemRating(System.Guid,System.Guid,System.Nullable{System.Boolean}) is likes.}
@returns(200) {Rating: num(double)?, PlayedPercentage: num(double)?, UnplayedItemCount: int(int32)?, PlaybackPositionTicks: int(int64), PlayCount: int(int32), IsFavorite: bool, Likes: bool?, LastPlayedDate: str(date-time)?, Played: bool, Key: str?, ItemId: str?} # Item rating updated.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Users/{userId}/Items/{itemId}/SpecialFeatures
@desc Gets special features for an item.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@returns(200) Special features returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Users/{userId}/Items/Latest
@desc Gets latest media.
@required {userId: str(uuid) # User id.}
@optional {parentId: str(uuid) # Specify this to localize the search to a specific item or folder. Omit to use the root., fields: [str] # Optional. Specify additional fields of information to return in the output., includeItemTypes: [str] # Optional. If specified, results will be filtered based on item type. This allows multiple, comma delimited., isPlayed: bool # Filter by items that are played, or not., enableImages: bool # Optional. include image information in output., imageTypeLimit: int(int32) # Optional. the max number of images to return, per image type., enableImageTypes: [str] # Optional. The image types to include in the output., enableUserData: bool # Optional. include user data., limit: int(int32)=20 # Return item limit., groupItems: bool=True # Whether or not to group items into a parent container.}
@returns(200) Latest media returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Users/{userId}/Items/Root
