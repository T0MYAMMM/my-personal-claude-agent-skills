@returns(204) Playback stop recorded.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Users
@endpoint POST /Users/{userId}/PlayedItems/{itemId}
@desc Marks an item as played for user.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@optional {datePlayed: str(date-time) # Optional. The date the item was played.}
@returns(200) {Rating: num(double)?, PlayedPercentage: num(double)?, UnplayedItemCount: int(int32)?, PlaybackPositionTicks: int(int64), PlayCount: int(int32), IsFavorite: bool, Likes: bool?, LastPlayedDate: str(date-time)?, Played: bool, Key: str?, ItemId: str?} # Item marked as played.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Users/{userId}/PlayedItems/{itemId}
@desc Marks an item as unplayed for user.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@returns(200) {Rating: num(double)?, PlayedPercentage: num(double)?, UnplayedItemCount: int(int32)?, PlaybackPositionTicks: int(int64), PlayCount: int(int32), IsFavorite: bool, Likes: bool?, LastPlayedDate: str(date-time)?, Played: bool, Key: str?, ItemId: str?} # Item marked as unplayed.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Users/{userId}/PlayingItems/{itemId}
@desc Reports that a user has begun playing an item.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@optional {mediaSourceId: str # The id of the MediaSource., audioStreamIndex: int(int32) # The audio stream index., subtitleStreamIndex: int(int32) # The subtitle stream index., playMethod: str # The play method., liveStreamId: str # The live stream id., playSessionId: str # The play session id., canSeek: bool=False # Indicates if the client can seek.}
@returns(204) Play start recorded.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Users/{userId}/PlayingItems/{itemId}
@desc Reports that a user has stopped playing an item.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@optional {mediaSourceId: str # The id of the MediaSource., nextMediaType: str # The next media type that will play., positionTicks: int(int64) # Optional. The position, in ticks, where playback stopped. 1 tick = 10000 ms., liveStreamId: str # The live stream id., playSessionId: str # The play session id.}
@returns(204) Playback stop recorded.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Users/{userId}/PlayingItems/{itemId}/Progress
@desc Reports a user's playback progress.
@required {userId: str(uuid) # User id., itemId: str(uuid) # Item id.}
@optional {mediaSourceId: str # The id of the MediaSource., positionTicks: int(int64) # Optional. The current position, in ticks. 1 tick = 10000 ms., audioStreamIndex: int(int32) # The audio stream index., subtitleStreamIndex: int(int32) # The subtitle stream index., volumeLevel: int(int32) # Scale of 0-100., playMethod: str # The play method., liveStreamId: str # The live stream id., playSessionId: str # The play session id., repeatMode: str # The repeat mode., isPaused: bool=False # Indicates if the player is paused., isMuted: bool=False # Indicates if the player is muted.}
@returns(204) Play progress recorded.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Plugins
@endpoint GET /Plugins
@desc Gets a list of currently installed plugins.
@returns(200) Installed plugins returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Plugins/{pluginId}
@desc Uninstalls a plugin.
@required {pluginId: str(uuid) # Plugin id.}
@returns(204) Plugin uninstalled.
@errors {404: Plugin not found., 401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Plugins/{pluginId}/{version}
@desc Uninstalls a plugin by version.
@required {pluginId: str(uuid) # Plugin id., version: map # Plugin version.}
@returns(204) Plugin uninstalled.
@errors {404: Plugin not found., 401: Unauthorized, 403: Forbidden}

@endpoint POST /Plugins/{pluginId}/{version}/Disable
@desc Disable a plugin.
@required {pluginId: str(uuid) # Plugin id., version: map # Plugin version.}
@returns(204) Plugin disabled.
@errors {404: Plugin not found., 401: Unauthorized, 403: Forbidden}

@endpoint POST /Plugins/{pluginId}/{version}/Enable
@desc Enables a disabled plugin.
@required {pluginId: str(uuid) # Plugin id., version: map # Plugin version.}
@returns(204) Plugin enabled.
@errors {404: Plugin not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Plugins/{pluginId}/{version}/Image
@desc Gets a plugin's image.
@required {pluginId: str(uuid) # Plugin id., version: map # Plugin version.}
@returns(200) Plugin image returned.
@errors {404: Not Found, 401: Unauthorized, 403: Forbidden}

@endpoint GET /Plugins/{pluginId}/Configuration
@desc Gets plugin configuration.
@required {pluginId: str(uuid) # Plugin id.}
@returns(200) Plugin configuration returned.
@errors {404: Plugin not found or plugin configuration not found., 401: Unauthorized, 403: Forbidden}

@endpoint POST /Plugins/{pluginId}/Configuration
@desc Updates plugin configuration.
@required {pluginId: str(uuid) # Plugin id.}
@returns(204) Plugin configuration updated.
@errors {404: Plugin not found or plugin does not have configuration., 401: Unauthorized, 403: Forbidden}

@endpoint POST /Plugins/{pluginId}/Manifest
@desc Gets a plugin's manifest.
@required {pluginId: str(uuid) # Plugin id.}
@returns(204) Plugin manifest returned.
@errors {404: Plugin not found., 401: Unauthorized, 403: Forbidden}

@endpoint POST /Plugins/SecurityInfo
@desc Updates plugin security info.
@optional {SupporterKey: str # Gets or sets the supporter key., IsMbSupporter: bool # Gets or sets a value indicating whether is mb supporter.}
@returns(204) Plugin security info updated.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group QuickConnect
@endpoint POST /QuickConnect/Activate
@desc Temporarily activates quick connect for five minutes.
@returns(204) Quick connect has been temporarily activated.
@errors {403: Quick connect is unavailable on this server., 401: Unauthorized}

@endpoint POST /QuickConnect/Authorize
@desc Authorizes a pending quick connect request.
@required {code: str # Quick connect code to authorize.}
@returns(200) Quick connect result authorized successfully.
@errors {403: Unknown user id., 401: Unauthorized}

@endpoint POST /QuickConnect/Available
@desc Enables or disables quick connect.
@optional {status: str # New MediaBrowser.Model.QuickConnect.QuickConnectState.}
@returns(204) Quick connect state set successfully.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /QuickConnect/Connect
@desc Attempts to retrieve authentication information.
@required {secret: str # Secret previously returned from the Initiate endpoint.}
@returns(200) {Authenticated: bool, Secret: str?, Code: str?, Authentication: str?, Error: str?, DateAdded: str(date-time)?} # Quick connect result returned.
@errors {404: Unknown quick connect secret.}

@endpoint POST /QuickConnect/Deauthorize
@desc Deauthorize all quick connect devices for the current user.
@returns(200) All quick connect devices were deleted.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /QuickConnect/Initiate
@desc Initiate a new quick connect request.
@returns(200) {Authenticated: bool, Secret: str?, Code: str?, Authentication: str?, Error: str?, DateAdded: str(date-time)?} # Quick connect request successfully created.
@errors {401: Quick connect is not active on this server.}

@endpoint GET /QuickConnect/Status
@desc Gets the current quick connect state.
@returns(200) Quick connect state returned.

@endgroup

@group Images
@endpoint GET /Images/Remote
@desc Gets a remote image.
@required {imageUrl: str(uri) # The image url.}
@returns(200) Remote image returned.
@errors {404: Remote image not found.}

@endgroup

@group Items
@endpoint GET /Items/{itemId}/RemoteImages
@desc Gets available remote images for an item.
@required {itemId: str(uuid) # Item Id.}
@optional {type: str # The image type., startIndex: int(int32) # Optional. The record index to start at. All items with a lower index will be dropped from the results., limit: int(int32) # Optional. The maximum number of records to return., providerName: str # Optional. The image provider to use., includeAllLanguages: bool=False # Optional. Include all languages.}
@returns(200) {Images: [map]?, TotalRecordCount: int(int32), Providers: [str]?} # Remote Images returned.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint POST /Items/{itemId}/RemoteImages/Download
@desc Downloads a remote image for an item.
@required {itemId: str(uuid) # Item Id., type: str # The image type.}
@optional {imageUrl: str # The image url.}
@returns(204) Remote image downloaded.
@errors {404: Remote image not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/RemoteImages/Providers
@desc Gets available remote image providers for an item.
@required {itemId: str(uuid) # Item Id.}
@returns(200) Returned remote image providers.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endgroup

@group ScheduledTasks
@endpoint GET /ScheduledTasks
@desc Get tasks.
@optional {isHidden: bool # Optional filter tasks that are hidden, or not., isEnabled: bool # Optional filter tasks that are enabled, or not.}
@returns(200) Scheduled tasks retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /ScheduledTasks/{taskId}
@desc Get task by id.
@required {taskId: str # Task Id.}
@returns(200) {Name: str?, State: str, CurrentProgressPercentage: num(double)?, Id: str?, LastExecutionResult: map{StartTimeUtc: str(date-time), EndTimeUtc: str(date-time), Status: str, Name: str?, Key: str?, Id: str?, ErrorMessage: str?, LongErrorMessage: str?}, Triggers: [map]?, Description: str?, Category: str?, IsHidden: bool, Key: str?} # Task retrieved.
@errors {404: Task not found., 401: Unauthorized, 403: Forbidden}

@endpoint POST /ScheduledTasks/{taskId}/Triggers
@desc Update specified task triggers.
@required {taskId: str # Task Id.}
@returns(204) Task triggers updated.
@errors {404: Task not found., 401: Unauthorized, 403: Forbidden}

@endpoint POST /ScheduledTasks/Running/{taskId}
@desc Start specified task.
@required {taskId: str # Task Id.}
@returns(204) Task started.
@errors {404: Task not found., 401: Unauthorized, 403: Forbidden}

@endpoint DELETE /ScheduledTasks/Running/{taskId}
@desc Stop specified task.
@required {taskId: str # Task Id.}
@returns(204) Task stopped.
@errors {404: Task not found., 401: Unauthorized, 403: Forbidden}

@endgroup

@group Search
@endpoint GET /Search/Hints
@desc Gets the search hint result.
@required {searchTerm: str # The search term to filter on.}
@optional {startIndex: int(int32) # Optional. The record index to start at. All items with a lower index will be dropped from the results., limit: int(int32) # Optional. The maximum number of records to return., userId: str(uuid) # Optional. Supply a user id to search within a user's library or omit to search all., includeItemTypes: [str] # If specified, only results with the specified item types are returned. This allows multiple, comma delimeted., excludeItemTypes: [str] # If specified, results with these item types are filtered out. This allows multiple, comma delimeted., mediaTypes: [str] # If specified, only results with the specified media types are returned. This allows multiple, comma delimeted., parentId: str(uuid) # If specified, only children of the parent are returned., isMovie: bool # Optional filter for movies., isSeries: bool # Optional filter for series., isNews: bool # Optional filter for news., isKids: bool # Optional filter for kids., isSports: bool # Optional filter for sports., includePeople: bool=True # Optional filter whether to include people., includeMedia: bool=True # Optional filter whether to include media., includeGenres: bool=True # Optional filter whether to include genres., includeStudios: bool=True # Optional filter whether to include studios., includeArtists: bool=True # Optional filter whether to include artists.}
@returns(200) {SearchHints: [map]?, TotalRecordCount: int(int32)} # Search hint returned.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Auth
@endpoint GET /Auth/PasswordResetProviders
@desc Get all password reset providers.
@returns(200) Password reset providers retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Auth/Providers
@desc Get all auth providers.
@returns(200) Auth providers retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Sessions
@endpoint GET /Sessions
@desc Gets a list of sessions.
@optional {controllableByUserId: str(uuid) # Filter by sessions that a given user is allowed to remote control., deviceId: str # Filter by device Id., activeWithinSeconds: int(int32) # Optional. Filter by sessions that were active in the last n seconds.}
@returns(200) List of sessions returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/Command
@desc Issues a full general command to a client.
@required {sessionId: str # The session id.}
@optional {Name: str() # This exists simply to identify a set of known commands., ControllingUserId: str(uuid), Arguments: map}
@returns(204) Full general command sent to session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/Command/{command}
@desc Issues a general command to a client.
@required {sessionId: str # The session id., command: str # The command to send.}
@returns(204) General command sent to session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/Message
@desc Issues a command to a client to display a message to the user.
@required {sessionId: str # The session id., text: str # The message test.}
@optional {header: str # The message header., timeoutMs: int(int64) # The message timeout. If omitted the user will have to confirm viewing the message.}
@returns(204) Message sent.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/Playing
@desc Instructs a session to play an item.
@required {sessionId: str # The session id., playCommand: str # The type of play command to issue (PlayNow, PlayNext, PlayLast). Clients who have not yet implemented play next and play last may play now., itemIds: [str(uuid)] # The ids of the items to play, comma delimited.}
@optional {startPositionTicks: int(int64) # The starting position of the first item.}
@returns(204) Instruction sent to session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/Playing/{command}
@desc Issues a playstate command to a client.
@required {sessionId: str # The session id., command: str # The MediaBrowser.Model.Session.PlaystateCommand.}
@optional {seekPositionTicks: int(int64) # The optional position ticks., controllingUserId: str # The optional controlling user id.}
@returns(204) Playstate command sent to session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/System/{command}
@desc Issues a system command to a client.
@required {sessionId: str # The session id., command: str # The command to send.}
@returns(204) System command sent to session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/User/{userId}
@desc Adds an additional user to a session.
@required {sessionId: str # The session id., userId: str(uuid) # The user id.}
@returns(204) User added to session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Sessions/{sessionId}/User/{userId}
@desc Removes an additional user from a session.
@required {sessionId: str # The session id., userId: str(uuid) # The user id.}
@returns(204) User removed from session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/{sessionId}/Viewing
@desc Instructs a session to browse to an item or view.
@required {sessionId: str # The session Id., itemType: str # The type of item to browse to., itemId: str # The Id of the item., itemName: str # The name of the item.}
@returns(204) Instruction sent to session.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/Capabilities
@desc Updates capabilities for a device.
@optional {id: str # The session id., playableMediaTypes: [str] # A list of playable media types, comma delimited. Audio, Video, Book, Photo., supportedCommands: [str] # A list of supported remote control commands, comma delimited., supportsMediaControl: bool=False # Determines whether media can be played remotely.., supportsSync: bool=False # Determines whether sync is supported., supportsPersistentIdentifier: bool=True # Determines whether the device supports a unique identifier.}
@returns(204) Capabilities posted.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/Capabilities/Full
@desc Updates capabilities for a device.
@optional {id: str # The session id., PlayableMediaTypes: [str] # Gets or sets the list of playable media types., SupportedCommands: [str] # Gets or sets the list of supported commands., SupportsMediaControl: bool # Gets or sets a value indicating whether session supports media control., SupportsContentUploading: bool # Gets or sets a value indicating whether session supports content uploading., MessageCallbackUrl: str # Gets or sets the message callback url., SupportsPersistentIdentifier: bool # Gets or sets a value indicating whether session supports a persistent identifier., SupportsSync: bool # Gets or sets a value indicating whether session supports sync., DeviceProfile: map{Name: str, Id: str, Identification: map{FriendlyName: str, ModelNumber: str, SerialNumber: str, ModelName: str, ModelDescription: str, ModelUrl: str, Manufacturer: str, ManufacturerUrl: str, Headers: [map]}, FriendlyName: str, Manufacturer: str, ManufacturerUrl: str, ModelName: str, ModelDescription: str, ModelNumber: str, ModelUrl: str, SerialNumber: str, EnableAlbumArtInDidl: bool, EnableSingleAlbumArtLimit: bool, EnableSingleSubtitleLimit: bool, SupportedMediaTypes: str, UserId: str, AlbumArtPn: str, MaxAlbumArtWidth: int(int32), MaxAlbumArtHeight: int(int32), MaxIconWidth: int(int32), MaxIconHeight: int(int32), MaxStreamingBitrate: int(int32), MaxStaticBitrate: int(int32), MusicStreamingTranscodingBitrate: int(int32), MaxStaticMusicBitrate: int(int32), SonyAggregationFlags: str, ProtocolInfo: str, TimelineOffsetSeconds: int(int32), RequiresPlainVideoItems: bool, RequiresPlainFolders: bool, EnableMSMediaReceiverRegistrar: bool, IgnoreTranscodeByteRangeRequests: bool, XmlRootAttributes: [map{Name: str, Value: str}], DirectPlayProfiles: [map{Container: str, AudioCodec: str, VideoCodec: str, Type: str}], TranscodingProfiles: [map{Container: str, Type: str, VideoCodec: str, AudioCodec: str, Protocol: str, EstimateContentLength: bool, EnableMpegtsM2TsMode: bool, TranscodeSeekInfo: str, CopyTimestamps: bool, Context: str, EnableSubtitlesInManifest: bool, MaxAudioChannels: str, MinSegments: int(int32), SegmentLength: int(int32), BreakOnNonKeyFrames: bool}], ContainerProfiles: [map{Type: str, Conditions: [map], Container: str}], CodecProfiles: [map{Type: str, Conditions: [map], ApplyConditions: [map], Codec: str, Container: str}], ResponseProfiles: [map{Container: str, AudioCodec: str, VideoCodec: str, Type: str, OrgPn: str, MimeType: str, Conditions: [map]}], SubtitleProfiles: [map{Format: str, Method: str, DidlMode: str, Language: str, Container: str}]} # Defines the MediaBrowser.Model.Dlna.DeviceProfile., AppStoreUrl: str # Gets or sets the app store url., IconUrl: str # Gets or sets the icon url.}
@returns(204) Capabilities updated.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/Logout
@desc Reports that a session has ended.
@returns(204) Session end reported to server.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Sessions/Viewing
@desc Reports that a session is viewing an item.
@required {itemId: str # The item id.}
@optional {sessionId: str # The session id.}
@returns(204) Session reported to server.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Startup
@endpoint POST /Startup/Complete
@desc Completes the startup wizard.
@returns(204) Startup wizard completed.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Startup/Configuration
@desc Gets the initial startup wizard configuration.
@returns(200) {UICulture: str?, MetadataCountryCode: str?, PreferredMetadataLanguage: str?} # Initial startup wizard configuration retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Startup/Configuration
@desc Sets the initial startup wizard configuration.
@optional {UICulture: str # Gets or sets UI language culture., MetadataCountryCode: str # Gets or sets the metadata country code., PreferredMetadataLanguage: str # Gets or sets the preferred language for the metadata.}
@returns(204) Configuration saved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Startup/FirstUser
@desc Gets the first user.
@returns(200) {Name: str?, Password: str?} # Initial user retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Startup/RemoteAccess
@desc Sets remote access and UPnP.
@required {EnableRemoteAccess: bool # Gets or sets a value indicating whether enable remote access., EnableAutomaticPortMapping: bool # Gets or sets a value indicating whether enable automatic port mapping.}
@returns(204) Configuration saved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Startup/User
@desc Gets the first user.
@returns(200) {Name: str?, Password: str?} # Initial user retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Startup/User
@desc Sets the user name and password.
@optional {Name: str # Gets or sets the username., Password: str # Gets or sets the user's password.}
@returns(204) Updated user name and password.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Studios
@endpoint GET /Studios
@desc Gets all studios from a given item, folder, or the entire library.
@optional {startIndex: int(int32) # Optional. The record index to start at. All items with a lower index will be dropped from the results., limit: int(int32) # Optional. The maximum number of records to return., searchTerm: str # Optional. Search term., parentId: str(uuid) # Specify this to localize the search to a specific item or folder. Omit to use the root., fields: [str] # Optional. Specify additional fields of information to return in the output., excludeItemTypes: [str] # Optional. If specified, results will be filtered out based on item type. This allows multiple, comma delimited., includeItemTypes: [str] # Optional. If specified, results will be filtered based on item type. This allows multiple, comma delimited., isFavorite: bool # Optional filter by items that are marked as favorite, or not., enableUserData: bool # Optional, include user data., imageTypeLimit: int(int32) # Optional, the max number of images to return, per image type., enableImageTypes: [str] # Optional. The image types to include in the output., userId: str(uuid) # User id., nameStartsWithOrGreater: str # Optional filter by items whose name is sorted equally or greater than a given input string., nameStartsWith: str # Optional filter by items whose name is sorted equally than a given input string., nameLessThan: str # Optional filter by items whose name is equally or lesser than a given input string., enableImages: bool=True # Optional, include image information in output., enableTotalRecordCount: bool=True # Total record count.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32)} # Studios returned.
@errors {401: Unauthorized, 403: Forbidden}

