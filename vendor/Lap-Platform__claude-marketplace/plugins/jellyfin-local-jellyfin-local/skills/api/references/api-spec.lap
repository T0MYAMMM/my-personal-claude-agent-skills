@optional {libraryContentType: str # Library content type., isNewLibrary: bool # Whether this is a new library.}
@returns(200) {MetadataSavers: [map]?, MetadataReaders: [map]?, SubtitleFetchers: [map]?, TypeOptions: [map]?} # Library options info returned.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Library
@endpoint POST /Library/Media/Updated
