@group Library
@endpoint GET /Library/VirtualFolders
@desc Gets all virtual folders.
@returns(200) Virtual folders retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Library/VirtualFolders
@desc Adds a virtual folder.
@optional {name: str # The name of the virtual folder., collectionType: str # The type of the collection., paths: [str] # The paths of the virtual folder., refreshLibrary: bool=False # Whether to refresh the library., LibraryOptions: map{EnablePhotos: bool, EnableRealtimeMonitor: bool, EnableChapterImageExtraction: bool, ExtractChapterImagesDuringLibraryScan: bool, PathInfos: [map{Path: str, NetworkPath: str}], SaveLocalMetadata: bool, EnableInternetProviders: bool, EnableAutomaticSeriesGrouping: bool, EnableEmbeddedTitles: bool, EnableEmbeddedEpisodeInfos: bool, AutomaticRefreshIntervalDays: int(int32), PreferredMetadataLanguage: str, MetadataCountryCode: str, SeasonZeroDisplayName: str, MetadataSavers: [str], DisabledLocalMetadataReaders: [str], LocalMetadataReaderOrder: [str], DisabledSubtitleFetchers: [str], SubtitleFetcherOrder: [str], SkipSubtitlesIfEmbeddedSubtitlesPresent: bool, SkipSubtitlesIfAudioTrackMatches: bool, SubtitleDownloadLanguages: [str], RequirePerfectSubtitleMatch: bool, SaveSubtitlesWithMedia: bool, TypeOptions: [map{Type: str, MetadataFetchers: [str], MetadataFetcherOrder: [str], ImageFetchers: [str], ImageFetcherOrder: [str], ImageOptions: [map]}]}}
@returns(204) Folder added.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Library/VirtualFolders
@desc Removes a virtual folder.
@optional {name: str # The name of the folder., refreshLibrary: bool=False # Whether to refresh the library.}
@returns(204) Folder removed.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Library/VirtualFolders/LibraryOptions
@desc Update library options.
@optional {Id: str(uuid) # Gets or sets the library item id., LibraryOptions: map{EnablePhotos: bool, EnableRealtimeMonitor: bool, EnableChapterImageExtraction: bool, ExtractChapterImagesDuringLibraryScan: bool, PathInfos: [map{Path: str, NetworkPath: str}], SaveLocalMetadata: bool, EnableInternetProviders: bool, EnableAutomaticSeriesGrouping: bool, EnableEmbeddedTitles: bool, EnableEmbeddedEpisodeInfos: bool, AutomaticRefreshIntervalDays: int(int32), PreferredMetadataLanguage: str, MetadataCountryCode: str, SeasonZeroDisplayName: str, MetadataSavers: [str], DisabledLocalMetadataReaders: [str], LocalMetadataReaderOrder: [str], DisabledSubtitleFetchers: [str], SubtitleFetcherOrder: [str], SkipSubtitlesIfEmbeddedSubtitlesPresent: bool, SkipSubtitlesIfAudioTrackMatches: bool, SubtitleDownloadLanguages: [str], RequirePerfectSubtitleMatch: bool, SaveSubtitlesWithMedia: bool, TypeOptions: [map{Type: str, MetadataFetchers: [str], MetadataFetcherOrder: [str], ImageFetchers: [str], ImageFetcherOrder: [str], ImageOptions: [map]}]}}
@returns(204) Library updated.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Library/VirtualFolders/Name
@desc Renames a virtual folder.
@optional {name: str # The name of the virtual folder., newName: str # The new name., refreshLibrary: bool=False # Whether to refresh the library.}
@returns(204) Folder renamed.
@errors {404: Library doesn't exist., 409: Library already exists., 401: Unauthorized, 403: Forbidden}

@endpoint POST /Library/VirtualFolders/Paths
@desc Add a media path to a library.
@required {Name: str # Gets or sets the name of the library.}
@optional {refreshLibrary: bool=False # Whether to refresh the library., Path: str # Gets or sets the path to add., PathInfo: map{Path: str, NetworkPath: str}}
@returns(204) Media path added.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Library/VirtualFolders/Paths
@desc Remove a media path.
@optional {name: str # The name of the library., path: str # The path to remove., refreshLibrary: bool=False # Whether to refresh the library.}
@returns(204) Media path removed.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Library/VirtualFolders/Paths/Update
@desc Updates a media path.
@optional {name: str # The name of the library., Path: str, NetworkPath: str}
@returns(204) Media path updated.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

