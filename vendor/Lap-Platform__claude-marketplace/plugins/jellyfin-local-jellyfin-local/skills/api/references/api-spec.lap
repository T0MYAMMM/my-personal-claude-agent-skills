@desc Gets a user's notifications.
@required {userId: str}
@returns(200) {Notifications: [map]?, TotalRecordCount: int(int32)} # Notifications returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Notifications/{userId}/Read
@desc Sets notifications as read.
@required {userId: str}
@returns(204) Notifications set as read.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Notifications/{userId}/Summary
@desc Gets a user's notification summary.
@required {userId: str}
@returns(200) {UnreadCount: int(int32), MaxUnreadNotificationLevel: str} # Summary of user's notifications returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Notifications/{userId}/Unread
@desc Sets notifications as unread.
@required {userId: str}
@returns(204) Notifications set as unread.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Notifications/Admin
@desc Sends a notification to all admins.
@optional {url: str # The URL of the notification., level: str # The level of the notification., name: str= # The name of the notification., description: str= # The description of the notification.}
@returns(204) Notification sent.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Notifications/Services
@desc Gets notification services.
@returns(200) All notification services returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Notifications/Types
@desc Gets notification types.
@returns(200) All notification types returned.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Packages
@endpoint GET /Packages
@desc Gets available packages.
@returns(200) Available packages returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Packages/{name}
@desc Gets a package by name or assembly GUID.
@required {name: str # The name of the package.}
@optional {assemblyGuid: str(uuid) # The GUID of the associated assembly.}
@returns(200) {name: str?, description: str?, overview: str?, owner: str?, category: str?, guid: str?, versions: [map]?, imageUrl: str?} # Package retrieved.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Packages/Installed/{name}
@desc Installs a package.
@required {name: str # Package name.}
@optional {assemblyGuid: str(uuid) # GUID of the associated assembly., version: str # Optional version. Defaults to latest version., repositoryUrl: str # Optional. Specify the repository to install from.}
@returns(204) Package found.
@errors {404: Package not found., 401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Packages/Installing/{packageId}
@desc Cancels a package installation.
@required {packageId: str(uuid) # Installation Id.}
@returns(204) Installation cancelled.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Repositories
@endpoint GET /Repositories
@desc Gets all package repositories.
@returns(200) Package repositories returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Repositories
@desc Sets the enabled and existing package repositories.
@returns(204) Package repositories saved.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Persons
@endpoint GET /Persons
@desc Gets all persons.
@optional {limit: int(int32) # Optional. The maximum number of records to return., searchTerm: str # The search term., fields: [str] # Optional. Specify additional fields of information to return in the output., filters: [str] # Optional. Specify additional filters to apply., isFavorite: bool # Optional filter by items that are marked as favorite, or not. userId is required., enableUserData: bool # Optional, include user data., imageTypeLimit: int(int32) # Optional, the max number of images to return, per image type., enableImageTypes: [str] # Optional. The image types to include in the output., excludePersonTypes: [str] # Optional. If specified results will be filtered to exclude those containing the specified PersonType. Allows multiple, comma-delimited., personTypes: [str] # Optional. If specified results will be filtered to include only those containing the specified PersonType. Allows multiple, comma-delimited., appearsInItemId: str(uuid) # Optional. If specified, person results will be filtered on items related to said persons., userId: str(uuid) # User id., enableImages: bool=True # Optional, include image information in output.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32)} # Persons returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Persons/{name}
