@errors {401: Unauthorized, 403: Forbidden}

@endpoint POST /Library/Movies/Updated
@desc Reports that new movies have been added by an external source.
@optional {tmdbId: str # The tmdbId., imdbId: str # The imdbId.}
@returns(204) Report success.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Library/PhysicalPaths
@desc Gets a list of physical paths from virtual folders.
@returns(200) Physical paths returned.
@errors {401: Unauthorized, 403: Forbidden}

