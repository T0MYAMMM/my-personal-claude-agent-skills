@returns(204) Item updated.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint DELETE /Items/{itemId}
@desc Deletes an item from the library and filesystem.
@required {itemId: str(uuid) # The item id.}
@returns(204) Item deleted.
@errors {401: Unauthorized access., 403: Forbidden}

@endpoint POST /Items/{itemId}/ContentType
@desc Updates an item's content type.
@required {itemId: str(uuid) # The item id.}
@optional {contentType: str # The content type of the item.}
@returns(204) Item content type updated.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/MetadataEditor
@desc Gets metadata editor info for an item.
@required {itemId: str(uuid) # The item id.}
@returns(200) {ParentalRatingOptions: [map]?, Countries: [map]?, Cultures: [map]?, ExternalIdInfos: [map]?, ContentType: str?, ContentTypeOptions: [map]?} # Item metadata editor returned.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endgroup

@group Albums
@endpoint GET /Albums/{itemId}/Similar
@desc Gets similar items.
@required {itemId: str(uuid) # The item id.}
@optional {excludeArtistIds: [str(uuid)] # Exclude artist ids., userId: str(uuid) # Optional. Filter by user id, and attach user data., limit: int(int32) # Optional. The maximum number of records to return., fields: [str] # Optional. Specify additional fields of information to return in the output. This allows multiple, comma delimited. Options: Budget, Chapters, DateCreated, Genres, HomePageUrl, IndexOptions, MediaStreams, Overview, ParentId, Path, People, ProviderIds, PrimaryImageAspectRatio, Revenue, SortName, Studios, Taglines, TrailerUrls.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32)} # Similar items returned.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Artists
@endpoint GET /Artists/{itemId}/Similar
@desc Gets similar items.
@required {itemId: str(uuid) # The item id.}
@optional {excludeArtistIds: [str(uuid)] # Exclude artist ids., userId: str(uuid) # Optional. Filter by user id, and attach user data., limit: int(int32) # Optional. The maximum number of records to return., fields: [str] # Optional. Specify additional fields of information to return in the output. This allows multiple, comma delimited. Options: Budget, Chapters, DateCreated, Genres, HomePageUrl, IndexOptions, MediaStreams, Overview, ParentId, Path, People, ProviderIds, PrimaryImageAspectRatio, Revenue, SortName, Studios, Taglines, TrailerUrls.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32)} # Similar items returned.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

@group Items
@endpoint GET /Items/{itemId}/Ancestors
@desc Gets all parents of an item.
@required {itemId: str(uuid) # The item id.}
@optional {userId: str(uuid) # Optional. Filter by user id, and attach user data.}
@returns(200) Item parents returned.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/CriticReviews
@desc Gets critic review for an item.
@required {itemId: str}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32)} # Critic reviews returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/Download
@desc Downloads item media.
@required {itemId: str(uuid) # The item id.}
@returns(200) Media downloaded.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/File
@desc Get the original file of an item.
@required {itemId: str(uuid) # The item id.}
@returns(200) File stream returned.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/Similar
@desc Gets similar items.
@required {itemId: str(uuid) # The item id.}
@optional {excludeArtistIds: [str(uuid)] # Exclude artist ids., userId: str(uuid) # Optional. Filter by user id, and attach user data., limit: int(int32) # Optional. The maximum number of records to return., fields: [str] # Optional. Specify additional fields of information to return in the output. This allows multiple, comma delimited. Options: Budget, Chapters, DateCreated, Genres, HomePageUrl, IndexOptions, MediaStreams, Overview, ParentId, Path, People, ProviderIds, PrimaryImageAspectRatio, Revenue, SortName, Studios, Taglines, TrailerUrls.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32)} # Similar items returned.
@errors {401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/ThemeMedia
@desc Get theme songs and videos for an item.
@required {itemId: str(uuid) # The item id.}
@optional {userId: str(uuid) # Optional. Filter by user id, and attach user data., inheritFromParent: bool=False # Optional. Determines whether or not parent items should be searched for theme media.}
@returns(200) {ThemeVideosResult: map{Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32), OwnerId: str(uuid)}, ThemeSongsResult: map{Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32), OwnerId: str(uuid)}, SoundtrackSongsResult: map{Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32), OwnerId: str(uuid)}} # Theme songs and videos returned.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/ThemeSongs
@desc Get theme songs for an item.
@required {itemId: str(uuid) # The item id.}
@optional {userId: str(uuid) # Optional. Filter by user id, and attach user data., inheritFromParent: bool=False # Optional. Determines whether or not parent items should be searched for theme media.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32), OwnerId: str(uuid)} # Theme songs returned.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/{itemId}/ThemeVideos
@desc Get theme videos for an item.
@required {itemId: str(uuid) # The item id.}
@optional {userId: str(uuid) # Optional. Filter by user id, and attach user data., inheritFromParent: bool=False # Optional. Determines whether or not parent items should be searched for theme media.}
@returns(200) {Items: [map]?, TotalRecordCount: int(int32), StartIndex: int(int32), OwnerId: str(uuid)} # Theme videos returned.
@errors {404: Item not found., 401: Unauthorized, 403: Forbidden}

@endpoint GET /Items/Counts
@desc Get item counts.
@optional {userId: str(uuid) # Optional. Get counts from a specific user's library., isFavorite: bool # Optional. Get counts of favorite items.}
@returns(200) {MovieCount: int(int32), SeriesCount: int(int32), EpisodeCount: int(int32), ArtistCount: int(int32), ProgramCount: int(int32), TrailerCount: int(int32), SongCount: int(int32), AlbumCount: int(int32), MusicVideoCount: int(int32), BoxSetCount: int(int32), BookCount: int(int32), ItemCount: int(int32)} # Item counts returned.
@errors {401: Unauthorized, 403: Forbidden}

@endgroup

