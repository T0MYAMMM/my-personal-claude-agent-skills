@endgroup

@group listWebsiteCertificateAuthorities
@endpoint POST /listWebsiteCertificateAuthorities
@desc Retrieves a list of certificate authorities added for the current account and Region.
@required {FleetArn: str}
@optional {MaxResults: int, NextToken: str}
@returns(200) {WebsiteCertificateAuthorities: [WebsiteCaSummary]?, NextToken: str?}

@endgroup

@group restoreDomainAccess
@endpoint POST /restoreDomainAccess
@desc Moves a domain to ACTIVE status if it was in the INACTIVE status.
@required {FleetArn: str, DomainName: str}

@endgroup

@group revokeDomainAccess
@endpoint POST /revokeDomainAccess
@desc Moves a domain to INACTIVE status if it was in the ACTIVE status.
@required {FleetArn: str, DomainName: str}

@endgroup

@group signOutUser
@endpoint POST /signOutUser
@desc Signs the user out from all of their devices. The user can sign in again if they have valid credentials.
@required {FleetArn: str, Username: str}

@endgroup

@group tags
@endpoint POST /tags/{ResourceArn}
@desc Adds or overwrites one or more tags for the specified resource, such as a fleet. Each tag consists of a key and an optional value. If a resource already has a tag with the same key, this operation updates its value.
@required {ResourceArn: str, Tags: map<str,str>}

@endpoint DELETE /tags/{ResourceArn}
@desc Removes one or more tags from the specified resource.
@required {ResourceArn: str, tagKeys: [str]}

@endgroup

