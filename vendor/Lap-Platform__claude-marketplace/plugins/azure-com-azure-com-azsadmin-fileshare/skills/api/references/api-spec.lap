@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api FabricAdminClient
@base https://management.azure.com
@version 2016-05-01
@auth OAuth2
@endpoints 2
@toc subscriptions(2)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Fabric.Admin/fabricLocations/{location}/fileShares/{fileShare}
@desc Returns the requested fabric file share.
@required {fileShare: any # Fabric file share name.}
@returns(200) OK
@errors {404: NOT FOUND}

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Fabric.Admin/fabricLocations/{location}/fileShares
@desc Returns a list of all fabric file shares at a certain location.
@returns(200) OK
@errors {404: NOT FOUND}

@end
