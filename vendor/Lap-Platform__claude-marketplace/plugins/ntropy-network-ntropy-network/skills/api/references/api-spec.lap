@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Ntropy Transaction API v1
@base https://api.ntropy.network
@auth ApiKey key in header
@endpoints 10
@toc classifier(7), types(1), health(1), performance(1)

@group classifier
@endpoint POST /classifier/consumer/batch
@desc Classify a batch of transactions.
@returns(202) {status: str, updated_at: str, id: str, progress: int, results: [map]} # Started a batch classification job.
@errors {404: Not found., 400: Bad request., 500: Internal server error.}

@endpoint GET /classifier/consumer/batch/{id}
@desc Get a batch of consumer transaction classification results.
@required {id: str # (Required) Batch id.}
@returns(200) {status: str, updated_at: str, id: str, progress: int, results: [map]} # Returned a batch of consumer transaction classification results.
@errors {404: Not found, 500: Internal server error}

@endpoint POST /classifier/consumer
@desc Classify a consumer transaction.
@required {transaction: map, user: map, device: map}
@returns(200) {transaction_id: str, labels: [str], rating: map{value: num, reviews: int}, contact: map{phone: str, email: str}, location: map{lat: num, lon: num, address: str, city: str, postal_code: str, country: str}, logo: str, website: str, merchant: str, person: str} # Classified consumer transaction.
@errors {400: Bad request.}

@endpoint POST /classifier/business/batch
@desc Classify a batch of business transactions.
@returns(202) {status: str, updated_at: str, id: str, progress: int, results: [map]} # Started a batch classification job.
@errors {404: Not found., 400: Bad request., 500: Internal server error.}

@endpoint GET /classifier/business/batch/{id}
@desc Get a batch of business transaction classification results.
@required {id: str # (Required) Batch id.}
@returns(200) {status: str, updated_at: str, id: str, progress: int, results: [map]} # Returned a batch of business transaction classification results.
@errors {500: Internal server error., 404: Not found.}

@endpoint POST /classifier/business
@desc Classify a business transaction.
@required {transaction: map, business: map, cardholder: map}
@returns(200) {transaction_id: str, logo: str, website: str, merchant: str, labels: [str]} # Classified a business transaction.
@errors {400: Bad request.}

@endpoint POST /classifier/report
@desc Report a wrongly classified transaction.
@required {transaction_id: str}
@returns(201) Reporting a transaction.

@endgroup

@group types
@endpoint GET /types
@desc Get dictionary of type values.
@returns(200) {moto_eci_code: [str], pan_entry_mode_auth: [str], pan_entry_mode_capture: [str]} # Received dictionary of type values.

@endgroup

@group health
@endpoint GET /health
@desc Check API health.
@returns(200) Received the API health info.

@endgroup

@group performance
@endpoint GET /performance
@desc Check the Transaction API performance report.
@returns(200) Received the Transaction API performance report.

@endgroup

@end
