@desc Update an Amazon SageMaker Model Card.  You cannot update both model card content and model card status in a single call.
@required {ModelCardName: str}
@optional {Content: str, ModelCardStatus: str}
@returns(200) {ModelCardArn: str}

@endpoint POST /
@desc Updates a versioned model.
