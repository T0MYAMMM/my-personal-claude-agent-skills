@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2017-10-01-preview
@auth OAuth2
@endpoints 1
@toc subscriptions(1)

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/tdeCertificates
@desc Creates a TDE certificate for a given server.
@required {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., managedInstanceName: any # The name of the managed instance., parameters: map # The requested TDE certificate to be created or updated., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@returns(200) Successfully created the TDE certificate.
@returns(202) Accepted

@end
