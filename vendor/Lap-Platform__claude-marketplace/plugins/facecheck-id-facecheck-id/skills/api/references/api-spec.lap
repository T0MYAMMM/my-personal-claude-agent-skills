@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Facial Recognition Reverse Image Face Search API
@version v1.02
@auth ApiKey Authorization in header
@endpoints 4
@toc api(4)

@endpoint POST /api/upload_pic
@returns(200) {id_search: str?, message: str?, progress: int(int32)?, error: str?, code: str?, output: map{items: [map]?, tookSeconds: num(double)?, tookSecondsDownload: num(double)?, tookSecondsQueue: num(double)?, searchedFaces: int(int64)?, freeRam: num(double)?, demo: bool?, face_per_sec: int(int32)?, performance: str?, max_score: int(int32), images_in_bundle: int(int32), scaned_till_index: int(int64), type: int(int32), hasItems: bool}, input: [map]?, facemon_status: str?, facemon_last_scann: int(int64)?, was_updated: bool, hasEmptyImages: bool, new_seen_count: int(int32)} # OK

@endpoint POST /api/delete_pic
@desc Remove an image from a search request
@optional {id_search: str, id_pic: str}
@returns(200) {id_search: str?, message: str?, progress: int(int32)?, error: str?, code: str?, output: map{items: [map]?, tookSeconds: num(double)?, tookSecondsDownload: num(double)?, tookSecondsQueue: num(double)?, searchedFaces: int(int64)?, freeRam: num(double)?, demo: bool?, face_per_sec: int(int32)?, performance: str?, max_score: int(int32), images_in_bundle: int(int32), scaned_till_index: int(int64), type: int(int32), hasItems: bool}, input: [map]?, facemon_status: str?, facemon_last_scann: int(int64)?, was_updated: bool, hasEmptyImages: bool, new_seen_count: int(int32)} # OK

@endpoint POST /api/info
@desc Returns remaining search credits, search engine online status, and number of indexed faces
@returns(200) {faces: int(int64)?, is_online: bool, remaining_credits: int(int32), has_credits_to_search: bool} # OK

@endpoint POST /api/search
@optional {id_search: str, with_progress: bool # true = return imediately with a progress. False waits until search is finished., id_captcha: str # captcha is not used, status_only: bool # true = don't submit a new search, demo: bool # true = searches only the first 100,000 faces, good for testing/debugging, shady_only: bool}
@returns(200) {id_search: str?, message: str?, progress: int(int32)?, error: str?, code: str?, output: map{items: [map]?, tookSeconds: num(double)?, tookSecondsDownload: num(double)?, tookSecondsQueue: num(double)?, searchedFaces: int(int64)?, freeRam: num(double)?, demo: bool?, face_per_sec: int(int32)?, performance: str?, max_score: int(int32), images_in_bundle: int(int32), scaned_till_index: int(int64), type: int(int32), hasItems: bool}, input: [map]?, facemon_status: str?, facemon_last_scann: int(int64)?, was_updated: bool, hasEmptyImages: bool, new_seen_count: int(int32)} # OK

@end
