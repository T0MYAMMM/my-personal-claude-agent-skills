@optional {Idempotency-Key: str # A unique identifier for the message with a maximum of 64 characters (we recommend a UUID)., applicationInfo: map{adyenLibrary: map, adyenPaymentSource: map, externalPlatform: map, merchantApplication: map, merchantDevice: map, shopperInteractionDevice: map}, enhancedSchemeData: map{airline: map, levelTwoThree: map}, reference: str # Your reference for the cancel request. Maximum length: 80 characters.}
