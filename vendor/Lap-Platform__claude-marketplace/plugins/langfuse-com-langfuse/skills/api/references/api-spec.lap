@returns(200) {schemas: [str], totalResults: int, Resources: [map]}
@errors {400, 401, 403, 404, 405}

@endpoint GET /api/public/scim/Users
@desc List users in the organization (requires organization-scoped API key)
@optional {filter: str # Filter expression (e.g. userName eq "value"), startIndex: int # 1-based index of the first result to return (default 1), count: int # Maximum number of results to return (default 100)}
@returns(200) {schemas: [str], totalResults: int, startIndex: int, itemsPerPage: int, Resources: [map]}
@errors {400, 401, 403, 404, 405}

