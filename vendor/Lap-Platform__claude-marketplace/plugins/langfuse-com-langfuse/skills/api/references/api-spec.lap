@errors {400, 401, 403, 404, 405}

@endpoint PUT /api/public/projects/{projectId}
@desc Update a project by ID (requires organization-scoped API key).
@required {projectId: str, name: str}
@optional {metadata: map # Optional metadata for the project, retention: int # Number of days to retain data. Must be 0 or at least 3 days. Requires data-retention entitlement for non-zero values. Optional. Will retain existing retention setting if omitted.}
@returns(200) {id: str, name: str, organization: map{id: str, name: str}, metadata: map, retentionDays: int?}
@errors {400, 401, 403, 404, 405}

@endpoint DELETE /api/public/projects/{projectId}
@desc Delete a project by ID (requires organization-scoped API key). Project deletion is processed asynchronously.
