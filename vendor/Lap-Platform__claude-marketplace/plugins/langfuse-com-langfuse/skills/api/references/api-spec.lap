@endpoint GET /api/public/projects/{projectId}/apiKeys
@desc Get all API keys for a project (requires organization-scoped API key)
@required {projectId: str}
@returns(200) {apiKeys: [map]}
@errors {400, 401, 403, 404, 405}

@endpoint POST /api/public/projects/{projectId}/apiKeys
@desc Create a new API key for a project (requires organization-scoped API key)
@required {projectId: str}
@optional {note: str # Optional note for the API key, publicKey: str # Optional predefined public key. Must start with 'pk-lf-'. If provided, secretKey must also be provided., secretKey: str # Optional predefined secret key. Must start with 'sk-lf-'. If provided, publicKey must also be provided.}
@returns(200) {id: str, createdAt: str(date-time), publicKey: str, secretKey: str, displaySecretKey: str, note: str?}
@errors {400, 401, 403, 404, 405}

@endpoint DELETE /api/public/projects/{projectId}/apiKeys/{apiKeyId}
