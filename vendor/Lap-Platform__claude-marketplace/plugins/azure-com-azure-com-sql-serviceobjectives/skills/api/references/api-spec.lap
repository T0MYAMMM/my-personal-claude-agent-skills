@auth OAuth2
@endpoints 2
@toc subscriptions(2)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/serviceObjectives/{serviceObjectiveName}
@desc Gets a database service objective.
@required {serverName: any # The name of the server., serviceObjectiveName: any # The name of the service objective to retrieve.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/serviceObjectives
@desc Returns database service objectives.
