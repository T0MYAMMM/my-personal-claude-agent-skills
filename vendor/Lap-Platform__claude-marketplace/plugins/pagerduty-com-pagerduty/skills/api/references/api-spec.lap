:300,"pagerduty_automation_actions":[{"action_id":"01CSBCGJXMG7ABIJZKPD8P9RCL","trigger_types":["alert_suspended"]}]}},{"label":"Never bother the on-call for info-level events outside of work hours","id":"cd770384","conditions":[{"expression":"event.severity matches 'info' and not (now in Mon,Tue,Wed,Thu,Fri 09:00:00 to 17:00:00 America/Los_Angeles)"}],"actions":{"suppress":true}}]}],"catch_all":{"actions":{"suppress":true},"incident_custom_field_updates":[{"id":"PEXCK89","value":"#general-incident-notifications"}]}}}

