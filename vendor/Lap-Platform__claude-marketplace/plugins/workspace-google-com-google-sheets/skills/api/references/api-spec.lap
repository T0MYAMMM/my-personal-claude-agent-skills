@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Google Sheets API
@base https://sheets.googleapis.com/
@version v4
@auth OAuth2 | OAuth2
@common_fields {spreadsheetId: str # The ID of the spreadsheet. This field is read-only.}
@endpoints 17
@toc spreadsheets(17)

@endpoint POST /v4/spreadsheets
@desc Creates a spreadsheet, returning the newly created spreadsheet.
@optional {dataSourceSchedules: [map{dailySchedule: map{startTime: map}, enabled: bool, monthlySchedule: map{daysOfMonth: [int(int32)], startTime: map}, nextRun: map{endTime: str(google-datetime), startTime: str(google-datetime)}, refreshScope: str, weeklySchedule: map{daysOfWeek: [str], startTime: map}}] # Output only. A list of data source refresh schedules., dataSources: [map{calculatedColumns: [map{formula: str, reference: map}], dataSourceId: str, sheetId: int(int32), spec: map{bigQuery: map, parameters: [map]}}] # A list of external data sources connected with the spreadsheet., developerMetadata: [map{location: map{dimensionRange: map, locationType: str, sheetId: int(int32), spreadsheet: bool}, metadataId: int(int32), metadataKey: str, metadataValue: str, visibility: str}] # The developer metadata associated with a spreadsheet., namedRanges: [map{name: str, namedRangeId: str, range: map{endColumnIndex: int(int32), endRowIndex: int(int32), sheetId: int(int32), startColumnIndex: int(int32), startRowIndex: int(int32)}}] # The named ranges defined in a spreadsheet., properties: map{autoRecalc: str, defaultFormat: map{backgroundColor: map, backgroundColorStyle: map, borders: map, horizontalAlignment: str, hyperlinkDisplayType: str, numberFormat: map, padding: map, textDirection: str, textFormat: map, textRotation: map, verticalAlignment: str, wrapStrategy: str}, iterativeCalculationSettings: map{convergenceThreshold: num(double), maxIterations: int(int32)}, locale: str, spreadsheetTheme: map{primaryFontFamily: str, themeColors: [map]}, timeZone: str, title: str} # Properties of a spreadsheet., sheets: [map{bandedRanges: [map{bandedRangeId: int(int32), columnProperties: map, range: map, rowProperties: map}], basicFilter: map{criteria: map, filterSpecs: [map], range: map, sortSpecs: [map]}, charts: [map{border: map, chartId: int(int32), position: map, spec: map}], columnGroups: [map{collapsed: bool, depth: int(int32), range: map}], conditionalFormats: [map{booleanRule: map, gradientRule: map, ranges: [map]}], data: [map{columnMetadata: [map], rowData: [map], rowMetadata: [map], startColumn: int(int32), startRow: int(int32)}], developerMetadata: [map{location: map, metadataId: int(int32), metadataKey: str, metadataValue: str, visibility: str}], filterViews: [map{criteria: map, filterSpecs: [map], filterViewId: int(int32), namedRangeId: str, range: map, sortSpecs: [map], title: str}], merges: [map{endColumnIndex: int(int32), endRowIndex: int(int32), sheetId: int(int32), startColumnIndex: int(int32), startRowIndex: int(int32)}], properties: map{dataSourceSheetProperties: map, gridProperties: map, hidden: bool, index: int(int32), rightToLeft: bool, sheetId: int(int32), sheetType: str, tabColor: map, tabColorStyle: map, title: str}, protectedRanges: [map{description: str, editors: map, namedRangeId: str, protectedRangeId: int(int32), range: map, requestingUserCanEdit: bool, unprotectedRanges: [map], warningOnly: bool}], rowGroups: [map{collapsed: bool, depth: int(int32), range: map}], slicers: [map{position: map, slicerId: int(int32), spec: map}]}] # The sheets that are part of a spreadsheet., spreadsheetUrl: str # The url of the spreadsheet. This field is read-only.}
@returns(200) {dataSourceSchedules: [map], dataSources: [map], developerMetadata: [map], namedRanges: [map], properties: map{autoRecalc: str, defaultFormat: map{backgroundColor: map{alpha: num(float), blue: num(float), green: num(float), red: num(float)}, backgroundColorStyle: map{rgbColor: map, themeColor: str}, borders: map{bottom: map, left: map, right: map, top: map}, horizontalAlignment: str, hyperlinkDisplayType: str, numberFormat: map{pattern: str, type: str}, padding: map{bottom: int(int32), left: int(int32), right: int(int32), top: int(int32)}, textDirection: str, textFormat: map{bold: bool, fontFamily: str, fontSize: int(int32), foregroundColor: map, foregroundColorStyle: map, italic: bool, link: map, strikethrough: bool, underline: bool}, textRotation: map{angle: int(int32), vertical: bool}, verticalAlignment: str, wrapStrategy: str}, iterativeCalculationSettings: map{convergenceThreshold: num(double), maxIterations: int(int32)}, locale: str, spreadsheetTheme: map{primaryFontFamily: str, themeColors: [map]}, timeZone: str, title: str}, sheets: [map], spreadsheetId: str, spreadsheetUrl: str} # Successful response

@endpoint GET /v4/spreadsheets/{spreadsheetId}
@desc Returns the spreadsheet at the given ID. The caller must specify the spreadsheet ID. By default, data within grids is not returned. You can include grid data in one of 2 ways: * Specify a [field mask](https://developers.google.com/sheets/api/guides/field-masks) listing your desired fields using the `fields` URL parameter in HTTP * Set the includeGridData URL parameter to true. If a field mask is set, the `includeGridData` parameter is ignored For large spreadsheets, as a best practice, retrieve only the specific spreadsheet fields that you want. To retrieve only subsets of spreadsheet data, use the ranges URL parameter. Ranges are specified using [A1 notation](/sheets/api/guides/concepts#cell). You can define a single cell (for example, `A1`) or multiple cells (for example, `A1:D5`). You can also get cells from other sheets within the same spreadsheet (for example, `Sheet2!A1:C4`) or retrieve multiple ranges at once (for example, `?ranges=A1:D5&ranges=Sheet2!A1:C4`). Limiting the range returns only the portions of the spreadsheet that intersect the requested ranges.
@optional {includeGridData: bool # True if grid data should be returned. This parameter is ignored if a field mask was set in the request., ranges: [str] # The ranges to retrieve from the spreadsheet.}
@returns(200) {dataSourceSchedules: [map], dataSources: [map], developerMetadata: [map], namedRanges: [map], properties: map{autoRecalc: str, defaultFormat: map{backgroundColor: map{alpha: num(float), blue: num(float), green: num(float), red: num(float)}, backgroundColorStyle: map{rgbColor: map, themeColor: str}, borders: map{bottom: map, left: map, right: map, top: map}, horizontalAlignment: str, hyperlinkDisplayType: str, numberFormat: map{pattern: str, type: str}, padding: map{bottom: int(int32), left: int(int32), right: int(int32), top: int(int32)}, textDirection: str, textFormat: map{bold: bool, fontFamily: str, fontSize: int(int32), foregroundColor: map, foregroundColorStyle: map, italic: bool, link: map, strikethrough: bool, underline: bool}, textRotation: map{angle: int(int32), vertical: bool}, verticalAlignment: str, wrapStrategy: str}, iterativeCalculationSettings: map{convergenceThreshold: num(double), maxIterations: int(int32)}, locale: str, spreadsheetTheme: map{primaryFontFamily: str, themeColors: [map]}, timeZone: str, title: str}, sheets: [map], spreadsheetId: str, spreadsheetUrl: str} # Successful response

@endpoint GET /v4/spreadsheets/{spreadsheetId}/developerMetadata/{metadataId}
@desc Returns the developer metadata with the specified ID. The caller must specify the spreadsheet ID and the developer metadata's unique metadataId.
@required {metadataId: int # The ID of the developer metadata to retrieve.}
@returns(200) {location: map{dimensionRange: map{dimension: str, endIndex: int(int32), sheetId: int(int32), startIndex: int(int32)}, locationType: str, sheetId: int(int32), spreadsheet: bool}, metadataId: int(int32), metadataKey: str, metadataValue: str, visibility: str} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/developerMetadata:search
@desc Returns all developer metadata matching the specified DataFilter. If the provided DataFilter represents a DeveloperMetadataLookup object, this will return all DeveloperMetadata entries selected by it. If the DataFilter represents a location in a spreadsheet, this will return all developer metadata associated with locations intersecting that region.
@optional {dataFilters: [map{a1Range: str, developerMetadataLookup: map{locationMatchingStrategy: str, locationType: str, metadataId: int(int32), metadataKey: str, metadataLocation: map, metadataValue: str, visibility: str}, gridRange: map{endColumnIndex: int(int32), endRowIndex: int(int32), sheetId: int(int32), startColumnIndex: int(int32), startRowIndex: int(int32)}}] # The data filters describing the criteria used to determine which DeveloperMetadata entries to return. DeveloperMetadata matching any of the specified filters are included in the response.}
@returns(200) {matchedDeveloperMetadata: [map]} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/sheets/{sheetId}:copyTo
@desc Copies a single sheet from a spreadsheet to another spreadsheet. Returns the properties of the newly created sheet.
@required {sheetId: int # The ID of the sheet to copy.}
@optional {destinationSpreadsheetId: str # The ID of the spreadsheet to copy the sheet to.}
@returns(200) {dataSourceSheetProperties: map{columns: [map], dataExecutionStatus: map{errorCode: str, errorMessage: str, lastRefreshTime: str(google-datetime), state: str}, dataSourceId: str}, gridProperties: map{columnCount: int(int32), columnGroupControlAfter: bool, frozenColumnCount: int(int32), frozenRowCount: int(int32), hideGridlines: bool, rowCount: int(int32), rowGroupControlAfter: bool}, hidden: bool, index: int(int32), rightToLeft: bool, sheetId: int(int32), sheetType: str, tabColor: map{alpha: num(float), blue: num(float), green: num(float), red: num(float)}, tabColorStyle: map{rgbColor: map{alpha: num(float), blue: num(float), green: num(float), red: num(float)}, themeColor: str}, title: str} # Successful response

@endpoint GET /v4/spreadsheets/{spreadsheetId}/values/{range}
@desc Returns a range of values from a spreadsheet. The caller must specify the spreadsheet ID and a range.
@required {range: str # The [A1 notation or R1C1 notation](/sheets/api/guides/concepts#cell) of the range to retrieve values from.}
@optional {dateTimeRenderOption: str(SERIAL_NUMBER/FORMATTED_STRING) # How dates, times, and durations should be represented in the output. This is ignored if value_render_option is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER., majorDimension: str(DIMENSION_UNSPECIFIED/ROWS/COLUMNS) # The major dimension that results should use. For example, if the spreadsheet data in Sheet1 is: `A1=1,B1=2,A2=3,B2=4`, then requesting `range=Sheet1!A1:B2?majorDimension=ROWS` returns `[[1,2],[3,4]]`, whereas requesting `range=Sheet1!A1:B2?majorDimension=COLUMNS` returns `[[1,3],[2,4]]`., valueRenderOption: str(FORMATTED_VALUE/UNFORMATTED_VALUE/FORMULA) # How values should be represented in the output. The default render option is FORMATTED_VALUE.}
@returns(200) {majorDimension: str, range: str, values: [[any]]} # Successful response

@endpoint PUT /v4/spreadsheets/{spreadsheetId}/values/{range}
@desc Sets values in a range of a spreadsheet. The caller must specify the spreadsheet ID, range, and a valueInputOption.
@required {range: str # The [A1 notation](/sheets/api/guides/concepts#cell) of the values to update.}
@optional {includeValuesInResponse: bool # Determines if the update response should include the values of the cells that were updated. By default, responses do not include the updated values. If the range to write was larger than the range actually written, the response includes all values in the requested range (excluding trailing empty rows and columns)., responseDateTimeRenderOption: str(SERIAL_NUMBER/FORMATTED_STRING) # Determines how dates, times, and durations in the response should be rendered. This is ignored if response_value_render_option is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER., responseValueRenderOption: str(FORMATTED_VALUE/UNFORMATTED_VALUE/FORMULA) # Determines how values in the response should be rendered. The default render option is FORMATTED_VALUE., valueInputOption: str(INPUT_VALUE_OPTION_UNSPECIFIED/RAW/USER_ENTERED) # How the input data should be interpreted., majorDimension: str(DIMENSION_UNSPECIFIED/ROWS/COLUMNS) # The major dimension of the values. For output, if the spreadsheet data is: `A1=1,B1=2,A2=3,B2=4`, then requesting `range=A1:B2,majorDimension=ROWS` will return `[[1,2],[3,4]]`, whereas requesting `range=A1:B2,majorDimension=COLUMNS` will return `[[1,3],[2,4]]`. For input, with `range=A1:B2,majorDimension=ROWS` then `[[1,2],[3,4]]` will set `A1=1,B1=2,A2=3,B2=4`. With `range=A1:B2,majorDimension=COLUMNS` then `[[1,2],[3,4]]` will set `A1=1,B1=3,A2=2,B2=4`. When writing, if this field is not set, it defaults to ROWS., range: str # The range the values cover, in [A1 notation](/sheets/api/guides/concepts#cell). For output, this range indicates the entire requested range, even though the values will exclude trailing rows and columns. When appending values, this field represents the range to search for a table, after which values will be appended., values: [[any]] # The data that was read or to be written. This is an array of arrays, the outer array representing all the data and each inner array representing a major dimension. Each item in the inner array corresponds with one cell. For output, empty trailing rows and columns will not be included. For input, supported value types are: bool, string, and double. Null values will be skipped. To set a cell to an empty value, set the string value to an empty string.}
@returns(200) {spreadsheetId: str, updatedCells: int(int32), updatedColumns: int(int32), updatedData: map{majorDimension: str, range: str, values: [[any]]}, updatedRange: str, updatedRows: int(int32)} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/values/{range}:append
@desc Appends values to a spreadsheet. The input range is used to search for existing data and find a "table" within that range. Values will be appended to the next row of the table, starting with the first column of the table. See the [guide](/sheets/api/guides/values#appending_values) and [sample code](/sheets/api/samples/writing#append_values) for specific details of how tables are detected and data is appended. The caller must specify the spreadsheet ID, range, and a valueInputOption. The `valueInputOption` only controls how the input data will be added to the sheet (column-wise or row-wise), it does not influence what cell the data starts being written to.
@required {range: str # The [A1 notation](/sheets/api/guides/concepts#cell) of a range to search for a logical table of data. Values are appended after the last row of the table.}
@optional {includeValuesInResponse: bool # Determines if the update response should include the values of the cells that were appended. By default, responses do not include the updated values., insertDataOption: str(OVERWRITE/INSERT_ROWS) # How the input data should be inserted., responseDateTimeRenderOption: str(SERIAL_NUMBER/FORMATTED_STRING) # Determines how dates, times, and durations in the response should be rendered. This is ignored if response_value_render_option is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER., responseValueRenderOption: str(FORMATTED_VALUE/UNFORMATTED_VALUE/FORMULA) # Determines how values in the response should be rendered. The default render option is FORMATTED_VALUE., valueInputOption: str(INPUT_VALUE_OPTION_UNSPECIFIED/RAW/USER_ENTERED) # How the input data should be interpreted., majorDimension: str(DIMENSION_UNSPECIFIED/ROWS/COLUMNS) # The major dimension of the values. For output, if the spreadsheet data is: `A1=1,B1=2,A2=3,B2=4`, then requesting `range=A1:B2,majorDimension=ROWS` will return `[[1,2],[3,4]]`, whereas requesting `range=A1:B2,majorDimension=COLUMNS` will return `[[1,3],[2,4]]`. For input, with `range=A1:B2,majorDimension=ROWS` then `[[1,2],[3,4]]` will set `A1=1,B1=2,A2=3,B2=4`. With `range=A1:B2,majorDimension=COLUMNS` then `[[1,2],[3,4]]` will set `A1=1,B1=3,A2=2,B2=4`. When writing, if this field is not set, it defaults to ROWS., range: str # The range the values cover, in [A1 notation](/sheets/api/guides/concepts#cell). For output, this range indicates the entire requested range, even though the values will exclude trailing rows and columns. When appending values, this field represents the range to search for a table, after which values will be appended., values: [[any]] # The data that was read or to be written. This is an array of arrays, the outer array representing all the data and each inner array representing a major dimension. Each item in the inner array corresponds with one cell. For output, empty trailing rows and columns will not be included. For input, supported value types are: bool, string, and double. Null values will be skipped. To set a cell to an empty value, set the string value to an empty string.}
@returns(200) {spreadsheetId: str, tableRange: str, updates: map{spreadsheetId: str, updatedCells: int(int32), updatedColumns: int(int32), updatedData: map{majorDimension: str, range: str, values: [[any]]}, updatedRange: str, updatedRows: int(int32)}} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/values/{range}:clear
@desc Clears values from a spreadsheet. The caller must specify the spreadsheet ID and range. Only values are cleared -- all other properties of the cell (such as formatting, data validation, etc..) are kept.
@required {range: str # The [A1 notation or R1C1 notation](/sheets/api/guides/concepts#cell) of the values to clear.}
@returns(200) {clearedRange: str, spreadsheetId: str} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/values:batchClear
@desc Clears one or more ranges of values from a spreadsheet. The caller must specify the spreadsheet ID and one or more ranges. Only values are cleared -- all other properties of the cell (such as formatting and data validation) are kept.
@optional {ranges: [str] # The ranges to clear, in [A1 notation or R1C1 notation](/sheets/api/guides/concepts#cell).}
@returns(200) {clearedRanges: [str], spreadsheetId: str} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/values:batchClearByDataFilter
@desc Clears one or more ranges of values from a spreadsheet. The caller must specify the spreadsheet ID and one or more DataFilters. Ranges matching any of the specified data filters will be cleared. Only values are cleared -- all other properties of the cell (such as formatting, data validation, etc..) are kept.
@optional {dataFilters: [map{a1Range: str, developerMetadataLookup: map{locationMatchingStrategy: str, locationType: str, metadataId: int(int32), metadataKey: str, metadataLocation: map, metadataValue: str, visibility: str}, gridRange: map{endColumnIndex: int(int32), endRowIndex: int(int32), sheetId: int(int32), startColumnIndex: int(int32), startRowIndex: int(int32)}}] # The DataFilters used to determine which ranges to clear.}
@returns(200) {clearedRanges: [str], spreadsheetId: str} # Successful response

@endpoint GET /v4/spreadsheets/{spreadsheetId}/values:batchGet
@desc Returns one or more ranges of values from a spreadsheet. The caller must specify the spreadsheet ID and one or more ranges.
@optional {dateTimeRenderOption: str(SERIAL_NUMBER/FORMATTED_STRING) # How dates, times, and durations should be represented in the output. This is ignored if value_render_option is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER., majorDimension: str(DIMENSION_UNSPECIFIED/ROWS/COLUMNS) # The major dimension that results should use. For example, if the spreadsheet data is: `A1=1,B1=2,A2=3,B2=4`, then requesting `ranges=["A1:B2"],majorDimension=ROWS` returns `[[1,2],[3,4]]`, whereas requesting `ranges=["A1:B2"],majorDimension=COLUMNS` returns `[[1,3],[2,4]]`., ranges: [str] # The [A1 notation or R1C1 notation](/sheets/api/guides/concepts#cell) of the range to retrieve values from., valueRenderOption: str(FORMATTED_VALUE/UNFORMATTED_VALUE/FORMULA) # How values should be represented in the output. The default render option is ValueRenderOption.FORMATTED_VALUE.}
@returns(200) {spreadsheetId: str, valueRanges: [map]} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/values:batchGetByDataFilter
@desc Returns one or more ranges of values that match the specified data filters. The caller must specify the spreadsheet ID and one or more DataFilters. Ranges that match any of the data filters in the request will be returned.
@optional {dataFilters: [map{a1Range: str, developerMetadataLookup: map{locationMatchingStrategy: str, locationType: str, metadataId: int(int32), metadataKey: str, metadataLocation: map, metadataValue: str, visibility: str}, gridRange: map{endColumnIndex: int(int32), endRowIndex: int(int32), sheetId: int(int32), startColumnIndex: int(int32), startRowIndex: int(int32)}}] # The data filters used to match the ranges of values to retrieve. Ranges that match any of the specified data filters are included in the response., dateTimeRenderOption: str(SERIAL_NUMBER/FORMATTED_STRING) # How dates, times, and durations should be represented in the output. This is ignored if value_render_option is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER., majorDimension: str(DIMENSION_UNSPECIFIED/ROWS/COLUMNS) # The major dimension that results should use. For example, if the spreadsheet data is: `A1=1,B1=2,A2=3,B2=4`, then a request that selects that range and sets `majorDimension=ROWS` returns `[[1,2],[3,4]]`, whereas a request that sets `majorDimension=COLUMNS` returns `[[1,3],[2,4]]`., valueRenderOption: str(FORMATTED_VALUE/UNFORMATTED_VALUE/FORMULA) # How values should be represented in the output. The default render option is FORMATTED_VALUE.}
@returns(200) {spreadsheetId: str, valueRanges: [map]} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/values:batchUpdate
@desc Sets values in one or more ranges of a spreadsheet. The caller must specify the spreadsheet ID, a valueInputOption, and one or more ValueRanges.
@optional {data: [map{majorDimension: str, range: str, values: [[any]]}] # The new values to apply to the spreadsheet., includeValuesInResponse: bool # Determines if the update response should include the values of the cells that were updated. By default, responses do not include the updated values. The `updatedData` field within each of the BatchUpdateValuesResponse.responses contains the updated values. If the range to write was larger than the range actually written, the response includes all values in the requested range (excluding trailing empty rows and columns)., responseDateTimeRenderOption: str(SERIAL_NUMBER/FORMATTED_STRING) # Determines how dates, times, and durations in the response should be rendered. This is ignored if response_value_render_option is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER., responseValueRenderOption: str(FORMATTED_VALUE/UNFORMATTED_VALUE/FORMULA) # Determines how values in the response should be rendered. The default render option is FORMATTED_VALUE., valueInputOption: str(INPUT_VALUE_OPTION_UNSPECIFIED/RAW/USER_ENTERED) # How the input data should be interpreted.}
@returns(200) {responses: [map], spreadsheetId: str, totalUpdatedCells: int(int32), totalUpdatedColumns: int(int32), totalUpdatedRows: int(int32), totalUpdatedSheets: int(int32)} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}/values:batchUpdateByDataFilter
@desc Sets values in one or more ranges of a spreadsheet. The caller must specify the spreadsheet ID, a valueInputOption, and one or more DataFilterValueRanges.
@optional {data: [map{dataFilter: map{a1Range: str, developerMetadataLookup: map, gridRange: map}, majorDimension: str, values: [[any]]}] # The new values to apply to the spreadsheet. If more than one range is matched by the specified DataFilter the specified values are applied to all of those ranges., includeValuesInResponse: bool # Determines if the update response should include the values of the cells that were updated. By default, responses do not include the updated values. The `updatedData` field within each of the BatchUpdateValuesResponse.responses contains the updated values. If the range to write was larger than the range actually written, the response includes all values in the requested range (excluding trailing empty rows and columns)., responseDateTimeRenderOption: str(SERIAL_NUMBER/FORMATTED_STRING) # Determines how dates, times, and durations in the response should be rendered. This is ignored if response_value_render_option is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER., responseValueRenderOption: str(FORMATTED_VALUE/UNFORMATTED_VALUE/FORMULA) # Determines how values in the response should be rendered. The default render option is FORMATTED_VALUE., valueInputOption: str(INPUT_VALUE_OPTION_UNSPECIFIED/RAW/USER_ENTERED) # How the input data should be interpreted.}
@returns(200) {responses: [map], spreadsheetId: str, totalUpdatedCells: int(int32), totalUpdatedColumns: int(int32), totalUpdatedRows: int(int32), totalUpdatedSheets: int(int32)} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}:batchUpdate
@desc Applies one or more updates to the spreadsheet. Each request is validated before being applied. If any request is not valid then the entire request will fail and nothing will be applied. Some requests have replies to give you some information about how they are applied. The replies will mirror the requests. For example, if you applied 4 updates and the 3rd one had a reply, then the response will have 2 empty replies, the actual reply, and another empty reply, in that order. Due to the collaborative nature of spreadsheets, it is not guaranteed that the spreadsheet will reflect exactly your changes after this completes, however it is guaranteed that the updates in the request will be applied together atomically. Your changes may be altered with respect to collaborator changes. If there are no collaborators, the spreadsheet should reflect your changes.
@optional {includeSpreadsheetInResponse: bool # Determines if the update response should include the spreadsheet resource., requests: [map{addBanding: map{bandedRange: map}, addChart: map{chart: map}, addConditionalFormatRule: map{index: int(int32), rule: map}, addDataSource: map{dataSource: map}, addDimensionGroup: map{range: map}, addFilterView: map{filter: map}, addNamedRange: map{namedRange: map}, addProtectedRange: map{protectedRange: map}, addSheet: map{properties: map}, addSlicer: map{slicer: map}, appendCells: map{fields: str(google-fieldmask), rows: [map], sheetId: int(int32)}, appendDimension: map{dimension: str, length: int(int32), sheetId: int(int32)}, autoFill: map{range: map, sourceAndDestination: map, useAlternateSeries: bool}, autoResizeDimensions: map{dataSourceSheetDimensions: map, dimensions: map}, clearBasicFilter: map{sheetId: int(int32)}, copyPaste: map{destination: map, pasteOrientation: str, pasteType: str, source: map}, createDeveloperMetadata: map{developerMetadata: map}, cutPaste: map{destination: map, pasteType: str, source: map}, deleteBanding: map{bandedRangeId: int(int32)}, deleteConditionalFormatRule: map{index: int(int32), sheetId: int(int32)}, deleteDataSource: map{dataSourceId: str}, deleteDeveloperMetadata: map{dataFilter: map}, deleteDimension: map{range: map}, deleteDimensionGroup: map{range: map}, deleteDuplicates: map{comparisonColumns: [map], range: map}, deleteEmbeddedObject: map{objectId: int(int32)}, deleteFilterView: map{filterId: int(int32)}, deleteNamedRange: map{namedRangeId: str}, deleteProtectedRange: map{protectedRangeId: int(int32)}, deleteRange: map{range: map, shiftDimension: str}, deleteSheet: map{sheetId: int(int32)}, duplicateFilterView: map{filterId: int(int32)}, duplicateSheet: map{insertSheetIndex: int(int32), newSheetId: int(int32), newSheetName: str, sourceSheetId: int(int32)}, findReplace: map{allSheets: bool, find: str, includeFormulas: bool, matchCase: bool, matchEntireCell: bool, range: map, replacement: str, searchByRegex: bool, sheetId: int(int32)}, insertDimension: map{inheritFromBefore: bool, range: map}, insertRange: map{range: map, shiftDimension: str}, mergeCells: map{mergeType: str, range: map}, moveDimension: map{destinationIndex: int(int32), source: map}, pasteData: map{coordinate: map, data: str, delimiter: str, html: bool, type: str}, randomizeRange: map{range: map}, refreshDataSource: map{dataSourceId: str, force: bool, isAll: bool, references: map}, repeatCell: map{cell: map, fields: str(google-fieldmask), range: map}, setBasicFilter: map{filter: map}, setDataValidation: map{range: map, rule: map}, sortRange: map{range: map, sortSpecs: [map]}, textToColumns: map{delimiter: str, delimiterType: str, source: map}, trimWhitespace: map{range: map}, unmergeCells: map{range: map}, updateBanding: map{bandedRange: map, fields: str(google-fieldmask)}, updateBorders: map{bottom: map, innerHorizontal: map, innerVertical: map, left: map, range: map, right: map, top: map}, updateCells: map{fields: str(google-fieldmask), range: map, rows: [map], start: map}, updateChartSpec: map{chartId: int(int32), spec: map}, updateConditionalFormatRule: map{index: int(int32), newIndex: int(int32), rule: map, sheetId: int(int32)}, updateDataSource: map{dataSource: map, fields: str(google-fieldmask)}, updateDeveloperMetadata: map{dataFilters: [map], developerMetadata: map, fields: str(google-fieldmask)}, updateDimensionGroup: map{dimensionGroup: map, fields: str(google-fieldmask)}, updateDimensionProperties: map{dataSourceSheetRange: map, fields: str(google-fieldmask), properties: map, range: map}, updateEmbeddedObjectBorder: map{border: map, fields: str(google-fieldmask), objectId: int(int32)}, updateEmbeddedObjectPosition: map{fields: str(google-fieldmask), newPosition: map, objectId: int(int32)}, updateFilterView: map{fields: str(google-fieldmask), filter: map}, updateNamedRange: map{fields: str(google-fieldmask), namedRange: map}, updateProtectedRange: map{fields: str(google-fieldmask), protectedRange: map}, updateSheetProperties: map{fields: str(google-fieldmask), properties: map}, updateSlicerSpec: map{fields: str(google-fieldmask), slicerId: int(int32), spec: map}, updateSpreadsheetProperties: map{fields: str(google-fieldmask), properties: map}}] # A list of updates to apply to the spreadsheet. Requests will be applied in the order they are specified. If any request is not valid, no requests will be applied., responseIncludeGridData: bool # True if grid data should be returned. Meaningful only if include_spreadsheet_in_response is 'true'. This parameter is ignored if a field mask was set in the request., responseRanges: [str] # Limits the ranges included in the response spreadsheet. Meaningful only if include_spreadsheet_in_response is 'true'.}
@returns(200) {replies: [map], spreadsheetId: str, updatedSpreadsheet: map{dataSourceSchedules: [map], dataSources: [map], developerMetadata: [map], namedRanges: [map], properties: map{autoRecalc: str, defaultFormat: map{backgroundColor: map, backgroundColorStyle: map, borders: map, horizontalAlignment: str, hyperlinkDisplayType: str, numberFormat: map, padding: map, textDirection: str, textFormat: map, textRotation: map, verticalAlignment: str, wrapStrategy: str}, iterativeCalculationSettings: map{convergenceThreshold: num(double), maxIterations: int(int32)}, locale: str, spreadsheetTheme: map{primaryFontFamily: str, themeColors: [map]}, timeZone: str, title: str}, sheets: [map], spreadsheetId: str, spreadsheetUrl: str}} # Successful response

@endpoint POST /v4/spreadsheets/{spreadsheetId}:getByDataFilter
@desc Returns the spreadsheet at the given ID. The caller must specify the spreadsheet ID. This method differs from GetSpreadsheet in that it allows selecting which subsets of spreadsheet data to return by specifying a dataFilters parameter. Multiple DataFilters can be specified. Specifying one or more data filters returns the portions of the spreadsheet that intersect ranges matched by any of the filters. By default, data within grids is not returned. You can include grid data one of 2 ways: * Specify a [field mask](https://developers.google.com/sheets/api/guides/field-masks) listing your desired fields using the `fields` URL parameter in HTTP * Set the includeGridData parameter to true. If a field mask is set, the `includeGridData` parameter is ignored For large spreadsheets, as a best practice, retrieve only the specific spreadsheet fields that you want.
@optional {dataFilters: [map{a1Range: str, developerMetadataLookup: map{locationMatchingStrategy: str, locationType: str, metadataId: int(int32), metadataKey: str, metadataLocation: map, metadataValue: str, visibility: str}, gridRange: map{endColumnIndex: int(int32), endRowIndex: int(int32), sheetId: int(int32), startColumnIndex: int(int32), startRowIndex: int(int32)}}] # The DataFilters used to select which ranges to retrieve from the spreadsheet., includeGridData: bool # True if grid data should be returned. This parameter is ignored if a field mask was set in the request.}
@returns(200) {dataSourceSchedules: [map], dataSources: [map], developerMetadata: [map], namedRanges: [map], properties: map{autoRecalc: str, defaultFormat: map{backgroundColor: map{alpha: num(float), blue: num(float), green: num(float), red: num(float)}, backgroundColorStyle: map{rgbColor: map, themeColor: str}, borders: map{bottom: map, left: map, right: map, top: map}, horizontalAlignment: str, hyperlinkDisplayType: str, numberFormat: map{pattern: str, type: str}, padding: map{bottom: int(int32), left: int(int32), right: int(int32), top: int(int32)}, textDirection: str, textFormat: map{bold: bool, fontFamily: str, fontSize: int(int32), foregroundColor: map, foregroundColorStyle: map, italic: bool, link: map, strikethrough: bool, underline: bool}, textRotation: map{angle: int(int32), vertical: bool}, verticalAlignment: str, wrapStrategy: str}, iterativeCalculationSettings: map{convergenceThreshold: num(double), maxIterations: int(int32)}, locale: str, spreadsheetTheme: map{primaryFontFamily: str, themeColors: [map]}, timeZone: str, title: str}, sheets: [map], spreadsheetId: str, spreadsheetUrl: str} # Successful response

@end
