@group sessions
@endpoint DELETE /sessions
@desc Delete user session (log out)
@returns(204) No body.
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found, 405: Method Not Allowed, 409: Conflict, 412: Precondition Failed, 422: Unprocessable Entity, 423: Locked, 429: Too Many Requests}

@endpoint POST /sessions
@desc Create user session (log in)
@optional {username: any # Username to sign in as, password: any # Password for sign in, otp: any # If this user has a 2FA device, provide its OTP or code here., partial_session_id: any # Identifier for a partially-completed login}
@returns(201) The Sessions object.
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found, 405: Method Not Allowed, 409: Conflict, 412: Precondition Failed, 422: Unprocessable Entity, 423: Locked, 429: Too Many Requests}

@endgroup

