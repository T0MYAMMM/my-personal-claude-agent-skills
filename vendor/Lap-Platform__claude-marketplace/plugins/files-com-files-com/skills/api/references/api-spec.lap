@group users
@endpoint POST /users/{id}/unlock
@desc Unlock user who has been locked out due to failed logins.
@required {id: any # User ID.}
@returns(204) No body.
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found, 405: Method Not Allowed, 409: Conflict, 412: Precondition Failed, 422: Unprocessable Entity, 423: Locked, 429: Too Many Requests}

@endpoint POST /users/{id}/resend_welcome_email
@desc Resend user welcome email
@required {id: any # User ID.}
@returns(204) No body.
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found, 405: Method Not Allowed, 409: Conflict, 412: Precondition Failed, 422: Unprocessable Entity, 423: Locked, 429: Too Many Requests}

@endpoint POST /users/{id}/2fa/reset
@desc Trigger 2FA Reset process for user who has lost access to their existing 2FA methods.
@required {id: any # User ID.}
@returns(204) No body.
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not Found, 405: Method Not Allowed, 409: Conflict, 412: Precondition Failed, 422: Unprocessable Entity, 423: Locked, 429: Too Many Requests}

@endpoint DELETE /users/{id}
@desc Delete User
@required {id: any # User ID.}
