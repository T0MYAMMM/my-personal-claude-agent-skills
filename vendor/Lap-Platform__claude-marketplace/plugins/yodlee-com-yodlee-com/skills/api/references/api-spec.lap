@returns(200) OK
@errors {400: Y800 : Invalid value for documentId, 401: Unauthorized, 404: Not Found}

@endpoint DELETE /documents/{documentId}
@desc Delete Document
@required {documentId: str # documentId}
@returns(204) OK
@errors {400: Y800 : Invalid value for documentId<br>Y868 : No action is allowed, as the data is being migrated to the Open Banking provider<br>, 401: Unauthorized, 404: Not Found}

@endgroup

