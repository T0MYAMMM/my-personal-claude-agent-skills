@endgroup

@group products
@endpoint DELETE /v1/products/{productId}/members/{userId}
@desc Delete Member from Product
@required {productId: str(uuid) # The identifier of the Product., userId: str # The identifier of the Member.}
@returns(204) When the delete was successful.
@errors {400: Bad request., 404: Not found., 429: Too many requests. In case of the request rate exceeds the rate limits.}

@endgroup

@end
