@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SEDRA IV API
@base http://sedra.bethmardutho.org/api
@version 1.0.0
@endpoints 2
@toc word(1), lexeme(1)

@group word
@endpoint GET /word/{id}
@desc Get Syriac word.
@required {id: any # The id parameters must contain either the Id of a word from the Sedra database or a Syriac word in the unicode character set. When the id parameter is a Syriac word it may be consonantal, partially vocalized, or fully vocalized. Fully vocalized Syriac words will have less false positive results than partially vocalized or consonantal Syriac words. When id is the Id of a word from the SEDRA database then that word will be the only word in the result.}
@returns(200) An array of Syriac words.

@endgroup

@group lexeme
@endpoint GET /lexeme/{id}
@desc Get Syriac lexeme.
@required {id: any # The Id of a lexeme from the Sedra database.}
@returns(200) A Syriac lexeme.

@endgroup

@end
