@optional {$expand: any # Expands resourceIds (of Firewalls/Network Security Groups etc.) back referenced by the IpGroups resource.}
@returns(200) Request successful. The operation returns the resulting IpGroups resource.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/ipGroups/{ipGroupsName}
@desc Creates or updates an ipGroups in a specified resource group.
@required {resourceGroupName: any # The name of the resource group., ipGroupsName: any # The name of the ipGroups., parameters: any # Parameters supplied to the create or update IpGroups operation.}
@returns(200) Request successful. The operation returns the resulting ipGroups resource.
@returns(201) Create successful. The operation returns the resulting ipGroups resource.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/ipGroups/{ipGroupsName}
@desc Updates tags of an IpGroups resource.
@required {resourceGroupName: any # The name of the resource group., ipGroupsName: any # The name of the ipGroups., parameters: any # Parameters supplied to the update ipGroups operation.}
@returns(200) Request successful. The operation returns the resulting ipGroups resource.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/ipGroups/{ipGroupsName}
@desc Deletes the specified ipGroups.
