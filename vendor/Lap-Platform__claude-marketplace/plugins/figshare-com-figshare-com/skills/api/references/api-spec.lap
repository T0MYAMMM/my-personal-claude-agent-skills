@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Figshare API
@base https://api.figshare.com/v2
@version 2.0.0
@auth OAuth2
@endpoints 151
@hint download_for_search
@toc token(2), articles(12), account(121), collections(6), item_types(1), projects(4), institutions(1), categories(1), licenses(1), institution(1), file(1)

@group token
@endpoint GET /token
@desc Get OAuth token information
@optional {access_token: any # OAuth access token}
@returns(200) OK. Token information
@errors {400: Bad Request, 403: Forbidden}

@endpoint POST /token
@desc Create OAuth token
@optional {body: map # Create OAuth Token Parameters}
@returns(200) OK. Token created successfully <a href='http://tools.ietf.org/html/rfc6749#section-5.1' target='_blank'>RFC 6749 Section 5.1</a>.
@errors {400: Bad Request <a href='http://tools.ietf.org/html/rfc6749#section-5.2' target='_blank'>RFC 6749 Section 5.2</a>.}

@endgroup

@group articles
@endpoint GET /articles
@desc Public Articles
@optional {X-Cursor: any # Unique hash used for bypassing the item retrieval limit of 9,000 entities. When using this parameter, please note that the offset parameter will not be available, but the limit parameter will still work as expected., page: any # Page number. Used for pagination with page_size, page_size: any # The number of results included on a page. Used for pagination with page, limit: any # Number of results included on a page. Used for pagination with query, offset: any # Where to start the listing (the offset of the first result). Used for pagination with limit, order: any # The field by which to order. Default varies by endpoint/resource., order_direction: any, institution: any # only return articles from this institution, published_since: any # Filter by article publishing date. Will only return articles published after the date. date(ISO 8601) YYYY-MM-DD or date-time(ISO 8601) YYYY-MM-DDTHH:mm:ssZ, modified_since: any # Filter by article modified date. Will only return articles modified after the date. date(ISO 8601) YYYY-MM-DD or date-time(ISO 8601) YYYY-MM-DDTHH:mm:ssZ, group: any # only return articles from this group, resource_doi: any # Deprecated by related materials. Only return articles with this resource_doi, item_type: any # Only return articles with the respective type. Mapping for item_type is: 1 - Figure, 2 - Media, 3 - Dataset, 5 - Poster, 6 - Journal contribution, 7 - Presentation, 8 - Thesis, 9 - Software, 11 - Online resource, 12 - Preprint, 13 - Book, 14 - Conference contribution, 15 - Chapter, 16 - Peer review, 17 - Educational resource, 18 - Report, 19 - Standard, 20 - Composition, 21 - Funding, 22 - Physical object, 23 - Data management plan, 24 - Workflow, 25 - Monograph, 26 - Performance, 27 - Event, 28 - Service, 29 - Model, doi: any # only return articles with this doi, handle: any # only return articles with this handle}
@returns(200) OK. An array of articles
@errors {400: Bad Request, 422: Unprocessable Entity. Syntax is correct but one of the parameters isn't correctly processed, 500: Internal Server Error}

@endpoint POST /articles/search
@desc Public Articles Search
@optional {X-Cursor: any # Unique hash used for bypassing the item retrieval limit of 9,000 entities. When using this parameter, please note that the offset parameter will not be available, but the limit parameter will still work as expected., search: map # Search Parameters}
@returns(200) OK. An array of articles
@errors {400: Bad Request, 422: Unprocessable Entity. Syntax is correct but one of the parameters isn't correctly processed, 500: Internal Server Error}

@endpoint GET /articles/{article_id}
@desc View article details
@required {article_id: any # Article Unique identifier}
@returns(200) OK. Article representation
@errors {400: Bad Request, 404: Not Found, 500: Internal Server Error}

@endpoint GET /articles/{article_id}/versions
@desc List article versions
@required {article_id: any # Article Unique identifier}
@returns(200) OK. Article version representations
@errors {400: Bad Request. Article ID must be an integer and bigger than 0., 404: Not Found, 500: Internal Server Error}

@endpoint GET /articles/{article_id}/versions/{version_id}
@desc Article details for version
@required {article_id: any # Article Unique identifier, version_id: any # Article Version Number}
@returns(200) OK. Article representation
@errors {400: Bad Request, 404: Not Found, 500: Internal Server Error}

@endpoint GET /articles/{article_id}/versions/{version_id}/files
@desc Article version file details
@required {article_id: any # Article Unique identifier, version_id: any # Article Version Unique identifier}
@optional {page: any # Page number. Used for pagination with page_size, page_size: any # The number of results included on a page. Used for pagination with page, limit: any # Number of results included on a page. Used for pagination with query, offset: any # Where to start the listing (the offset of the first result). Used for pagination with limit}
@returns(200) OK. List of article version files
@errors {400: Bad Request, 404: Not Found, 500: Internal Server Error}

@endpoint GET /articles/{article_id}/download
@desc Public Article Download
@required {article_id: any # Article unique identifier}
@optional {folder_path: any # Folder path to download. If not provided, all files from the article will be downloaded}
@returns(200) OK
@errors {500: Internal Server Error}

@endpoint GET /articles/{article_id}/versions/{version_id}/download
@desc Public Article Version Download
@required {article_id: any # Article unique identifier, version_id: any # Version Number}
@optional {folder_path: any # Folder path to download. If not provided, all files from the article will be downloaded}
@returns(200) OK
@errors {500: Internal Server Error}

@endpoint GET /articles/{article_id}/versions/{version_id}/embargo
@desc Public Article Embargo for article version
@required {article_id: any # Article Unique identifier, version_id: any # Version Number}
@returns(200) OK. Embargo representation
@errors {400: Bad Request, 404: Not Found, 500: Internal Server Error}

@endpoint GET /articles/{article_id}/versions/{version_id}/confidentiality
@desc Public Article Confidentiality for article version
@required {article_id: any # Article Unique identifier, version_id: any # Version Number}
@returns(200) OK. Confidentiality representation
@errors {400: Bad Request, 404: Not Found, 500: Internal Server Error}

@endpoint GET /articles/{article_id}/files
@desc List article files
@required {article_id: any # Article Unique identifier}
@optional {page: any # Page number. Used for pagination with page_size, page_size: any # The number of results included on a page. Used for pagination with page, limit: any # Number of results included on a page. Used for pagination with query, offset: any # Where to start the listing (the offset of the first result). Used for pagination with limit}
@returns(200) OK. List of article files
@errors {400: Bad Request, 404: Not Found, 500: Internal Server Error}

@endpoint GET /articles/{article_id}/files/{file_id}
@desc Article file details
@required {article_id: any # Article Unique identifier, file_id: any # File Unique identifier}
@returns(200) OK. File representation
@errors {400: Bad Request, 404: Not Found, 500: Internal Server Error}

@endgroup

