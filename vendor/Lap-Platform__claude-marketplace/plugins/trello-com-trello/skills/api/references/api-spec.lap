@required {callbackURL: str(url) # The URL that the webhook should POST information to., idModel: str # ID of the object to create a webhook on.}
@optional {description: str # A description to be displayed when retrieving information about the webhook.}
@returns(200) {id: str, description: str, idModel: str, callbackURL: str(url), active: bool, consecutiveFailures: num, firstConsecutiveFailDate: str(date)?} # Success

@endpoint GET /tokens/{token}/webhooks/{idWebhook}
@desc Get a Webhook belonging to a Token
@returns(200) {id: str, description: str, idModel: str, callbackURL: str(url), active: bool, consecutiveFailures: num, firstConsecutiveFailDate: str(date)?} # Success

@endpoint DELETE /tokens/{token}/webhooks/{idWebhook}
@desc Delete a Webhook created by Token
@returns(200) Success

@endpoint PUT /tokens/{token}/webhooks/{idWebhook}
@desc Update a Webhook created by Token
@optional {description: str # A description to be displayed when retrieving information about the webhook., callbackURL: str(url) # The URL that the webhook should `POST` information to., idModel: str # ID of the object that the webhook is on.}
@returns(200) Success

@endpoint DELETE /tokens/{token}/
@desc Delete a Token
@required {token: str}
@returns(200) Success

@endgroup

@group webhooks
@endpoint POST /webhooks/
@desc Create a Webhook
@required {callbackURL: str(url) # A valid URL that is reachable with a `HEAD` and `POST` request., idModel: str # ID of the model to be monitored}
@optional {description: str # A string with a length from `0` to `16384`., active: bool # Determines whether the webhook is active and sending `POST` requests.}
@returns(200) {id: str, description: str, idModel: str, callbackURL: str(url), active: bool, consecutiveFailures: num, firstConsecutiveFailDate: str(date)?} # Success

@endpoint GET /webhooks/{id}
@desc Get a Webhook
@returns(200) {id: str, description: str, idModel: str, callbackURL: str(url), active: bool, consecutiveFailures: num, firstConsecutiveFailDate: str(date)?} # Success

@endpoint PUT /webhooks/{id}
@desc Update a Webhook
@optional {description: str # A string with a length from `0` to `16384`., callbackURL: str(url) # A valid URL that is reachable with a `HEAD` and `POST` request., idModel: str # ID of the model to be monitored, active: bool # Determines whether the webhook is active and sending `POST` requests.}
@returns(200) {id: str, description: str, idModel: str, callbackURL: str(url), active: bool, consecutiveFailures: num, firstConsecutiveFailDate: str(date)?} # Success

@endpoint DELETE /webhooks/{id}
@desc Delete a Webhook
@returns(200) Success

@endpoint GET /webhooks/{id}/{field}
@desc Get a field on a Webhook
@required {id: str # ID of the webhook., field: str(active/callbackURL/description/idModel/consecutiveFailures/firstConsecutiveFailDate) # Field to retrieve. One of: `active`, `callbackURL`, `description`, `idModel`}
@returns(200) Success

@endgroup

@end
