@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2015-05-01-preview
@auth OAuth2
@common_fields {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., serverName: any # The name of the server., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@endpoints 9
@toc subscriptions(9)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/advisors
@desc Gets a list of database advisors.
@required {databaseName: any # The name of the database.}
@returns(200) Successfully retrieved the list of database advisors.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/advisors/{advisorName}
@desc Gets a database advisor.
@required {databaseName: any # The name of the database., advisorName: any # The name of the Database Advisor.}
@returns(200) Successfully retrieved details of specified database advisor.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/advisors/{advisorName}
@desc Updates a database advisor.
@required {databaseName: any # The name of the database., advisorName: any # The name of the Database Advisor., parameters: map # The requested advisor resource state.}
@returns(200) Successfully updated the specified database advisor.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/advisors/{advisorName}/recommendedActions
@desc Gets list of Database Recommended Actions.
@required {databaseName: any # The name of the database., advisorName: any # The name of the Database Advisor.}
@returns(200) Successfully retrieved the list of database recommended actions.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/advisors/{advisorName}/recommendedActions/{recommendedActionName}
@desc Gets a database recommended action.
@required {databaseName: any # The name of the database., advisorName: any # The name of the Database Advisor., recommendedActionName: any # The name of Database Recommended Action.}
@returns(200) Successfully retrieved details of specified database recommended action.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/advisors/{advisorName}/recommendedActions/{recommendedActionName}
@desc Updates a database recommended action.
@required {databaseName: any # The name of the database., advisorName: any # The name of the Database Advisor., recommendedActionName: any # The name of Database Recommended Action., parameters: map # The requested recommended action resource state.}
@returns(200) Successfully updated the specified database recommended action.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/advisors
@desc Gets a list of server advisors.
@returns(200) Successfully retrieved the list of server advisors.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/advisors/{advisorName}
@desc Gets a server advisor.
@required {advisorName: any # The name of the Server Advisor.}
@returns(200) Successfully retrieved details of specified server advisor.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/advisors/{advisorName}
@desc Updates a server advisor.
@required {advisorName: any # The name of the Server Advisor., parameters: map # The requested advisor resource state.}
