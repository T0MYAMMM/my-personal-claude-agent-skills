@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2015-05-01-preview
@auth OAuth2
@common_fields {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., serverName: any # The name of the server., databaseName: any # The name of the database on which the sync group is hosted., syncGroupName: any # The name of the sync group on which the sync member is hosted., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@endpoints 7
@toc subscriptions(7)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/syncGroups/{syncGroupName}/syncMembers/{syncMemberName}
@desc Gets a sync member.
@required {syncMemberName: any # The name of the sync member.}
@returns(200) Successfully retrieved the specified sync member.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/syncGroups/{syncGroupName}/syncMembers/{syncMemberName}
@desc Creates or updates a sync member.
@required {syncMemberName: any # The name of the sync member., parameters: map # The requested sync member resource state.}
@returns(200) Successfully updated the sync member.
@returns(202) Creating or updating the sync member is in progress.
@returns(201) Successfully created the sync member.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/syncGroups/{syncGroupName}/syncMembers/{syncMemberName}
@desc Deletes a sync member.
@required {syncMemberName: any # The name of the sync member.}
@returns(200) Successfully deleted the sync member.
@returns(202) Deleting the sync member is in progress.
@returns(204) The specified sync member does not exist.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/syncGroups/{syncGroupName}/syncMembers/{syncMemberName}
@desc Updates an existing sync member.
@required {syncMemberName: any # The name of the sync member., parameters: map # The requested sync member resource state.}
@returns(200) Successfully updated the sync member.
@returns(202) Updating the sync member is in progress.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/syncGroups/{syncGroupName}/syncMembers
@desc Lists sync members in the given sync group.
@returns(200) Successfully retrieved the list of sync members.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/syncGroups/{syncGroupName}/syncMembers/{syncMemberName}/schemas
@desc Gets a sync member database schema.
@required {syncMemberName: any # The name of the sync member.}
@returns(200) Successfully get a sync member schema.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/databases/{databaseName}/syncGroups/{syncGroupName}/syncMembers/{syncMemberName}/refreshSchema
@desc Refreshes a sync member database schema.
@required {syncMemberName: any # The name of the sync member.}
@returns(200) Successfully refreshed a sync member schema.
@returns(202) The sync member schema refresh operation is on going.

@end
