@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api ETSI GS MEC 010-2 - Part 2: Application lifecycle, rules and requirements management
@base https://localhost/app_pkgm/v1
@version 2.1.1
@endpoints 16
@toc app_packages(8), subscriptions(4), user_defined_notification(1), onboarded_app_packages(3)

@group app_packages
@endpoint POST /app_packages
@desc Create a resource for on-boarding an application package to a MEO
@required {appPkgName: str # Name of the application package to be onboarded., appPkgPath: str, appPkgVersion: str # Version of the application package to be onboarded. The appPkgName with appPkgVersion can be used to uniquely identify the application package., checksum: map{algorithm!: str, hash!: str}}
@optional {appProvider: str # The provider's name of the application package to be onboarded., userDefinedData: map # 'This data type represents a list of key-value pairs. The order of the pairs in the list is not significant. In JSON, a set of key-value pairs is represented as an object. It shall comply with the provisions defined in clause 4 of IETF RFC 8259'}
@returns(201) Successful response for resource creation
@errors {400, 401, 403, 404, 406, 429}

@endpoint GET /app_packages
@desc Queries information relating to on-boarded application packages in the MEO
@optional {filter: str # Attribute-based filtering parameters according to ETSI GS MEC 009, all_fields: str # Include all complex attributes in the response., fields: str # Complex attributes of AppPkgInfo to be included into the response, exclude_fields: str # Complex attributes of AppPkgInfo to be excluded from the response., exclude_default: str # Indicates to exclude the following complex attributes of AppPkgInfo from the response.}
@returns(200) Contains a representation of the application package resource
@errors {400, 401, 403, 404, 406, 429}

@endpoint GET /app_packages/{appPkgId}
@desc Queries the information related to individual application package resources
@returns(200) {id: str, appDId: str, appProvider: str, appName: str, appSoftwareVersion: str, appDVersion: str, checksum: map{algorithm: str, hash: str}, softwareImages: any, additionalArtifacts: any, onboardingState: str(enum), operationalState: str, usageState: str(enum), userDefinedData: map, _links: map{self: map{href: str(uri)}, appD: map{href: str(uri)}, appPkgContent: map{href: str(uri)}}} # Contains a representation of the application package resource
@errors {400, 401, 403, 404, 406, 429}

@endpoint DELETE /app_packages/{appPkgId}
@desc Deletes an individual application package resources
@returns(204)
@errors {400, 401, 403, 404, 406, 429}

@endpoint PATCH /app_packages/{appPkgId}
@desc Updates the operational state of an individual application package resource
@required {operationState: str(DISABLED/ENABLED)}
@returns(200) {operationState: str} # Shows that the operation has been completed successfully
@errors {400, 401, 403, 404, 406, 409, 429}

@endgroup

@group subscriptions
@endpoint POST /subscriptions
@desc Subscribe to notifications about on-boarding an application package
@required {callbackUri: str(uri) # The URI of the endpoint for the notification to be sent to., subsctiptionType: str(AppPackageOnBoarding/AppPacakgeOperationChange/AppPackageDeletion) # 'Subscribed notification type'}
@optional {appPkgFilter: [str]}
@returns(201) {id: str, subscriptionType: str, callbackUri: str(uri), _links: map{self: map{href: str(uri)}}} # Successful response for created subscription
@errors {400, 401, 403, 404, 406, 429}

@endpoint GET /subscriptions
@desc used to retrieve the information of subscriptions to individual application package resource in MEO
@returns(200) {_links: map{self: map{href: str(uri)}, subscriptions: [map]}} # List of zero or more subscriptions
@errors {400, 401, 403, 404, 406, 429}

@endpoint GET /subscriptions/{subscriptionId}
@desc Used to represent an individual subscription to notifications about application package changes.
@returns(200) {id: str, subscriptionType: str, callbackUri: str(uri), _links: map{self: map{href: str(uri)}}} # Representation of the resource.
@errors {400, 401, 403, 404, 406, 429}

@endpoint DELETE /subscriptions/{subscriptionId}
@desc Deletes the individual subscription to notifications about application package changes in MEO.
@returns(204)
@errors {401, 403, 404, 429}

@endgroup

@group user_defined_notification
@endpoint POST /user_defined_notification
@desc Registers a notification endpoint to notify application package operations
@required {id: str # '', notificationType: str(AppPackageOnBoarded/AppPacakgeEnabled/AppPacakgeDisabled/AppPackageDeleted) # Discriminator for the different notification types, subscriptionId: str # Identifier of the subscription related to this notification., timeStamp: map{nanoSeconds!: int(Uint32), seconds!: int(Uint32)}, appPkgId: str # Identifier of the onboarded application package., appDId: str # Identifier of this MEC application descriptor. This attribute shall be globally unique., operationalState: str(DISABLED/ENABLED), _links: map{subscription!: map{href!: str(uri)}} # Links to resources related to this resource.}
@returns(204)
@errors {401, 403, 404, 429}

@endgroup

@group app_packages
@endpoint GET /app_packages/{appPkgId}/appd
@desc Reads the content of the AppD of on-boarded individual application package resources.
@optional {filter: str # Attribute-based filtering parameters according to ETSI GS MEC 009, all_fields: str # Include all complex attributes in the response., fields: str # Complex attributes of AppPkgInfo to be included into the response, exclude_fields: str # Complex attributes of AppPkgInfo to be excluded from the response., exclude_default: str # Indicates to exclude the following complex attributes of AppPkgInfo from the response.}
@returns(200) Content of the AppD is returned.
@errors {400, 401, 403, 404, 406, 429}

@endgroup

@group onboarded_app_packages
@endpoint GET /onboarded_app_packages/{appDId}/appd
@desc Reads the content of the AppD of on-boarded individual application package resources.
@optional {filter: str # Attribute-based filtering parameters according to ETSI GS MEC 009, all_fields: str # Include all complex attributes in the response., fields: str # Complex attributes of AppPkgInfo to be included into the response, exclude_fields: str # Complex attributes of AppPkgInfo to be excluded from the response., exclude_default: str # Indicates to exclude the following complex attributes of AppPkgInfo from the response.}
@returns(200) Content of the AppD is returned.
@errors {400, 401, 403, 404, 406, 429}

@endgroup

@group app_packages
@endpoint GET /app_packages/{appPkgId}/package_content
@desc Fetch the onboarded application package content identified by appPkgId or appDId.
@returns(200) The payload body shall contain a copy of the file representing the AppD or a ZIP file that contains the file or multiple files representing the AppD.
@returns(206)
@errors {400, 401, 403, 404, 416, 406, 429}

@endpoint PUT /app_packages/{appPkgId}/package_content
@desc Uploads the content of application package.
@returns(202) The application package has been accepted for uploading, but the processing has not been completed.
@errors {400, 401, 403, 404, 406, 409, 429}

@endgroup

@group onboarded_app_packages
@endpoint GET /onboarded_app_packages/{appDId}/package_content
@desc Fetch the onboarded application package content identified by appPkgId or appDId.
@returns(200) The payload body shall contain a copy of the file representing the AppD or a ZIP file that contains the file or multiple files representing the AppD.
@returns(206)
@errors {400, 401, 403, 404, 416, 406, 429}

@endpoint PUT /onboarded_app_packages/{appDId}/package_content
@desc Uploads the content of application package.
@returns(202) The application package has been accepted for uploading, but the processing has not been completed.
@errors {400, 401, 403, 404, 406, 409, 429}

@endgroup

@end
