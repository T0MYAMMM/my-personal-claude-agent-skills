@optional {ServerlessCacheName: str, ServerlessCacheSnapshotName: str, SnapshotType: str, NextToken: str, MaxResults: int}
@returns(200) {NextToken: str?, ServerlessCacheSnapshots: [ServerlessCacheSnapshot]?}

@endpoint POST /
@desc Returns information about a specific serverless cache. If no identifier is specified, then the API returns information on all the serverless caches belonging to this Amazon Web Services account.
