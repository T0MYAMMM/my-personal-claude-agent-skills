or the HTTPS health check request. The default value is 443., requestPath: str # The request path of the HTTPS health check request. The default value is "/". Must comply with RFC3986., selfLink: str # [Output Only] Server-defined URL for the resource., timeoutSec: int(int32) # How long (in seconds) to wait before claiming failure. The default value is 5 seconds. It is invalid for timeoutSec to have a greater value than checkIntervalSec., unhealthyThreshold: int(int32) # A so-far healthy instance will be marked unhealthy after this many consecutive failures. The default value is 2.}
