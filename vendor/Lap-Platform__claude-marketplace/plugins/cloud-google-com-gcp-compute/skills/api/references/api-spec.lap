@returns(200) {associations: [map], creationTimestamp: str, description: str, displayName: str, fingerprint: str(byte), id: str(uint64), kind: str, name: str, parent: str, region: str, ruleTupleCount: int(int32), rules: [map], selfLink: str, selfLinkWithId: str, shortName: str} # Successful response

