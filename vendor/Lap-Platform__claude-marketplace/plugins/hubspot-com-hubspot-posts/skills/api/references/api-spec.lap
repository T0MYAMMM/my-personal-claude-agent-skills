vo-001/vun/vun-tz/wa/wae/wae-ch/wo/wo-sn/xh/xh-za/xog/xog-ug/yav/yav-cm/yi/yi-001/yo/yo-bj/yo-ng/yrl/yrl-br/yrl-co/yrl-ve/yue/yue-cn/yue-hk/za/zgh/zgh-ma/zh/zh-cn/zh-hans/zh-hant/zh-hk/zh-mo/zh-sg/zh-tw/zu/zu-za) # The explicitly defined ISO 639 language code of the post. If null, the post will default to the language of the parent blog., layoutSections: map # A structure detailing the layout sections of the blog post., linkRelCanonicalUrl: str # Optional override to set the URL to be used in the rel=canonical link tag on the page., mabExperimentId: str # Unique identifier of the MAB Experiment, metaDescription: str # A description that goes in <meta> tag on the page., name: str # The internal name of the post., pageExpiryDate: int(int64) # The date at which this blog post should expire and begin redirecting to another url or page., pageExpiryEnabled: bool # Boolean describing if the page expiration feature is enabled for this blog post., pageExpiryRedirectId: int(int64) # The ID of another page this blog post's url should redirect to once this blog post expires. Should only set this or pageExpiryRedirectUrl., pageExpiryRedirectUrl: str # The URL this blog post's url should redirect to once it expires. Should only set this or pageExpiryRedirectId., password: str # Set this to create a password protected page. Entering the password will be required to view the blog post., postBody: str # The HTML of the main post body., postSummary: str # The summary of the blog post that will appear on the main listing page., publicAccessRules: [map{}] # Rules for require member registration to access private content., publicAccessRulesEnabled: bool # Boolean to determine whether or not to respect publicAccessRules., publishDate: str(date-time) # The date (ISO8601 format) the blog post is to be published at., publishImmediately: bool # Set this to true if you want to be published immediately when the schedule publish endpoint is called, and to ignore the publish_date setting., rssBody: str # The contents of the RSS body for this Blog Post., rssSummary: str # The contents of the RSS summary for this Blog Post., slug: str # The URL slug of the blog post. This field is appended to the domain to construct the url of this post., state: str # An enumeration describing the current publish state of the post., tagIds: [int(int64)] # The IDs of the tags associated with this post., themeSettingsValues: map # A collection of settings specific to the theme applied to the blog post., translatedFromId: str # ID of the primary blog author this object was translated from., translations: map # A map of translations for the blog post, each associated with a specific language variation., updated: str(date-time) # The timestamp (ISO8601 format) when this Blog Post was updated., updatedById: str # The ID of the user that updated this Blog Post., url: str # A generated field representing the URL of this blog post., useFeaturedImage: bool # Boolean to determine if this post should use a featured image., widgetContainers: map # A data structure containing the data for all the modules inside the containers for this post. This will only be populated if the page has widget containers., widgets: map # A data structure containing the data for all the modules for this page.}
