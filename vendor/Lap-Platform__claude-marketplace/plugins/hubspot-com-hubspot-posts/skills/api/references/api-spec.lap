@endpoint POST /cms/v3/blogs/posts/{objectId}/draft/push-live
@desc Publish blog post draft
@required {objectId: str # The ID of the post to publish.}
@returns(204) No content

@endpoint POST /cms/v3/blogs/posts/{objectId}/draft/reset
@desc Reset post draft to the live version
@required {objectId: str # The ID of the blog post to reset.}
@returns(204) No content

@endpoint GET /cms/v3/blogs/posts/{objectId}/revisions
@desc Retrieves all previous versions of a post
@required {objectId: str # The ID of the blog post to retrieve previous versions of.}
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., before: str # A paging cursor token for retrieving previous pages., limit: int(int32) # The maximum number of results to return. Default is 100.}
@returns(200) {paging: map{next: map{after: str, link: str}, prev: map{before: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint GET /cms/v3/blogs/posts/{objectId}/revisions/{revisionId}
@desc Retrieve a previous version of a blog post
@required {objectId: str # The ID of the blog post., revisionId: str # The ID of the version to retrieve.}
@returns(200) {id: str, object: map{abStatus: str, abTestId: str, archivedAt: int(int64), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, blogAuthorId: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableGoogleAmpOutputOverride: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, password: str, postBody: str, postSummary: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, rssBody: str, rssSummary: str, slug: str, state: str, tagIds: [int(int64)], themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map}, updatedAt: str(date-time), user: map{email: str, fullName: str, id: str}} # successful operation

@endpoint POST /cms/v3/blogs/posts/{objectId}/revisions/{revisionId}/restore
@desc Restore a previous version
@required {objectId: str # The ID of the blog post., revisionId: str # The ID of the version to restore the blog post to.}
@returns(200) {abStatus: str, abTestId: str, archivedAt: int(int64), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, blogAuthorId: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableGoogleAmpOutputOverride: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, password: str, postBody: str, postSummary: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, rssBody: str, rssSummary: str, slug: str, state: str, tagIds: [int(int64)], themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@endpoint POST /cms/v3/blogs/posts/{objectId}/revisions/{revisionId}/restore-to-draft
@desc Restore a draft to a previous version
@required {objectId: str # The ID of the blog post., revisionId: int(int64) # The ID of the version to restore the blog post to.}
@returns(200) {abStatus: str, abTestId: str, archivedAt: int(int64), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, blogAuthorId: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableGoogleAmpOutputOverride: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, password: str, postBody: str, postSummary: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, rssBody: str, rssSummary: str, slug: str, state: str, tagIds: [int(int64)], themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@endpoint GET /cms/v3/blogs/tags/cursor
@optional {after: str, archived: bool, createdAfter: str(date-time), createdAt: str(date-time), createdBefore: str(date-time), limit: int(int32), property: str, sort: [str], updatedAfter: str(date-time), updatedAt: str(date-time), updatedBefore: str(date-time)}
@returns(200) successful operation

@endpoint GET /cms/v3/blogs/tags/cursor/query
@optional {after: str, archived: bool, createdAfter: str(date-time), createdAt: str(date-time), createdBefore: str(date-time), limit: int(int32), property: str, sort: [str], updatedAfter: str(date-time), updatedAt: str(date-time), updatedBefore: str(date-time)}
@returns(200) successful operation

@end
