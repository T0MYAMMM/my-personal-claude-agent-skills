g/xog-ug/yav/yav-cm/yi/yi-001/yo/yo-bj/yo-ng/yrl/yrl-br/yrl-co/yrl-ve/yue/yue-cn/yue-hk/za/zgh/zgh-ma/zh/zh-cn/zh-hans/zh-hant/zh-hk/zh-mo/zh-sg/zh-tw/zu/zu-za) # The explicitly defined ISO 639 language code of the post. If null, the post will default to the language of the parent blog., layoutSections: map # A structure detailing the layout sections of the blog post., linkRelCanonicalUrl: str # Optional override to set the URL to be used in the rel=canonical link tag on the page., mabExperimentId: str # Unique identifier of the MAB Experiment, metaDescription: str # A description that goes in <meta> tag on the page., name: str # The internal name of the post., pageExpiryDate: int(int64) # The date at which this blog post should expire and begin redirecting to another url or page., pageExpiryEnabled: bool # Boolean describing if the page expiration feature is enabled for this blog post., pageExpiryRedirectId: int(int64) # The ID of another page this blog post's url should redirect to once this blog post expires. Should only set this or pageExpiryRedirectUrl., pageExpiryRedirectUrl: str # The URL this blog post's url should redirect to once it expires. Should only set this or pageExpiryRedirectId., password: str # Set this to create a password protected page. Entering the password will be required to view the blog post., postBody: str # The HTML of the main post body., postSummary: str # The summary of the blog post that will appear on the main listing page., publicAccessRules: [map{}] # Rules for require member registration to access private content., publicAccessRulesEnabled: bool # Boolean to determine whether or not to respect publicAccessRules., publishDate: str(date-time) # The date (ISO8601 format) the blog post is to be published at., publishImmediately: bool # Set this to true if you want to be published immediately when the schedule publish endpoint is called, and to ignore the publish_date setting., rssBody: str # The contents of the RSS body for this Blog Post., rssSummary: str # The contents of the RSS summary for this Blog Post., slug: str # The URL slug of the blog post. This field is appended to the domain to construct the url of this post., state: str # An enumeration describing the current publish state of the post., tagIds: [int(int64)] # The IDs of the tags associated with this post., themeSettingsValues: map # A collection of settings specific to the theme applied to the blog post., translatedFromId: str # ID of the primary blog author this object was translated from., translations: map # A map of translations for the blog post, each associated with a specific language variation., updated: str(date-time) # The timestamp (ISO8601 format) when this Blog Post was updated., updatedById: str # The ID of the user that updated this Blog Post., url: str # A generated field representing the URL of this blog post., useFeaturedImage: bool # Boolean to determine if this post should use a featured image., widgetContainers: map # A data structure containing the data for all the modules inside the containers for this post. This will only be populated if the page has widget containers., widgets: map # A data structure containing the data for all the modules for this page.}
@returns(201) {abStatus: str, abTestId: str, archivedAt: int(int64), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, blogAuthorId: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableGoogleAmpOutputOverride: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, password: str, postBody: str, postSummary: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, rssBody: str, rssSummary: str, slug: str, state: str, tagIds: [int(int64)], themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@endpoint POST /cms/v3/blogs/posts/batch/archive
@desc Delete a batch of blog posts
@required {inputs: [str] # Strings to input.}
@returns(204) No content

@endpoint POST /cms/v3/blogs/posts/batch/create
@desc Create a batch of blog posts
@required {inputs: [map{abStatus!: str, abTestId!: str, archivedAt!: int(int64), archivedInDashboard!: bool, attachedStylesheets!: [map], authorName!: str, blogAuthorId!: str, campaign!: str, categoryId!: int(int32), contentGroupId!: str, contentTypeCategory!: str, created!: str(date-time), createdById!: str, currentState!: str, currentlyPublished!: bool, domain!: str, dynamicPageDataSourceId!: str, dynamicPageDataSourceType!: int(int32), dynamicPageHubDbTableId!: str, enableDomainStylesheets!: bool, enableGoogleAmpOutputOverride!: bool, enableLayoutStylesheets!: bool, featuredImage!: str, featuredImageAltText!: str, folderId!: str, footerHtml!: str, headHtml!: str, htmlTitle!: str, id!: str, includeDefaultCustomCss!: bool, language!: str, layoutSections!: map, linkRelCanonicalUrl!: str, mabExperimentId!: str, metaDescription!: str, name!: str, pageExpiryDate!: int(int64), pageExpiryEnabled!: bool, pageExpiryRedirectId!: int(int64), pageExpiryRedirectUrl!: str, password!: str, postBody!: str, postSummary!: str, publicAccessRules!: [map], publicAccessRulesEnabled!: bool, publishDate!: str(date-time), publishImmediately!: bool, rssBody!: str, rssSummary!: str, slug!: str, state!: str, tagIds!: [int(int64)], themeSettingsValues!: map, translatedFromId!: str, translations!: map, updated!: str(date-time), updatedById!: str, url!: str, useFeaturedImage!: bool, widgetContainers!: map, widgets!: map}] # JSON nodes to input.}
@returns(201) {completedAt: str(date-time), links: map, requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # successful operation
@returns(207) {completedAt: str(date-time), errors: [map], links: map, numErrors: int(int32), requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # multiple statuses

@endpoint POST /cms/v3/blogs/posts/batch/read
@desc Retrieve a batch of Blog Posts
@required {inputs: [str] # Strings to input.}
@optional {archived: bool # Specifies whether to return deleted blog posts Defaults to `false`.}
@returns(200) {completedAt: str(date-time), links: map, requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # successful operation
@returns(207) {completedAt: str(date-time), errors: [map], links: map, numErrors: int(int32), requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # multiple statuses

@endpoint POST /cms/v3/blogs/posts/batch/update
@desc Update a batch of Blog Posts
@required {inputs: [map{}] # JSON nodes to input.}
@optional {archived: bool # Specifies whether to update deleted Blog Posts. Defaults to `false`.}
@returns(200) {completedAt: str(date-time), links: map, requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # successful operation
@returns(207) {completedAt: str(date-time), errors: [map], links: map, numErrors: int(int32), requestedAt: str(date-time), results: [map], startedAt: str(date-time), status: str} # multiple statuses

@endpoint POST /cms/v3/blogs/posts/clone
@desc Clone a blog post
@required {id: str # ID of object to set as primary in multi-language group.}
@optional {cloneName: str # Name of the cloned object.}
@returns(200) {abStatus: str, abTestId: str, archivedAt: int(int64), archivedInDashboard: bool, attachedStylesheets: [map], authorName: str, blogAuthorId: str, campaign: str, categoryId: int(int32), contentGroupId: str, contentTypeCategory: str, created: str(date-time), createdById: str, currentState: str, currentlyPublished: bool, domain: str, dynamicPageDataSourceId: str, dynamicPageDataSourceType: int(int32), dynamicPageHubDbTableId: str, enableDomainStylesheets: bool, enableGoogleAmpOutputOverride: bool, enableLayoutStylesheets: bool, featuredImage: str, featuredImageAltText: str, folderId: str, footerHtml: str, headHtml: str, htmlTitle: str, id: str, includeDefaultCustomCss: bool, language: str, layoutSections: map, linkRelCanonicalUrl: str, mabExperimentId: str, metaDescription: str, name: str, pageExpiryDate: int(int64), pageExpiryEnabled: bool, pageExpiryRedirectId: int(int64), pageExpiryRedirectUrl: str, password: str, postBody: str, postSummary: str, publicAccessRules: [map], publicAccessRulesEnabled: bool, publishDate: str(date-time), publishImmediately: bool, rssBody: str, rssSummary: str, slug: str, state: str, tagIds: [int(int64)], themeSettingsValues: map, translatedFromId: str, translations: map, updated: str(date-time), updatedById: str, url: str, useFeaturedImage: bool, widgetContainers: map, widgets: map} # successful operation

@endpoint GET /cms/v3/blogs/posts/cursor
@optional {after: str, archived: bool, createdAfter: str(date-time), createdAt: str(date-time), createdBefore: str(date-time), limit: int(int32), property: str, sort: [str], updatedAfter: str(date-time), updatedAt: str(date-time), updatedBefore: str(date-time)}
@returns(200) successful operation

@endpoint GET /cms/v3/blogs/posts/cursor/query
@optional {after: str, archived: bool, createdAfter: str(date-time), createdAt: str(date-time), createdBefore: str(date-time), limit: int(int32), property: str, sort: [str], updatedAfter: str(date-time), updatedAt: str(date-time), updatedBefore: str(date-time)}
@returns(200) successful operation

@endpoint POST /cms/v3/blogs/posts/multi-language/attach-to-lang-group
@desc Attach post to a multi-language group
