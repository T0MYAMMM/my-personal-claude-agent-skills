@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Compute Admin Client
@base https://management.azure.com
@version 2018-02-09
@auth OAuth2
@endpoints 4
@toc subscriptions(4)

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Compute.Admin/locations/{location}/quotas/{quotaName}
@desc Returns the requested Compute quota.
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/providers/Microsoft.Compute.Admin/locations/{location}/quotas/{quotaName}
@desc Creates or Updates a Compute Quota.
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}/providers/Microsoft.Compute.Admin/locations/{location}/quotas/{quotaName}
@desc Deletes specified Compute quota
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Compute.Admin/locations/{location}/quotas
@desc Lists all Compute quotas.
@returns(200) OK

@end
