ting through results, starting at page 1, per_page: any # The number of results returned per page. Defaults to 20., sort: any # Provide a field to sort by. Use `-` for descending order., sort_hide_null: any # Hide null values on sorted column(s)., sort_null_only: any # Toggle that filters out all rows having sort column that is non-null, sort_nulls_last: any # Toggle that sorts null values last}

