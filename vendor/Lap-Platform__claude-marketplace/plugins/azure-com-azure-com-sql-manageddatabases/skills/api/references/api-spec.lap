@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2018-06-01-preview
@auth OAuth2
@common_fields {resourceGroupName: any # The name of the resource group that contains the resource. You can obtain this value from the Azure Resource Manager API or the portal., managedInstanceName: any # The name of the managed instance., subscriptionId: any # The subscription ID that identifies an Azure subscription., api-version: any # The API version to use for the request.}
@endpoints 7
@toc subscriptions(7)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/databases/{databaseName}/restoreDetails/{restoreDetailsName}
@desc Gets managed database restore details.
@required {databaseName: any # The name of the database., restoreDetailsName: any # The name of the restore details to retrieve.}
@returns(200) Successfully retrieved restore details.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/databases
@desc Gets a list of managed databases.
@returns(200) Successfully retrieved the list of databases.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/databases/{databaseName}
@desc Gets a managed database.
@required {databaseName: any # The name of the database.}
@returns(200) Successfully retrieved the specified managed database.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/databases/{databaseName}
@desc Creates a new database or updates an existing database.
@required {databaseName: any # The name of the database., parameters: map # The requested database resource state.}
@returns(200) Successfully updated the database.
@returns(202) Accepted
@returns(201) Successfully created the database.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/databases/{databaseName}
@desc Deletes a managed database.
@required {databaseName: any # The name of the database.}
@returns(200) Successfully deleted the managed database.
@returns(202) Deleting the managed database is in progress.
@returns(204) The specified managed database does not exist.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/databases/{databaseName}
@desc Updates an existing database.
@required {databaseName: any # The name of the database., parameters: map # The requested database resource state.}
@returns(200) Successfully updated the database.
@returns(202) Updating the managed database is in progress.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/managedInstances/{managedInstanceName}/databases/{databaseName}/completeRestore
@desc Completes the restore operation on a managed database.
@required {databaseName: any # The name of the database., parameters: map # The definition for completing the restore of this managed database.}
@returns(200) Successfully completed restore request.
@returns(202) Completing restore request is in progress.

@end
