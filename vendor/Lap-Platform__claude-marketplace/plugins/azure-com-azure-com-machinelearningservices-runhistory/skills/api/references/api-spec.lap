@returns(200) Success

@endpoint POST /history/v1.0/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.MachineLearningServices/workspaces/{workspaceName}/experiments/{experimentName}/runs/{runId}/artifacts/batch/metadata
@desc Create a batch of empty Artifacts.
@required {experimentName: any # The experiment name., runId: any # The identifier of the Run.}
@optional {artifactPaths: map # The list of artifact paths.}
@returns(200) The Batch Artifacts are created successfully.

@endpoint POST /history/v1.0/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.MachineLearningServices/workspaces/{workspaceName}/experiments/{experimentName}/runs/{runId}/metrics
@desc Post Metric to a Run.
@required {experimentName: any # The experiment name., runId: any # The identifier for a run.}
@optional {metricDto: map # Details of the metric which will be added to the Run Id.}
@returns(200) The Run Metric is posted successfully.

@endpoint POST /history/v1.0/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.MachineLearningServices/workspaces/{workspaceName}/experiments/{experimentName}/runs/{runId}/batch/metrics
@desc Post Metrics to a Run.
@required {experimentName: any # The experiment name., runId: any # The identifier for a run.}
@optional {batchMetricDto: map # Details of the Metrics which will be added to the Run Id.}
@returns(200) The Run Metrics are posted successfully.

@endpoint GET /history/v1.0/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.MachineLearningServices/workspaces/{workspaceName}/experiments/{experimentName}/metrics/{metricId}
@desc Get Metric details.
@required {experimentName: any # The experiment name., metricId: any # The identifier for a Metric.}
@returns(200) Success

@endpoint POST /history/v1.0/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.MachineLearningServices/workspaces/{workspaceName}/experiments/{experimentName}/metrics:query
@desc Get all Run Metrics for the specific Experiment.
@required {experimentName: any # The experiment name.}
@optional {queryParams: map # Query Parameters for data sorting and filtering., MergeStrategyType: any # The type of merge strategy. Currently supported strategies are: None - all logged values are returned as individual metrics. MergeToVector - merges multiple values into a vector of values. Default - the system determines the behavior., MergeStrategyOptions: any # Controls behavior of the merge strategy in certain cases; e.g. when a metric is not merged., MergeStrategySettings.Version: any # The strategy settings version., MergeStrategySettings.SelectMetrics: any # Defines how to select metrics when merging them together.}
@returns(200) The Run Metrics are returned successfully.

@end
