@required {findingId: str}
@returns(200) {finding: AuditFinding?{findingId: str?, taskId: str?, checkName: str?, taskStartTime: str(timestamp)?, findingTime: str(timestamp)?, severity: str?, nonCompliantResource: NonCompliantResource?{resourceType: str?, resourceIdentifier: ResourceIdentifier?{deviceCertificateId: str?, caCertificateId: str?, cognitoIdentityPoolId: str?, clientId: str?, policyVersionIdentifier: PolicyVersionIdentifier?, account: str?, iamRoleArn: str?, roleAliasArn: str?, issuerCertificateIdentifier: IssuerCertificateIdentifier?, deviceCertificateArn: str?}, additionalInfo: map<str, str>?: any}, relatedResources: [RelatedResource]?, reasonForNonCompliance: str?, reasonForNonComplianceCode: str?, isSuppressed: bool?}}

