@group audit
@endpoint GET /audit/configuration
@desc Gets information about the Device Defender audit settings for this account. Settings include how audit notifications are sent and which audit checks are enabled or disabled. Requires permission to access the DescribeAccountAuditConfiguration action.
@returns(200) {roleArn: str?, auditNotificationTargetConfigurations: map<str,AuditNotificationTarget>?, auditCheckConfigurations: map<str,AuditCheckConfiguration>?}

@endpoint GET /audit/findings/{findingId}
