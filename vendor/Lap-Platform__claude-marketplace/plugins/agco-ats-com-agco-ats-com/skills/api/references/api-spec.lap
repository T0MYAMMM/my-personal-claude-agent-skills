@endpoint GET /api/v2/activities
@desc Get Activities
@optional {limit: any # Optional. The page limit.  If not specified, the default page limit is 10., offset: any # Optional. The page offset.  If not specified, the default page offset is 0., isIncludeDeleted: any # Does it include deleted activity, or not}
@returns(200) OK

@endpoint POST /api/v2/activities
@desc Create an Activity
@required {activity: map # The activity to create.  The ActivityID will be assigned on creation of the Activity.}
@returns(200) OK

@endpoint GET /api/v2/activities/{activityID}
@desc Get an Activity by ID
@required {activityID: any # The ID of the Activity to get.}
@optional {isIncludeDeleted: any # Does it include deleted activity, or not}
@returns(200) OK

@endpoint PUT /api/v2/activities/{activityID}
@desc Update an Activity
@required {activityID: any # The id of the activity to update, activity: map # The updated activity}
@returns(204) No Content

@endpoint DELETE /api/v2/activities/{activityID}
@desc Mark the delete flag for the Activity
@required {activityID: any # The id of the activity to delete}
@returns(204) No Content

