@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Marketing Emails
@base https://api.hubapi.com
@version v3
@auth OAuth2 | ApiKey private-app in header
@endpoints 19
@toc marketing(19)

@endpoint GET /marketing/v3/emails/
@desc Get all marketing emails
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., archived: bool # Specifies whether to return archived emails. Defaults to `false`., campaign: str, createdAfter: str(date-time) # Only return emails created after the specified time., createdAt: str(date-time) # Only return emails created at exactly the specified time., createdBefore: str(date-time) # Only return emails created before the specified time., includedProperties: [str], includeStats: bool # Include statistics with emails., isPublished: bool # Filter by published/draft emails. All emails will be returned if not present., limit: int(int32) # The maximum number of results to return. Default is 100., marketingCampaignNames: bool, publishedAfter: str(date-time), publishedAt: str(date-time), publishedBefore: str(date-time), sort: [str] # Specifies which fields to use for sorting results. Valid fields are `name`, `createdAt`, `updatedAt`, `createdBy`, `updatedBy`. `createdAt` will be used by default., type: str(AB_EMAIL/AUTOMATED_AB_EMAIL/AUTOMATED_EMAIL/BATCH_EMAIL/BLOG_EMAIL/BLOG_EMAIL_CHILD/FEEDBACK_CES_EMAIL/FEEDBACK_CUSTOM_EMAIL/FEEDBACK_CUSTOM_SURVEY_EMAIL/FEEDBACK_NPS_EMAIL/FOLLOWUP_EMAIL/LEADFLOW_EMAIL/LOCALTIME_EMAIL/MANAGE_PREFERENCES_EMAIL/MARKETING_SINGLE_SEND_API/MEMBERSHIP_EMAIL_VERIFICATION_EMAIL/MEMBERSHIP_FOLLOW_UP_EMAIL/MEMBERSHIP_OTP_LOGIN_EMAIL/MEMBERSHIP_PASSWORD_RESET_EMAIL/MEMBERSHIP_PASSWORD_SAVED_EMAIL/MEMBERSHIP_PASSWORDLESS_AUTH_EMAIL/MEMBERSHIP_REGISTRATION_EMAIL/MEMBERSHIP_REGISTRATION_FOLLOW_UP_EMAIL/MEMBERSHIP_VERIFICATION_EMAIL/OPTIN_EMAIL/OPTIN_FOLLOWUP_EMAIL/RESUBSCRIBE_EMAIL/RSS_EMAIL/RSS_EMAIL_CHILD/SINGLE_SEND_API/SMTP_TOKEN/TICKET_EMAIL) # Email types to be filtered by. Multiple types can be included. All emails will be returned if not present., updatedAfter: str(date-time) # Only return emails last updated after the specified time., updatedAt: str(date-time) # Only return emails last updated at exactly the specified time., updatedBefore: str(date-time) # Only return emails last updated before the specified time., variantStats: bool, workflowNames: bool}
@returns(200) {paging: map{next: map{after: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint POST /marketing/v3/emails/
@desc Create a new marketing email
