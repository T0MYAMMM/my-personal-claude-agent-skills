@desc Publish or send a marketing email
@required {emailId: str}
@returns(204) No content

@endpoint GET /marketing/v3/emails/{emailId}/revisions
@desc Get revisions of a marketing email
@required {emailId: str # The marketing email ID.}
@optional {after: str # The cursor token value to get the next set of results. You can get this from the `paging.next.after` JSON property of a paged response containing more results., before: str # The cursor token value to get the previous set of results. You can get this from the `paging.prev.before` JSON property of a paged response containing more results., limit: int(int32) # The maximum number of results to return. Default is 100.}
@returns(200) {paging: map{next: map{after: str, link: str}, prev: map{before: str, link: str}}, results: [map], total: int(int32)} # successful operation

@endpoint GET /marketing/v3/emails/{emailId}/revisions/{revisionId}
