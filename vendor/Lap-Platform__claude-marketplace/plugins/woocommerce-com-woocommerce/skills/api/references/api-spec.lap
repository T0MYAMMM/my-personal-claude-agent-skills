@endpoint GET /orders/{orderId}/notes
@desc This API helps you to view all notes for an order.
@required {orderId: int # ID of order for notes to return}
@optional {context: str(view/edit)=view # Scope under which the request is made; determines fields present in response. Options: view and edit. Default is view., page: int=1 # Current page of the collection. Default is 1., per_page: int=10 # Maximum number of items to be returned in result set. Default is 10.}
@returns(200) Returns list of order notes.
@errors {401: Unauthorized, 404: Not Found}

@endpoint POST /orders/{orderId}/notes
@desc This API helps you to create a new order note.
@required {orderId: int # ID of order for note to create}
@optional {id: int # Unique identifier for the resource. read-only, author: str # Note author. Displays as "system" for WooCommerce-generated notes, otherwise the author name. read-only, date_created: str(date-time) # The date the note was created, in the site's timezone. read-only, date_created_gmt: str(date-time) # The date the note was created, as GMT. read-only, note: str # Note content. mandatory, customer_note: bool # If true, the note will be visible to customers. mandatory}
@returns(201) {id: int, author: str, date_created: str(date-time), date_created_gmt: str(date-time), note: str, customer_note: bool} # Returns created order note.
@errors {401: Unauthorized, 404: Not Found}

@endpoint GET /orders/{orderId}/notes/{noteId}
@desc This API lets you retrieve and view a specific order note by ID.
@required {orderId: int # ID of order for note to return, noteId: int # ID of note to return}
@returns(200) {id: int, author: str, date_created: str(date-time), date_created_gmt: str(date-time), note: str, customer_note: bool} # Returns specified order note.
@errors {401: Unauthorized, 404: Not Found}

@endpoint DELETE /orders/{orderId}/notes/{noteId}
@desc This API helps you delete an order note.
@required {orderId: int # ID of order for note to delete, noteId: int # ID of note to delete, force: bool=True # Required to be true, as resource does not support trashing.}
@returns(200) {id: int, author: str, date_created: str(date-time), date_created_gmt: str(date-time), note: str, customer_note: bool} # Returns deleted order note.
@errors {401: Unauthorized, 404: Not Found}

@endgroup

@group products
@endpoint GET /products/reviews
@desc List all product reviews
@optional {context: str(view/edit)=view # Scope under which the request is made; determines fields present in response. Options: view and edit. Default is view., page: int=1 # Current page of the collection. Default is 1., per_page: int=10 # Maximum number of items to be returned in result set. Default is 10., search: str # Limit results to those matching a string., after: str(date-time) # Limit response to reviews published after a given ISO8601 compliant date., before: str(date-time) # Limit response to reviews published before a given ISO8601 compliant date., exclude: [int] # Ensure result set excludes specific IDs., include: [int] # Limit result set to specific IDs., offset: int # Offset the result set by a specific number of items., order: str(asc/desc)=desc # Order sort attribute ascending or descending. Options: asc and desc. Default is desc., orderby: str(date/date_gmt/id/slug/include/product)=date_gmt # Sort collection by resource attribute. Options: date, date_gmt, id, slug, include and product. Default is date_gmt., reviewer: [int] # Ensure result set excludes specific IDs., reviewer_exclude: [int] # Limit result set to specific IDs., reviewer_email: [int] # Limit result set to that from a specific author email., product: [int] # Limit result set to reviews assigned to specific product IDs, status: str(all/hold/approved/spam/trash)=approved # Limit result set to reviews assigned a specific status. Options: all, hold, approved, spam and trash. Default is approved.}
@returns(200) Returns list of product reviews
@errors {400: Bad Request, 401: Unauthorized, 404: Not Found}

@endpoint POST /products/reviews
@desc Create a product review
@optional {id: int # Unique identifier for the resource., date_created: str(date-time) # The date the review was created, in the site's timezone., date_created_gmt: str(date-time) # The date the review was created, as GMT., product_id: int # Unique identifier for the product that the review belongs to., status: str(approved/hold/spam/unspam/trash/untrash)=approved # Status of the review., reviewer: str # Reviewer name., reviewer_email: str(email) # Reviewer email., review: str # The content of the review., rating: int # Review rating (0 to 5)., verified: bool # Shows if the reviewer bought the product or not.}
@returns(201) {id: int, date_created: str(date-time), date_created_gmt: str(date-time), product_id: int, status: str, reviewer: str, reviewer_email: str(email), review: str, rating: int, verified: bool} # Returns created product review

@endpoint GET /products/reviews/{reviewId}
@desc Retrieve a product review
@required {reviewId: int}
@returns(200) {id: int, date_created: str(date-time), date_created_gmt: str(date-time), product_id: int, status: str, reviewer: str, reviewer_email: str(email), review: str, rating: int, verified: bool} # Returns specified product review

@endpoint PUT /products/reviews/{reviewId}
@desc Update a product review
@required {reviewId: int}
@optional {id: int # Unique identifier for the resource., date_created: str(date-time) # The date the review was created, in the site's timezone., date_created_gmt: str(date-time) # The date the review was created, as GMT., product_id: int # Unique identifier for the product that the review belongs to., status: str(approved/hold/spam/unspam/trash/untrash)=approved # Status of the review., reviewer: str # Reviewer name., reviewer_email: str(email) # Reviewer email., review: str # The content of the review., rating: int # Review rating (0 to 5)., verified: bool # Shows if the reviewer bought the product or not.}
@returns(200) {id: int, date_created: str(date-time), date_created_gmt: str(date-time), product_id: int, status: str, reviewer: str, reviewer_email: str(email), review: str, rating: int, verified: bool} # Returns updated product review

@endpoint DELETE /products/reviews/{reviewId}
@desc Delete a product review
@required {reviewId: int, force: bool=True # Required to be true, as resource does not support trashing.}
@returns(200) {id: int, date_created: str(date-time), date_created_gmt: str(date-time), product_id: int, status: str, reviewer: str, reviewer_email: str(email), review: str, rating: int, verified: bool} # Product review deleted

@endpoint POST /products/reviews/batch
@desc Batch update product reviews
@optional {create: [map{id: int, date_created: str(date-time), date_created_gmt: str(date-time), product_id: int, status: str, reviewer: str, reviewer_email: str(email), review: str, rating: int, verified: bool}], update: [map{id: int, date_created: str(date-time), date_created_gmt: str(date-time), product_id: int, status: str, reviewer: str, reviewer_email: str(email), review: str, rating: int, verified: bool}], delete: [int]}
@returns(200) Returns batch operation result

@endgroup

