@errors {400: Bad Request, 401: Unauthorized}

@endgroup

@group system_status
@endpoint GET /system_status
@desc This API helps you to view the system status.
@returns(200) {environment: map, database: map, active_plugins: [map], inactive_plugins: [map], dropins_mu_plugins: [map], theme: map, settings: map, security: map, pages: [map]} # Returns system status.
@errors {401: Unauthorized}

@endpoint GET /system_status/tools
@desc This API helps you to view all system status tools.
@returns(200) Returns list of system status tools.
@errors {401: Unauthorized}

@endpoint GET /system_status/tools/{id}
@desc This API lets you retrieve and view a specific system status tool by ID.
@required {id: str # ID of system status tool to return}
@returns(200) {id: str, name: str, action: str, description: str, success: bool, message: str} # Returns specified system status tool.
@errors {401: Unauthorized, 404: Not Found}

@endpoint PUT /system_status/tools/{id}
@desc This API helps you to run a system status tool.
@required {id: str # ID of system status tool to run}
@returns(200) {id: str, name: str, action: str, description: str, success: bool, message: str} # Returns system status tool execution result.
@errors {400: Bad Request, 401: Unauthorized, 404: Not Found}

@endgroup

@end
