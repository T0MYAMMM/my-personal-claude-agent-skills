@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Members API
@version v1
@endpoints 43
@hint download_for_search
@toc api(43)

@endpoint GET /api/Location/Browse/{locationType}/{locationName}
@desc Returns a list of locations, both parent and child
@required {locationType: any # Location by type of location, locationName: str # Location by name specified}
@returns(200) {value: any?, links: [map]?} # OK
@errors {400: Bad Request, 404: Not Found}

@endpoint GET /api/Location/Constituency/Search
@desc Returns a list of constituencies
@optional {searchText: str # Constituencies containing serach term in their name, skip: int(int32)=0 # The number of records to skip from the first, default is 0, take: int(int32)=20 # The number of records to return, default is 20. Maximum is 20}
@returns(200) {items: [map]?, totalResults: int(int32), resultContext: str?, skip: int(int32), take: int(int32), links: [map]?, resultType: any?} # OK
@errors {400: Bad Request}

@endpoint GET /api/Location/Constituency/{id}
@desc Returns a constituency by ID
@required {id: int(int32) # Constituency by ID}
@returns(200) {value: any?, links: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/Location/Constituency/{id}/Synopsis
@desc Returns a synopsis by constituency ID
@required {id: int(int32) # Synopsis by constituency ID}
@returns(200) {value: str?, links: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/Location/Constituency/{id}/Representations
@desc Returns a list of representations by constituency ID
@required {id: int(int32) # Representations by constituency ID}
@returns(200) {value: [map]?, links: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/Location/Constituency/{id}/Geometry
@desc Returns geometry by constituency ID
@required {id: int(int32) # Geometry by constituency ID}
@returns(200) {value: str?, links: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/Location/Constituency/{id}/ElectionResults
@desc Returns a list of election results by constituency ID
@required {id: int(int32) # Elections results by constituency ID}
@returns(200) {value: [map]?, links: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/Location/Constituency/{id}/ElectionResult/{electionId}
@desc Returns an election result by constituency and election id
@required {id: int(int32) # Election result by constituency id, electionId: int(int32) # Election result by election id}
@returns(200) {value: any?, links: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/Location/Constituency/{id}/ElectionResult/Latest
@desc Returns latest election result by constituency id
@required {id: int(int32) # Latest election result by constituency id}
@returns(200) {value: any?, links: [map]?} # OK
@errors {404: Not Found, 400: Bad Request}

@endpoint GET /api/LordsInterests/Register
@desc Returns a list of registered interests
@optional {searchTerm: str # Registered interests containing search term, page: int(int32) # Page of results to return, default 0. Results per page 20., includeDeleted: bool=False # Registered interests that have been deleted}
@returns(200) {items: [map]?, totalResults: int(int32), resultContext: str?, skip: int(int32), take: int(int32), links: [map]?, resultType: any?} # OK
@errors {400: Bad Request}

@endpoint GET /api/LordsInterests/Staff
@desc Returns a list of staff
@optional {searchTerm: str # Staff containing search term, page: int(int32) # Page of results to return, default 0. Results per page 20.}
@returns(200) {items: [map]?, totalResults: int(int32), resultContext: str?, skip: int(int32), take: int(int32), links: [map]?, resultType: any?} # OK
@errors {400: Bad Request}

@endpoint GET /api/Members/Search
@desc Returns a list of current members of the Commons or Lords
@optional {Name: str # Members where name contains term specified, Location: str # Members where postcode or geographical location matches the term specified Searches for current constituencies with full postcode, or outward code; and name of constituency If there are no results based on above, searches for all current and past constituencies in specified area of UK. To explicitly search by area (ignoring name of constituency); please prefix query with `region:`., PostTitle: str # Members which have held the post specified, PartyId: int(int32) # Members which are currently affiliated with party with party ID, House: any # Members where their most recent house is the house specified, ConstituencyId: int(int32) # Members which currently hold the constituency with constituency id, NameStartsWith: str # Members with surname begining with letter(s) specified, Gender: str # Members with the gender specified, MembershipStartedSince: str(date-time) # Members who started on or after the date given, MembershipEnded.MembershipEndedSince: str(date-time) # Members who left the House on or after the date given, MembershipEnded.MembershipEndReasonIds: [int(int32)], MembershipInDateRange.WasMemberOnOrAfter: str(date-time) # Members who were active on or after the date specified, MembershipInDateRange.WasMemberOnOrBefore: str(date-time) # Members who were active on or before the date specified, MembershipInDateRange.WasMemberOfHouse: any # Members who were active in the house specifid, IsEligible: bool # Members currently Eligible to sit in their House, IsCurrentMember: bool # Members who are current or former members, PolicyInterestId: int(int32) # Members with specified policy interest, Experience: str # Members with specified experience, skip: int(int32)=0 # The number of records to skip from the first, default is 0, take: int(int32)=20 # The number of records to return, default is 20. Maximum is 20}
@returns(200) {items: [map]?, totalResults: int(int32), resultContext: str?, skip: int(int32), take: int(int32), links: [map]?, resultType: any?} # OK
@errors {400: Bad Request}

@endpoint GET /api/Members/SearchHistorical
@desc Returns a list of members of the Commons or Lords
@optional {name: str # Members with names containing the term specified, dateToSearchFor: str(date-time) # Members that were an active member of the Commons or Lords on the date specified, skip: int(int32)=0 # The number of records to skip from the first, default is 0, take: int(int32)=20 # The number of records to return, default is 20. Maximum is 20}
@returns(200) {items: [map]?, totalResults: int(int32), resultContext: str?, skip: int(int32), take: int(int32), links: [map]?, resultType: any?} # OK
@errors {400: Bad Request}

