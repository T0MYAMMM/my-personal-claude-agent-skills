@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api FRC Events
@base https://frc-api.firstinspires.org/v3.0
@auth Basic username:password
@endpoints 19
@toc root(1), {season}(18)

@group root
@endpoint GET /
@desc API Index
@returns(200) {currentSeason: int, maxSeason: int, name: str, apiVersion: str, status: str} # Details about the API
@errors {500: unexpected error}

@endgroup

@group {season}
@endpoint GET /{season}
@desc Season Summary
@auth Basic username:password
@optional {If-Modified-Since: str # <p>(Required) </p>}
@returns(200) {eventCount: int, gameName: str, kickoff: str, rookieStart: int, teamCount: int, frcChampionships: [map]} # Details about a season
@errors {500: unexpected error}

@endpoint GET /{season}/events
@desc Event Listings
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Events: [map], eventCount: int} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/districts
@desc District Listings
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {districts: [map], districtCount: int} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/teams
@desc Team Listings
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {teams: [map], teamCountTotal: int, teamCountPage: int, pageCurrent: int, pageTotal: int} # List of teams
@errors {500: unexpected error}

@endpoint GET /{season}/avatars
@desc Team Avatar Listings
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {teams: [map], teamCountTotal: int, teamCountPage: int, pageCurrent: int, pageTotal: int} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/awards/event/{eventCode}
@desc Event Awards
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Awards: [map]} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/awards/list
@desc Awards Listings
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {awards: [map]} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/awards/team/{teamNumber}
@desc Team Awards
@auth Basic username:password
@returns(200) {Awards: [map]} # Response
@returns(200) {code: int, message: str} # unexpected error

@endpoint GET /{season}/awards/eventteam/{eventCode}/{teamNumber}
@desc Event Team Awards
@auth Basic username:password
@returns(200) {Awards: [map]} # Response
@returns(200) {code: int, message: str} # unexpected error

@endpoint GET /{season}/scores/{eventCode}/{tournamentLevel}
@desc Score Details
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {MatchScores: [map]} # 2015 Score Details
@returns(200) {MatchScores: [map]} # 2016 Score Details
@returns(200) {MatchScores: [map]} # 2017 Score Details
@returns(200) {MatchScores: [map]} # 2018 Score Details
@returns(200) {MatchScores: [map]} # 2019 Score Details
@returns(200) {MatchScores: [map]} # 2020 Score Details
@returns(200) {MatchScores: [map]} # 2024 Score Details
@errors {500: unexpected error}

@endpoint GET /{season}/matches/{eventCode}
@desc Event Match Results
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Matches: [map]} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/rankings/district/qualPerformanceCalculation
@desc Qual Performance Points
@returns(200) Qual Performance Points

@endpoint GET /{season}/rankings/district/allianceSelectionCalculation
@desc Alliance Selection Points
@returns(200) Alliance Selection Points

@endpoint GET /{season}/rankings/district/playoffAdvancementCalculation
@desc Playoff Advancement Points
@returns(200) Playoff Advancement Points

@endpoint GET /{season}/rankings/{eventCode}
@desc Event Rankings
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Rankings: [map]} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/rankings/district
@desc District Rankings
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {districtRanks: [map], rankingCountTotal: int, rankingCountPage: int, pageCurrent: int, pageTotal: int} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/schedule/{eventCode}
@desc Event Schedule
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Schedule: [map]} # Response
@errors {500: unexpected error}

@endpoint GET /{season}/alliances/{eventCode}
@desc Event Alliances
@auth Basic username:password

@endgroup

@end
