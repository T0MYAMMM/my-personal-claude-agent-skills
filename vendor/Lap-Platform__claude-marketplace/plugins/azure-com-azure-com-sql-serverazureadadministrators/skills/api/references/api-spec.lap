@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SqlManagementClient
@base https://management.azure.com
@version 2018-06-01-preview
@auth OAuth2
@endpoints 4
@toc subscriptions(4)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/administrators/{administratorName}
@desc Gets a server Administrator.
@required {serverName: any # The name of the server., administratorName: any # The name of server active directory administrator.}
@returns(200) Successfully retrieved a specified Azure Active Directory administrator.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/administrators/{administratorName}
@desc Creates a new Server Active Directory Administrator or updates an existing server Active Directory Administrator.
@required {serverName: any # The name of the server., administratorName: any, parameters: map # The required parameters for creating or updating an Active Directory Administrator.}
@returns(200) Successfully updated a Azure Active Directory administrator.
@returns(202) Accepted
@returns(201) Successfully created a Azure Active Directory administrator.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/administrators/{administratorName}
@desc Deletes an existing server Active Directory Administrator.
@required {serverName: any # The name of the server., administratorName: any # The name of server active directory administrator.}
@returns(200) Successfully deleted the Azure Active Directory administrator.
@returns(202) Accepted
@returns(204) The specified Azure Active Directory administrator does not exist.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/administrators
@desc Gets a list of server Administrators.
@required {serverName: any # The name of the server.}
@returns(200) Successfully retrieved the list of Azure Active Directory administrators.

@end
