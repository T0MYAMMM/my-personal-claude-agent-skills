@returns(200) OK - Returns an array of deny assignments.

@endgroup

@group {scope}
@endpoint GET /{scope}/providers/Microsoft.Authorization/denyAssignments/{denyAssignmentId}
@desc Get the specified deny assignment.
@required {scope: any # The scope of the deny assignment., denyAssignmentId: any # The ID of the deny assignment to get.}
@returns(200) OK - Returns information about the deny assignment.

@endgroup

@group {denyAssignmentId}
@endpoint GET /{denyAssignmentId}
@desc Gets a deny assignment by ID.
@required {denyAssignmentId: any # The fully qualified deny assignment ID. For example, use the format, /subscriptions/{guid}/providers/Microsoft.Authorization/denyAssignments/{denyAssignmentId} for subscription level deny assignments, or /providers/Microsoft.Authorization/denyAssignments/{denyAssignmentId} for tenant level deny assignments.}
@returns(200) OK - Returns the deny assignment.

@endgroup

