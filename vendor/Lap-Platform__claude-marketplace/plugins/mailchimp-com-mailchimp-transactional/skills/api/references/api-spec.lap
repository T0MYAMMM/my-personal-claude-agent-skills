@returns(200) {id: int, url: str(uri), auth_key: str?, description: str?, events: [str], created_at: str, last_sent_at: str?, batches_sent: int, events_sent: int, last_error: str?} # Deleted webhook configuration
@errors {401: Invalid API key, 404: Unknown webhook}

