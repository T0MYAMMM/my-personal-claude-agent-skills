@group inbound
@endpoint POST /inbound/domains
@desc List inbound domains
@required {key: str # A valid Mandrill API key}
@returns(200) The inbound domains associated with the account
@errors {401: Invalid API key}

@endpoint POST /inbound/add-domain
@desc Add inbound domain
@returns(200) {domain: str, created_at: str, valid_mx: bool} # Information about the domain
@errors {401: Invalid API key}

@endpoint POST /inbound/check-domain
@desc Check domain settings
@returns(200) {domain: str, created_at: str, valid_mx: bool} # Information about the inbound domain
@errors {401: Invalid API key, 404: Unknown inbound domain}

@endpoint POST /inbound/delete-domain
@desc Delete inbound domain
@returns(200) {domain: str, created_at: str, valid_mx: bool} # Information about the deleted domain
@errors {401: Invalid API key, 404: Unknown inbound domain}

@endpoint POST /inbound/routes
@desc List routes
@returns(200) The routes associated with the domain or phone
@errors {401: Invalid API key, 404: Unknown inbound domain or SMS program}

@endpoint POST /inbound/add-route
@desc Add route
@returns(200) {id: str, pattern: str, url: str(uri)} # The added route information
@errors {401: Invalid API key, 404: Unknown inbound domain or SMS program}

@endpoint POST /inbound/update-route
@desc Update mailbox route
@returns(200) {id: str, pattern: str, url: str(uri)} # The updated mailbox route information
@errors {401: Invalid API key, 404: Unknown inbound route}

@endpoint POST /inbound/delete-route
@desc Delete mailbox route
@returns(200) {id: str, pattern: str, url: str(uri)} # The deleted mailbox route information
@errors {401: Invalid API key, 404: Unknown inbound route}

@endpoint POST /inbound/send-raw
@desc Send mime document
@returns(200) Processing results for each recipient or null if no recipients processed
@errors {401: Invalid API key, 404: Unknown inbound domain}

@endgroup

@group mctemplates
@endpoint POST /mctemplates/info
@desc Get Mailchimp Transactional template information
@required {key: str # Valid API key, mc_template_id: int # Mailchimp template ID}
@returns(200) {mc_template_id: int, mc_template_name: str, labels: [str], code: str, subject: str, from_email: str, from_name: str, text: str, publish_code: str, publish_text: str, published_at: str(date-time), created_at: str(date-time), updated_at: str(date-time), draft_updated_at: str(date-time), is_broken_template: bool} # Template information retrieved successfully
@errors {401: Invalid API key, 404: Template not found}

@endpoint POST /mctemplates/list
@desc List Mailchimp Transactional templates
@required {key: str # Valid API key}
@optional {search_query: str # Optional search query to filter templates}
@returns(200) List of templates retrieved successfully
@errors {401: Invalid API key}

@endpoint POST /mctemplates/render
@desc Render a Mailchimp Transactional template
@required {key: str # Valid API key, mc_template_id: int # Mailchimp template ID}
@optional {mc_template_version: str(published/draft)=published # Template version - "published" or "draft". Note: requesting "published" when the template has not been published will return a 404 error., merge_vars: [map{name: str, content: str}] # Merge variables to inject into template}
@returns(200) {html: str} # Template rendered successfully
@errors {400:MC_Exception_ValidationError: Invalid mc_template_version parameter, 401:Invalid_Key: Invalid API key, 404:Unknown_Template: Template not found}

@endpoint POST /mctemplates/time-series
@desc Get Mailchimp Transactional template time series
@required {key: str # Valid API key, mc_template_id: int # Mailchimp template ID}
@returns(200) Time series data retrieved successfully (may be empty array if template never used)
@errors {401: Invalid API key, 404: Template not found}

@endgroup

@group messages
@endpoint POST /messages/send
@desc Send a new transactional message through the Transactional API.
@returns(200) an array of objects for each recipient containing the key "email" with the email address, and details of the message status for that recipient
@errors {401:Invalid_Key: Invalid API key, 402:MC_Exception_PaymentRequired: Payment required, 404:Unknown_Subaccount: Subaccount not found}

@endpoint POST /messages/send-template
@desc Send a new transactional message using a template
@returns(200) Per-recipient send results
@errors {401:Invalid_Key: Invalid API key, 402:MC_Exception_PaymentRequired: Payment required, 404: Error 404}

@endpoint POST /messages/send-mc-template
@desc Send a new transactional message using a Mailchimp Transactional template
@returns(200) Per-recipient send results
@errors {400:MC_Exception_ValidationError: Validation error, 401:Invalid_Key: Invalid API key, 402:MC_Exception_PaymentRequired: Payment required, 404: Error 404}

@endpoint POST /messages/search
@desc Search recently sent messages
@returns(200) Messages matching the search query (can include both email and SMS messages)
@errors {401:Invalid_Key: Invalid API key, 503: Service unavailable}

@endpoint POST /messages/search-time-series
@desc Get time series data for message search
@returns(200) Hourly stats for matching messages
@errors {401:Invalid_Key: Invalid API key, 503: Service unavailable}

@endpoint POST /messages/info
@desc Get information about a single sent message
@returns(200) Information about the message (email or SMS)
@errors {401:Invalid_Key: Invalid API key, 404:Unknown_Message: Message not found}

@endpoint POST /messages/content
@desc Get the full content of a sent message
@returns(200) The content of the message (email or SMS)
@errors {401:Invalid_Key: Invalid API key, 404:Unknown_Message: Message not found}

@endpoint POST /messages/parse
@desc Parse a MIME message
@returns(200) {headers: map, text: str, text_flowed: bool, attachments: [map], from_email: str(email), from_name: str, html: str, to: [map], subject: str} # The parsed message content
@errors {401:Invalid_Key: Invalid API key, 422: Validation error}

@endpoint POST /messages/send-raw
@desc Send a raw MIME message through Mandrill
@returns(200) Per-recipient send results
@errors {401:Invalid_Key: Invalid API key, 402:MC_Exception_PaymentRequired: Payment required, 404:Unknown_Subaccount: Subaccount not found}

@endpoint POST /messages/list-scheduled
@desc Get scheduled emails
@returns(200) A list of up to 1000 scheduled emails
@errors {401:Invalid_Key: Invalid API key}

@endpoint POST /messages/cancel-scheduled
@desc Cancel a scheduled email
@returns(200) {_id: str, created_at: str, send_at: str, from_email: str(email), to: str(email), subject: str} # Information about the scheduled email that was cancelled
@errors {401:Invalid_Key: Invalid API key, 404:Unknown_Message: Message not found}

@endpoint POST /messages/reschedule
@desc Reschedule a scheduled email
@returns(200) {_id: str, created_at: str, send_at: str, from_email: str(email), to: str(email), subject: str} # Information about the scheduled email that was rescheduled
@errors {401:Invalid_Key: Invalid API key, 404:Unknown_Message: Message not found}

@endpoint POST /messages/send-sms
@desc Send SMS message
@returns(200) SMS sending results
@errors {400:Unknown_Subaccount: Unknown subaccount, 401:Invalid_Key: Invalid API key}

@endgroup

@group senders
@endpoint POST /senders/delete-domain
@desc Delete a sender domain
@returns(200) {domain: str(hostname), created_at: str(date-time), last_tested_at: str(date-time), spf: map{valid: bool, valid_after: str(date-time), error: str}, dkim: map{valid: bool, valid_after: str(date-time), error: str}, dkim2: map{valid: bool, valid_after: str(date-time), error: str}, dmarc: map{valid: bool, error: str}, verified_at: str(date-time), valid_signing: bool, verify_txt_key: str} # Information about the deleted sender domain
@errors {401: Invalid API key, 403: Cannot delete verified domain - please login to confirm deletion, 404: Unknown domain}

@endgroup

@group urls
@endpoint POST /urls/delete-tracking-domain
@desc Delete a tracking domain
@required {key: str # A valid API key, domain: str(hostname) # An existing tracking domain name}
@returns(200) {domain: str(hostname), created_at: str, last_tested_at: str, cname: map{valid: bool, valid_after: str, error: any}, valid_tracking: bool} # Information about the deleted tracking domain
@errors {401: Invalid API key, 403: Cannot delete verified tracking domain - please login to confirm deletion, 404: Unknown tracking domain}

@endgroup

@end
