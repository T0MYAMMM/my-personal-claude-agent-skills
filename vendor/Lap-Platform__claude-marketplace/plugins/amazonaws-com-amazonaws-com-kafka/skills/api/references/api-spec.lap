@returns(200) {VpcConnectionArn: str?, State: str?, Authentication: str?, VpcId: str?, ClientSubnets: [str]?, SecurityGroups: [str]?, CreationTime: str(timestamp)?, Tags: map<str,str>?}

@endgroup

