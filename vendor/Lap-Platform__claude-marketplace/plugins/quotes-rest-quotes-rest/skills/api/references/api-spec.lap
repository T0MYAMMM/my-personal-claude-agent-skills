@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api They Said So Quotes API
@base https://quotes.rest
@version 5.1
@auth Bearer bearer
@endpoints 45
@hint download_for_search
@toc qod(5), quote(32), qshow(8)

@group qod
@endpoint GET /qod
@desc Gets `Quote of the Day` (QOD). Optional `category` param determines the category of returned quote of the day
@optional {category: str(string) # QOD Category (Used in public QOD only), language: str(string)=en # Language of the QOD. The language must be supported in our QOD system., id: str(string) # QOD defition id (Used in private QOD only)}
@returns(200) {success: str, contents: any} # 200  response
@errors {400: 400  response}

@endpoint PUT /qod
@desc Create a private `Quote of the Day` service.
@required {title: str(string) # Title of the Quote of the day category}
@optional {repeat_after: int(integer)=30 # How many days after the quotes can repeat? If you are setting this up from your private collection make sure you have more quotes that meet the filter conditions than the days you specify here., authors: str(array) # Comma seperated author names. Quotes will be chosen from one of these authors., private: bool=False # Should apply the filters to the private collection. Default is public quotes in the platform., language: str(string)=en # Quotes language., sfw: bool=False # Consider only quotes marked as "sfw" (Safe for work).}
@returns(200) {success: str, contents: [any]} # 200  response
@errors {400: 400  response, 403: 403  No access response}

@endpoint PATCH /qod
@desc Update an existing private `Quote of the Day` definition.
@required {title: str(string) # Title of the Quote of the day category}
@optional {repeat_after: int(integer)=30 # How many days after the quotes can repeat? If you are setting this up from your private collection make sure you have more quotes that meet the filter conditions than the days you specify here., authors: str(array) # Comma seperated author names. Quotes will be chosen from one of these authors., private: bool=False # Should apply the filters to the private collection. Default is public quotes in the platform., language: str(string)=en # Quotes language., sfw: bool=False # Consider only quotes marked as "sfw" (Safe for work).}
@returns(200) {success: str, contents: any} # 200  response
@errors {400: 400  response, 403: 403  No access response}

@endpoint GET /qod/categories
@desc Gets a list of `Quote of the Day` Categories.
@optional {language: str(string)=en # Language of the QOD category. The language must be supported in our QOD system., detailed: bool=False # Return detailed information of the categories. Note the data format changes between the two values of this switch.}
@returns(200) 200  response
@errors {400: 400  response}

@endpoint GET /qod/languages
@desc Gets a list of supported languages for `Quote of the Day`.
@returns(200) 200  response

@endgroup

@group quote
@endpoint GET /quote/random
@desc Gets a `Random Quote`. When you are in a hurry this is what you call to get a random famous quote.
@optional {language: str(string)=en # Language of the Quote. The language must be supported in our system., limit: int(integer)=1 # No of quotes to return. The max limit depends on the subscription level.}
@returns(200) {success: str, contents: any} # 200  response
@errors {401: 401  response}

@endpoint GET /quote/search
@desc Search for a `Quote` in They Said So platform. Optional `category` , `author`, `minlength`, `maxlength` params determines the filters applied while searching for the quote.
@optional {category: str(string) # Quote Category, author: str(string) # Quote Author, minlength: int(int32)=100 # Quote minimum Length, maxlength: int(int32)=300 # Quote maximum Length, query: str(string) # keyword to search for in the quote, private: bool=False # Should search private collection? Default searches public collection., language: str(string)=en # Language of the Quote. The language must be supported in our system., limit: int(integer)=1 # No of quotes to return. The max limit depends on the subscription level., sfw: bool=False # Should search only SFW (Safe For Work) quotes?}
@returns(200) {success: str, contents: any} # 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/categories/popular
@desc Gets a list of popular `Quote` Categories.
@optional {start: int(int32)=0 # Response is paged. This parameter controls where response starts the listing at, limit: int(int32)=5 # Response is paged. This parameter controls how many is returned in the result. The maximum depends on the subscription level.}
@returns(200) 200  response

@endpoint GET /quote/categories/search
@desc Gets a list of `Quote` Categories matching the query string.
@optional {query: str(string)=0 # Text string to search for in the categories, start: int(int32)=0 # Response is paged. This parameter controls where response starts the listing at, limit: int(int32)=2 # Response is paged. This parameter controls how many is returned in the result. The maximum depends on the subscription level.}
@returns(200) 200  response

@endpoint GET /quote/authors/popular
@desc Gets a list of popular author names in the system.
@optional {language: str(string)=en # Language. A same author may have quotes in two or more different languages. So for example 'Mahatma Gandhi' may be returned for language "en"(English), and "மஹாத்மா காந்தி" may be returned when the language is "ta" (Tamil)., detailed: bool=False # Should return detailed author information such as `birthday`, `death date`, `occupation`, `description` etc. Only available at certain subscription levels., start: int(int32)=0 # Response is paged. This parameter controls where response starts the listing at, limit: int(int32)=5 # Response is paged. This parameter controls how many is returned in the result. The maximum depends on the subscription level.}
@returns(200) 200  response
@errors {400: 400  response}

@endpoint GET /quote/authors/search
@desc Gets a list of author names in the system.
@optional {query: str(string) # Text string to search for in author names, language: str(string)=en # Language. A same author may have quotes in two or more different languages. So for example 'Mahatma Gandhi' may be returned for language "en"(English), and "மஹாத்மா காந்தி" may be returned when the language is "ta" (Tamil)., detailed: bool=False # Should return detailed author information such as `birthday`, `death date`, `occupation`, `description` etc. Only available at certain subscription levels., start: int(int32)=0 # Response is paged. This parameter controls where response starts the listing at, limit: int(int32)=1 # Response is paged. This parameter controls how many is returned in the result. The maximum depends on the subscription level.}
@returns(200) 200  response
@errors {400: 400  response}

@endpoint PUT /quote
@desc Add a new quote to your private collection.
@required {quote: str(string) # Quote}
@optional {author: str(string) # Quote Author, tags: str(string) # Comma Separated tags, language: str(string)=en # Language. If not supplied an auto detection mechanism will be used to detect a language.}
@returns(200) 200  response
@errors {401: 401  response}

@endpoint POST /quote
@desc Add a new quote to your private collection. Same as 'PUT' but added since some clients don't handle PUT well.
@required {quote: str(string) # Quote}
@optional {author: str(string) # Quote Author, tags: str(string) # Comma Separated tags, language: str(string)=en # Language. If not supplied an auto detection mechanism will be used to detect a language.}
@returns(200) 200  response
@errors {401: 401  response}

@endpoint PATCH /quote
@desc Update a quote
@required {id: str(string) # Quote ID}
@optional {quote: str(string) # Quote, author: str(string) # Quote Author, language: str(string)=en # Language. If not supplied an auto detection mechanism will be used to detect a language., tags: str # Comma Separated tags}
@returns(200) 200  response
@errors {401: 401  response}

@endpoint GET /quote
@desc Gets a `Quote` with a given `id`.
@optional {id: str(string) # Quote ID}
@returns(200) {success: str, contents: any} # 200  response
@errors {401: 401  response}

@endpoint DELETE /quote
@desc Delete a quote. The user needs to be the owner of the quote to be able to delete it.
@required {id: str(string) # Quote ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/list
@desc Get the list of quotes in your private collection.
@optional {start: int(int32)=0 # Response is paged. This parameter controls where response starts the listing at, limit: int(int32)=10 # Response is paged. This parameter controls how many is returned in the result.}
@returns(200) 200  response
@errors {401: 401  response}

@endpoint POST /quote/tags/add
@desc Add a tag to a given Quote.
@required {id: str(string) # Quote ID, tags: str(string) # Comma Separated tags}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /quote/tags/remove
@desc Remove a tag from a given quote.
@required {id: str(string) # Quote ID, tags: str(string) # Comma Separated tags}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/like/toggle
@desc Toggle the user like of the given Quote as a user of the API Key.
@required {quote_id: str(string) # Quote ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/bookmark/toggle
@desc Toggle the user bookmark of the given Quote as a user of the API Key.
@required {quote_id: str(string) # Quote ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endgroup

@group qshow
@endpoint PUT /qshow
@desc Create and add a new qshow to your private collection.
@required {title: str(string) # Qshow title}
@optional {description: str(string) # Qshow description, tags: [str] # Tags for the qshow}
@returns(200) 200  response
@errors {401: 401  response}

@endpoint GET /qshow
@desc Gets a details about a qshow.
@required {id: str(string) # Qshow ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint PATCH /qshow
@desc Update an existing qshow.
@required {id: str(string) # Qshow ID}
@optional {title: str(string) # Qshow title, description: str(string) # Qshow description, tags: [str] # Tags for the qshow}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint DELETE /qshow
@desc Delete a qshow.
@required {id: str(string) # Qshow ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /qshow/quotes/add
@desc Add a quote to a given Qshow.
@required {id: str(string) # Qshow ID, quoteid: str(string) # Quote ID to add the qshow collection}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /qshow/quotes/remove
@desc Remove a quote to a given Qshow.
@required {id: str(string) # Qshow ID, quoteid: str(string) # Quote ID to remove from the qshow collection}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /qshow/quotes
@desc Get the quotes in a given Qshow.
@required {id: str(string) # Qshow ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /qshow/list
@desc Get the list of Qshows in They Said So platform.
@optional {start: int(int32)=0 # Response is paged. This parameter controls where response starts the listing at, public: bool=False # Should include public qshows or not in the list}
@returns(200) 200  response
@errors {401: 401  response}

@endgroup

@group quote
@endpoint PUT /quote/image
@desc Create a new quote image for a given quote. Choose background colors/images , choose different font styles and generate a beautiful quote image. Did you just had a feeling of being a god or what?!
@required {quote_id: str(string) # Quote id}
@optional {bgimage_id: str(string)=theysaidso_default_background_image # Background Image id ( Will override bgcolor if supplied), bg_color: str(string) # Background Color(if background image id is not supplied), font_id: str(string)=theysaidso_default_font # Font id, text_color: str(string) # Text Color, text_size: str(string) # Text/font size, halign: str(string)=center # Horizontal text Alignment Value, valign: str(string)=center # Vertical text Alignment Value, width: int(integer) # Image Width(By default this takes the width of the background image), height: int(integer) # Image Height(By default this takes the height of the background image), branding: bool=False # Disable They Said So branding (Only available in certain subscription levels. Ignored in other levels), include_transparent_layer: bool=True # Should include a transparent layer between the text and the background image? This helps when the background image is bright and obscures the text.}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/image
@desc Gets a Quote image for a given id. Response can be an image file as a binary or a base64 encoded contents wrapped in json. `TODO`
@required {id: str(string) # Quote Image id}
@optional {binary: bool=True # Should the response be a direct file download of the image or a base64 encoded image file wrapped in json?}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint DELETE /quote/image
@desc Delete a quote image. The user needs to be the owner of the quote image to be able to delete it.
@required {id: str(string) # Quote Image ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/image/search
@desc Gets a Random Quote image. Optional `category` param determines the category of quote used in the image. Optional `author` param gets the quote image of a given author.
@optional {category: str(string) # Quote Category, author: str(string) # Quote Author, private: bool=False # Should search private collection. Default searches public image collection.}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /quote/image/background
@desc Add an image for use later as a quote background image.
@returns(200) 200  response
@errors {401: 401  response}

@endpoint DELETE /quote/image/background
@desc Delete a background image file. The user needs to be the owner of the background image to be able to delete it.
@required {id: str(string) # Font ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/image/background/search
@desc Searches for a background image with a given tag.
@optional {query: str(string) # Tag string}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/image/background/list
@desc Lists background images in your private collection.
@optional {start: int(integer) # Response is paged. This parameter determines where the response should start.}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /quote/image/background/tags/add
@desc Add a tag to a given Image.
@required {id: str(string) # Image ID, tags: str(string) # Comma Separated tags}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /quote/image/background/tags/remove
@desc Remove a tag from a given Image.
@required {id: str(string) # Image ID, tags: str(string) # Comma Separated tags}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /quote/image/font
@desc Add a font file for use later in creating a quote image. This is essentially a `PUT` but not many clients handle PUT with binary stream i.e. a file, gracefully.
@returns(200) 200  response
@errors {401: 401  response}

@endpoint DELETE /quote/image/font
@desc Delete a font file. The user needs to be the owner of the font to be able to delete it.
@required {id: str(string) # Font ID}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/image/font/search
@desc Searches for a font with a given tag.
@optional {query: str(string) # Tag string}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint GET /quote/image/font/list
@desc Lists background images in your private collection.
@optional {start: int(integer) # Response is paged. This parameter determines where the response should start.}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /quote/image/font/tags/add
@desc Add a tag to a given font.
@required {id: str(string) # Font ID, tags: str(string) # Comma Separated tags}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endpoint POST /quote/image/font/tags/remove
@desc Remove a tag from a given Font.
@required {id: str(string) # Font ID, tags: str(string) # Comma Separated tags}
@returns(200) 200  response
@errors {401: 401  response, 404: 404  response}

@endgroup

@end
