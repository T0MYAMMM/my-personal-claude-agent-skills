@returns(200) {defaultWorkflow: str, description: str, draft: bool, id: int(int64), issueTypeMappings: map, issueTypes: map, lastModified: str, lastModifiedUser: any, name: str, originalDefaultWorkflow: str, originalIssueTypeMappings: map, self: str(uri), updateDraftIfNeeded: bool} # Returned if the request is successful.
