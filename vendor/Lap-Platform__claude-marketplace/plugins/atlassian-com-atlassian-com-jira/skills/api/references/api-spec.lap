@optional {nextPageToken: str # The cursor for pagination, maxResults: int(int32)=50 # The maximum number of results to return. Must be an integer between 1 and 200.}
@returns(200) {projects: map{nextPageToken: str, values: [map]}, workflowSchemeId: str} # Returned if the request is successful.
@errors {400: Returned if the request is not valid., 401: Returned if the authentication credentials are incorrect or missing, or the caller doesn't have permissions to perform the operation., 404: Returned if the workflow scheme with the given ID does not exist.}

@endpoint GET /rest/api/3/worklog/deleted
@desc Get IDs of deleted worklogs
@optional {since: int(int64)=0 # The date and time, as a UNIX timestamp in milliseconds, after which deleted worklogs are returned.}
@returns(200) {lastPage: bool, nextPage: str(uri), self: str(uri), since: int(int64), until: int(int64), values: [map]} # Returned if the request is successful.
@errors {401: Returned if the authentication credentials are incorrect or missing.}

@endpoint POST /rest/api/3/worklog/list
@desc Get worklogs
@required {ids: [int(int64)] # A list of worklog IDs.}
@optional {expand: str= # Use [expand](#expansion) to include additional information about worklogs in the response. This parameter accepts `properties` that returns the properties of each worklog.}
@returns(200) Returned if the request is successful.
@errors {400: Returned if the request contains more than 1000 worklog IDs or is empty., 401: Returned if the authentication credentials are incorrect or missing.}
@example_request {"ids":[1,2,5,10]}

@endpoint GET /rest/api/3/worklog/updated
@desc Get IDs of updated worklogs
@optional {since: int(int64)=0 # The date and time, as a UNIX timestamp in milliseconds, after which updated worklogs are returned., expand: str= # Use [expand](#expansion) to include additional information about worklogs in the response. This parameter accepts `properties` that returns the properties of each worklog.}
@returns(200) {lastPage: bool, nextPage: str(uri), self: str(uri), since: int(int64), until: int(int64), values: [map]} # Returned if the request is successful.
@errors {401: Returned if the authentication credentials are incorrect or missing.}

@endpoint GET /rest/atlassian-connect/1/addons/{addonKey}/properties
@desc Get app properties
@required {addonKey: str # The key of the app, as defined in its descriptor.}
@returns(200) {keys: [map]} # Returned if the request is successful.
@errors {401: Returned if the authentication credentials are incorrect or missing.}

@endpoint DELETE /rest/atlassian-connect/1/addons/{addonKey}/properties/{propertyKey}
@desc Delete app property
@required {addonKey: str # The key of the app, as defined in its descriptor., propertyKey: str # The key of the property.}
@returns(204) Returned if the request is successful.
@errors {400: Returned if the property key is longer than 127 characters., 401: Returned if the authentication credentials are incorrect or missing., 404: Returned if the property is not found or doesn't belong to the app.}

@endpoint GET /rest/atlassian-connect/1/addons/{addonKey}/properties/{propertyKey}
@desc Get app property
@required {addonKey: str # The key of the app, as defined in its descriptor., propertyKey: str # The key of the property.}
@returns(200) {key: str, value: any} # Returned if the request is successful.
@errors {400: Returned if the property key is longer than 127 characters., 401: Returned if the authentication credentials are incorrect or missing., 404: Returned if the property is not found or doesn't belong to the app.}

@endpoint PUT /rest/atlassian-connect/1/addons/{addonKey}/properties/{propertyKey}
@desc Set app property
@required {addonKey: str # The key of the app, as defined in its descriptor., propertyKey: str # The key of the property.}
@returns(200) {message: str, statusCode: int} # Returned if the property is updated.
@returns(201) {message: str, statusCode: int} # Returned is the property is created.
@errors {400: Returned if:   * the property key is longer than 127 characters.   * the value is not valid JSON.   * the value is longer than 32768 characters., 401: Returned if the authentication credentials are incorrect or missing.}

@endpoint DELETE /rest/atlassian-connect/1/app/module/dynamic
@desc Remove modules
@optional {moduleKey: [str] # The key of the module to remove. To include multiple module keys, provide multiple copies of this parameter. For example, `moduleKey=dynamic-attachment-entity-property&moduleKey=dynamic-select-field`. Nonexistent keys are ignored.}
@returns(204) Returned if the request is successful.
@errors {401: Returned if the call is not from a Connect app.}

@endpoint GET /rest/atlassian-connect/1/app/module/dynamic
@desc Get modules
@returns(200) {modules: [map]} # Returned if the request is successful.
@errors {401: Returned if the call is not from a Connect app.}

@endpoint POST /rest/atlassian-connect/1/app/module/dynamic
@desc Register modules
@required {modules: [map] # A list of app modules in the same format as the `modules` property in the [app descriptor](https://developer.atlassian.com/cloud/jira/platform/app-descriptor/).}
@returns(200) Returned if the request is successful.
@errors {400: Returned if: * any of the provided modules is invalid. For example, required properties are missing. * any of the modules conflict with registered dynamic modules or modules defined in the app descriptor. For example, there are duplicate keys.  Details of the issues encountered are included in the error message., 401: Returned if the call is not from a Connect app.}

@endpoint PUT /rest/atlassian-connect/1/migration/field
@desc Bulk update custom field value
@required {Atlassian-Transfer-Id: str(uuid) # The ID of the transfer.}
