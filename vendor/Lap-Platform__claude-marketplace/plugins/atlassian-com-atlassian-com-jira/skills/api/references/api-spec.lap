@returns(200) {invalidRules: [str(uuid)], validRules: [map], workflowEntityId: str(uuid)} # Returned if the request is successful.
@errors {400: Returned if the request is not valid., 403: Returned if the authorisation credentials are incorrect or missing.}

@endpoint GET /rest/atlassian-connect/1/migration/{connectKey}/{jiraIssueFieldsKey}/task
@desc Get Connect issue field migration task
@required {connectKey: str # The key of the Connect app that contains the Jira issue field being migrated., jiraIssueFieldsKey: str # The module key of the Connect issue field being migrated.}
@returns(200) {description: str, elapsedRuntime: int(int64), finished: str(date-time), id: str, lastUpdate: str(date-time), message: str, progress: int(int64), result: any, self: str(uri), started: str(date-time), status: str, submitted: str(date-time), submittedBy: int(int64)} # Returned if the request is successful and a migration task is found.
@errors {401: Returned if the authentication credentials are incorrect or missing., 404: Returned if: * no migrated Forge module with the given key is found. * no ongoing migration task exists for the custom field.}

@endpoint GET /rest/atlassian-connect/1/service-registry
@desc Retrieve the attributes of service registries
@required {serviceIds: [str] # The ID of the services (the strings starting with "b:" need to be decoded in Base64).}
@returns(200) Returned if the request is successful.
@errors {400: Returned if the request is invalid., 401: The request needs to be authenticated., 403: The request isn't authorized., 500: The endpoint failed internally., 501: The endpoint isn't ready for receiving requests., 504: The upstream service is busy.}

@endpoint GET /rest/forge/1/app/properties
@desc Get app property keys (Forge)
@returns(200) {keys: [map]} # Returned if the request is successful.
@errors {401: Returned if the authentication credentials are incorrect or missing., 403: Returned if the request isn't made directly by an app or if it's an impersonated request.}

@endpoint DELETE /rest/forge/1/app/properties/{propertyKey}
@desc Delete app property (Forge)
@required {propertyKey: str # The key of the property.}
@returns(204) Returned if the request is successful.
@errors {400: Returned if the property key is longer than 127 characters., 401: Returned if the authentication credentials are incorrect or missing., 403: Returned if the request isn't made directly by an app or if it's an impersonated request., 404: Returned if the property isn't found or doesn't belong to the app.}

@endpoint GET /rest/forge/1/app/properties/{propertyKey}
@desc Get app property (Forge)
@required {propertyKey: str # The key of the property.}
@returns(200) {key: str, value: any} # Returned if the request is successful.
@errors {400: Returned if the property key is longer than 127 characters., 401: Returned if the authentication credentials are incorrect or missing., 403: Returned if the request isn't made directly by an app or if it's an impersonated request., 404: Returned if the property isn't found or doesn't belong to the app.}

@endpoint PUT /rest/forge/1/app/properties/{propertyKey}
@desc Set app property (Forge)
@required {propertyKey: str # The key of the property.}
@returns(200) {message: str, statusCode: int} # Returned if the property is updated.
@returns(201) {message: str, statusCode: int} # Returned is the property is created.
@errors {400: Returned if:   * the property key is longer than 127 characters.   * the value isn't valid JSON.   * the value is longer than 32768 characters., 401: Returned if the authentication credentials are incorrect or missing., 403: Returned if the request isn't made directly by an app or if it's an impersonated request.}

@endpoint POST /rest/internal/api/latest/worklog/bulk
@desc Get worklogs by issue id and worklog id
@optional {requests: [map{issueId: int(int64), worklogId: int(int64)}] # A list of issue and worklog ID pairs.}
@returns(200) {worklogs: [map]} # Returned if the request is successful.
@errors {400: Returned if the request contains more than 1000 worklog pairs, is empty, or has invalid format., 401: Returned if the authentication credentials are incorrect or missing., 500: Returned if there is an internal server error.}

@end
