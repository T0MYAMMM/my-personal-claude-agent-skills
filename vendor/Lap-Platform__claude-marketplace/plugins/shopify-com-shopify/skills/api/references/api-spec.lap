@endpoint GET /admin/api/2020-04/products/{product_id}/images/count.json
@desc Get a count of all product images
@required {product_id: str # product_id}
@optional {since_id: any # Restrict results to after the specified ID}
@returns(200)

@endpoint GET /admin/api/2020-04/products/{product_id}/images/{image_id}.json
@desc Get a single product image by id
@required {product_id: str # product_id, image_id: str # image_id}
@optional {fields: any # comma-separated list of fields to include in the response}
@returns(200)

@endpoint PUT /admin/api/2020-04/products/{product_id}/images/{image_id}.json
@desc Modify an existing product image
@required {product_id: str # product_id, image_id: str # image_id}
@returns(200)
@example_request {"image":{"id":850703190,"position":2,"alt":"new alt tag content"}}

@endpoint DELETE /admin/api/2020-04/products/{product_id}/images/{image_id}.json
@desc https://shopify.dev/docs/admin-api/rest/reference/products/product-image#destroy-2020-04
@required {product_id: str # product_id, image_id: str # image_id}
@returns(200)

@endpoint GET /admin/api/2020-07/products/{product_id}/images.json
@desc Get all product images
@required {product_id: str # product_id}
@optional {since_id: any # Restrict results to after the specified ID, fields: any # comma-separated list of fields to include in the response}
@returns(200)

@endpoint POST /admin/api/2020-07/products/{product_id}/images.json
@desc Create a new product image
@required {product_id: str # product_id}
@returns(200)
