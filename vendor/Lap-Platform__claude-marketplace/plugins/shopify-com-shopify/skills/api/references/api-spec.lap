@endpoint GET /admin/api/2020-01/gift_cards.json
@desc Retrieves a list of gift cards. Note: As of version 2019-10, this endpoint implements pagination by using links that are provided in the response header. Sending the page parameter will return an error. To learn more, see Making requests to paginated REST Admin API endpoints.
@optional {status: any # Retrieve gift cards with a given status. Valid values:                                              enabled: Restrict results to only enabled gift cards                         disabled: Restrict results to only disabled gift cards, limit: any # The maximum number of results to show.                   (default: 50, maximum: 250), since_id: any # Restrict results to after the specified ID., fields: any # Show only certain fields, specified by a comma-separated list of field names.}
@returns(200)

@endpoint POST /admin/api/2020-01/gift_cards.json
@desc Creates a gift card
@returns(200)
@example_request {"gift_card":{"note":"This is a note","initial_value":100,"code":"ABCD EFGH IJKL MNOP","template_suffix":"gift_cards.birthday.liquid"}}

@endpoint GET /admin/api/2020-01/gift_cards/{gift_card_id}.json
@desc Retrieves a single gift card by its ID
@required {gift_card_id: str # gift_card_id}
@returns(200)

@endpoint PUT /admin/api/2020-01/gift_cards/{gift_card_id}.json
@desc Updates an existing gift card.
@required {gift_card_id: str # gift_card_id}
@returns(200)
@example_request {"gift_card":{"id":48394658,"note":"Updating with a new note"}}

@endpoint GET /admin/api/2020-01/gift_cards/count.json
@desc Retrieves a count of gift cards
@optional {status: any # Count gift cards with a given status. Valid values:                                              enabled: Count only enabled gift cards                         disabled: Count only disabled gift cards}
@returns(200)

@endpoint POST /admin/api/2020-01/gift_cards/{gift_card_id}/disable.json
@desc Disables a gift card. Disabling a gift card can't be undone.
@required {gift_card_id: str # gift_card_id}
@returns(200)
@example_request {"gift_card":{"id":48394658}}

@endpoint GET /admin/api/2020-01/gift_cards/search.json
@desc Searches for gift cards that match a supplied query. The following fields are indexed by search:
