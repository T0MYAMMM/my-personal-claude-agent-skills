@endpoint GET /admin/api/unstable/products/{product_id}/images/count.json
@desc Get a count of all product images
@required {product_id: str # product_id}
@optional {since_id: any # Restrict results to after the specified ID}
@returns(200)

@endpoint GET /admin/api/unstable/products/{product_id}/images/{image_id}.json
@desc Get a single product image by id
@required {product_id: str # product_id, image_id: str # image_id}
@optional {fields: any # comma-separated list of fields to include in the response}
@returns(200)

@endpoint PUT /admin/api/unstable/products/{product_id}/images/{image_id}.json
@desc Modify an existing product image
@required {product_id: str # product_id, image_id: str # image_id}
@returns(200)
@example_request {"image":{"id":850703190,"position":2,"alt":"new alt tag content"}}

@endpoint DELETE /admin/api/unstable/products/{product_id}/images/{image_id}.json
@desc https://shopify.dev/docs/admin-api/rest/reference/products/product-image#destroy-unstable
@required {product_id: str # product_id, image_id: str # image_id}
@returns(200)

@endpoint GET /admin/api/2020-01/smart_collections.json
@desc Retrieves a list of smart collections. Note: As of version 2019-10, this endpoint implements pagination by using links that are provided in the response header. To learn more, see Making requests to paginated REST Admin API endpoints.
@optional {limit: any # The number of results to show.                   (default: 50, maximum: 250), ids: any # Show only the smart collections specified by a comma-separated list of IDs., since_id: any # Restrict results to after the specified ID., title: any # Show smart collections with the specified title., product_id: any # Show smart collections that includes the specified product., handle: any # Filter results by smart collection handle., updated_at_min: any # Show smart collections last updated after this date. (format: 2014-04-25T16:15:47-04:00), updated_at_max: any # Show smart collections last updated before this date. (format: 2014-04-25T16:15:47-04:00), published_at_min: any # Show smart collections published after this date. (format: 2014-04-25T16:15:47-04:00), published_at_max: any # Show smart collections published before this date. (format: 2014-04-25T16:15:47-04:00), published_status: any # Filter results based on the published status of smart collections.                   (default: any)                                              published: Show only published smart collections.                         unpublished: Show only unpublished smart collections.                         any: Show all smart collections., fields: any # Show only certain fields, specified by a comma-separated list of field names.}
@returns(200)

@endpoint POST /admin/api/2020-01/smart_collections.json
@desc Creates a new smart collection using the specified rules.
@returns(200)
@example_request {"smart_collection":{"title":"IPods","rules":[{"column":"title","relation":"starts_with","condition":"iPod"}]}}

@endpoint GET /admin/api/2020-01/smart_collections/count.json
@desc Retrieves a count of smart collections
@optional {title: any # Show smart collections with the specified title., product_id: any # Show smart collections that include the specified product., updated_at_min: any # Show smart collections last updated after this date. (format: 2014-04-25T16:15:47-04:00), updated_at_max: any # Show smart collections last updated before this date.  (format: 2014-04-25T16:15:47-04:00), published_at_min: any # Show smart collections published after this date.  (format: 2014-04-25T16:15:47-04:00), published_at_max: any # Show smart collections published before this date.  (format: 2014-04-25T16:15:47-04:00), published_status: any # Filter results based on the published status of smart collections.                   (default: any)                                              published: Show only published smart collections.                         unpublished: Show only unpublished smart collections.                         any: Show all smart collections.}
@returns(200)

@endpoint GET /admin/api/2020-01/smart_collections/{smart_collection_id}.json
@desc Retrieves a single smart collection
@required {smart_collection_id: str # smart_collection_id}
@optional {fields: any # Show only certain fields, specified by a comma-separated list of field names.}
@returns(200)

@endpoint PUT /admin/api/2020-01/smart_collections/{smart_collection_id}.json
@desc Updates an existing smart collection
@required {smart_collection_id: str # smart_collection_id}
@returns(200)
@example_request {"smart_collection":{"id":482865238,"body_html":"<p>5000 songs in your pocket</p>"}}

@endpoint DELETE /admin/api/2020-01/smart_collections/{smart_collection_id}.json
@desc Removes a smart collection
@required {smart_collection_id: str # smart_collection_id}
@returns(200)

@endpoint PUT /admin/api/2020-01/smart_collections/{smart_collection_id}/order.json
@desc Updates the ordering type of products in a smart collection
@required {smart_collection_id: str # smart_collection_id}
@optional {products: any # An array of product IDs, in the order that you want them to appear at the top of the collection. When products is specified but empty, any previously sorted products are cleared., sort_order: any # The type of sorting to apply. Valid values are listed in the Properties section above.                   (default: (current value)), products[]: int # products[]}
@returns(200)

