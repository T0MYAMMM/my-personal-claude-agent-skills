@endpoint GET /admin/api/unstable/orders/{order_id}/fulfillment_orders.json
@desc Retrieves a list of fulfillment orders for a specific order.
@required {order_id: str # order_id}
@optional {order_id: any # The ID of the order that is associated with the fulfillment orders.}
@returns(200)

@endpoint GET /admin/api/unstable/fulfillment_orders/{fulfillment_order_id}.json
@desc Retrieves a specific fulfillment order.
@required {fulfillment_order_id: str # fulfillment_order_id}
@returns(200)

@endpoint POST /admin/api/unstable/fulfillment_orders/{fulfillment_order_id}/cancel.json
@desc Marks a fulfillment order as cancelled.
@required {fulfillment_order_id: str # fulfillment_order_id}
@returns(200)

@endpoint POST /admin/api/unstable/fulfillment_orders/release_hold.json
@desc Releases the fulfillment order holds for a specific order. Fulfillment orders are created
@optional {order_id: any # The ID of the order that is associated to the fulfillment orders.}
@returns(200)
@example_request {"order_id":450789469}

@endpoint POST /admin/api/unstable/fulfillment_orders/{fulfillment_order_id}/close.json
@desc Marks an in progress fulfillment order as incomplete, indicating the fulfillment service
@required {fulfillment_order_id: str # fulfillment_order_id}
@optional {message: any # An optional reason for marking the fulfillment order as incomplete.}
@returns(200)
@example_request {"fulfillment_order":{"message":"Not enough inventory to complete this work."}}

@endpoint POST /admin/api/unstable/fulfillment_orders/{fulfillment_order_id}/move.json
@desc Moves a fulfillment order from one merchant managed location to another merchant managed location.
@required {fulfillment_order_id: str # fulfillment_order_id}
@optional {new_location_id: any # The id of the location to which the fulfillment order will be moved.}
@returns(200)
@example_request {"fulfillment_order":{"new_location_id":905684977}}

@endpoint POST /admin/api/unstable/fulfillment_orders/{fulfillment_order_id}/open.json
@desc Marks a scheduled fulfillment order as ready for fulfillment.
@required {fulfillment_order_id: str # fulfillment_order_id}
@returns(200)

@endpoint POST /admin/api/unstable/fulfillment_orders/{fulfillment_order_id}/reschedule.json
@desc Updates the fulfill_at time of a scheduled fulfillment order.
@required {fulfillment_order_id: str # fulfillment_order_id}
@returns(200)
@example_request {"fulfillment_order":{"new_fulfill_at":"2021-12-05"}}

@endpoint POST /admin/api/2020-01/fulfillment_orders/{fulfillment_order_id}/fulfillment_request.json
