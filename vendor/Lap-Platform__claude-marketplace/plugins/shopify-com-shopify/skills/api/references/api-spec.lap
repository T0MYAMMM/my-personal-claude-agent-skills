@endpoint GET /admin/api/2020-01/customers.json
@desc Retrieves a list of customers. Note: As of version 2019-10, this endpoint implements pagination by using links that are provided in the response header. Sending the page parameter will return an error. To learn more, see Making requests to paginated REST Admin API endpoints.
@optional {ids: any # Restrict results to customers specified by a comma-separated list of IDs., since_id: any # Restrict results to those after the specified ID., created_at_min: any # Show customers created after a specified date.(format: 2014-04-25T16:15:47-04:00), created_at_max: any # Show customers created before a specified date.(format: 2014-04-25T16:15:47-04:00), updated_at_min: any # Show customers last updated after a specified date.(format: 2014-04-25T16:15:47-04:00), updated_at_max: any # Show customers last updated before a specified date.(format: 2014-04-25T16:15:47-04:00), limit: any # The maximum number of results to show.                   (default: 50, maximum: 250), fields: any # Show only certain fields, specified by a comma-separated list of field names.}
@returns(200)

@endpoint POST /admin/api/2020-01/customers.json
@desc Creates a customer.
@returns(200)
@example_request {"customer":{"first_name":"Steve","last_name":"Lastnameson","email":"steve.lastnameson@example.com","phone":"+15142546011","verified_email":true,"addresses":[{"address1":"123 Oak St","city":"Ottawa","province":"ON","phone":"555-1212","zip":"123 ABC","last_name":"Lastnameson","first_name":"Mother","country":"CA"}]}}

@endpoint GET /admin/api/2020-01/customers/search.json
@desc Searches for customers that match a supplied query. Note: As of version 2019-10, this endpoint implements pagination by using links that are provided in the response header. Sending the page parameter will return an error. To learn more, see Making requests to paginated REST Admin API endpoints.
@optional {order: any # Set the field and direction by which to order results.                   (default: last_order_date DESC), query: any # Text to search for in the shop's customer data., limit: any # The maximum number of results to show.                   (default: 50, maximum: 250), fields: any # Show only certain fields, specified by a comma-separated list of field names.}
@returns(200)

@endpoint GET /admin/api/2020-01/customers/{customer_id}.json
@desc Retrieves a single customer.
@required {customer_id: str # customer_id}
@optional {fields: any # Show only certain fields, specified by a comma-separated list of field names.}
@returns(200)

@endpoint PUT /admin/api/2020-01/customers/{customer_id}.json
@desc Updates a customer.
@required {customer_id: str # customer_id}
@returns(200)
@example_request {"customer":{"id":207119551,"email":"changed@email.address.com","note":"Customer is a great guy"}}

@endpoint DELETE /admin/api/2020-01/customers/{customer_id}.json
@desc Deletes a customer. A customer can't be deleted if they have existing orders.
@required {customer_id: str # customer_id}
@returns(200)

@endpoint POST /admin/api/2020-01/customers/{customer_id}/account_activation_url.json
@desc Generate an account activation URL for a customer whose account is not yet enabled. This is useful when you've imported a large number of customers and want to send them activation emails all at once. Using this approach, you'll need to generate and send the activation emails yourself.
@required {customer_id: str # customer_id}
@returns(200)

@endpoint POST /admin/api/2020-01/customers/{customer_id}/send_invite.json
@desc Sends an account invite to a customer.
@required {customer_id: str # customer_id}
@returns(200)
@example_request {"customer_invite":{}}

@endpoint GET /admin/api/2020-01/customers/count.json
@desc Retrieves a count of all customers.
@returns(200)

@endpoint GET /admin/api/2020-01/customers/{customer_id}/orders.json
@desc Retrieves all orders belonging to a customer. The query string parameters that are available to the  Order resource are also available to this endpoint.
@required {customer_id: str # customer_id}
@returns(200)

