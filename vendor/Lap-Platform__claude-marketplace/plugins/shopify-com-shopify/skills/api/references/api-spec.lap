@endpoint GET /admin/api/2020-01/reports.json
@desc Retrieves a list of reports. Note: As of version 2019-10, this endpoint implements pagination by using links that are provided in the response header. Sending the page parameter will return an error. To learn more, see Making requests to paginated REST Admin API endpoints.
@optional {ids: any # A comma-separated list of report IDs., limit: any # The amount of results to return.                   (default: 50, maximum: 250), since_id: any # Restrict results to after the specified ID., updated_at_min: any # Show reports last updated after date. (format: 2014-04-25T16:15:47-04:00), updated_at_max: any # Show reports last updated before date. (format: 2014-04-25T16:15:47-04:00), fields: any # A comma-separated list of fields to include in the response.}
@returns(200)

@endpoint POST /admin/api/2020-01/reports.json
@desc Creates a new report
@optional {name: any # The name of the report. Maximum length: 255 characters., shopify_ql: any # The ShopifyQL the report will query.}
@returns(200)
@example_request {"report":{"name":"A new app report","shopify_ql":"SHOW total_sales BY order_id FROM sales SINCE -1m UNTIL today ORDER BY total_sales"}}

@endpoint GET /admin/api/2020-01/reports/{report_id}.json
@desc Retrieves a single report created by your app
@required {report_id: str # report_id}
@optional {fields: any # A comma-separated list of fields to include in the response.}
@returns(200)

@endpoint PUT /admin/api/2020-01/reports/{report_id}.json
@desc Updates a report
@required {report_id: str # report_id}
@returns(200)
@example_request {"report":{"id":517154478,"name":"Changed Report Name","shopify_ql":"SHOW total_sales BY order_id FROM sales SINCE -12m UNTIL today ORDER BY total_sales"}}

@endpoint DELETE /admin/api/2020-01/reports/{report_id}.json
@desc Deletes a report
