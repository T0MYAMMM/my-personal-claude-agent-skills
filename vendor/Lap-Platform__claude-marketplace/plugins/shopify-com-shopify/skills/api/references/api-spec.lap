@endpoint GET /admin/api/2020-01/shopify_payments/disputes.json
@desc Retrieve all disputes ordered by initiated_at date and time (ISO 8601 format), with the most recent being first.
@optional {since_id: any # Return only disputes after the specified ID., last_id: any # Return only disputes before the specified ID., status: any # Return only disputes with the specified status., initiated_at: any # Return only disputes with the specified initiated_at date (ISO 8601 format).}
@returns(200)

