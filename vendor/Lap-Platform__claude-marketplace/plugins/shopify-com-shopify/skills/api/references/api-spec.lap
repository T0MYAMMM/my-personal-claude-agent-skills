@endpoint GET /admin/api/2020-01/comments/count.json
@desc Retrieves a count of comments
@optional {created_at_min: any # Count comments created after date (format: 2014-04-25T16:15:47-04:00)., created_at_max: any # Count comments created before date (format: 2014-04-25T16:15:47-04:00)., updated_at_min: any # Count comments last updated after date (format: 2014-04-25T16:15:47-04:00)., updated_at_max: any # Count comments last updated before date (format: 2014-04-25T16:15:47-04:00)., published_at_min: any # Count comments published after date (format: 2014-04-25T16:15:47-04:00)., published_at_max: any # Count comments published before date (format: 2014-04-25T16:15:47-04:00)., published_status: any # Retrieve a count of comments with a given published status.                   (default: any)                                              published: Count only published comments.                         unpublished: Count only unpublished comments.                         any: Count comments of any published status., status: any # Retrieve a count of comments with a given status.                                              pending: Count pending comments.                         published: Count published comments.                         unapproved: Count unapproved comments., article_id: int # article_id, blog_id: int # blog_id}
@returns(200)

@endpoint GET /admin/api/2020-01/comments/{comment_id}.json
@desc Retrieves a single comment by its ID
@required {comment_id: str # comment_id}
@optional {fields: any # Show only certain fields, specified by a comma-separated list of field names.}
@returns(200)

@endpoint PUT /admin/api/2020-01/comments/{comment_id}.json
@desc Updates a comment of an article
@required {comment_id: str # comment_id}
@returns(200)
@example_request {"comment":{"id":118373535,"body":"You can even update through a web service.","author":"Your new name","email":"your@updated-email.com","published_at":"2020-11-05T00:48:11.132Z"}}

@endpoint POST /admin/api/2020-01/comments/{comment_id}/spam.json
@desc Marks a comment as spam
@required {comment_id: str # comment_id}
@returns(200)

@endpoint POST /admin/api/2020-01/comments/{comment_id}/not_spam.json
@desc Marks a comment as not spam
@required {comment_id: str # comment_id}
@returns(200)

@endpoint POST /admin/api/2020-01/comments/{comment_id}/approve.json
@desc Approves a comment
@required {comment_id: str # comment_id}
@returns(200)

@endpoint POST /admin/api/2020-01/comments/{comment_id}/remove.json
@desc Removes a comment
@required {comment_id: str # comment_id}
@returns(200)

@endpoint POST /admin/api/2020-01/comments/{comment_id}/restore.json
@desc Restores a previously removed comment
@required {comment_id: str # comment_id}
@returns(200)

