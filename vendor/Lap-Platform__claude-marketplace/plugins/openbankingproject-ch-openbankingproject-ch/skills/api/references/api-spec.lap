@returns(200) {authorisationIds: [str]} # OK
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not found, 405: Method Not Allowed, 406: Not Acceptable, 408: Request Timeout, 409: Conflict, 415: Unsupported Media Type, 429: Too Many Requests, 500: Internal Server Error, 503: Service Unavailable}

@endpoint GET /v1/consents/{consentId}/authorisations/{authorisationId}
@desc Read the SCA status of the consent authorisation
