@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not found, 405: Method Not Allowed, 406: Not Acceptable, 408: Request Timeout, 409: Conflict, 415: Unsupported Media Type, 429: Too Many Requests, 500: Internal Server Error, 503: Service Unavailable}

@endpoint PUT /v1/signing-baskets/{basketId}/authorisations/{authorisationId}
@desc Update PSU data for signing basket
@required {basketId: str # This identification of the corresponding signing basket object., authorisationId: str # Resource identification of the related SCA.}
@optional {PSU-ID: str # Client ID of the PSU in the ASPSP client interface.  Might be mandated in the ASPSP's documentation.  It might be contained even if an OAuth2 based authentication was performed in a pre-step or an OAuth2 based SCA was performed in an preceding AIS service in the same session. In this case the ASPSP might check whether PSU-ID and token match, according to ASPSP documentation., PSU-ID-Type: str # Type of the PSU-ID, needed in scenarios where PSUs have several PSU-IDs as access possibility.  In this case, the mean and use are then defined in the ASPSP's documentation., PSU-Corporate-ID: str # Might be mandated in the ASPSP's documentation. Only used in a corporate context., PSU-Corporate-ID-Type: str # Might be mandated in the ASPSP's documentation. Only used in a corporate context.}
@returns(200) OK
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not found, 405: Method Not Allowed, 406: Not Acceptable, 408: Request Timeout, 409: Conflict, 415: Unsupported Media Type, 429: Too Many Requests, 500: Internal Server Error, 503: Service Unavailable}

@endpoint GET /v1/signing-baskets/{basketId}/authorisations/{authorisationId}
@desc Read the SCA status of the signing basket authorisation
@required {basketId: str # This identification of the corresponding signing basket object., authorisationId: str # Resource identification of the related SCA.}
@returns(200) {scaStatus: str, psuMessage: str, trustedBeneficiaryFlag: bool} # OK
@errors {400: Bad Request, 401: Unauthorized, 403: Forbidden, 404: Not found, 405: Method Not Allowed, 406: Not Acceptable, 408: Request Timeout, 409: Conflict, 415: Unsupported Media Type, 429: Too Many Requests, 500: Internal Server Error, 503: Service Unavailable}

@endgroup

@end
