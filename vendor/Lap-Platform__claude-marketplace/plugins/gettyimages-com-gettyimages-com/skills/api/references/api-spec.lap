@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Getty Images API
@version 3
@auth ApiKey Api-Key in header | OAuth2
@endpoints 76
@hint download_for_search
@toc affiliates(2), ai(22), artists(2), asset-changes(3), asset-licensing(1), boards(14), collections(1), countries(1), customers(1), downloads(3), events(2), image-match(1), images(5), orders(1), products(1), purchased-assets(1), search(9), usage-batches(1), videos(5)

@group affiliates
@endpoint GET /v3/affiliates/search/images
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., GI-Country-Code: str # Receive regionally relevant search results based on the value specified. Accepts only ISO Alpha-3 country codes. The Countries operation can be used to retrieve the codes., phrase: str # Search images using a search phrase., style: str # Filter based on graphical style of the image.}
@returns(200) {images: [map]?, auto_corrections: map{phrase: str?}} # OK

@endpoint GET /v3/affiliates/search/videos
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., GI-Country-Code: str # Receive regionally relevant search results based on the value specified. Accepts only ISO Alpha-3 country codes. The Countries operation can be used to retrieve the codes., phrase: str}
@returns(200) {videos: [map]?, auto_corrections: map{phrase: str?}} # OK

@endgroup

@group ai
@endpoint POST /v3/ai/image-generations
@desc Generates images from a prompt
@optional {prompt: str # The only required parameter, this is the primary text used for the generation of the images., aspect_ratio: str # Aspect ratio of the result images.  Must be one of 1:1, 3:4, 4:3, 9:16, or 16:9, media_type: str(photography/illustration), mood: str(black_and_white/warm/cool/natural/vivid/dramatic/bold), product_id: int(int32) # If you have multiple Getty products, indicate which one you would like to use for this generation request, project_code: str # The project code to use for the generation request.  Some products require this value., notes: str # The notes to use for the generation request.  Some products require this value.}
@returns(202) {generation_request_id: str?} # Returns the request ID
@errors {400: The request was invalid, 403: Product quota exceeded, 409: ConcurrencyConflict, 429: TooManyConcurrentGenerations}

@endpoint GET /v3/ai/image-generations/{generationRequestId}
@desc Get generated images from a previous generation request
@required {generationRequestId: str # The ID from a previous request to generate images}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request
@returns(200) {generation_request_id: str?, seed: int(int32)?, results: [map]?, original_asset: map{id: str?}} # Returns the result of a request to generate images
@errors {404: The request ID was not found, 409: ConcurrencyConflict, 400: InvalidProduct, 403: NoProducts, 429: TooManyConcurrentGenerations, 410: GenerationRequestGone}

@endpoint POST /v3/ai/image-generations/{generationRequestId}/images/{index}/variations
@desc Get variations on a generated image
@required {generationRequestId: str # The ID from a previous request to generate images, index: int(int32) # The index of the image from the specific images generation}
@optional {product_id: int(int32) # If you have multiple Getty products, indicate which one you would like to use for this generation request, project_code: str # The project code to use for the generation request.  Some products require this value., notes: str # The notes to use for the generation request.  Some products require this value.}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to generate a variation of images
@errors {403: Product quota exceeded, 404: Either the generation id does not exist, the index is incorrect, or the generation is still pending, 409: ConcurrencyConflict, 400: InvalidProduct, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/file-registrations
@desc Register a client provided file for use with AIGenerator endpoints
@optional {url: str # The location of the file., rights_claimed: bool # Acknowledgment of ownership or licensing of file., category: str(ImageReference/CustomerProduct)}
@returns(200) {id: str?} # Returns the response
@errors {400: The request was invalid, 403: Not authorized}

@endpoint GET /v3/ai/file-registrations
@optional {page: int(int32) # The page number of results.  Default is 1., page_size: int(int32) # The page size of results.  Default is 30.}
@returns(200) {result_count: int(int32), file_registrations: [map]?} # OK
@errors {403: NotAuthorized}

@endpoint GET /v3/ai/file-registrations/{fileRegistrationId}
@desc Get details on a registered file
@required {fileRegistrationId: str # The id from a previous request to register a file}
@returns(200) {id: str?, preview_urls: [map]?} # Returns the response
@errors {400: The request was invalid, 403: Not authorized, 404: FileRegistrationIdNotFound}

@endpoint DELETE /v3/ai/file-registrations/{fileRegistrationId}
@desc Archives a registered file
@required {fileRegistrationId: str}
@returns(200) OK
@returns(204) The file was successfully archived
@errors {404: The file registration id does not exist, 403: Not authorized}

@endpoint POST /v3/ai/image-generations/refine
@desc Refine an image
@required {prompt: str, mask_url: str}
@optional {reference_asset_id: str, reference_generation: map{generation_request_id: str, index: int(int32)}, product_id: int(int32), project_code: str, notes: str}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to refine an image
@errors {403: Product quota exceeded, 404: Image not found, 409: ConcurrencyConflict, 400: InvalidProduct, 410: GenerationRequestGone, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/image-generations/extend
@desc Extend an image
@optional {reference_asset_id: str, reference_generation: map{generation_request_id: str, index: int(int32)}, prompt: str, product_id: int(int32), project_code: str, notes: str, left_percentage: num(float), right_percentage: num(float), top_percentage: num(float), bottom_percentage: num(float)}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to extend an image
@errors {403: Product quota exceeded, 404: Image not found, 409: ConcurrencyConflict, 400: InvalidProduct, 410: GenerationRequestGone, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/image-generations/background-removal
@desc Remove a background
@optional {reference_asset_id: str # Asset Id to modify., reference_generation: map{generation_request_id: str, index: int(int32)}, product_id: int(int32) # If you have multiple Getty products, indicate which one you would like to use for this refine request, project_code: str # The project code to use for the request.  Some products require this value., notes: str # The notes to use for the request.  Some products require this value.}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to extend an image
@errors {400: The request was invalid, 403: Product quota exceeded, 404: Image not found, 409: ConcurrencyConflict, 410: GenerationRequestGone, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/image-generations/object-removal
@desc Remove object(s)
@optional {reference_asset_id: str # Asset Id to modify., reference_generation: map{generation_request_id: str, index: int(int32)}, product_id: int(int32) # If you have multiple Getty products, indicate which one you would like to use for this refine request, project_code: str # The project code to use for the request.  Some products require this value., notes: str # The notes to use for the request.  Some products require this value., mask_url: str # The location of the mask.}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to refine images
@errors {403: Product quota exceeded, 404: Either the generation id does not exist, the index is incorrect, or the generation is still pending, 409: ConcurrencyConflict, 400: InvalidProduct, 410: GenerationRequestGone, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/image-generations/background-replacement
@desc Replace the background of an existing image
@optional {prompt: str, reference_asset_id: str, reference_generation: map{generation_request_id: str, index: int(int32)}, product_id: int(int32), media_type: str(photography/illustration), negative_prompt: str, background_color: str, project_code: str, notes: str}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to replace a background
@errors {409: ConcurrencyConflict, 403: NotAuthorized, 400: InvalidProduct, 404: GenerationRequestIdNotFound, 410: GenerationRequestGone, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/image-generations/influence-color-by-image
@desc Influence the color of generated images using a reference image
@optional {reference_asset_id: str # Asset Id to modify., reference_generation: map{generation_request_id: str, index: int(int32)}, reference_file_registration_id: str # File Id to modify., prompt: str # This is the primary text used for refining the images., noise_level: num(float) # Accepted values are 0-1. Higher values will increase differences between the reference and generated images., media_type: str(photography/illustration), product_id: int(int32) # If you have multiple Getty products, indicate which one you would like to use for this refine request, project_code: str # The project code to use for the request.  Some products require this value., notes: str # The notes to use for the request.  Some products require this value.}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to extend an image
@errors {400: The request was invalid, 403: Product quota exceeded, 404: Image not found, 409: ConcurrencyConflict, 410: GenerationRequestGone, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/image-generations/influence-composition-by-image
@desc Influence the composition of generated images using a reference image
@optional {reference_asset_id: str # Asset Id to modify., reference_generation: map{generation_request_id: str, index: int(int32)}, reference_file_registration_id: str # File Id to modify., prompt: str # This is the primary text used for refining the images., influence_level: num(float) # Accepted values are 0-1. Higher values will increase the similarities between the reference and generated images., media_type: str(photography/illustration), mood: str(black_and_white/warm/cool/natural/vivid/dramatic/bold), product_id: int(int32) # If you have multiple Getty products, indicate which one you would like to use for this refine request, project_code: str # The project code to use for the request.  Some products require this value., notes: str # The notes to use for the request.  Some products require this value.}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request to extend an image
@errors {403: Product quota exceeded, 404: Image not found, 409: ConcurrencyConflict, 400: InvalidProduct, 410: GenerationRequestGone, 429: TooManyConcurrentGenerations}

@endpoint POST /v3/ai/image-generations/background-generations
@desc Add a background to a reference image
@optional {reference_file_registration_id: str, prompt: str, product_id: int(int32), project_code: str, notes: str, left_percentage: num(float), right_percentage: num(float), top_percentage: num(float), bottom_percentage: num(float), background_file_registration_id: str, background_asset_id: str, background_reference_generation: map{generation_request_id: str, index: int(int32)}, background_reference_adherence: str(flexible/strong)}
@returns(202) {generation_request_id: str?} # Returns the request ID for a pending request
@errors {403: Product quota exceeded, 404: Image not found, 409: ConcurrencyConflict, 400: InvalidProduct, 429: TooManyConcurrentGenerations}

@endpoint GET /v3/ai/generation-history
@desc Retrieve history of AI generations
@optional {date_start: str(date-time) # If included, limits the results to those generation requests made on or after date_start. Both dates and datetimes are supported.  Dates should be submitted in ISO 8601 format YYYY-MM-DD. The time will default to 00:00:00 UTC.  Datetimes should be submitted in ISO 8601 format YYYY-MM-DDTHH:mm:ssZ., date_end: str(date-time) # If included, limits the results to those generation requests made on or before date_end. Both dates and datetimes are supported.  Dates should be submitted in ISO 8601 format YYYY-MM-DD. The time will default to 00:00:00 UTC.  Datetimes should be submitted in ISO 8601 format YYYY-MM-DDTHH:mm:ssZ., media_type: str # If included, limits the results to those generation requests made for the given media type., page_size: int(int32) # The page size of results.  Default is 30., page: int(int32) # The page number of results.  Default is 1., product_ids: [int(int32)] # If included, limits the results to only those requests made against the indicated products., company_generations: bool=False # If `true`, returns the list of previously downloaded images for all users in             your company. Your account must be enabled for this functionality. Contact your Getty Images account rep for             more information. Default is `false`.}
@returns(200) {generations: [map]?, result_count: int(int32)} # Returns the history of AI generations
@errors {403: Company generations were requested but your account is not configured for access., 409: ConcurrencyConflict}

@endpoint GET /v3/ai/generation-history/{generationRequestId}
@desc Retrieve history item for an individual generation request
@required {generationRequestId: str # The ID from a previous request to generate images}
@returns(200) {generation_request_id: str?, seed: int(int32)?, generation_date: str(date-time), product_revoked_date: str(date-time)?, prompt: str?, negative_prompt: str?, product_id: int(int32), notes: str?, project_code: str?, generation_type: str, generation_options: map{media_type: str, aspect_ratio: str?, mood: str}, source_generation_request: map{source_generation_request_id: str?, source_generation_result_index: int(int32)}, original_asset: map{id: str?}, results: [map]?, user: map{username: str?, first_name: str?, middle_name: str?, last_name: str?}} # Returns the history item for the request
@errors {404: The request ID was not found, 409: ConcurrencyConflict, 403: NotAuthorized}

@endpoint GET /v3/ai/image-generations/{generationRequestId}/images/{index}/download-sizes
@desc Get download sizes for a generated image
@required {generationRequestId: str # The ID from a previous request to generate images, index: int(int32) # The index of the image from the specific images generation}
@returns(200) {download_sizes: [map]?} # Returns the result of a request
@errors {404: Either the generation id does not exist, the index is incorrect, or the generation is still pending, 409: ConcurrencyConflict, 403: NotAuthorized, 400: InvalidProduct, 410: GenerationRequestGone, 429: DailyRequestLimitExceeded}

@endpoint PUT /v3/ai/image-generations/{generationRequestId}/images/{index}/download
@desc Begin the download process
@required {generationRequestId: str # The ID from a previous request to generate images, index: int(int32) # The index of the image from the specific images generation}
@optional {notes: str # The notes to use for the download request.  Some products require this value., project_code: str # The project code to use for the download request.  Some products require this value., size_name: str # The size name.  Valid values are 1k or 4k., product_id: int(int32) # The product id to download against. Only required when the customer has more than one agreement.}
@returns(202) Download request was successful but is pending
@errors {409: A download is already in progress for the given `generationRequestId` and `index`., 403: NotAuthorized, 400: InvalidProduct, 410: GenerationRequestGone, 404: GenerationRequestIdNotFound, 429: DailyRequestLimitExceeded}

@endpoint GET /v3/ai/image-generations/{generationRequestId}/images/{index}/download
@desc Once the download process has started, this endpoint can be used to check the status of the download and get the
@required {generationRequestId: str # The ID from a previous request to generate images, index: int(int32) # The index of the image from the specific images generation}
@returns(202) Download request was successful put is pending
@returns(200) {url: str?, generated_asset_id: str?} # Download request was successful and is complete
@errors {409: ConcurrencyConflict, 403: NotAuthorized, 400: InvalidProduct, 410: GenerationRequestGone, 404: GenerationRequestIdNotFound, 429: DailyRequestLimitExceeded}

@endpoint POST /v3/ai/redownloads
@desc Re-download a previously downloaded item
@optional {generated_asset_id: str # The identifier of the previously-downloaded generated asset., product_id: int(int32) # The product ID to use for the download., size_name: str # The size name.  Valid values are 1k or 4k., project_code: str # The project code to use for the download request.  Some products require this value., notes: str # The notes to use for the download request.  Some products require this value.}
@returns(200) {url: str?, generated_asset_id: str?} # Returns the re-download response
@errors {400: The request was invalid, 404: Could not find source generated_asset_id, 403: Product is not active or quota exceeded, 409: ConcurrencyConflict, 410: GenerationRequestGone, 429: DailyRequestLimitExceeded}

@endpoint POST /v3/ai/enhance-prompt
@desc Expands and enriches a short prompt to produce a more detailed and descriptive prompt which can then be used to generate images.
@required {prompt: str}
@returns(200) {enhanced_prompt: str?} # OK
@errors {400: PromptEnhancementFailed}

@endgroup

@group artists
@endpoint GET /v3/artists/images
@desc Search for images by a photographer
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., artist_name: str # Name of artist for desired images, fields: [str] # Comma separated list of fields. Allows restricting which fields are returned. If no fields are selected, the summary_set of fields are returned., page: int(int32)=1 # Identifies page to return. Default page is 1., page_size: int(int32)=10 # Specifies page size. Default page_size is 10, maximum page_size is 100.}
@returns(200) {images: [map]?, result_count: int(int32)} # OK
@errors {400: InvalidParameterValue, 401: Unauthorized}

@endpoint GET /v3/artists/videos
@desc Search for videos by a photographer
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., artist_name: str # Name of artist for desired images, fields: [str] # Comma separated list of fields. Allows restricting which fields are returned. If no fields are selected, the summary_set of fields are returned., page: int(int32)=1 # Identifies page to return. Default page is 1., page_size: int(int32)=10 # Specifies page size. Default page_size is 10, maximum page_size is 100.}
@returns(200) {videos: [map]?, result_count: int(int32)} # OK
@errors {400: InvalidParameterValue, 401: Unauthorized}

@endgroup

@group asset-changes
@endpoint PUT /v3/asset-changes/change-sets
@desc Get asset change notifications.
@optional {channel_id: int(int32) # Specifies the id of the channel for the asset data. Valid channel ids can be found in the results of the Get Partner Channel query., batch_size: int(int32) # Specifies the number of assets to return. The default is 2200; maximum is 2200.}
@returns(201) {change_set_id: str?, changed_assets: [map]?} # Created
@returns(200) {change_set_id: str?, changed_assets: [map]?} # Success - Channel contains unconfirmed asset change notifications
@errors {403: Your access token does not authorize access to this resource, 404: The channel you specified does not exist, 400: InvalidChannelIdException}

@endpoint DELETE /v3/asset-changes/change-sets/{change-set-id}
@desc Confirm asset change notifications.
@required {change-set-id: int(int64) # Specify the change-set-id associated with a transaction resource whose receipt you want to confirm.}
@returns(200) Success
@errors {403: Your access token does not authorize access to this resource, 404: Transaction was not found, 400: InvalidChangeSetId}

@endpoint GET /v3/asset-changes/channels
@desc Get a list of asset change notification channels.
@returns(200) OK
@errors {404: ChannelsNotFound, 403: UnauthorizedToAccessResource}

@endgroup

@group asset-licensing
@endpoint POST /v3/asset-licensing/{assetId}
@desc Endpoint for acquiring extended licenses with iStock credits for an asset.
@required {assetId: str # Getty Images assetId - examples 520621493, 112301284, extended_licenses: [str]}
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., use_team_credits: bool # Defaults to false.}
@returns(200) {credits_used: int(int32), acquired_licenses: [str]?} # OK
@errors {401: AuthorizationTokenRequired, 400: InvalidRequestParameters, 402: NotEnoughCreditsForPurchase, 404: StandardLicenseNotFound}

@endgroup

@group boards
@endpoint GET /v3/boards
@desc Get all boards that the user participates in
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., page: int(int32)=1 # Request results starting at a page number (default is 1)., board_relationship: str # Search for boards the user owns or has been invited to as an editor., sort_order: str # Sort the list of boards by last update date or name. Defaults to date_last_updated_descending., pageSize: int(int32)=30 # Request number of boards to return in each page. (default is 30).}
@returns(200) {boards: [map]?, board_count: int(int32)} # OK
@errors {400: InvalidParameterValue, 401: Unauthorized}

@endpoint POST /v3/boards
@desc Create a new board
@required {name: str}
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., description: str}
@returns(201) {id: str?} # Created
@errors {400: InvalidParameterValue, 401: Unauthorized}

@endpoint GET /v3/boards/{board_id}
@desc Get assets and metadata for a specific board
@required {board_id: str # Retrieve details for a specific board.}
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only).}
@returns(200) {id: str?, asset_count: int(int32), assets: [map]?, date_created: str(date-time), date_last_updated: str(date-time), description: str?, name: str?, comment_count: int(int32), permissions: map{can_delete_board: bool, can_invite_to_board: bool, can_update_name: bool, can_update_description: bool, can_add_assets: bool, can_remove_assets: bool}, links: map{invitation: str?, share: str?}} # OK
@errors {400: InvalidParameterValue, 401: Unauthorized, 404: BoardNotFound}

@endpoint DELETE /v3/boards/{board_id}
@desc Delete a board
@required {board_id: str # Specifies the board to delete.}
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only).}
@returns(200) OK
@returns(204)
@errors {400: InvalidParameterValue, 401: Unauthorized, 404: BoardNotFound, 403: InsufficientAccess}

@endpoint PUT /v3/boards/{board_id}
@desc Update a board
@required {board_id: str # Specifies the board to update., name: str}
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., description: str}
@returns(200) OK
@returns(204) Updated
@errors {400: InvalidParameterValue, 401: Unauthorized, 403: InsufficientAccess, 404: BoardNotFound}

@endpoint PUT /v3/boards/{board_id}/assets
@desc Add assets to a board
@required {board_id: str # Specifies the board to add assets to.}
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only).}
@returns(201) {assets_added: [map]?, assets_not_added: [str]?} # Created
@errors {400: InvalidParameterValue, 401: Unauthorized, 403: InsufficientAccess, 404: BoardNotFound}

@endpoint DELETE /v3/boards/{board_id}/assets
@desc Remove assets from a board
@required {board_id: str # Specifies the board to remove assets from.}
@optional {Accept-Language: str # Provide a header to specify the language of result values. Supported values: cs (iStock only), de, en-GB, en-US, es, fi (iStock only), fr, hu (iStock only), id (iStock only), it, ja, ko (creative assets only), nl, pl (creative assets only), pt-BR, pt-PT, ro (iStock only), ru (creative assets only), sv, th (iStock only), tr, uk (iStock only), vi (iStock only), zh-HK (creative assets only)., asset_ids: [str] # List the assets to be removed from the board.}
