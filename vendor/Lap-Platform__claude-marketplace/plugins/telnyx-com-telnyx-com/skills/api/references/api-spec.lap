@returns(200) {data: map{active: bool, anchorsite_override: str, call_cost_in_webhooks: bool, created_at: str, dtmf_type: str, first_command_timeout: bool, first_command_timeout_secs: int, friendly_name: str, id: str, inbound: map{channel_limit: int, shaken_stir_enabled: bool, sip_subdomain: str, sip_subdomain_receive_settings: str}, outbound: map{channel_limit: int, outbound_voice_profile_id: str}, record_type: str, status_callback: str(uri), status_callback_method: str, tags: [str], updated_at: str, voice_fallback_url: str(uri), voice_method: str, voice_url: str(uri)}} # Successful response
