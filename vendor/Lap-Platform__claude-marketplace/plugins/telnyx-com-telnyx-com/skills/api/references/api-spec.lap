@endpoint POST /authentication_providers
@desc Creates an authentication provider
@required {name: str # The name associated with the authentication provider., settings: map{idp_cert_fingerprint!: str, idp_cert_fingerprint_algorithm: str, idp_entity_id!: str(uri), idp_sso_target_url!: str(uri)} # The settings associated with the authentication provider., short_name: str # The short name associated with the authentication provider. This must be unique and URL-friendly, as it's going to be part of the login URL.}
@optional {active: bool=True # The active status of the authentication provider, settings_url: str(uri) # The URL for the identity provider metadata file to populate the settings automatically. If the settings attribute is provided, that will be used instead.}
@returns(200) {data: map{activated_at: str(date-time), active: bool, created_at: str(date-time), id: str(uuid), name: str, organization_id: str(uuid), record_type: str, settings: map{assertion_consumer_service_url: str(uri), idp_attribute_names: map, idp_cert_fingerprint: str, idp_cert_fingerprint_algorithm: str, idp_certificate: str, idp_entity_id: str(uri), idp_slo_target_url: str(uri), idp_sso_target_url: str(uri), name_identifier_format: str, provision_groups: bool, service_provider_entity_id: str(uri), service_provider_login_url: str(uri)}, short_name: str, updated_at: str(date-time)}} # Successful response
@errors {422: Bad request}

@endpoint DELETE /authentication_providers/{id}
@desc Deletes an authentication provider
@required {id: str # authentication provider ID}
@returns(200) {data: map{activated_at: str(date-time), active: bool, created_at: str(date-time), id: str(uuid), name: str, organization_id: str(uuid), record_type: str, settings: map{assertion_consumer_service_url: str(uri), idp_attribute_names: map, idp_cert_fingerprint: str, idp_cert_fingerprint_algorithm: str, idp_certificate: str, idp_entity_id: str(uri), idp_slo_target_url: str(uri), idp_sso_target_url: str(uri), name_identifier_format: str, provision_groups: bool, service_provider_entity_id: str(uri), service_provider_login_url: str(uri)}, short_name: str, updated_at: str(date-time)}} # Successful response
@errors {401: Unauthorized, 404: Resource not found, 422: Bad request}

@endpoint GET /authentication_providers/{id}
@desc Retrieve an authentication provider
@required {id: str # authentication provider ID}
@returns(200) {data: map{activated_at: str(date-time), active: bool, created_at: str(date-time), id: str(uuid), name: str, organization_id: str(uuid), record_type: str, settings: map{assertion_consumer_service_url: str(uri), idp_attribute_names: map, idp_cert_fingerprint: str, idp_cert_fingerprint_algorithm: str, idp_certificate: str, idp_entity_id: str(uri), idp_slo_target_url: str(uri), idp_sso_target_url: str(uri), name_identifier_format: str, provision_groups: bool, service_provider_entity_id: str(uri), service_provider_login_url: str(uri)}, short_name: str, updated_at: str(date-time)}} # Successful response
@errors {401: Unauthorized, 404: Resource not found, 422: Bad request}

@endpoint PATCH /authentication_providers/{id}
@desc Update an authentication provider
@required {id: str # Identifies the resource.}
@optional {active: bool=True # The active status of the authentication provider, name: str # The name associated with the authentication provider., settings: map{idp_cert_fingerprint!: str, idp_cert_fingerprint_algorithm: str, idp_entity_id!: str(uri), idp_sso_target_url!: str(uri)} # The settings associated with the authentication provider., settings_url: str(uri) # The URL for the identity provider metadata file to populate the settings automatically. If the settings attribute is provided, that will be used instead., short_name: str # The short name associated with the authentication provider. This must be unique and URL-friendly, as it's going to be part of the login URL.}
