@returns(201) {data: map{active: bool, anchorsite_override: str, application_name: str, created_at: str, id: str, inbound: map{channel_limit: int, sip_subdomain: str, sip_subdomain_receive_settings: str}, outbound: map{channel_limit: int, outbound_voice_profile_id: str}, record_type: str, tags: [str], updated_at: str, webhook_event_failover_url: str(uri)?, webhook_event_url: str(uri), webhook_timeout_secs: int?}} # Successful response
@errors {401: Unauthorized, 403: Unauthorized, 422: Unprocessable entity. The request was well-formed but contains semantic errors.}

