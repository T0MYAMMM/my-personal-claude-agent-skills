@group ai
@endpoint GET /ai/assistants
@desc List assistants
@returns(200) {data: [map]} # Successful Response
@errors {422: Validation Error}

@endpoint POST /ai/assistants
@desc Create an assistant
@required {instructions: str # System instructions for the assistant. These may be templated with [dynamic variables](https://developers.telnyx.com/docs/inference/ai-assistants/dynamic-variables), model: str # ID of the model to use. You can use the [Get models API](https://developers.telnyx.com/api-reference/chat/get-available-models) to see all of your available models,, name: str}
@optional {description: str, dynamic_variables: map # Map of dynamic variables and their default values, dynamic_variables_webhook_url: str # If the dynamic_variables_webhook_url is set for the assistant, we will send a request at the start of the conversation. See our [guide](https://developers.telnyx.com/docs/inference/ai-assistants/dynamic-variables) for more information., enabled_features: [str], greeting: str # Text that the assistant will use to start the conversation. This may be templated with [dynamic variables](https://developers.telnyx.com/docs/inference/ai-assistants/dynamic-variables). Use an empty string to have the assistant wait for the user to speak first. Use the special value `<assistant-speaks-first-with-model-generated-message>` to have the assistant generate the greeting based on the system instructions., insight_settings: map{insight_group_id: str}, llm_api_key_ref: str # This is only needed when using third-party inference providers. The `identifier` for an integration secret [/v2/integration_secrets](https://developers.telnyx.com/api-reference/integration-secrets/create-a-secret) that refers to your LLM provider's API key. Warning: Free plans are unlikely to work with this integration., messaging_settings: map{conversation_inactivity_minutes: int, default_messaging_profile_id: str, delivery_status_webhook_url: str}, privacy_settings: map{data_retention: bool}, telephony_settings: map{default_texml_app_id: str, noise_suppression: str, noise_suppression_config: map{attenuation_limit: int, mode: str}, recording_settings: map{channels: str, format: str}, supports_unauthenticated_web_calls: bool, time_limit_secs: int, user_idle_timeout_secs: int, voicemail_detection: map{on_voicemail_detected: map}}, tools: [any] # The tools that the assistant can use. These may be templated with [dynamic variables](https://developers.telnyx.com/docs/inference/ai-assistants/dynamic-variables), transcription: map{language: str, model: str, region: str, settings: map{eager_eot_threshold: num, eot_threshold: num, eot_timeout_ms: int, numerals: bool, smart_format: bool}}, voice_settings: map{api_key_ref: str, background_audio: any, language_boost: str, similarity_boost: num, speed: num, style: num, temperature: num, use_speaker_boost: bool, voice!: str, voice_speed: num}, widget_settings: map{agent_thinking_text: str, audio_visualizer_config: map{color: str, preset: str}, default_state: str, give_feedback_url: str, logo_icon_url: str, position: str, report_issue_url: str, speak_to_interrupt_text: str, start_call_text: str, theme: str, view_history_url: str} # Configuration settings for the assistant's web widget.}
@returns(200) {created_at: str(date-time), description: str, dynamic_variables: map, dynamic_variables_webhook_url: str, enabled_features: [str], greeting: str, id: str, import_metadata: map{import_id: str, import_provider: str}, insight_settings: map{insight_group_id: str}, instructions: str, llm_api_key_ref: str, messaging_settings: map{conversation_inactivity_minutes: int, default_messaging_profile_id: str, delivery_status_webhook_url: str}, model: str, name: str, privacy_settings: map{data_retention: bool}, telephony_settings: map{default_texml_app_id: str, noise_suppression: str, noise_suppression_config: map{attenuation_limit: int, mode: str}, recording_settings: map{channels: str, format: str}, supports_unauthenticated_web_calls: bool, time_limit_secs: int, user_idle_timeout_secs: int, voicemail_detection: map{on_voicemail_detected: map{action: str, voicemail_message: map}}}, tools: [any], transcription: map{language: str, model: str, region: str, settings: map{eager_eot_threshold: num, eot_threshold: num, eot_timeout_ms: int, numerals: bool, smart_format: bool}}, voice_settings: map{api_key_ref: str, background_audio: any, language_boost: str?, similarity_boost: num, speed: num, style: num, temperature: num, use_speaker_boost: bool, voice: str, voice_speed: num}, widget_settings: map{agent_thinking_text: str, audio_visualizer_config: map{color: str, preset: str}, default_state: str, give_feedback_url: str?, logo_icon_url: str?, position: str, report_issue_url: str?, speak_to_interrupt_text: str, start_call_text: str, theme: str, view_history_url: str?}} # Successful Response
@errors {422: Validation Error}

@endpoint POST /ai/assistants/import
@desc Import assistants from external provider
@required {api_key_ref: str # Integration secret pointer that refers to the API key for the external provider. This should be an identifier for an integration secret created via /v2/integration_secrets., provider: str(elevenlabs/vapi/retell) # The external provider to import assistants from.}
@optional {import_ids: [str] # Optional list of assistant IDs to import from the external provider. If not provided, all assistants will be imported.}
@returns(200) {data: [map]} # Successful Response
@errors {422: Validation Error}

@endpoint GET /ai/assistants/tests
@desc List assistant tests with pagination
@optional {test_suite: str # Filter tests by test suite name, telnyx_conversation_channel: str # Filter tests by communication channel (e.g., 'web_chat', 'sms'), destination: str # Filter tests by destination (phone number, webhook URL, etc.), page: map # Consolidated page parameter (deepObject style). Originally: page[size], page[number]}
@returns(200) {data: [map], meta: any} # Returns paginated test list with metadata for navigation and filtering
@errors {422: Validation Error}

@endpoint POST /ai/assistants/tests
@desc Create a new assistant test
@required {destination: str # The target destination for the test conversation. Format depends on the channel: phone number for SMS/voice, webhook URL for web chat, etc., instructions: str # Detailed instructions that define the test scenario and what the assistant should accomplish. This guides the test execution and evaluation., name: str # A descriptive name for the assistant test. This will be used to identify the test in the UI and reports., rubric: [map{criteria!: str, name!: str}] # Evaluation criteria used to assess the assistant's performance. Each rubric item contains a name and specific criteria for evaluation.}
@optional {description: str # Optional detailed description of what this test evaluates and its purpose. Helps team members understand the test's objectives., max_duration_seconds: int # Maximum duration in seconds that the test conversation should run before timing out. If not specified, uses system default timeout., telnyx_conversation_channel: any=web_chat # The communication channel through which the test will be conducted. Determines how the assistant will receive and respond to test messages., test_suite: str # Optional test suite name to group related tests together. Useful for organizing tests by feature, team, or release cycle.}
@returns(201) {created_at: str(date-time), description: str, destination: str, instructions: str, max_duration_seconds: int, name: str, rubric: [map], telnyx_conversation_channel: any, test_id: str(uuid), test_suite: str} # Returns the created test configuration with assigned test ID
@errors {422: Validation Error}

@endpoint GET /ai/assistants/tests/test-suites
@desc Get all test suite names
@returns(200) {data: [str]} # Returns an array of unique test suite names for filtering and organization
@errors {422: Validation Error}

@endpoint GET /ai/assistants/tests/test-suites/{suite_name}/runs
@desc Get test suite run history
@required {suite_name: str}
@optional {status: str # Filter runs by execution status (pending, running, completed, failed, timeout), test_suite_run_id: str # Filter runs by specific suite execution batch ID, page: map # Consolidated page parameter (deepObject style). Originally: page[size], page[number]}
@returns(200) {data: [map], meta: map{page_number: int, page_size: int, total_pages: int, total_results: int}} # Returns paginated list of test runs within the specified suite
@errors {422: Validation Error}

@endpoint POST /ai/assistants/tests/test-suites/{suite_name}/runs
@desc Trigger test suite execution
@required {suite_name: str}
@optional {destination_version_id: str # Optional assistant version ID to use for all test runs in this suite. If provided, the version must exist or a 400 error will be returned. If not provided, test will run on main version}
@returns(201) Returns array of created test runs for all tests in the suite
@errors {422: Validation Error}

@endpoint DELETE /ai/assistants/tests/{test_id}
@desc Delete an assistant test
@required {test_id: str}
@returns(200) Returns success status when test is successfully deleted
