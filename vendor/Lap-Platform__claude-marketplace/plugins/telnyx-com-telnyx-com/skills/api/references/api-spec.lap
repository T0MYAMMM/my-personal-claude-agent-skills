@group oauth
@endpoint GET /oauth/authorize
@desc OAuth authorization endpoint
@required {response_type: str # OAuth response type, client_id: str # OAuth client identifier, redirect_uri: str(uri) # Redirect URI}
@optional {scope: str # Space-separated list of requested scopes, state: str # State parameter for CSRF protection, code_challenge: str # PKCE code challenge, code_challenge_method: str(plain/S256) # PKCE code challenge method}
@returns(200) Consent page displayed (when consent UI is embedded)
@errors {302: Redirect to consent page or client with authorization code/error, 400: Invalid request, 404: Client not found, 422: Invalid redirect URI}

@endpoint GET /oauth/consent/{consent_token}
@desc Get OAuth consent token
@required {consent_token: str # OAuth consent token}
@returns(200) {data: map{client_id: str, logo_uri: str(uri)?, name: str, policy_uri: str(uri)?, redirect_uri: str(uri), requested_scopes: [map], tos_uri: str(uri)?, verified: bool}} # Consent token details
@errors {422: Invalid consent token}

@endpoint POST /oauth/grants
@desc Create OAuth grant
@required {allowed: bool # Whether the grant is allowed, consent_token: str # Consent token}
@returns(200) {redirect_uri: str(uri)} # Grant created successfully
@errors {422: Invalid consent token}

@endpoint POST /oauth/introspect
@desc Token introspection
@required {token: str # The token to introspect}
@returns(200) {active: bool, aud: str, client_id: str, exp: int, iat: int, iss: str, scope: str} # Introspection response
@errors {400: Invalid request, 401: Invalid client credentials}

@endpoint GET /oauth/jwks
@desc JSON Web Key Set
@returns(200) {keys: [map]} # JSON Web Key Set
@errors {400: Bad Request, 401: Unauthorized}

@endpoint POST /oauth/register
@desc Dynamic client registration
@optional {client_name: str # Human-readable string name of the client to be presented to the end-user, grant_types: [str]=['authorization_code'] # Array of OAuth 2.0 grant type strings that the client may use, logo_uri: str(uri) # URL of the client logo, policy_uri: str(uri) # URL of the client's privacy policy, redirect_uris: [str(uri)] # Array of redirection URI strings for use in redirect-based flows, response_types: [str]=['code'] # Array of the OAuth 2.0 response type strings that the client may use, scope: str # Space-separated string of scope values that the client may use, token_endpoint_auth_method: str(none/client_secret_basic/client_secret_post)=client_secret_basic # Authentication method for the token endpoint, tos_uri: str(uri) # URL of the client's terms of service}
@returns(201) {client_id: str, client_id_issued_at: int, client_name: str, client_secret: str, grant_types: [str], logo_uri: str(uri), policy_uri: str(uri), redirect_uris: [str(uri)], response_types: [str], scope: str, token_endpoint_auth_method: str, tos_uri: str(uri)} # Client registered successfully
@errors {400: Invalid client metadata}

@endpoint POST /oauth/token
@desc OAuth token endpoint
@required {grant_type: str(client_credentials/authorization_code/refresh_token) # OAuth 2.0 grant type}
@optional {client_id: str # OAuth client ID (if not using HTTP Basic auth), client_secret: str # OAuth client secret (if not using HTTP Basic auth), code: str # Authorization code (for authorization_code flow), code_verifier: str # PKCE code verifier (for authorization_code flow), redirect_uri: str(uri) # Redirect URI (for authorization_code flow), refresh_token: str # Refresh token (for refresh_token flow), scope: str # Space-separated list of requested scopes (for client_credentials)}
@returns(200) {access_token: str, expires_in: int, refresh_token: str, scope: str, token_type: str} # Token response
@errors {400: Invalid request, 401: Invalid client credentials}

@endgroup

@group oauth_clients
@endpoint GET /oauth_clients
@desc List OAuth clients
@optional {page[size]: int=20: any # Number of results per page, page[number]: int=1 # Page number, filter[client_type]: str(confidential/public) # Filter by client type, filter[verified]: bool # Filter by verification status, filter[allowed_grant_types][contains]: str(client_credentials/authorization_code/refresh_token) # Filter by allowed grant type, filter[name]: str # Filter by exact client name, filter[name][contains]: str # Filter by client name containing text, filter[client_id]: str # Filter by client ID}
