@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api PrivateDnsManagementClient
@base https://management.azure.com
@version 2018-09-01
@auth OAuth2
@common_fields {api-version: any # Client Api Version., subscriptionId: any # Gets subscription credentials which uniquely identify Microsoft Azure subscription. The subscription ID forms part of the URI for every service call.}
@endpoints 17
@toc subscriptions(17)

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}
@desc Creates or updates a Private DNS zone. Does not modify Links to virtual networks or DNS records within the zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., parameters: any # Parameters supplied to the CreateOrUpdate operation.}
@optional {If-Match: any # The ETag of the Private DNS zone. Omit this value to always overwrite the current zone. Specify the last-seen ETag value to prevent accidentally overwriting any concurrent changes., If-None-Match: any # Set to '*' to allow a new Private DNS zone to be created, but to prevent updating an existing zone. Other values will be ignored.}
@returns(201) The Private DNS zone has been created.
@returns(200) The Private DNS zone has been updated.
@returns(202) The Private DNS zone upsert operation has been accepted and will complete asynchronously.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}
@desc Updates a Private DNS zone. Does not modify virtual network links or DNS records within the zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., parameters: any # Parameters supplied to the Update operation.}
@optional {If-Match: any # The ETag of the Private DNS zone. Omit this value to always overwrite the current zone. Specify the last-seen ETag value to prevent accidentally overwriting any concurrent changes.}
@returns(200) The Private DNS zone has been updated.
@returns(202) The Private DNS zone update operation has been accepted and will complete asynchronously.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}
@desc Deletes a Private DNS zone. WARNING: All DNS records in the zone will also be deleted. This operation cannot be undone. Private DNS zone cannot be deleted unless all virtual network links to it are removed.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot).}
@optional {If-Match: any # The ETag of the Private DNS zone. Omit this value to always delete the current zone. Specify the last-seen ETag value to prevent accidentally deleting any concurrent changes.}
@returns(200) The Private DNS zone has been deleted.
@returns(202) The Private DNS zone delete operation has been accepted and will complete asynchronously.
@returns(204) The Private DNS zone was not found.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}
@desc Gets a Private DNS zone. Retrieves the zone properties, but not the virtual networks links or the record sets within the zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot).}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Network/privateDnsZones
@desc Lists the Private DNS zones in all resource groups in a subscription.
@optional {$top: any # The maximum number of Private DNS zones to return. If not specified, returns up to 100 zones.}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones
@desc Lists the Private DNS zones within a resource group.
@required {resourceGroupName: any # The name of the resource group.}
@optional {$top: any # The maximum number of record sets to return. If not specified, returns up to 100 record sets.}
@returns(200) Success.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/virtualNetworkLinks/{virtualNetworkLinkName}
@desc Creates or updates a virtual network link to the specified Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., virtualNetworkLinkName: any # The name of the virtual network link., parameters: any # Parameters supplied to the CreateOrUpdate operation.}
@optional {If-Match: any # The ETag of the virtual network link to the Private DNS zone. Omit this value to always overwrite the current virtual network link. Specify the last-seen ETag value to prevent accidentally overwriting any concurrent changes., If-None-Match: any # Set to '*' to allow a new virtual network link to the Private DNS zone to be created, but to prevent updating an existing link. Other values will be ignored.}
@returns(201) The virtual network link to the Private DNS zone has been created.
@returns(200) The virtual network link to the Private DNS zone has been updated.
@returns(202) The operation to upsert virtual network link to the Private DNS zone has been accepted and will complete asynchronously.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/virtualNetworkLinks/{virtualNetworkLinkName}
@desc Updates a virtual network link to the specified Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., virtualNetworkLinkName: any # The name of the virtual network link., parameters: any # Parameters supplied to the Update operation.}
@optional {If-Match: any # The ETag of the virtual network link to the Private DNS zone. Omit this value to always overwrite the current virtual network link. Specify the last-seen ETag value to prevent accidentally overwriting any concurrent changes.}
@returns(200) The virtual network link to the Private DNS zone has been updated.
@returns(202) The operation to link virtual network link to Private DNS zone has been accepted and will complete asynchronously.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/virtualNetworkLinks/{virtualNetworkLinkName}
@desc Deletes a virtual network link to the specified Private DNS zone. WARNING: In case of a registration virtual network, all auto-registered DNS records in the zone for the virtual network will also be deleted. This operation cannot be undone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., virtualNetworkLinkName: any # The name of the virtual network link.}
@optional {If-Match: any # The ETag of the virtual network link to the Private DNS zone. Omit this value to always delete the current zone. Specify the last-seen ETag value to prevent accidentally deleting any concurrent changes.}
@returns(200) The virtual network link to the Private DNS zone has been deleted.
@returns(202) The operation to delete virtual network link to the Private DNS zone has been accepted and will complete asynchronously.
@returns(204) The virtual network link to the Private DNS zone was not found.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/virtualNetworkLinks/{virtualNetworkLinkName}
@desc Gets a virtual network link to the specified Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., virtualNetworkLinkName: any # The name of the virtual network link.}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/virtualNetworkLinks
@desc Lists the virtual network links to the specified Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot).}
@optional {$top: any # The maximum number of virtual network links to return. If not specified, returns up to 100 virtual network links.}
@returns(200) Success.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/{recordType}/{relativeRecordSetName}
@desc Creates or updates a record set within a Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., recordType: any # The type of DNS record in this record set. Record sets of type SOA can be updated but not created (they are created when the Private DNS zone is created)., relativeRecordSetName: any # The name of the record set, relative to the name of the zone., parameters: any # Parameters supplied to the CreateOrUpdate operation.}
@optional {If-Match: any # The ETag of the record set. Omit this value to always overwrite the current record set. Specify the last-seen ETag value to prevent accidentally overwriting any concurrent changes., If-None-Match: any # Set to '*' to allow a new record set to be created, but to prevent updating an existing record set. Other values will be ignored.}
@returns(201) The record set has been created.
@returns(200) The record set has been updated.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/{recordType}/{relativeRecordSetName}
@desc Updates a record set within a Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., recordType: any # The type of DNS record in this record set., relativeRecordSetName: any # The name of the record set, relative to the name of the zone., parameters: any # Parameters supplied to the Update operation.}
@optional {If-Match: any # The ETag of the record set. Omit this value to always overwrite the current record set. Specify the last-seen ETag value to prevent accidentally overwriting concurrent changes.}
@returns(200) The record set has been updated.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/{recordType}/{relativeRecordSetName}
@desc Deletes a record set from a Private DNS zone. This operation cannot be undone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., recordType: any # The type of DNS record in this record set. Record sets of type SOA cannot be deleted (they are deleted when the Private DNS zone is deleted)., relativeRecordSetName: any # The name of the record set, relative to the name of the zone.}
@optional {If-Match: any # The ETag of the record set. Omit this value to always delete the current record set. Specify the last-seen ETag value to prevent accidentally deleting any concurrent changes.}
@returns(200) The record set has been deleted.
@returns(204) The record set was not found.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/{recordType}/{relativeRecordSetName}
@desc Gets a record set.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., recordType: any # The type of DNS record in this record set., relativeRecordSetName: any # The name of the record set, relative to the name of the zone.}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/{recordType}
@desc Lists the record sets of a specified type in a Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot)., recordType: any # The type of record sets to enumerate.}
@optional {$top: any # The maximum number of record sets to return. If not specified, returns up to 100 record sets., $recordsetnamesuffix: any # The suffix label of the record set name to be used to filter the record set enumeration. If this parameter is specified, the returned enumeration will only contain records that end with ".<recordsetnamesuffix>".}
@returns(200) Success.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/privateDnsZones/{privateZoneName}/ALL
@desc Lists all record sets in a Private DNS zone.
@required {resourceGroupName: any # The name of the resource group., privateZoneName: any # The name of the Private DNS zone (without a terminating dot).}
@optional {$top: any # The maximum number of record sets to return. If not specified, returns up to 100 record sets., $recordsetnamesuffix: any # The suffix label of the record set name to be used to filter the record set enumeration. If this parameter is specified, the returned enumeration will only contain records that end with ".<recordsetnamesuffix>".}
@returns(200) Success.

@end
