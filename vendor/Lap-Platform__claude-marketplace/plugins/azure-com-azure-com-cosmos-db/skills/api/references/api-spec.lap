@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Cosmos DB
@base https://management.azure.com
@version 2019-08-01
@auth OAuth2
@common_fields {resourceGroupName: any # Name of an Azure resource group., accountName: any # Cosmos DB database account name., api-version: any # Version of the API to be used with the client request. The current version is 2019-08-01.}
@endpoints 101
@hint download_for_search
@toc subscriptions(99), providers(2)

@group subscriptions
@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}
@desc Retrieves the properties of an existing Azure Cosmos DB database account.
@returns(200) The database account properties were retrieved successfully.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}
@desc Updates the properties of an existing Azure Cosmos DB database account.
@required {updateParameters: map # The parameters to provide for the current database account.}
@returns(200) The database account update operation will complete asynchronously.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}
@desc Creates or updates an Azure Cosmos DB database account. The "Update" method is preferred when performing updates on an account.
@required {createUpdateParameters: map # The parameters to provide for the current database account.}
@returns(200) The database account create or update operation will complete asynchronously.

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}
@desc Deletes an existing Azure Cosmos DB database account.
@returns(202) The database account delete operation will complete asynchronously.
@returns(204) The specified account does not exist in the subscription.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/failoverPriorityChange
@desc Changes the failover priority for the Azure Cosmos DB database account. A failover priority of 0 indicates a write region. The maximum value for a failover priority = (total number of regions - 1). Failover priority values must be unique for each of the regions in which the database account exists.
@required {failoverParameters: any # The new failover policies for the database account.}
@returns(202) Accepted. The failover policy change operation will complete asynchronously.
@returns(204) No Content

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.DocumentDB/databaseAccounts
@desc Lists all the Azure Cosmos DB database accounts available under the subscription.
@returns(200) The operation completed successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts
@desc Lists all the Azure Cosmos DB database accounts available under the given resource group.
@returns(200) The operation completed successfully.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/listKeys
@desc Lists the access keys for the specified Azure Cosmos DB database account.
@returns(200) The operation completed successfully.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/listConnectionStrings
@desc Lists the connection strings for the specified Azure Cosmos DB database account.
@returns(200) The operation completed successfully.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/offlineRegion
@desc Offline the specified region for the specified Azure Cosmos DB database account.
@required {regionParameterForOffline: any # Cosmos DB region to offline for the database account.}
@returns(200) The offline region operation is completed successfully.
@returns(202) Accepted. The offline region operation will complete asynchronously.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/onlineRegion
@desc Online the specified region for the specified Azure Cosmos DB database account.
@required {regionParameterForOnline: any # Cosmos DB region to online for the database account.}
@returns(200) The online region operation is completed successfully.
@returns(202) Accepted. The online region operation will complete asynchronously.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/readonlykeys
@desc Lists the read-only access keys for the specified Azure Cosmos DB database account.
@returns(200) The operation completed successfully.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/readonlykeys
@desc Lists the read-only access keys for the specified Azure Cosmos DB database account.
@returns(200) The operation completed successfully.

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/regenerateKey
@desc Regenerates an access key for the specified Azure Cosmos DB database account.
@required {keyToRegenerate: map # The name of the key to regenerate.}
@returns(200) OK
@returns(202) Accepted. The regenerate key operation will complete asynchronously.

@endgroup

@group providers
@endpoint HEAD /providers/Microsoft.DocumentDB/databaseAccountNames/{accountName}
@desc Checks that the Azure Cosmos DB account name already exists. A valid account name may contain only lowercase letters, numbers, and the '-' character, and must be between 3 and 50 characters.
@returns(200) OK. The account name is valid but is already in use.
@errors {404: Not Found. The account name is available and valid.}

@endpoint GET /providers/Microsoft.DocumentDB/operations
@desc Lists all of the available Cosmos DB Resource Provider operations.
@returns(200) OK

@endgroup

@group subscriptions
@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/metrics
@desc Retrieves the metrics determined by the given filter for the given database account.
@required {$filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The metrics for the database account were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/databases/{databaseRid}/metrics
@desc Retrieves the metrics determined by the given filter for the given database account and database.
@required {databaseRid: any # Cosmos DB database rid., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The metrics for the database account were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/databases/{databaseRid}/collections/{collectionRid}/metrics
@desc Retrieves the metrics determined by the given filter for the given database account and collection.
@required {databaseRid: any # Cosmos DB database rid., collectionRid: any # Cosmos DB collection rid., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The metrics for the database account were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/region/{region}/databases/{databaseRid}/collections/{collectionRid}/metrics
@desc Retrieves the metrics determined by the given filter for the given database account, collection and region.
@required {region: any # Cosmos DB region, with spaces between words and each word capitalized., databaseRid: any # Cosmos DB database rid., collectionRid: any # Cosmos DB collection rid., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The metrics for the database account were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/region/{region}/metrics
@desc Retrieves the metrics determined by the given filter for the given database account and region.
@required {region: any # Cosmos DB region, with spaces between words and each word capitalized., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The metrics for the database account were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/sourceRegion/{sourceRegion}/targetRegion/{targetRegion}/percentile/metrics
@desc Retrieves the metrics determined by the given filter for the given account, source and target region. This url is only for PBS and Replication Latency data
@required {sourceRegion: any # Source region from which data is written. Cosmos DB region, with spaces between words and each word capitalized., targetRegion: any # Target region to which data is written. Cosmos DB region, with spaces between words and each word capitalized., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The percentile metrics for the account, source and target regions were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/targetRegion/{targetRegion}/percentile/metrics
@desc Retrieves the metrics determined by the given filter for the given account target region. This url is only for PBS and Replication Latency data
@required {targetRegion: any # Target region to which data is written. Cosmos DB region, with spaces between words and each word capitalized., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The percentile metrics for the account and target regions were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/percentile/metrics
@desc Retrieves the metrics determined by the given filter for the given database account. This url is only for PBS and Replication Latency data
@required {$filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The percentile metrics for the account were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/region/{region}/databases/{databaseRid}/collections/{collectionRid}/partitions/metrics
@desc Retrieves the metrics determined by the given filter for the given collection and region, split by partition.
@required {region: any # Cosmos DB region, with spaces between words and each word capitalized., databaseRid: any # Cosmos DB database rid., collectionRid: any # Cosmos DB collection rid., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The partition-level metrics for the collection and region were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/databases/{databaseRid}/collections/{collectionRid}/partitions/metrics
@desc Retrieves the metrics determined by the given filter for the given collection, split by partition.
@required {databaseRid: any # Cosmos DB database rid., collectionRid: any # Cosmos DB collection rid., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The partition-level metrics for the collection were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/databases/{databaseRid}/collections/{collectionRid}/partitionKeyRangeId/{partitionKeyRangeId}/metrics
@desc Retrieves the metrics determined by the given filter for the given partition key range id.
@required {databaseRid: any # Cosmos DB database rid., collectionRid: any # Cosmos DB collection rid., partitionKeyRangeId: any # Partition Key Range Id for which to get data., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The partition-level metrics for the partition key range id were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/region/{region}/databases/{databaseRid}/collections/{collectionRid}/partitionKeyRangeId/{partitionKeyRangeId}/metrics
@desc Retrieves the metrics determined by the given filter for the given partition key range id and region.
@required {region: any # Cosmos DB region, with spaces between words and each word capitalized., databaseRid: any # Cosmos DB database rid., collectionRid: any # Cosmos DB collection rid., partitionKeyRangeId: any # Partition Key Range Id for which to get data., $filter: any # An OData filter expression that describes a subset of metrics to return. The parameters that can be filtered are name.value (name of the metric, can have an or of multiple names), startTime, endTime, and timeGrain. The supported operator is eq.}
@returns(200) The partition-level metrics for the partition key range id and region were retrieved successfully.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.DocumentDB/databaseAccounts/{accountName}/usages
