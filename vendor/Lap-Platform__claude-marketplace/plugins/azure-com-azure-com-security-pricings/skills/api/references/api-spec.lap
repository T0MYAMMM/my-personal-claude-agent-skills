@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Microsoft Defender for Cloud
@base https://management.azure.com
@version 2018-06-01
@auth OAuth2
@endpoints 3
@toc subscriptions(3)

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/pricings
@desc Lists Microsoft Defender for Cloud pricing configurations in the subscription.
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Security/pricings/{pricingName}
@desc Gets a provided Microsoft Defender for Cloud pricing configuration in the subscription.
@required {pricingName: any # name of the pricing configuration}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/providers/Microsoft.Security/pricings/{pricingName}
@desc Updates a provided Microsoft Defender for Cloud pricing configuration in the subscription.
@required {pricingName: any # name of the pricing configuration, pricing: map # Pricing object}
@returns(200) OK

@end
