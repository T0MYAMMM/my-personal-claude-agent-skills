@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Flickr API Schema
@base https://api.flickr.com/services
@version 1.0.0
@auth ApiKey api_key in query
@endpoints 25
@hint download_for_search
@toc rest?method=flickr.favorites.getList(1), rest?method=flickr.people.getPhotos(1), rest?method=flickr.photosets.getList(1), rest?method=flickr.favorites.getContext(1), rest?method=flickr.groups.getInfo(1), rest?method=flickr.groups.pools.getPhotos(1), rest?method=flickr.groups.discuss.topics.getList(1), rest?method=flickr.groups.discuss.replies.getInfo(1), rest?method=flickr.groups.discuss.topics.getInfo(1), rest?method=flickr.groups.pools.getContext(1), rest?method=flickr.photolist.getContext(1), rest?method=flickr.photos.getContext(1), rest?method=flickr.photos.licenses.getInfo(1), rest?method=flickr.people.getInfo(1), rest?method=flickr.photos.getExif(1), rest?method=flickr.photos.getInfo(1), rest?method=flickr.photos.getSizes(1), rest?method=flickr.photosets.getContext(1), rest?method=flickr.photosets.getPhotos(1), rest?method=flickr.galleries.getPhotos(1), rest?method=flickr.photos.search(1), upload(1), rest?method=flickr.test.echo(1), oauth(2)

@group rest?method=flickr.favorites.getList
@endpoint GET /rest?method=flickr.favorites.getList
@desc Returns a list of the user's favorite photos. Only photos which the calling user has permission to see are returned.
@required {api_key: any, user_id: any}
@optional {min_fave_date: any, max_fave_date: any, page: any, per_page: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.people.getPhotos
@endpoint GET /rest?method=flickr.people.getPhotos
@desc Return photos from the given user's photostream
@required {api_key: any, user_id: any}
@optional {safe_search: any, min_upload_date: any, max_upload_date: any, min_taken_date: any, max_taken_date: any, content_type: any, privacy_filter: any, page: any, per_page: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photosets.getList
@endpoint GET /rest?method=flickr.photosets.getList
@desc Returns the albums belonging to the specified user
@required {api_key: any, user_id: any}
@optional {page: any, per_page: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.favorites.getContext
@endpoint GET /rest?method=flickr.favorites.getContext
@desc Returns next and previous favorites for a photo in a user's favorites
@required {api_key: any, photo_id: any}
@optional {user_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.groups.getInfo
@endpoint GET /rest?method=flickr.groups.getInfo
@desc Get information about a group
@required {api_key: any}
@optional {group_id: any, group_path_alias: any, lang: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.groups.pools.getPhotos
@endpoint GET /rest?method=flickr.groups.pools.getPhotos
@desc Returns a list of pool photos for a given group
@required {api_key: any}
@optional {group_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.groups.discuss.topics.getList
@endpoint GET /rest?method=flickr.groups.discuss.topics.getList
@desc Get a list of discussion topics in a group.
@required {api_key: any}
@optional {group_id: any, page: any, per_page: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.groups.discuss.replies.getInfo
@endpoint GET /rest?method=flickr.groups.discuss.replies.getInfo
@desc Get information on a group topic reply
@required {api_key: any, topic_id: any, reply_id: any}
@optional {group_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.groups.discuss.topics.getInfo
@endpoint GET /rest?method=flickr.groups.discuss.topics.getInfo
@desc Get information about a group discussion topic
@required {api_key: any, topic_id: any}
@optional {group_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.groups.pools.getContext
@endpoint GET /rest?method=flickr.groups.pools.getContext
@desc Returns next and previous photos for a photo in a group pool
@required {api_key: any, photo_id: any}
@optional {group_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photolist.getContext
@endpoint GET /rest?method=flickr.photolist.getContext
@desc Returns next and previous photos in a photo list
@required {api_key: any, photo_id: any, photolist_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photos.getContext
@endpoint GET /rest?method=flickr.photos.getContext
@desc Returns next and previous photos for a photo in a photostream
@required {api_key: any, photo_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photos.licenses.getInfo
@endpoint GET /rest?method=flickr.photos.licenses.getInfo
@desc Fetches a list of available photo licenses for Flickr
@required {api_key: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.people.getInfo
@endpoint GET /rest?method=flickr.people.getInfo
@desc Returns a person
@required {api_key: any}
@optional {user_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photos.getExif
@endpoint GET /rest?method=flickr.photos.getExif
@desc Retrieves a list of EXIF/TIFF/GPS tags for a given photo. The calling user must have permission to view the photo.
@required {api_key: any, photo_id: any}
@optional {secret: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photos.getInfo
@endpoint GET /rest?method=flickr.photos.getInfo
@desc Returns a photo
@required {api_key: any, photo_id: any}
@returns(200) a photo

@endgroup

@group rest?method=flickr.photos.getSizes
@endpoint GET /rest?method=flickr.photos.getSizes
@desc Returns photo sizes
@required {api_key: any, photo_id: any}
@returns(200) Photo sizes

@endgroup

@group rest?method=flickr.photosets.getContext
@endpoint GET /rest?method=flickr.photosets.getContext
@desc Returns next and previous photos for a photo in a set
@required {api_key: any, photo_id: any}
@optional {photoset_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photosets.getPhotos
@endpoint GET /rest?method=flickr.photosets.getPhotos
@desc Returns a list of photos in an album.
@required {api_key: any, photoset_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.galleries.getPhotos
@endpoint GET /rest?method=flickr.galleries.getPhotos
@desc Returns a list of photos in a gallery.
@required {api_key: any, gallery_id: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.photos.search
@endpoint GET /rest?method=flickr.photos.search
@desc Return a list of photos matching some criteria.
@required {api_key: any}
@optional {text: any # A free text search. Photos who's title, description or tags contain the text will be returned. You can exclude results that match a term by prepending it with a - character., tags: any # A comma-delimited list of tags. Photos with one or more of the tags listed will be returned. You can exclude results that match a term by prepending it with a - character., user_id: any # The NSID of the user who's photo to search. If this parameter isn't passed then everybody's public photos will be searched. A value of "me" will search against the calling user's photos for authenticated calls., min_upload_date: any # Minimum upload date. Photos with an upload date greater than or equal to this value will be returned. The date can be in the form of a unix timestamp or mysql datetime., max_upload_date: any # Maximum upload date. Photos with an upload date less than or equal to this value will be returned. The date can be in the form of a unix timestamp or mysql datetime., min_taken_date: any # Minimum taken date. Photos with an taken date greater than or equal to this value will be returned. The date can be in the form of a mysql datetime or unix timestamp., max_taken_date: any # Maximum taken date. Photos with an taken date less than or equal to this value will be returned. The date can be in the form of a mysql datetime or unix timestamp., license: any # The license id for photos (for possible values see the flickr.photos.licenses.getInfo method). Multiple licenses may be comma-separated., sort: any # The order in which to sort returned photos. Deafults to date-posted-desc (unless you are doing a radial geo query, in which case the default sorting is by ascending distance from the point specified). The possible values are:   date-posted-asc,   date-posted-desc,   date-taken-asc,   date-taken-desc,   interestingness-desc,   interestingness-asc, and   relevance., privacy_filter: any # Return photos only matching a certain privacy level. This only applies when making an authenticated call to view photos you own. Valid values are:,   1: public photos,   2: private photos visible to friends,   3: private photos visible to family,   4: private photos visible to friends & family,   5: completely private photos, bbox: any # A comma-delimited list of 4 values defining the Bounding Box of the area that will be searched., accuracy: any # Recorded accuracy level of the location information. Current range is 1-16:   World level is 1   Country is ~3   Region is ~6   City is ~11   Street is ~16, safe_search: any # Safe search setting:   1: for safe,   2: for moderate,   3: for restricted, content_type: any # Content Type setting:   1: photos only.   2: screenshots only.   3: 'other' only.   4: photos and screenshots.   5: screenshots and 'other'.   6: photos and 'other'.   7: photos, screenshots, and 'other' (all)., machine_tags: any # Aside from passing in a fully formed machine tag, there is a special syntax for searching on specific properties : Find photos using the 'dc' namespace : "machine_tags" => "dc:" Find photos with a title in the 'dc' namespace : "machine_tags" => "dc:title=" Find photos titled "mr. camera" in the 'dc' namespace : "machine_tags" => "dc:title=\"mr. camera\" Find photos whose value is "mr. camera" : "machine_tags" => "*:*=\"mr. camera\"" Find photos that have a title, in any namespace : "machine_tags" => "*:title=" Find photos that have a title, in any namespace, whose value is "mr. camera" : "machine_tags" => "*:title=\"mr. camera\"" Find photos, in the 'dc' namespace whose value is "mr. camera" : "machine_tags" => "dc:*=\"mr. camera\"" Multiple machine tags may be queried by passing a comma-separated list. The number of machine tags you can pass in a single query depends on the tag mode (AND or OR) that you are querying with. "AND" queries are limited to (16) machine tags. "OR" queries are limited to (8)., machine_tag_mode: any # Either 'any' for an OR combination of tags, or 'all' for an AND combination. Defaults to 'any' if not specified., group_id: any # The id of a group who's pool to search. If specified, only matching photos posted to the group's pool will be returned., contacts: any # Search your contacts. Either 'all' or 'ff' for just friends and family. (Experimental), woe_id: any # A 32-bit identifier that uniquely represents spatial entities. (not used if bbox argument is present)., place_id: any # A Flickr place id. (not used if bbox argument is present). Geo queries require some sort of limiting agent in order to prevent the database from crying. This is basically like the check against "parameterless searches" for queries without a geo component. A tag, for instance, is considered a limiting agent as are user defined min_date_taken and min_date_upload parameters — If no limiting factor is passed we return only photos added in the last 12 hours (though we may extend the limit in the future)., media: any # Filter results by media type. Possible values are all (default), photos or videos, has_geo: any # Any photo that has been geotagged, or if the value is "0" any photo that has not been geotagged. Geo queries require some sort of limiting agent in order to prevent the database from crying. This is basically like the check against "parameterless searches" for queries without a geo component. A tag, for instance, is considered a limiting agent as are user defined min_date_taken and min_date_upload parameters — If no limiting factor is passed we return only photos added in the last 12 hours (though we may extend the limit in the future)., geo_context: any # Geo context is a numeric value representing the photo's geotagginess beyond latitude and longitude. For example, you may wish to search for photos that were taken "indoors" or "outdoors". The current list of context IDs is: 0, not defined. 1, indoors. 2, outdoors. Geo queries require some sort of limiting agent in order to prevent the database from crying. This is basically like the check against "parameterless searches" for queries without a geo component. A tag, for instance, is considered a limiting agent as are user defined min_date_taken and min_date_upload parameters — If no limiting factor is passed we return only photos added in the last 12 hours (though we may extend the limit in the future)., lat: any # A valid latitude, in decimal format, for doing radial geo queries. Geo queries require some sort of limiting agent in order to prevent the database from crying. This is basically like the check against "parameterless searches" for queries without a geo component. A tag, for instance, is considered a limiting agent as are user defined min_date_taken and min_date_upload parameters — If no limiting factor is passed we return only photos added in the last 12 hours (though we may extend the limit in the future)., lon: any # A valid longitude, in decimal format, for doing radial geo queries. Geo queries require some sort of limiting agent in order to prevent the database from crying. This is basically like the check against "parameterless searches" for queries without a geo component. A tag, for instance, is considered a limiting agent as are user defined min_date_taken and min_date_upload parameters — If no limiting factor is passed we return only photos added in the last 12 hours (though we may extend the limit in the future)., radius: any # A valid radius used for geo queries, greater than zero and less than 20 miles (or 32 kilometers), for use with point-based geo queries. The default value is 5 (km)., radius_units: any # The unit of measure when doing radial geo queries. Valid options are "mi" (miles) and "km" (kilometers). The default is "km"., is_commons: any # Limit the scope of the search to only photos that are part of the Flickr Commons project. Default is false., in_gallery: any # Limit the scope of the search to only photos that are in a gallery? Default is false, search all photos., is_getty: any # Limit the scope of the search to only photos that are for sale on Getty. Default is false., per_page: any # Number of photos to return per page. If this argument is omitted, it defaults to 100. The maximum allowed value is 500., page: any # The page of results to return. If this argument is omitted, it defaults to 1.}
@returns(200) OK

@endgroup

@group upload
@endpoint POST /upload
@desc Uploads a new photo to Flickr
@required {api_key: any, photo: any}
@optional {title: any, description: any, tags: any, is_public: any, is_friend: any, is_family: any, safety_level: any, content_type: any, hidden: any}
@returns(200) OK

@endgroup

@group rest?method=flickr.test.echo
@endpoint GET /rest?method=flickr.test.echo
@desc Echos the input parameters back in the response
@required {api_key: any}
@optional {echo: any}
@returns(200) OK

@endgroup

@group oauth
@endpoint GET /oauth/request_token
@desc Returns an oauth token and oauth token secret
@required {oauth_consumer_key: any, oauth_nonce: any, oauth_timestamp: any, oauth_signature_method: any, oauth_version: any, oauth_signature: any, oauth_callback: any}
@returns(200) OK

@endpoint GET /oauth/access_token
@desc Returns an access token
@required {oauth_consumer_key: any, oauth_nonce: any, oauth_timestamp: any, oauth_signature_method: any, oauth_version: any, oauth_signature: any, oauth_verifier: any, oauth_token: any}
@returns(200) OK

@endgroup

@end
