@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/publicIPAddresses/{publicIpAddressName}
@desc Deletes the specified public IP address.
@required {resourceGroupName: any # The name of the resource group., publicIpAddressName: any # The name of the subnet.}
@returns(204) Request successful. Resource does not exist.
@returns(202) Accepted and the operation will complete asynchronously.
@returns(200) Delete successful.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/publicIPAddresses/{publicIpAddressName}
@desc Gets the specified public IP address in a specified resource group.
@required {resourceGroupName: any # The name of the resource group., publicIpAddressName: any # The name of the subnet.}
@optional {$expand: any # Expands referenced resources.}
@returns(200) Request successful. The operation returns the resulting PublicIPAddress resource.

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/publicIPAddresses/{publicIpAddressName}
@desc Creates or updates a static or dynamic public IP address.
@required {resourceGroupName: any # The name of the resource group., publicIpAddressName: any # The name of the public IP address., parameters: any # Parameters supplied to the create or update public IP address operation.}
@returns(201) Create successful. The operation returns the resulting PublicIPAddress resource.
@returns(200) Update successful. The operation returns the resulting PublicIPAddress resource.

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/publicIPAddresses/{publicIpAddressName}
@desc Updates public IP address tags.
@required {resourceGroupName: any # The name of the resource group., publicIpAddressName: any # The name of the public IP address., parameters: any # Parameters supplied to update public IP address tags.}
@returns(200) Update successful. The operation returns the resulting PublicIPAddress resource.

@endpoint GET /subscriptions/{subscriptionId}/providers/Microsoft.Network/publicIPAddresses
@desc Gets all the public IP addresses in a subscription.
@returns(200) Request successful. The operation returns a list of PublicIPAddress resources.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/publicIPAddresses
@desc Gets all public IP addresses in a resource group.
@required {resourceGroupName: any # The name of the resource group.}
@returns(200) Request successful. The operation returns a list of PublicIPAddress resources.

