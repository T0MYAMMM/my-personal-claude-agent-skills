@required {fossil: str # The name of the individual fossil you wish to retrieve fossil information about.}
@optional {thumbsize: int # Specify the desired width of returned image URLs. When unspecified, the linked image(s) returned by the API will be full-resolution. Note that images can only be reduced in size; specifying a width greater than than the maximum size will return the default full-size image URL.}
@returns(200) {name: str, url: str, image_url: str, fossil_group: str, interactable: bool, sell: int, hha_base: int, width: int, length: int, colors: [str]} # A JSON object describing the individual fossil.
@errors {401: Failed to authenticate user from `X-API-KEY`., 500: There was an error fetching the requested data.}

@endpoint GET /nh/fossils/groups
@desc All New Horizons fossil groups
@optional {thumbsize: int # Specify the desired width of returned image URLs. When unspecified, the linked image(s) returned by the API will be full-resolution. Note that images can only be reduced in size; specifying a width greater than than the maximum size will return the default full-size image URL.}
@returns(200) A JSON array of fossil groups.
@errors {401: Failed to authenticate user from `X-API-KEY`., 500: There was an error fetching the requested data.}

@endpoint GET /nh/fossils/groups/{fossil_group}
@desc Single New Horizons fossil group
@required {fossil_group: str # The name of the fossil group you wish to retrieve information about.}
@optional {thumbsize: int # Specify the desired width of returned image URLs. When unspecified, the linked image(s) returned by the API will be full-resolution. Note that images can only be reduced in size; specifying a width greater than than the maximum size will return the default full-size image URL.}
@returns(200) {name: str, url: str, room: int, description: str} # A JSON object describing the fossil group.
@errors {401: Failed to authenticate user from `X-API-KEY`., 500: There was an error fetching the requested data.}

@endpoint GET /nh/fossils/all
@desc All New Horizons fossil groups or individual fossil
@optional {thumbsize: int # Specify the desired width of returned image URLs. When unspecified, the linked image(s) returned by the API will be full-resolution. Note that images can only be reduced in size; specifying a width greater than than the maximum size will return the default full-size image URL.}
@returns(200) A JSON array of fossil groups.
@errors {401: Failed to authenticate user from `X-API-KEY`., 500: There was an error fetching the requested data.}

@endpoint GET /nh/fossils/all/{fossil}
@desc Single New Horizons fossil group with individual fossils
@required {fossil: str # The name of the fossil OR fossil group you wish to retrieve information about. If a fossil is provided, a fossil group that the specified fossil belongs to will be returned.}
@optional {thumbsize: int # Specify the desired width of returned image URLs. When unspecified, the linked image(s) returned by the API will be full-resolution. Note that images can only be reduced in size; specifying a width greater than than the maximum size will return the default full-size image URL.}
@returns(200) {name: str, url: str, room: int, description: str, matched: map{type: str, name: str}, fossils: [map]} # A JSON object describing the fossil group.
@errors {401: Failed to authenticate user from `X-API-KEY`., 500: There was an error fetching the requested data.}

@endpoint GET /nh/gyroids
@desc All New Horizons gyroids
@optional {sound: str(crash/drum set/hi-hat/kick/melody/snare) # Specify the sound of the gyroid., excludedetails: str # When set to `true`, only gyroid names are returned. Instead of an array of objects with all details, the return will be an array of strings.}
@returns(200) A JSON array of gyroids.
@errors {401: Failed to authenticate user from `X-API-KEY`., 500: There was an error fetching the requested data.}

@endpoint GET /nh/gyroids/{gyroid}
@desc Single New Horizons gyroid
@required {gyroid: str # The name of the gyroid you wish to retrieve information about.}
@optional {thumbsize: int # Specify the desired width of returned image URLs. When unspecified, the linked image(s) returned by the API will be full-resolution. Note that images can only be reduced in size; specifying a width greater than than the maximum size will return the default full-size image URL.}
@returns(200) {name: str, url: str, hha_base: int, sell: int, customizable: bool, custom_kits: int, custom_kit_type: str, custom_body_part: str, cyrus_price: int, variation_total: int, grid_width: num(float), grid_length: num(float), sound: str, version_added: str, unlocked: bool, notes: str, availability: [map], buy: [map], variations: [map]} # A JSON object describing the gyroid.
@errors {401: Failed to authenticate user from `X-API-KEY`., 500: There was an error fetching the requested data.}

@endgroup

@end
