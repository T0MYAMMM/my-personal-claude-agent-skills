@required {subscriptionId: any # Azure subscription ID., resourceGroupName: any # Name of an Azure resource group., spatialAnchorsAccountName: any # Name of an Mixed Reality Spatial Anchors Account., spatialAnchorsAccountKeyRegenerate: map # Specifying which key to be regenerated.}
