@returns(200) OK

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.MixedReality/spatialAnchorsAccounts/{spatialAnchorsAccountName}
@desc Updating a Spatial Anchors Account
@required {subscriptionId: any # Azure subscription ID., resourceGroupName: any # Name of an Azure resource group., spatialAnchorsAccountName: any # Name of an Mixed Reality Spatial Anchors Account., spatialAnchorsAccount: map # Spatial Anchors Account parameter.}
@returns(200) OK

@endpoint PUT /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.MixedReality/spatialAnchorsAccounts/{spatialAnchorsAccountName}
@desc Creating or Updating a Spatial Anchors Account.
@required {subscriptionId: any # Azure subscription ID., resourceGroupName: any # Name of an Azure resource group., spatialAnchorsAccountName: any # Name of an Mixed Reality Spatial Anchors Account., spatialAnchorsAccount: map # Spatial Anchors Account parameter.}
