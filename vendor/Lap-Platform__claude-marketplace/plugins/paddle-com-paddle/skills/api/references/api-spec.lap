@desc Get a discount
@required {discount_id: str # Paddle ID of the discount entity to work with.}
@optional {include: [str] # Include related entities in the response. Use a comma-separated list to specify multiple entities.}
@returns(200) {data: map{id: any, status: any, description: str, enabled_for_checkout: bool, code: any, type: str, mode: any, amount: str, currency_code: any, recur: bool, maximum_recurring_intervals: any, usage_limit: any, restrict_to: any, expires_at: any, custom_data: any, times_used: int, discount_group_id: any, created_at: any, updated_at: any, import_meta: any, discount_group: any}, meta: map{request_id: str}} # The request has succeeded.

@endpoint PATCH /discounts/{discount_id}
@desc Update a discount
@required {discount_id: str # Paddle ID of the discount entity to work with.}
