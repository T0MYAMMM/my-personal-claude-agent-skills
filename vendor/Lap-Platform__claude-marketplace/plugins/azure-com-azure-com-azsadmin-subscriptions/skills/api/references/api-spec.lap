@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api SubscriptionClient
@base https://management.azure.com
@version 2015-11-01
@auth OAuth2
@endpoints 4
@toc subscriptions(4)

@endpoint GET /subscriptions
@desc Get the list of subscriptions.
@required {api-version: any # Client Api Version.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}
@desc Gets details about particular subscription.
@required {subscriptionId: any # Id of the subscription., api-version: any # Client Api Version.}
@returns(200)

@endpoint PUT /subscriptions/{subscriptionId}
@desc Create or updates a subscription.
@required {subscriptionId: any # Id of the subscription., subscriptionDefinition: map # Subscription parameter., api-version: any # Client Api Version.}
@returns(201) Created
@returns(200) OK

@endpoint DELETE /subscriptions/{subscriptionId}
@desc Delete the specified subscription.
@required {subscriptionId: any # Id of the subscription., api-version: any # Client Api Version.}
@returns(200) OK
@returns(204) No Content

@end
