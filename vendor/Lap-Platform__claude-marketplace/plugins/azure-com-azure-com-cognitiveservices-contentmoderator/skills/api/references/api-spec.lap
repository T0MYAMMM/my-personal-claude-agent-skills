@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Content Moderator Client
@version 1.0
@auth ApiKey Ocp-Apim-Subscription-Key in header
@endpoints 35
@hint download_for_search
@toc contentmoderator(35)

@endpoint POST /contentmoderator/moderate/v1.0/ProcessImage/FindFaces
@desc Returns the list of faces found.
@optional {CacheImage: any # Whether to retain the submitted image for future use. If it's omitted, the default is false.}
@returns(200) List of faces found.

@endpoint POST /contentmoderator/moderate/v1.0/ProcessImage/OCR
@desc Returns any text found in the image for the specified language. If no language is specified in the input, the detection defaults to English.
@required {language: any # Language of the terms.}
@optional {CacheImage: any # Whether to retain the submitted image for future use. If it's omitted, the default is false., enhanced: any # When it's set to true, the image goes through additional processing to come with additional candidates.  The image or TIFF file is not supported when enhanced is set to true.  Note: This affects the response time.}
@returns(200) Text found and list of candidate text details.

@endpoint POST /contentmoderator/moderate/v1.0/ProcessImage/Evaluate
@desc Returns probabilities of the image containing racy or adult content.
@optional {CacheImage: any # Whether to retain the submitted image for future use. If it's omitted, the default is false.}
@returns(200)

@endpoint POST /contentmoderator/moderate/v1.0/ProcessImage/Match
@desc Fuzzily match an image against one of your custom image lists. You can create and manage your custom image lists by using <a href="/docs/services/578ff44d2703741568569ab9/operations/578ff7b12703741568569abe">this API</a>.
@optional {listId: any # List ID., CacheImage: any # Whether to retain the submitted image for future use. If it's omitted, the default is false.}
@returns(200) Supported values for tags are:

@endpoint POST /contentmoderator/moderate/v1.0/ProcessText/Screen/
@desc Detect profanity and match against custom and shared blocklists
@required {Content-Type: any # Content type., Text Content: map # Content to screen.}
@optional {language: any # Language of the text., autocorrect: any # Autocorrect text., PII: any # Detect personal identifiable information., listId: any # List ID., classify: any # Classify input.}
@returns(200) Status 200.

@endpoint POST /contentmoderator/moderate/v1.0/ProcessText/DetectLanguage
@desc This operation detects the language of input content. It returns the <a href="http://www-01.sil.org/iso639-3/codes.asp">ISO 639-3 code</a> for the predominant language in the submitted text. More than 110 languages are supported.
@required {Content-Type: any # Content type., Text Content: map # Content to screen.}
@returns(200) Detected language result.

@endpoint GET /contentmoderator/lists/v1.0/imagelists/{listId}
@desc Returns the details of the image list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@returns(200) OK.

@endpoint DELETE /contentmoderator/lists/v1.0/imagelists/{listId}
@desc Deletes the image list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@returns(200) OK.

@endpoint PUT /contentmoderator/lists/v1.0/imagelists/{listId}
@desc Updates an image list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list., Content-Type: any # Content type., body: map # Schema of the body.}
@returns(200) OK.

@endpoint POST /contentmoderator/lists/v1.0/imagelists
@desc Creates an image list.
@required {Content-Type: any # Content type., body: map # Schema of the body.}
@returns(200) OK.

@endpoint GET /contentmoderator/lists/v1.0/imagelists
@desc Gets all the image lists.
@returns(200) OK.

@endpoint POST /contentmoderator/lists/v1.0/imagelists/{listId}/RefreshIndex
@desc Refreshes the index of the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@returns(200) OK.

@endpoint GET /contentmoderator/lists/v1.0/termlists/{listId}
@desc Returns list ID details of the term list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@returns(200) OK.

@endpoint DELETE /contentmoderator/lists/v1.0/termlists/{listId}
@desc Deletes the term list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@returns(200) OK.

@endpoint PUT /contentmoderator/lists/v1.0/termlists/{listId}
@desc Updates a term list.
@required {listId: any # List ID of the image list., Content-Type: any # Content type., body: map # Schema of the body.}
@returns(200) OK.

@endpoint POST /contentmoderator/lists/v1.0/termlists
@desc Creates a term list.
@required {Content-Type: any # Content type., body: map # Schema of the body.}
@returns(200) OK.

@endpoint GET /contentmoderator/lists/v1.0/termlists
@desc Gets all the term lists.
@returns(200) OK.

@endpoint POST /contentmoderator/lists/v1.0/termlists/{listId}/RefreshIndex
@desc Refreshes the index of the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list., language: any # Language of the terms.}
@returns(200) OK.

@endpoint POST /contentmoderator/lists/v1.0/imagelists/{listId}/images
@desc Add an image to the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@optional {tag: any # Tag for the image., label: any # Image label.}
@returns(200) OK.

@endpoint DELETE /contentmoderator/lists/v1.0/imagelists/{listId}/images
@desc Deletes all images from the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@returns(200) OK.

@endpoint GET /contentmoderator/lists/v1.0/imagelists/{listId}/images
@desc Gets all image IDs from the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list.}
@returns(200) OK.

@endpoint DELETE /contentmoderator/lists/v1.0/imagelists/{listId}/images/{ImageId}
@desc Deletes an image from the list with the passed list ID and image ID.
@required {listId: any # List ID of the image list., ImageId: any # Image ID.}
@returns(200) OK.

@endpoint POST /contentmoderator/lists/v1.0/termlists/{listId}/terms/{term}
@desc Adds a term to the term list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list., term: any # Term to be deleted, language: any # Language of the terms.}
@returns(201) Created.

@endpoint DELETE /contentmoderator/lists/v1.0/termlists/{listId}/terms/{term}
@desc Deletes a term from the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list., term: any # Term to be deleted, language: any # Language of the terms.}
@returns(204) No content.

@endpoint GET /contentmoderator/lists/v1.0/termlists/{listId}/terms
@desc Gets all terms from the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list., language: any # Language of the terms.}
@optional {offset: any # Pagination start index., limit: any # Maximum number.}
@returns(200) OK.

@endpoint DELETE /contentmoderator/lists/v1.0/termlists/{listId}/terms
@desc Deletes all terms from the list with listId equal to the passed list ID.
@required {listId: any # List ID of the image list., language: any # Language of the terms.}
@returns(204) No content.

@endpoint GET /contentmoderator/review/v1.0/teams/{teamName}/reviews/{reviewId}
@desc Returns review details for the passed review ID.
@required {teamName: any # Your team name., reviewId: any # ID of the review.}
@returns(200) OK.

@endpoint GET /contentmoderator/review/v1.0/teams/{teamName}/jobs/{JobId}
@desc Get the job details for a job ID.
@required {teamName: any # Your team name., JobId: any # ID of the job.}
@returns(200) OK.

@endpoint POST /contentmoderator/review/v1.0/teams/{teamName}/reviews
@desc The created reviews appear for reviewers on your team. As reviewers finish reviewing, results of the reviews are posted (that is, HTTP POST) on the specified CallBackEndpoint value.
@required {UrlContentType: any # Content type., teamName: any # Your team name., createReviewBody: [map] # Body of the API for creating reviews.}
@optional {subTeam: any # Subteam that you want to assign the created review to.}
@returns(200) OK.

@endpoint POST /contentmoderator/review/v1.0/teams/{teamName}/jobs
@desc A job ID will be returned for the content posted on this endpoint.
@required {teamName: any # Your team name., ContentType: any # Image, text or video., ContentId: any # ID or name to identify the submitted content., WorkflowName: any # Workflow name that you want to invoke., Content-Type: any # Content type., Content: map # Content to evaluate.}
@optional {CallBackEndpoint: any # Callback endpoint for posting the result of creating a job.}
@returns(200) OK.

@endpoint POST /contentmoderator/review/v1.0/teams/{teamName}/reviews/{reviewId}/frames
@desc The created reviews appear for reviewers on your team. As reviewers finish reviewing, results of the reviews are posted (that is, HTTP POST) on the specified CallBackEndpoint value.
@required {teamName: any # Your team name., reviewId: any # ID of the review.}
@optional {timescale: any # Timescale of the video that you're adding frames to.}
@returns(200) OK.

@endpoint GET /contentmoderator/review/v1.0/teams/{teamName}/reviews/{reviewId}/frames
@desc The created reviews appear for reviewers on your team. As reviewers finish reviewing, results of the reviews are posted (that is, HTTP POST) on the specified CallBackEndpoint value.
@required {teamName: any # Your team name., reviewId: any # ID of the review.}
@optional {startSeed: any # Time stamp of the frame from where you want to start fetching the frames., noOfRecords: any # Number of frames to fetch., filter: any # Get frames filtered by tags.}
@returns(200) OK.

@endpoint POST /contentmoderator/review/v1.0/teams/{teamName}/reviews/{reviewId}/publish
@desc Publish a video review.
@required {teamName: any # Your team name., reviewId: any # ID of the review.}
@returns(204) No content.

@endpoint PUT /contentmoderator/review/v1.0/teams/{teamName}/reviews/{reviewId}/transcriptmoderationresult
@desc This API adds a transcript screen text result file for a video review. The transcript screen text result file is a result of the Screen Text API. To generate a transcript screen text result file, you must screen a transcript file for profanity by using the Screen Text API.
@required {Content-Type: any # Content type., teamName: any # Your team name., reviewId: any # ID of the review., transcriptModerationBody: [map] # Body of the API for adding video transcript moderation results.}
@returns(204) No content.

@endpoint PUT /contentmoderator/review/v1.0/teams/{teamName}/reviews/{reviewId}/transcript
@desc This API adds a transcript file (text version of all the words spoken in a video) to a video review. The file should be in a valid WebVTT format.
@required {teamName: any # Your team name., reviewId: any # ID of the review., Content-Type: any # Content type., VTT file: map # Transcript file of the video.}
@returns(204) No content.

@end
