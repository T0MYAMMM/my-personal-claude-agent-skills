@required {model: str, input_audio_format: str=pcm_s16le_16000 # Audio format specification. Currently supports 16-bit PCM at 16kHz sample rate.}
@errors {101: Switching Protocols - WebSocket connection established successfully.  Error message format: ```json {   "type": "conversation.item.input_audio_transcription.failed",   "error": {     "message": "Error description",     "type": "invalid_request_error",     "param": null,     "code": "error_code"   } } ```}

@endgroup

@group queue
@endpoint POST /queue/cancel
@desc Cancel a queued job
@required {model: str # Model identifier the job was submitted to, request_id: str # The request ID returned from the submit endpoint}
@returns(200) {status: str} # Successfully canceled
@errors {400: Invalid request, 404: Request not found, 409: Job could not be canceled (already completed/failed), 500: Internal server error}

@endpoint GET /queue/metrics
@desc Get queue metrics
@required {model: str}
@returns(200) {messages_running: int, messages_waiting: int, total_jobs: int} # Queue metrics
@errors {400: Invalid request, 401: Unauthorized, 500: Internal server error}

@endpoint GET /queue/status
@desc Get job status
@required {request_id: str, model: str}
@returns(200) {claimed_at: str(date-time), created_at: str(date-time), done_at: str(date-time), info: map, inputs: map, model: str, outputs: map, priority: int, request_id: str, retries: int, status: str, warnings: [str]} # Status information
@errors {400: Invalid request, 401: Unauthorized, 404: Request not found, 500: Internal server error}

@endpoint POST /queue/submit
@desc Submit a queued job
@required {model: str # Required model identifier, payload: map # Freeform model input. Passed unchanged to the model. Contents are model-specific.}
@optional {info: map # Arbitrary JSON metadata stored with the job and returned in status responses. The model and system may add or update keys during processing., priority: int=0 # Job priority. Higher values are processed first (strict priority ordering). Jobs with equal priority are processed in submission order (FIFO).}
@returns(200) {error: map{code: str, message: str, param: str, type: str}, requestId: str} # Successfully queued request
@errors {400: Invalid request, 401: Unauthorized, 500: Internal server error}

@endgroup

@group rl
@endpoint GET /rl/training-sessions
@desc List training sessions
@optional {status: str, limit: int(int32)=20, offset: int(int32)=0}
@returns(200) {data: [map], meta: map{total: str(int64), limit: int(int32), offset: int(int32)}} # List of training sessions

@endpoint POST /rl/training-sessions
@desc Create training session
@required {base_model: str # Base model to use for the training session}
@optional {checkpoint_id: str # Checkpoint ID to use for the training session, lora_config: map{rank: int(int64), alpha: int(int64), dropout: num(float)} # LoRA adapter configuration}
@returns(200) {session_id: str, status: str, base_model: str, checkpoint_id: str, step: str(uint64), created_at: str(date-time), updated_at: str(date-time), lora_config: map{rank: int(int64), alpha: int(int64), dropout: num(float)}} # Training session details

@endpoint GET /rl/training-sessions/{session_id}
@desc Get training session
@required {session_id: str}
@returns(200) {session_id: str, status: str, base_model: str, checkpoint_id: str, step: str(uint64), created_at: str(date-time), updated_at: str(date-time), lora_config: map{rank: int(int64), alpha: int(int64), dropout: num(float)}} # Training session details

@endpoint GET /rl/training-sessions/{session_id}/operations/forward-backward/{operation_id}
@desc Get forward-backward operation
@required {session_id: str, operation_id: str}
@returns(200) {id: str, status: str, output: map{loss: num, metrics: map}, error: map{code: str, message: str}} # Forward-backward operation details

@endpoint GET /rl/training-sessions/{session_id}/operations/optim-step/{operation_id}
@desc Get optim-step operation
@required {session_id: str, operation_id: str}
@returns(200) {id: str, status: str, output: map{step: str(uint64)}, error: map{code: str, message: str}}

@endpoint GET /rl/training-sessions/{session_id}/operations/sample/{operation_id}
@desc Get sample operation
@required {session_id: str, operation_id: str}
@returns(200) {id: str, status: str, output: map{sequences: [map]}, error: map{code: str, message: str}}

@endpoint POST /rl/training-sessions/{session_id}/operations/forward-backward
@desc Forward-backward pass
@required {session_id: str, samples: [map{model_input!: map{chunks!: [map]}, loss_inputs!: map{target_tokens: map, loss_mask: map, grpo_inputs: map}}] # Batch of training samples to process, loss: map{type!: str, cross_entropy_params: map, grpo_params: map{clip_low: num(float), clip_high: num(float), beta: num(float), agg_type: str}}}
@returns(200) {id: str, status: str, output: map{loss: num, metrics: map}, error: map{code: str, message: str}}

@endpoint POST /rl/training-sessions/{session_id}/operations/optim-step
@desc Optimizer step
@required {session_id: str}
@optional {learning_rate: num(float)=0.0001 # Learning rate for this step., adamw_params: map{beta1: num(float), beta2: num(float), eps: num(float), weight_decay: num(float)} # AdamW optimizer parameters}
@returns(200) {id: str, status: str, output: map{step: str(uint64)}, error: map{code: str, message: str}} # Optimizer step operation details

@endpoint POST /rl/training-sessions/{session_id}/operations/sample
@desc Sample
@required {session_id: str, prompt: map{chunks!: [map{encoded_text: map}]}}
@optional {sampling_params: map{max_tokens: int(int32), temperature: num(float), top_p: num(float), top_k: int(int32), stop: [str], seed: str(int64)}, num_samples: int(int64)=1 # Number of completions to generate for this prompt}
@returns(200) {id: str, status: str, output: map{sequences: [map]}, error: map{code: str, message: str}}

@endpoint POST /rl/training-sessions/{session_id}/stop
@desc Stop training session
@required {session_id: str}
@returns(200) {session_id: str, status: str, base_model: str, checkpoint_id: str, step: str(uint64), created_at: str(date-time), updated_at: str(date-time), lora_config: map{rank: int(int64), alpha: int(int64), dropout: num(float)}} # Training session details

@endgroup

@end
