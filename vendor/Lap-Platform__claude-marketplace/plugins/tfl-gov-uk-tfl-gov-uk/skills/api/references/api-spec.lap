@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Transport for London Unified API
@base https://api.digital.tfl.gov.uk
@version v1
@auth ApiKey app_key in query | ApiKey app_id in query
@endpoints 84
@hint download_for_search
@toc AccidentStats(1), AirQuality(1), BikePoint(3), Cabwise(1), Journey(2), Line(21), Mode(2), Occupancy(5), Place(9), Road(8), Search(5), StopPoint(23), TravelTimes(2), Vehicle(1)

@group AccidentStats
@endpoint GET /AccidentStats/{year}
@desc Gets all accident details for accidents occuring in the specified year
@required {year: any # The year for which to filter the accidents on.}
@returns(200) OK

@endgroup

@group AirQuality
@endpoint GET /AirQuality
@desc Gets air quality data feed
@returns(200) OK

@endgroup

@group BikePoint
@endpoint GET /BikePoint
@desc Gets all bike point locations. The Place object has an addtionalProperties array which contains the nbBikes, nbDocks and nbSpaces
@returns(200) OK

@endpoint GET /BikePoint/{id}
@desc Gets the bike point with the given id.
@required {id: any # A bike point id (a list of ids can be obtained from the above BikePoint call)}
@returns(200) OK

@endpoint GET /BikePoint/Search
@desc Search for bike stations by their name, a bike point's name often contains information about the name of the street
@required {query: any # The search term e.g. "St. James"}
@returns(200) OK

@endgroup

@group Cabwise
@endpoint GET /Cabwise/search
@desc Gets taxis and minicabs contact information
@required {lat: any # Latitude, lon: any # Longitude}
@optional {optype: any # Operator Type e.g Minicab, Executive, Limousine, wc: any # Wheelchair accessible, radius: any # The radius of the bounding circle in metres, name: any # Trading name of operating company, maxResults: any # An optional parameter to limit the number of results return. Default and maximum is 20., legacyFormat: any # Legacy Format, forceXml: any # Force Xml, twentyFourSevenOnly: any # Twenty Four Seven Only}
@returns(200) OK

@endgroup

@group Journey
@endpoint GET /Journey/Meta/Modes
@desc Gets a list of all of the available journey planner modes
@returns(200) OK

@endpoint GET /Journey/JourneyResults/{from}/to/{to}
@desc Perform a Journey Planner search from the parameters specified in simple types
@required {from: any # Origin of the journey. Can be WGS84 coordinates expressed as "lat,long", a UK postcode, a Naptan (StopPoint) id, an ICS StopId, or a free-text string (will cause disambiguation unless it exactly matches a point of interest name)., to: any # Destination of the journey. Can be WGS84 coordinates expressed as "lat,long", a UK postcode, a Naptan (StopPoint) id, an ICS StopId, or a free-text string (will cause disambiguation unless it exactly matches a point of interest name).}
@optional {via: any # Travel through point on the journey. Can be WGS84 coordinates expressed as "lat,long", a UK postcode, a Naptan (StopPoint) id, an ICS StopId, or a free-text string (will cause disambiguation unless it exactly matches a point of interest name)., nationalSearch: any # Does the journey cover stops outside London? eg. "nationalSearch=true", date: any # The date must be in yyyyMMdd format, time: any # The time must be in HHmm format, timeIs: any # Does the time given relate to arrival or leaving time? Possible options: "departing" | "arriving", journeyPreference: any # The journey preference eg possible options: "leastinterchange" | "leasttime" | "leastwalking", mode: any # The mode must be a comma separated list of modes. eg possible options: "public-bus,overground,train,tube,coach,dlr,cablecar,tram,river,walking,cycle", accessibilityPreference: any # The accessibility preference must be a comma separated list eg. "noSolidStairs,noEscalators,noElevators,stepFreeToVehicle,stepFreeToPlatform", fromName: any # An optional name to associate with the origin of the journey in the results., toName: any # An optional name to associate with the destination of the journey in the results., viaName: any # An optional name to associate with the via point of the journey in the results., maxTransferMinutes: any # The max walking time in minutes for transfer eg. "120", maxWalkingMinutes: any # The max walking time in minutes for journeys eg. "120", walkingSpeed: any # The walking speed. eg possible options: "slow" | "average" | "fast"., cyclePreference: any # The cycle preference. eg possible options: "allTheWay" | "leaveAtStation" | "takeOnTransport" | "cycleHire", adjustment: any # Time adjustment command. eg possible options: "TripFirst" | "TripLast", bikeProficiency: any # A comma separated list of cycling proficiency levels. eg possible options: "easy,moderate,fast", alternativeCycle: any # Option to determine whether to return alternative cycling journey, alternativeWalking: any # Option to determine whether to return alternative walking journey, applyHtmlMarkup: any # Flag to determine whether certain text (e.g. walking instructions) should be output with HTML tags or not., useMultiModalCall: any # A boolean to indicate whether or not to return 3 public transport journeys, a bus journey, a cycle hire journey, a personal cycle journey and a walking journey, walkingOptimization: any # A boolean to indicate whether to optimize journeys using walking, taxiOnlyTrip: any # A boolean to indicate whether to return one or more taxi journeys. Note, setting this to true will override "useMultiModalCall"., routeBetweenEntrances: any # A boolean to indicate whether public transport routes should include directions between platforms and station entrances., useRealTimeLiveArrivals: any # A boolean to indicate if we want to receive real time live arrivals data where available., calcOneDirection: any # A boolean to make Journey Planner calculate journeys in one temporal direction only. In other words, only calculate journeys after the 'depart' time, or before the 'arrive' time. By default, the Journey Planner engine (EFA) calculates journeys in both temporal directions., includeAlternativeRoutes: any # A boolean to make Journey Planner return alternative routes. Alternative routes are calculated by removing one or more lines included in the fastest route and re-calculating. By default, these journeys will not be returned., overrideMultiModalScenario: any # An optional integer to indicate what multi modal scenario we want to use., combineTransferLegs: any # A boolean to indicate whether walking leg to station entrance and walking leg from station entrance to platform should be combined. Defaults to true}
@returns(200) OK

@endgroup

@group Line
@endpoint GET /Line/Meta/Modes
@desc Gets a list of valid modes
@returns(200) OK

@endpoint GET /Line/Meta/Severity
@desc Gets a list of valid severity codes
@returns(200) OK

@endpoint GET /Line/Meta/DisruptionCategories
@desc Gets a list of valid disruption categories
@returns(200) OK

@endpoint GET /Line/Meta/ServiceTypes
@desc Gets a list of valid ServiceTypes to filter on
@returns(200) OK

@endpoint GET /Line/{ids}
@desc Gets lines that match the specified line ids.
@required {ids: any # A comma-separated list of line ids e.g. victoria,circle,N133. Max. approx. 20 ids.}
@returns(200) OK

@endpoint GET /Line/Mode/{modes}
@desc Gets lines that serve the given modes.
@required {modes: any # A comma-separated list of modes e.g. tube,dlr}
@returns(200) OK

@endpoint GET /Line/Route
@desc Get all valid routes for all lines, including the name and id of the originating and terminating stops for each route.
@optional {serviceTypes: any # A comma seperated list of service types to filter on. Supported values: Regular, Night. Defaulted to 'Regular' if not specified}
@returns(200) OK

@endpoint GET /Line/{ids}/Route
@desc Get all valid routes for given line ids, including the name and id of the originating and terminating stops for each route.
@required {ids: any # A comma-separated list of line ids e.g. victoria,circle,N133. Max. approx. 20 ids.}
@optional {serviceTypes: any # A comma seperated list of service types to filter on. Supported values: Regular, Night. Defaulted to 'Regular' if not specified}
@returns(200) OK

@endpoint GET /Line/Mode/{modes}/Route
@desc Gets all lines and their valid routes for given modes, including the name and id of the originating and terminating stops for each route
@required {modes: any # A comma-separated list of modes e.g. tube,dlr}
@optional {serviceTypes: any # A comma seperated list of service types to filter on. Supported values: Regular, Night. Defaulted to 'Regular' if not specified}
@returns(200) OK

@endpoint GET /Line/{id}/Route/Sequence/{direction}
@desc Gets all valid routes for given line id, including the sequence of stops on each route.
@required {id: any # A single line id e.g. victoria, direction: any # The direction of travel. Can be inbound or outbound.}
@optional {serviceTypes: any # A comma seperated list of service types to filter on. Supported values: Regular, Night. Defaulted to 'Regular' if not specified, excludeCrowding: any # That excludes crowding from line disruptions. Can be true or false.}
@returns(200) OK

@endpoint GET /Line/{ids}/Status/{StartDate}/to/{EndDate}
@desc Gets the line status for given line ids during the provided dates e.g Minor Delays
@required {ids: any # A comma-separated list of line ids e.g. victoria,circle,N133. Max. approx. 20 ids., startDate: any, endDate: any}
@optional {detail: any # Include details of the disruptions that are causing the line status including the affected stops and routes, dateRange.startDate: any, dateRange.endDate: any}
@returns(200) OK

@endpoint GET /Line/{ids}/Status
@desc Gets the line status of for given line ids e.g Minor Delays
@required {ids: any # A comma-separated list of line ids e.g. victoria,circle,N133. Max. approx. 20 ids.}
@optional {detail: any # Include details of the disruptions that are causing the line status including the affected stops and routes}
@returns(200) OK

@endpoint GET /Line/Search/{query}
@desc Search for lines or routes matching the query string
@required {query: any # Search term e.g victoria}
@optional {modes: any # Optionally filter by the specified modes, serviceTypes: any # A comma seperated list of service types to filter on. Supported values: Regular, Night. Defaulted to 'Regular' if not specified}
@returns(200) OK

@endpoint GET /Line/Status/{severity}
@desc Gets the line status for all lines with a given severity
@required {severity: any # The level of severity (eg: a number from 0 to 14)}
@returns(200) OK

@endpoint GET /Line/Mode/{modes}/Status
@desc Gets the line status of for all lines for the given modes
@required {modes: any # A comma-separated list of modes to filter by. e.g. tube,dlr}
@optional {detail: any # Include details of the disruptions that are causing the line status including the affected stops and routes, severityLevel: any # If specified, ensures that only those line status(es) are returned within the lines that have disruptions with the matching severity level.}
@returns(200) OK

@endpoint GET /Line/{id}/StopPoints
@desc Gets a list of the stations that serve the given line id
@required {id: any # A single line id e.g. victoria}
@optional {tflOperatedNationalRailStationsOnly: any # If the national-rail line is requested, this flag will filter the national rail stations so that only those operated by TfL are returned}
@returns(200) OK

@endpoint GET /Line/{id}/Timetable/{fromStopPointId}
@desc Gets the timetable for a specified station on the give line
@required {fromStopPointId: any # The originating station's stop point id (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name), id: any # A single line id e.g. victoria}
@returns(200) OK

@endpoint GET /Line/{id}/Timetable/{fromStopPointId}/to/{toStopPointId}
@desc Gets the timetable for a specified station on the give line with specified destination
@required {fromStopPointId: any # The originating station's stop point id (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name), id: any # A single line id e.g. victoria, toStopPointId: any # The destination stations's Naptan code}
@returns(200) OK

@endpoint GET /Line/{ids}/Disruption
@desc Get disruptions for the given line ids
@required {ids: any # A comma-separated list of line ids e.g. victoria,circle,N133. Max. approx. 20 ids.}
@returns(200) OK

@endpoint GET /Line/Mode/{modes}/Disruption
@desc Get disruptions for all lines of the given modes.
@required {modes: any # A comma-separated list of modes e.g. tube,dlr}
@returns(200) OK

@endpoint GET /Line/{ids}/Arrivals/{stopPointId}
@desc Get the list of arrival predictions for given line ids based at the given stop
@required {ids: any # A comma-separated list of line ids e.g. victoria,circle,N133. Max. approx. 20 ids., stopPointId: any # Optional. Id of stop to get arrival predictions for (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name)}
@optional {direction: any # Optional. The direction of travel. Can be inbound or outbound or all. If left blank, and destinationStopId is set, will default to all, destinationStationId: any # Optional. Id of destination stop}
@returns(200) OK

@endgroup

@group Mode
@endpoint GET /Mode/ActiveServiceTypes
@desc Returns the service type active for a mode.
@returns(200) OK

@endpoint GET /Mode/{mode}/Arrivals
@desc Gets the next arrival predictions for all stops of a given mode
@required {mode: any # A mode name e.g. tube, dlr}
@optional {count: any # A number of arrivals to return for each stop, -1 to return all available.}
@returns(200) OK

@endgroup

@group Occupancy
@endpoint GET /Occupancy/CarPark/{id}
@desc Gets the occupancy for a car park with a given id
@required {id: any}
@returns(200) OK

@endpoint GET /Occupancy/CarPark
@desc Gets the occupancy for all car parks that have occupancy data
@returns(200) OK

@endpoint GET /Occupancy/ChargeConnector/{ids}
@desc Gets the occupancy for a charge connectors with a given id (sourceSystemPlaceId)
@required {ids: any}
@returns(200) OK

@endpoint GET /Occupancy/ChargeConnector
@desc Gets the occupancy for all charge connectors
@returns(200) OK

@endpoint GET /Occupancy/BikePoints/{ids}
@desc Get the occupancy for bike points.
@required {ids: any}
@returns(200) OK

@endgroup

@group Place
@endpoint GET /Place/Meta/Categories
@desc Gets a list of all of the available place property categories and keys.
@returns(200) OK

@endpoint GET /Place/Meta/PlaceTypes
@desc Gets a list of the available types of Place.
@returns(200) OK

@endpoint GET /Place/Address/Streets/{Postcode}
@desc Gets the set of streets associated with a post code.
@required {postcode: any}
@optional {postcodeInput.postcode: any}
@returns(200) OK

@endpoint GET /Place/Type/{types}
@desc Gets all places of a given type
@required {types: any # A comma-separated list of the types to return. Max. approx 12 types. A valid list of place types can be obtained from the /Place/Meta/placeTypes endpoint.}
@optional {activeOnly: any # An optional parameter to limit the results to active records only (Currently only the 'VariableMessageSign' place type is supported)}
@returns(200) OK

@endpoint GET /Place/{id}
@desc Gets the place with the given id.
@required {id: any # The id of the place, you can use the /Place/Types/{types} endpoint to get a list of places for a given type including their ids}
@optional {includeChildren: any # Defaults to false. If true child places e.g. individual charging stations at a charge point while be included, otherwise just the URLs of any child places will be returned}
@returns(200) OK

@endpoint GET /Place
@desc Gets the places that lie within a geographic region. The geographic region of interest can either be specified
@optional {radius: any # The radius of the bounding circle in metres when only lat/lon are specified., categories: any # An optional list of comma separated property categories to return in the Place's property bag. If null or empty, all categories of property are returned. Pass the keyword "none" to return no properties (a valid list of categories can be obtained from the /Place/Meta/categories endpoint), includeChildren: any # Defaults to false. If true child places e.g. individual charging stations at a charge point while be included, otherwise just the URLs of any child places will be returned, type: any # Place types to filter on, or null to return all types, activeOnly: any # An optional parameter to limit the results to active records only (Currently only the 'VariableMessageSign' place type is supported), numberOfPlacesToReturn: any # If specified, limits the number of returned places equal to the given value, placeGeo.swLat: any, placeGeo.swLon: any, placeGeo.neLat: any, placeGeo.neLon: any, placeGeo.lat: any, placeGeo.lon: any}
@returns(200) OK

@endpoint GET /Place/{type}/At/{Lat}/{Lon}
@desc Gets any places of the given type whose geography intersects the given latitude and longitude. In practice this means the Place
@required {type: any # The place type (a valid list of place types can be obtained from the /Place/Meta/placeTypes endpoint), lat: any, lon: any, location.lat: any, location.lon: any}
@returns(200) OK

@endpoint GET /Place/{type}/overlay/{z}/{Lat}/{Lon}/{width}/{height}
@desc Gets the place overlay for a given set of co-ordinates and a given width/height.
@required {z: any # The zoom level, type: any # The place type (a valid list of place types can be obtained from the /Place/Meta/placeTypes endpoint), width: any # The width of the requested overlay., height: any # The height of the requested overlay., lat: any, lon: any, location.lat: any, location.lon: any}
@returns(200) OK

@endpoint GET /Place/Search
@desc Gets all places that matches the given query
@required {name: any # The name of the place, you can use the /Place/Types/{types} endpoint to get a list of places for a given type including their names.}
@optional {types: any # A comma-separated list of the types to return. Max. approx 12 types.}
@returns(200) OK

@endgroup

@group Road
@endpoint GET /Road
@desc Gets all roads managed by TfL
@returns(200) OK

@endpoint GET /Road/{ids}
@desc Gets the road with the specified id (e.g. A1)
@required {ids: any # Comma-separated list of road identifiers e.g. "A406, A2" (a full list of supported road identifiers can be found at the /Road/ endpoint)}
@returns(200) OK

@endpoint GET /Road/{ids}/Status
@desc Gets the specified roads with the status aggregated over the date range specified, or now until the end of today if no dates are passed.
@required {ids: any # Comma-separated list of road identifiers e.g. "A406, A2" or use "all" to ignore id filter (a full list of supported road identifiers can be found at the /Road/ endpoint)}
@optional {dateRangeNullable.startDate: any, dateRangeNullable.endDate: any}
@returns(200) OK

@endpoint GET /Road/{ids}/Disruption
@desc Get active disruptions, filtered by road ids
@required {ids: any # Comma-separated list of road identifiers e.g. "A406, A2" use all for all to ignore id filter (a full list of supported road identifiers can be found at the /Road/ endpoint)}
@optional {stripContent: any # Optional, defaults to false. When true, removes every property/node except for id, point, severity, severityDescription, startDate, endDate, corridor details, location, comments and streets, severities: any # an optional list of Severity names to filter on (a valid list of severities can be obtained from the /Road/Meta/severities endpoint), categories: any # an optional list of category names to filter on (a valid list of categories can be obtained from the /Road/Meta/categories endpoint), closures: any # Optional, defaults to true. When true, always includes disruptions that have road closures, regardless of the severity filter. When false, the severity filter works as normal.}
@returns(200) OK

@endpoint GET /Road/all/Street/Disruption
@desc Gets a list of disrupted streets. If no date filters are provided, current disruptions are returned.
@required {startDate: any # Optional, the start time to filter on., endDate: any # Optional, The end time to filter on.}
@returns(200) OK

@endpoint GET /Road/all/Disruption/{disruptionIds}
@desc Gets a list of active disruptions filtered by disruption Ids.
@required {disruptionIds: any # Comma-separated list of disruption identifiers to filter by.}
@optional {stripContent: any # Optional, defaults to false. When true, removes every property/node except for id, point, severity, severityDescription, startDate, endDate, corridor details, location and comments.}
@returns(200) OK

@endpoint GET /Road/Meta/Categories
@desc Gets a list of valid RoadDisruption categories
@returns(200) OK

@endpoint GET /Road/Meta/Severities
@desc Gets a list of valid RoadDisruption severity codes
@returns(200) OK

@endgroup

@group Search
@endpoint GET /Search
@desc Search the site for occurrences of the query string. The maximum number of results returned is equal to the maximum page size
@required {query: any # The search query}
@returns(200) OK

@endpoint GET /Search/BusSchedules
@desc Searches the bus schedules folder on S3 for a given bus number.
@required {query: any # The search query}
@returns(200) OK

@endpoint GET /Search/Meta/SearchProviders
@desc Gets the available searchProvider names.
@returns(200) OK

@endpoint GET /Search/Meta/Categories
@desc Gets the available search categories.
@returns(200) OK

@endpoint GET /Search/Meta/Sorts
@desc Gets the available sorting options.
@returns(200) OK

@endgroup

@group StopPoint
@endpoint GET /StopPoint/Meta/Categories
@desc Gets the list of available StopPoint additional information categories
@returns(200) OK

@endpoint GET /StopPoint/Meta/StopTypes
@desc Gets the list of available StopPoint types
@returns(200) OK

@endpoint GET /StopPoint/Meta/Modes
@desc Gets the list of available StopPoint modes
@returns(200) OK

@endpoint GET /StopPoint/{ids}
@desc Gets a list of StopPoints corresponding to the given list of stop ids.
@required {ids: any # A comma-separated list of stop point ids (station naptan code e.g. 940GZZLUASL). Max. approx. 20 ids. You can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name.}
@optional {includeCrowdingData: any # Include the crowding data (static). To Filter further use: /StopPoint/{ids}/Crowding/{line}}
@returns(200) OK

@endpoint GET /StopPoint/{id}/placeTypes
@desc Get a list of places corresponding to a given id and place types.
@required {id: any # A naptan id for a stop point (station naptan code e.g. 940GZZLUASL)., placeTypes: any # A comcomma-separated value representing the place types.}
@returns(200) OK

@endpoint GET /StopPoint/{id}/Crowding/{line}
@desc Gets all the Crowding data (static) for the StopPointId, plus crowding data for a given line and optionally a particular direction.
@required {id: any # The Naptan id of the stop, line: any # A particular line e.g. victoria, circle, northern etc., direction: any # The direction of travel. Can be inbound or outbound.}
@returns(200) OK

@endpoint GET /StopPoint/Type/{types}
@desc Gets all stop points of a given type
@required {types: any # A comma-separated list of the types to return. Max. approx. 12 types.  A list of valid stop types can be obtained from the StopPoint/meta/stoptypes endpoint.}
@returns(200) OK

@endpoint GET /StopPoint/Type/{types}/page/{page}
@desc Gets all the stop points of given type(s) with a page number
@required {types: any, page: any}
@returns(200) OK

@endpoint GET /StopPoint/ServiceTypes
@desc Gets the service types for a given stoppoint
@required {id: any # The Naptan id of the stop}
@optional {lineIds: any # The lines which contain the given Naptan id (all lines relevant to the given stoppoint if empty), modes: any # The modes which the lines are relevant to (all if empty)}
@returns(200) OK

@endpoint GET /StopPoint/{id}/Arrivals
@desc Gets the list of arrival predictions for the given stop point id
@required {id: any # A StopPoint id (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name)}
@returns(200) OK

@endpoint GET /StopPoint/{id}/ArrivalDepartures
@desc Gets the list of arrival and departure predictions for the given stop point id (overground, Elizabeth line and thameslink only)
@required {id: any # A StopPoint id (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name), lineIds: any # A comma-separated list of line ids e.g. elizabeth, london-overground, thameslink}
@returns(200) OK

@endpoint GET /StopPoint/{id}/CanReachOnLine/{lineId}
@desc Gets Stopoints that are reachable from a station/line combination.
@required {id: any # The id (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name) of the stop point to filter by, lineId: any # Line id of the line to filter by (e.g. victoria)}
@optional {serviceTypes: any # A comma-separated list of service types to filter on. If not specified. Supported values: Regular, Night. Defaulted to 'Regular' if not specified}
@returns(200) OK

@endpoint GET /StopPoint/{id}/Route
@desc Returns the route sections for all the lines that service the given stop point ids
@required {id: any # A stop point id (station naptan codes e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name)}
@optional {serviceTypes: any # A comma-separated list of service types to filter on. If not specified. Supported values: Regular, Night. Defaulted to 'Regular' if not specified}
@returns(200) OK

@endpoint GET /StopPoint/Mode/{modes}/Disruption
@desc Gets a distinct list of disrupted stop points for the given modes
@required {modes: any # A comma-seperated list of modes e.g. tube,dlr}
@optional {includeRouteBlockedStops: any}
@returns(200) OK

@endpoint GET /StopPoint/{ids}/Disruption
@desc Gets all disruptions for the specified StopPointId, plus disruptions for any child Naptan records it may have.
@required {ids: any # A comma-seperated list of stop point ids. Max. approx. 20 ids. You can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name.}
@optional {getFamily: any # Specify true to return disruptions for entire family, or false to return disruptions for just this stop point. Defaults to false., includeRouteBlockedStops: any, flattenResponse: any # Specify true to associate all disruptions with parent stop point. (Only applicable when getFamily is true).}
@returns(200) OK

@endpoint GET /StopPoint/{id}/DirectionTo/{toStopPointId}
@desc Returns the canonical direction, "inbound" or "outbound", for a given pair of stop point Ids in the direction from -&gt; to.
@required {id: any # Originating stop id (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name), toStopPointId: any # Destination stop id (station naptan code e.g. 940GZZLUASL, you can use /StopPoint/Search/{query} endpoint to find a stop point id from a station name)}
@optional {lineId: any # Optional line id filter e.g. victoria}
@returns(200) OK

@endpoint GET /StopPoint
@desc Gets a list of StopPoints within {radius} by the specified criteria
@required {stopTypes: any # a list of stopTypes that should be returned (a list of valid stop types can be obtained from the StopPoint/meta/stoptypes endpoint), location.lat: any, location.lon: any}
@optional {radius: any # the radius of the bounding circle in metres (default : 200), useStopPointHierarchy: any # Re-arrange the output into a parent/child hierarchy, modes: any # the list of modes to search (comma separated mode names e.g. tube,dlr), categories: any # an optional list of comma separated property categories to return in the StopPoint's property bag. If null or empty, all categories of property are returned. Pass the keyword "none" to return no properties (a valid list of categories can be obtained from the /StopPoint/Meta/categories endpoint), returnLines: any # true to return the lines that each stop point serves as a nested resource}
@returns(200) OK

@endpoint GET /StopPoint/Mode/{modes}
@desc Gets a list of StopPoints filtered by the modes available at that StopPoint.
@required {modes: any # A comma-seperated list of modes e.g. tube,dlr}
@optional {page: any # The data set page to return. Page 1 equates to the first 1000 stop points, page 2 equates to 1001-2000 etc. Must be entered for bus mode as data set is too large.}
@returns(200) OK

@endpoint GET /StopPoint/Search/{query}
@desc Search StopPoints by their common name, or their 5-digit Countdown Bus Stop Code.
@required {query: any # The query string, case-insensitive. Leading and trailing wildcards are applied automatically.}
@optional {modes: any # An optional, parameter separated list of the modes to filter by, faresOnly: any # True to only return stations in that have Fares data available for single fares to another station., maxResults: any # An optional result limit, defaulting to and with a maximum of 50. Since children of the stop point heirarchy are returned for matches, it is possible that the flattened result set will contain more than 50 items., lines: any # An optional, parameter separated list of the lines to filter by, includeHubs: any # If true, returns results including HUBs., tflOperatedNationalRailStationsOnly: any # If the national-rail mode is included, this flag will filter the national rail stations so that only those operated by TfL are returned}
@returns(200) OK

@endpoint GET /StopPoint/Search
@desc Search StopPoints by their common name, or their 5-digit Countdown Bus Stop Code.
@required {query: any # The query string, case-insensitive. Leading and trailing wildcards are applied automatically.}
@optional {modes: any # An optional, parameter separated list of the modes to filter by, faresOnly: any # True to only return stations in that have Fares data available for single fares to another station., maxResults: any # An optional result limit, defaulting to and with a maximum of 50. Since children of the stop point heirarchy are returned for matches, it is possible that the flattened result set will contain more than 50 items., lines: any # An optional, parameter separated list of the lines to filter by, includeHubs: any # If true, returns results including HUBs., tflOperatedNationalRailStationsOnly: any # If the national-rail mode is included, this flag will filter the national rail stations so that only those operated by TfL are returned}
@returns(200) OK

@endpoint GET /StopPoint/Sms/{id}
@desc Gets a StopPoint for a given sms code.
@required {id: any # A 5-digit Countdown Bus Stop Code e.g. 73241, 50435, 56334.}
@optional {output: any # If set to "web", a 302 redirect to relevant website bus stop page is returned. Valid values are : web. All other values are ignored.}
@returns(200) OK

@endpoint GET /StopPoint/{stopPointId}/TaxiRanks
@desc Gets a list of taxi ranks corresponding to the given stop point id.
@required {stopPointId: any # stopPointId is required to get the taxi ranks.}
@returns(200) OK

@endpoint GET /StopPoint/{stopPointId}/CarParks
@desc Get car parks corresponding to the given stop point id.
@required {stopPointId: any # stopPointId is required to get the car parks.}
@returns(200) OK

@endgroup

@group TravelTimes
@endpoint GET /TravelTimes/overlay/{z}/mapcenter/{mapCenterLat}/{mapCenterLon}/pinlocation/{pinLat}/{pinLon}/dimensions/{width}/{height}
@desc Gets the TravelTime overlay.
@required {z: any # The zoom level., pinLat: any # The latitude of the pin., pinLon: any # The longitude of the pin., mapCenterLat: any # The map center latitude., mapCenterLon: any # The map center longitude., scenarioTitle: any # The title of the scenario., timeOfDayId: any # The id for the time of day (AM/INTER/PM), modeId: any # The id of the mode., width: any # The width of the requested overlay., height: any # The height of the requested overlay., direction: any # The direction of travel., travelTimeInterval: any # The total minutes between the travel time bands}
@returns(200) OK

@endpoint GET /TravelTimes/compareOverlay/{z}/mapcenter/{mapCenterLat}/{mapCenterLon}/pinlocation/{pinLat}/{pinLon}/dimensions/{width}/{height}
@desc Gets the TravelTime overlay.
@required {z: any # The zoom level., pinLat: any # The latitude of the pin., pinLon: any # The longitude of the pin., mapCenterLat: any # The map center latitude., mapCenterLon: any # The map center longitude., scenarioTitle: any # The title of the scenario., timeOfDayId: any # The id for the time of day (AM/INTER/PM), modeId: any # The id of the mode., width: any # The width of the requested overlay., height: any # The height of the requested overlay., direction: any # The direction of travel., travelTimeInterval: any # The total minutes between the travel time bands, compareType: any, compareValue: any}
@returns(200) OK

@endgroup

@group Vehicle
@endpoint GET /Vehicle/{ids}/Arrivals
@desc Gets the predictions for a given list of vehicle Id's.
@required {ids: any # A comma-separated list of vehicle ids e.g. LX58CFV,LX11AZB,LX58CFE. Max approx. 25 ids.}
@returns(200) OK

@endgroup

@end
