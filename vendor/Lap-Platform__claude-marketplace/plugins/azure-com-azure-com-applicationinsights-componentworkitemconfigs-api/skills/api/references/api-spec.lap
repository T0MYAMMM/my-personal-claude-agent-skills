@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api ApplicationInsightsManagementClient
@base https://management.azure.com
@version 2015-05-01
@auth OAuth2
@common_fields {resourceName: any # The name of the Application Insights component resource.}
@endpoints 6
@toc subscriptions(6)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Insights/components/{resourceName}/WorkItemConfigs
@desc Gets the list work item configurations that exist for the application
@returns(200) successful operation

@endpoint POST /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Insights/components/{resourceName}/WorkItemConfigs
@desc Create a work item configuration for an Application Insights component.
@required {WorkItemConfigurationProperties: map # Properties that need to be specified to create a work item configuration of a Application Insights component.}
@returns(200) An object containing the work item configuration definition created by this PUT call.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Insights/components/{resourceName}/DefaultWorkItemConfig
@desc Gets default work item configurations that exist for the application
@returns(200) successful operation

@endpoint DELETE /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Insights/components/{resourceName}/WorkItemConfigs/{workItemConfigId}
@desc Delete a work item configuration of an Application Insights component.
@required {workItemConfigId: any # The unique work item configuration Id. This can be either friendly name of connector as defined in connector configuration}
@returns(200) The work item configuration that was successfully deleted.

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Insights/components/{resourceName}/WorkItemConfigs/{workItemConfigId}
@desc Gets specified work item configuration for an Application Insights component.
@required {workItemConfigId: any # The unique work item configuration Id. This can be either friendly name of connector as defined in connector configuration}
@returns(200) successful operation

@endpoint PATCH /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Insights/components/{resourceName}/WorkItemConfigs/{workItemConfigId}
@desc Update a work item configuration for an Application Insights component.
@required {workItemConfigId: any # The unique work item configuration Id. This can be either friendly name of connector as defined in connector configuration, WorkItemConfigurationProperties: map # Properties that need to be specified to update a work item configuration for this Application Insights component.}
@returns(200) Successful operation indicating the config updated by this PATCH call.

@end
