@required {AccountId: str, ClusterIdentifier: str, DatabaseName: str, PartnerName: str}
@returns(200) {DatabaseName: str?, PartnerName: str?}

@endpoint POST /
@desc Deletes an Amazon Redshift IAM Identity Center application.
@required {RedshiftIdcApplicationArn: str}

@endpoint POST /
@desc Deletes the resource policy for a specified resource.
@required {ResourceArn: str}

@endpoint POST /
@desc Deletes a scheduled action.
