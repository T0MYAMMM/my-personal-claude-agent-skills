@endpoint POST /v1/dubbing/resource/{dubbing_id}/translate
@desc Translates All Or Some Segments And Languages
@required {dubbing_id: str # ID of the dubbing project., segments: [str] # Translate only this list of segments., languages: any # Translate only these languages for each segment.}
@returns(200) {version: int} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/dubbing/resource/{dubbing_id}/dub
@desc Dubs All Or Some Segments And Languages
