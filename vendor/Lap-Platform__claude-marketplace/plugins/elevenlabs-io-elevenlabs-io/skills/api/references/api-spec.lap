@returns(200) {version: int} # Successful Response
@errors {422: Validation Error}

@endpoint PATCH /v1/dubbing/resource/{dubbing_id}/speaker/{speaker_id}
@desc Update Metadata For A Speaker
@required {dubbing_id: str # ID of the dubbing project., speaker_id: str # ID of the speaker.}
@optional {speaker_name: any # Name to attribute to this speaker., voice_id: any # Either the identifier of a voice from the ElevenLabs voice library, or one of ['track-clone', 'clip-clone']., voice_stability: any # For models that support it, the voice similarity value to use. This will default to 0.65, with a valid range of [0.0, 1.0]., voice_similarity: any # For models that support it, the voice similarity value to use. This will default to 1.0, with a valid range of [0.0, 1.0]., voice_style: any # For models that support it, the voice style value to use. This will default to 1.0, with a valid range of [0.0, 1.0]., languages: any # Languages to apply these changes to. If empty, will apply to all languages.}
@returns(200) {version: int} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/dubbing/resource/{dubbing_id}/speaker
@desc Create A New Speaker
@required {dubbing_id: str # ID of the dubbing project.}
@optional {speaker_name: any # Name to attribute to this speaker., voice_id: any # Either the identifier of a voice from the ElevenLabs voice library, or one of ['track-clone', 'clip-clone']., voice_stability: any # For models that support it, the voice similarity value to use. This will default to 0.65, with a valid range of [0.0, 1.0]., voice_similarity: any # For models that support it, the voice similarity value to use. This will default to 1.0, with a valid range of [0.0, 1.0]., voice_style: any # For models that support it, the voice style value to use. This will default to 1.0, with a valid range of [0.0, 1.0].}
@returns(200) {version: int, speaker_id: str} # Successful Response
@errors {422: Validation Error}

