@returns(200) {version: int} # Successful Response
@errors {422: Validation Error}

@endpoint DELETE /v1/dubbing/resource/{dubbing_id}/segment/{segment_id}
@desc Deletes A Single Segment
@required {dubbing_id: str # ID of the dubbing project., segment_id: str # ID of the segment}
@returns(200) {version: int} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/dubbing/resource/{dubbing_id}/transcribe
