@endpoint POST /v1/convai/agents/{agent_id}/branches
@desc Create A New Branch
@required {agent_id: str # The id of an agent. This is returned on agent creation., parent_version_id: str # ID of the version to branch from, name: str # Name of the branch. It is unique within the agent., description: str # Description for the branch}
@optional {conversation_config: any # Changes to apply to conversation config, platform_settings: any # Changes to apply to platform settings, workflow: any # Updated workflow definition}
@returns(200) {created_branch_id: str, created_version_id: str} # Successful Response
@errors {422: Validation Error}

@endpoint GET /v1/convai/agents/{agent_id}/branches
@desc List Agent Branches
@required {agent_id: str # The id of an agent. This is returned on agent creation.}
@optional {include_archived: bool=False # Whether archived branches should be included, limit: int=100 # How many results at most should be returned}
@returns(200) {meta: map{total: any, page: any, page_size: any}, results: [map]} # Successful Response
@errors {422: Validation Error}

@endpoint GET /v1/convai/agents/{agent_id}/branches/{branch_id}
@desc Get Agent Branch
@required {agent_id: str # The id of an agent. This is returned on agent creation., branch_id: str # Unique identifier for the branch.}
@returns(200) {id: str, name: str, agent_id: str, description: str, created_at: int, last_committed_at: int, is_archived: bool, protection_status: str, access_info: any, current_live_percentage: num, parent_branch: any, most_recent_versions: [map]} # Successful Response
@errors {422: Validation Error}

@endpoint PATCH /v1/convai/agents/{agent_id}/branches/{branch_id}
@desc Update Agent Branch
@required {agent_id: str # The id of an agent. This is returned on agent creation., branch_id: str # Unique identifier for the branch.}
@optional {name: any # New name for the branch. Must be unique within the agent., is_archived: any # Whether the branch should be archived, protection_status: any # The protection level for the branch}
@returns(200) {id: str, name: str, agent_id: str, description: str, created_at: int, last_committed_at: int, is_archived: bool, protection_status: str, access_info: any, current_live_percentage: num, parent_branch: any, most_recent_versions: [map]} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/convai/agents/{agent_id}/branches/{source_branch_id}/merge
@desc Merge A Branch Into A Target Branch
@required {agent_id: str # The id of an agent. This is returned on agent creation., source_branch_id: str # Unique identifier for the source branch to merge from., target_branch_id: str # The ID of the target branch to merge into (must be the main branch).}
@optional {archive_source_branch: bool=True # Whether to archive the source branch after merging}
@returns(200) Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/convai/agents/{agent_id}/deployments
@desc Create Or Update Deployments
@required {agent_id: str # The id of an agent. This is returned on agent creation., deployment_request: map{requests!: [map{branch_id!: str, deployment_strategy!: map}]}}
@returns(200) {traffic_percentage_branch_id_map: map} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/convai/agents/{agent_id}/drafts
@desc Create Agent Draft
@required {agent_id: str # The id of an agent. This is returned on agent creation., branch_id: str # The ID of the agent branch to use, conversation_config: map # Conversation config for the draft, platform_settings: map # Platform settings for the draft, workflow: map{edges: map, nodes: map, prevent_subagent_loops: bool}, name: str # Name for the draft}
@optional {tags: any # Tags to help classify and filter the agent}
@returns(200) Successful Response
@errors {422: Validation Error}

@endpoint DELETE /v1/convai/agents/{agent_id}/drafts
@desc Delete Agent Draft
@required {agent_id: str # The id of an agent. This is returned on agent creation., branch_id: str # The ID of the agent branch to use}
@returns(200) Successful Response
@errors {422: Validation Error}

@endgroup

@group music
@endpoint POST /v1/music/plan
@desc Generate Composition Plan
@required {prompt: str # A simple text prompt to compose a plan from.}
@optional {music_length_ms: any # The length of the composition plan to generate in milliseconds. Must be between 3000ms and 600000ms. Optional - if not provided, the model will choose a length based on the prompt., source_composition_plan: any # An optional composition plan to use as a source for the new composition plan., model_id: str=music_v1 # The model to use for the generation.}
@returns(200) {positive_global_styles: [str], negative_global_styles: [str], sections: [map]} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/music
@desc Compose Music
@optional {output_format: str(mp3_22050_32/mp3_24000_48/mp3_44100_32/mp3_44100_64/mp3_44100_96/mp3_44100_128/mp3_44100_192/pcm_8000/pcm_16000/pcm_22050/pcm_24000/pcm_32000/pcm_44100/pcm_48000/ulaw_8000/alaw_8000/opus_48000_32/opus_48000_64/opus_48000_96/opus_48000_128/opus_48000_192)=mp3_44100_128 # Output format of the generated audio. Formatted as codec_sample_rate_bitrate. So an mp3 with 22.05kHz sample rate at 32kbs is represented as mp3_22050_32. MP3 with 192kbps bitrate requires you to be subscribed to Creator tier or above. PCM with 44.1kHz sample rate requires you to be subscribed to Pro tier or above. Note that the μ-law format (sometimes written mu-law, often approximated as u-law) is commonly used for Twilio audio inputs., prompt: any # A simple text prompt to generate a song from. Cannot be used in conjunction with `composition_plan`., music_prompt: any # A music prompt. Deprecated. Use `composition_plan` instead., composition_plan: any # A detailed composition plan to guide music generation. Cannot be used in conjunction with `prompt`., music_length_ms: any # The length of the song to generate in milliseconds. Used only in conjunction with `prompt`. Must be between 3000ms and 600000ms. Optional - if not provided, the model will choose a length based on the prompt., model_id: str=music_v1 # The model to use for the generation., seed: any # Random seed to initialize the music generation process. Providing the same seed with the same parameters can help achieve more consistent results, but exact reproducibility is not guaranteed and outputs may change across system updates. Cannot be used in conjunction with prompt., force_instrumental: bool=False # If true, guarantees that the generated song will be instrumental. If false, the song may or may not be instrumental depending on the `prompt`. Can only be used with `prompt`., finetune_id: any # The ID of the finetune to use for the generation, use_phonetic_names: bool=False # If true, proper names in the prompt will be phonetically spelled in the lyrics for better pronunciation by the music model. The original names will be restored in word timestamps., respect_sections_durations: bool=True # Controls how strictly section durations in the `composition_plan` are enforced. Only used with `composition_plan`. When set to true, the model will precisely respect each section's `duration_ms` from the plan. When set to false, the model may adjust individual section durations which will generally lead to better generation quality and improved latency, while always preserving the total song duration from the plan., store_for_inpainting: bool=False # Whether to store the generated song for inpainting. Only available to enterprise clients with access to the inpainting API., sign_with_c2pa: bool=False # Whether to sign the generated song with C2PA. Applicable only for mp3 files.}
@returns(200) The generated audio file in the format specified
@errors {422: Validation Error}

@endpoint POST /v1/music/detailed
@desc Compose Music With A Detailed Response
@optional {output_format: str(mp3_22050_32/mp3_24000_48/mp3_44100_32/mp3_44100_64/mp3_44100_96/mp3_44100_128/mp3_44100_192/pcm_8000/pcm_16000/pcm_22050/pcm_24000/pcm_32000/pcm_44100/pcm_48000/ulaw_8000/alaw_8000/opus_48000_32/opus_48000_64/opus_48000_96/opus_48000_128/opus_48000_192)=mp3_44100_128 # Output format of the generated audio. Formatted as codec_sample_rate_bitrate. So an mp3 with 22.05kHz sample rate at 32kbs is represented as mp3_22050_32. MP3 with 192kbps bitrate requires you to be subscribed to Creator tier or above. PCM with 44.1kHz sample rate requires you to be subscribed to Pro tier or above. Note that the μ-law format (sometimes written mu-law, often approximated as u-law) is commonly used for Twilio audio inputs., prompt: any # A simple text prompt to generate a song from. Cannot be used in conjunction with `composition_plan`., music_prompt: any # A music prompt. Deprecated. Use `composition_plan` instead., composition_plan: any # A detailed composition plan to guide music generation. Cannot be used in conjunction with `prompt`., music_length_ms: any # The length of the song to generate in milliseconds. Used only in conjunction with `prompt`. Must be between 3000ms and 600000ms. Optional - if not provided, the model will choose a length based on the prompt., model_id: str=music_v1 # The model to use for the generation., seed: any # Random seed to initialize the music generation process. Providing the same seed with the same parameters can help achieve more consistent results, but exact reproducibility is not guaranteed and outputs may change across system updates. Cannot be used in conjunction with prompt., force_instrumental: bool=False # If true, guarantees that the generated song will be instrumental. If false, the song may or may not be instrumental depending on the `prompt`. Can only be used with `prompt`., finetune_id: any # The ID of the finetune to use for the generation, use_phonetic_names: bool=False # If true, proper names in the prompt will be phonetically spelled in the lyrics for better pronunciation by the music model. The original names will be restored in word timestamps., store_for_inpainting: bool=False # Whether to store the generated song for inpainting. Only available to enterprise clients with access to the inpainting API., with_timestamps: bool=False # Whether to return the timestamps of the words in the generated song., sign_with_c2pa: bool=False # Whether to sign the generated song with C2PA. Applicable only for mp3 files.}
@returns(200) Multipart/mixed response with JSON metadata and binary audio file
@errors {422: Validation Error}

@endpoint POST /v1/music/stream
@desc Stream Composed Music
@optional {output_format: str(mp3_22050_32/mp3_24000_48/mp3_44100_32/mp3_44100_64/mp3_44100_96/mp3_44100_128/mp3_44100_192/pcm_8000/pcm_16000/pcm_22050/pcm_24000/pcm_32000/pcm_44100/pcm_48000/ulaw_8000/alaw_8000/opus_48000_32/opus_48000_64/opus_48000_96/opus_48000_128/opus_48000_192)=mp3_44100_128 # Output format of the generated audio. Formatted as codec_sample_rate_bitrate. So an mp3 with 22.05kHz sample rate at 32kbs is represented as mp3_22050_32. MP3 with 192kbps bitrate requires you to be subscribed to Creator tier or above. PCM with 44.1kHz sample rate requires you to be subscribed to Pro tier or above. Note that the μ-law format (sometimes written mu-law, often approximated as u-law) is commonly used for Twilio audio inputs., prompt: any # A simple text prompt to generate a song from. Cannot be used in conjunction with `composition_plan`., music_prompt: any # A music prompt. Deprecated. Use `composition_plan` instead., composition_plan: any # A detailed composition plan to guide music generation. Cannot be used in conjunction with `prompt`., music_length_ms: any # The length of the song to generate in milliseconds. Used only in conjunction with `prompt`. Must be between 3000ms and 600000ms. Optional - if not provided, the model will choose a length based on the prompt., model_id: str=music_v1 # The model to use for the generation., seed: any # Random seed to initialize the music generation process. Providing the same seed with the same parameters can help achieve more consistent results, but exact reproducibility is not guaranteed and outputs may change across system updates. Cannot be used in conjunction with prompt., force_instrumental: bool=False # If true, guarantees that the generated song will be instrumental. If false, the song may or may not be instrumental depending on the `prompt`. Can only be used with `prompt`., finetune_id: any # The ID of the finetune to use for the generation, use_phonetic_names: bool=False # If true, proper names in the prompt will be phonetically spelled in the lyrics for better pronunciation by the music model. The original names will be restored in word timestamps., store_for_inpainting: bool=False # Whether to store the generated song for inpainting. Only available to enterprise clients with access to the inpainting API.}
@returns(200) Streaming audio data in the format specified
@errors {422: Validation Error}

@endpoint POST /v1/music/upload
@desc Upload Music
@returns(200) {song_id: str, composition_plan: any} # Successfully uploaded music file with optional composition plan
@errors {422: Validation Error}

@endpoint POST /v1/music/stem-separation
@desc Stem Separation
@optional {output_format: str(mp3_22050_32/mp3_24000_48/mp3_44100_32/mp3_44100_64/mp3_44100_96/mp3_44100_128/mp3_44100_192/pcm_8000/pcm_16000/pcm_22050/pcm_24000/pcm_32000/pcm_44100/pcm_48000/ulaw_8000/alaw_8000/opus_48000_32/opus_48000_64/opus_48000_96/opus_48000_128/opus_48000_192)=mp3_44100_128 # Output format of the generated audio. Formatted as codec_sample_rate_bitrate. So an mp3 with 22.05kHz sample rate at 32kbs is represented as mp3_22050_32. MP3 with 192kbps bitrate requires you to be subscribed to Creator tier or above. PCM with 44.1kHz sample rate requires you to be subscribed to Pro tier or above. Note that the μ-law format (sometimes written mu-law, often approximated as u-law) is commonly used for Twilio audio inputs.}
@returns(200) ZIP archive containing separated audio stems. Each stem is provided as a separate audio file in the requested output format.
@errors {422: Validation Error}

@endgroup

@group voices
@endpoint POST /v1/voices/pvc
@desc Create Pvc Voice
@required {name: str # The name that identifies this voice. This will be displayed in the dropdown of the website., language: str # Language used in the samples.}
@optional {description: any # Description to use for the created voice., labels: any # Labels for the voice. Keys can be language, accent, gender, or age.}
@returns(200) {voice_id: str} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/voices/pvc/{voice_id}
@desc Edit Pvc Voice
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices.}
@optional {name: str # The name that identifies this voice. This will be displayed in the dropdown of the website., language: str # Language used in the samples., description: any # Description to use for the created voice., labels: any # Labels for the voice. Keys can be language, accent, gender, or age.}
@returns(200) {voice_id: str} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/voices/pvc/{voice_id}/samples
@desc Add Samples To Pvc Voice
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices.}
@returns(200) Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/voices/pvc/{voice_id}/samples/{sample_id}
@desc Update Pvc Voice Sample
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices., sample_id: str # Sample ID to be used}
@optional {remove_background_noise: bool=False # If set will remove background noise for voice samples using our audio isolation model. If the samples do not include background noise, it can make the quality worse., selected_speaker_ids: any # Speaker IDs to be used for PVC training. Make sure you send all the speaker IDs you want to use for PVC training in one request because the last request will override the previous ones., trim_start_time: any # The start time of the audio to be used for PVC training. Time should be in milliseconds, trim_end_time: any # The end time of the audio to be used for PVC training. Time should be in milliseconds, file_name: any # The name of the audio file to be used for PVC training.}
@returns(200) {voice_id: str} # Successful Response
@errors {422: Validation Error}

@endpoint DELETE /v1/voices/pvc/{voice_id}/samples/{sample_id}
@desc Delete Pvc Voice Sample
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices., sample_id: str # Sample ID to be used}
@returns(200) {status: str} # Successful Response
@errors {422: Validation Error}

@endpoint GET /v1/voices/pvc/{voice_id}/samples/{sample_id}/audio
@desc Retrieve Voice Sample Audio
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices., sample_id: str # Sample ID to be used}
@optional {remove_background_noise: bool=False # If set will remove background noise for voice samples using our audio isolation model. If the samples do not include background noise, it can make the quality worse.}
@returns(200) {audio_base_64: str, voice_id: str, sample_id: str, media_type: str, duration_secs: any} # Successful Response
@errors {422: Validation Error}

@endpoint GET /v1/voices/pvc/{voice_id}/samples/{sample_id}/waveform
@desc Retrieve Voice Sample Visual Waveform
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices., sample_id: str # Sample ID to be used}
@returns(200) {sample_id: str, visual_waveform: [num]} # Successful Response
@errors {422: Validation Error}

@endpoint GET /v1/voices/pvc/{voice_id}/samples/{sample_id}/speakers
@desc Retrieve Speaker Separation Status
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices., sample_id: str # Sample ID to be used}
@returns(200) {voice_id: str, sample_id: str, status: str, speakers: any, selected_speaker_ids: any} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/voices/pvc/{voice_id}/samples/{sample_id}/separate-speakers
@desc Start Speaker Separation
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices., sample_id: str # Sample ID to be used}
@returns(200) {status: str} # Successful Response
@errors {422: Validation Error}

@endpoint GET /v1/voices/pvc/{voice_id}/samples/{sample_id}/speakers/{speaker_id}/audio
@desc Retrieve Separated Speaker Audio
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices., sample_id: str # Sample ID to be used, speaker_id: str # Speaker ID to be used, you can use GET https://api.elevenlabs.io/v1/voices/{voice_id}/samples/{sample_id}/speakers to list all the available speakers for a sample.}
@returns(200) {audio_base_64: str, media_type: str, duration_secs: num} # Successful Response
@errors {422: Validation Error}

@endpoint GET /v1/voices/pvc/{voice_id}/captcha
@desc Get Pvc Voice Captcha
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices.}
@returns(200) Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/voices/pvc/{voice_id}/captcha
@desc Verify Pvc Voice Captcha
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices.}
@returns(200) {status: str} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/voices/pvc/{voice_id}/train
@desc Run Pvc Training
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices.}
@optional {model_id: any # The model ID to use for the conversion.}
@returns(200) {status: str} # Successful Response
@errors {422: Validation Error}

@endpoint POST /v1/voices/pvc/{voice_id}/verification
@desc Request Manual Verification
@required {voice_id: str # Voice ID to be used, you can use https://api.elevenlabs.io/v1/voices to list all the available voices.}
@returns(200) {status: str} # Successful Response
@errors {422: Validation Error}

@endgroup

@group docs
@endpoint GET /docs
@desc Redirect To Mintlify
@returns(200) Successful Response

@endgroup

@end
