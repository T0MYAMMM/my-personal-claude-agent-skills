@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Azure SQL Database Backup
@base https://management.azure.com
@version 2014-04-01
@auth OAuth2
@endpoints 4
@toc subscriptions(4)

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/recoverableDatabases/{databaseName}
@desc Gets a recoverable database, which is a resource representing a database's geo backup
@required {serverName: any # The name of the server., databaseName: any # The name of the database}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/recoverableDatabases
@desc Gets a list of recoverable databases
@required {serverName: any # The name of the server.}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/restorableDroppedDatabases/{restorableDroppededDatabaseId}
@desc Gets a deleted database that can be restored
@required {serverName: any # The name of the server., restorableDroppededDatabaseId: any # The id of the deleted database in the form of databaseName,deletionTimeInFileTimeFormat}
@returns(200) OK

@endpoint GET /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Sql/servers/{serverName}/restorableDroppedDatabases
@desc Gets a list of deleted databases that can be restored
@required {serverName: any # The name of the server.}
@returns(200) OK

@end
