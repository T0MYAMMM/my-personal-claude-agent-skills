@errors {400: Bad request, 403: Permission error, 500: Server Error}

@endpoint GET /messaging/v1/email/messages/
@desc getEmailsNotSentToRecipients
@required {type: any # Only notSent is supported.}
@optional {$pageSize: any # Number of messageKeys (array elements) to return per response page., lastEventId: any # Event ID from which you want the response to start. To obtain the initial event ID, submit a request without a lastEventId. The events in the response are listed top to bottom from oldest to newest.}
@returns(200)
@errors {400: Bad request, 401: Unauthorized, 500: Server Error}

@endpoint GET /messaging/v1/email/messages/{messageKey}
@desc getEmailSendStatusForRecipient
@required {messageKey: any # Unique identifier to track message send status. You must provide it in singleton requests using the recipient attribute. To provide it in batch requests, use the recipients array attribute. If you don’t provide the message key for recipients, it’s generated in the response.}
@returns(200) Email send status for recipient succesfully retrieved.
@errors {400: Bad request, 401: Unauthorized, 500: Server Error}

@endpoint POST /messaging/v1/email/messages/{messageKey}
@desc sendEmailToSingleRecipient
@required {messageKey: any # Unique identifier used to track message status. Can be automatically created when you create a message or provided as part of the request. Each recipient in a request must have a unique messageKey. If you use a duplicate messageKey in the same send request, the message is rejected., body: map # JSON Parameters}
@returns(202)
@errors {400: Bad request, 401: Unauthorized, 403: Permission error, 500: Server Error}

