@group asset
@endpoint GET /asset/v1/content/assets/{id}
@desc getAssetById
@required {id: any # The ID of the asset}
@returns(200) A single asset
@errors {400: Bad request, 403: Permission error}

@endpoint PATCH /asset/v1/content/assets/{id}
@desc partiallyUpdateAssetById
@required {id: any # The ID of the asset to update, body: map # JSON Parameters}
@returns(200) A single asset
@errors {400: Bad request, 403: Permission error}

@endpoint DELETE /asset/v1/content/assets/{id}
@desc deleteAssetById
@required {id: any # The ID of the asset to delete}
@errors {400: Bad request, 403: Permission error}

@endpoint POST /asset/v1/content/assets
@desc createAsset
@required {body: map # JSON Parameters}
@returns(200) A single asset
@errors {400: Bad request, 403: Permission error}

@endgroup

@group hub
