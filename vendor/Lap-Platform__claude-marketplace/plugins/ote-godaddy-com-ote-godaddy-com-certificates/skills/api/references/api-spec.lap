@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api spec
@base https://api.ote-godaddy.com
@endpoints 28
@hint download_for_search
@toc certificates(23), customers(5)

@group certificates
@endpoint POST /v1/certificates
@desc Create a pending order for certificate
@required {certificateCreate: any # The certificate order information}
@optional {X-Market-Id: any # Setting locale for communications such as emails and error messages}
@returns(202) Request was successful
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 409: Certificate state does not allow renew, 422: `email` is not empty<br>`csr` is invalid, 500: Internal server error}

@endpoint POST /v1/certificates/validate
@desc Validate a pending order for certificate
@required {certificateCreate: any # The certificate order info}
@optional {X-Market-Id: any # Setting locale for communications such as emails and error messages}
@returns(204) Request validated successfully
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 409: Certificate state does not allow renew, 422: `email` is not empty <br> `csr` is invalid, 500: Internal server error}

@endpoint GET /v1/certificates/{certificateId}
@desc Retrieve certificate details
@required {certificateId: any # Certificate id to lookup}
@returns(200) Certificate details retrieved
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 500: Internal server error}

@endpoint GET /v1/certificates/{certificateId}/actions
@desc Retrieve all certificate actions
@required {certificateId: any # Certificate id to register for callback}
@returns(200) Action retrieval successful
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate not found, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/email/{emailId}/resend
@desc Resend an email
@required {certificateId: any # Certificate id to resend email, emailId: any # Email id for email to resend}
@returns(204) Email sent successfully
@errors {404: Certificate not found, 409: Email Id not found, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/email/resend/{emailAddress}
@desc Add alternate email address
@required {certificateId: any # Certificate id to resend emails, emailAddress: any # Specific email address to resend email}
@returns(200) Alternate email address added and emails re-sent
@errors {404: Certificate not found, 409: Certificate state does not allow alternate email address, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/email/{emailId}/resend/{emailAddress}
@desc Resend email to email address
@required {certificateId: any # Certificate id to resend emails, emailId: any # Email id for email to resend, emailAddress: any # Specific email address to resend email}
@returns(204) Email sent successfully
@errors {404: Certificate not found, 409: Email Id not found, 500: Internal server error}

@endpoint GET /v1/certificates/{certificateId}/email/history
@desc Retrieve email history
@required {certificateId: any # Certificate id to retrieve email history}
@returns(200) Email history retrieval successful
@errors {409: Email history not found, 500: Internal server error}

@endpoint DELETE /v1/certificates/{certificateId}/callback
@desc Unregister system callback
@required {certificateId: any # Certificate id to unregister callback}
@returns(204) Callback removed
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 500: Internal server error}

@endpoint GET /v1/certificates/{certificateId}/callback
@desc Retrieve system stateful action callback url
@required {certificateId: any # Certificate id to register for stateful action callback}
@returns(200) Callback registered
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 500: Internal server error}

@endpoint PUT /v1/certificates/{certificateId}/callback
@desc Register of certificate action callback
@required {certificateId: any # Certificate id to register/replace for callback, callbackUrl: any # Callback url registered/replaced to receive stateful actions}
@returns(204) Callback replaced/registered
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 422: Callback url is missing <br> Callback url is malformed, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/cancel
@desc Cancel a pending certificate
@required {certificateId: any # Certificate id to cancel}
@returns(204) Certificate order has been canceled
@errors {401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 409: Certificate state does not allow cancel, 500: Internal server error}

@endpoint GET /v1/certificates/{certificateId}/download
@desc Download certificate
@required {certificateId: any # Certificate id to download}
@returns(200) Certificate retrieved
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 409: Certificate state does not allow download, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/reissue
@desc Reissue active certificate
@required {certificateId: any # Certificate id to reissue, reissueCreate: any # The reissue request info}
@returns(202) Reissue request created
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 409: Certificate state does not allow reissue, 422: `csr` is invalid<br>Delay revocation exceeds maximum, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/renew
@desc Renew active certificate
@required {certificateId: any # Certificate id to renew, renewCreate: any # The renew request info}
@returns(202) Renew request created
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 409: Certificate state does not allow renew, 422: `csr` is invalid, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/revoke
@desc Revoke active certificate
@required {certificateId: any # Certificate id to revoke, certificateRevoke: any # The certificate revocation request}
@returns(204) Certificate Revoked
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 409: Certificate state does not allow revoke, 500: Internal server error}

@endpoint GET /v1/certificates/{certificateId}/siteSeal
@desc Get Site seal
@required {certificateId: any # Certificate id}
@optional {theme: any # This value represents the visual theme of the seal. If seal doesn't exist, default values are used if params not present. If seal does exist, default values will not be used to update unless params present., locale: any # Determine locale for text displayed in seal image and verification page. If seal doesn't exist, default values are used if params not present. If seal does exist, default values will not be used to update unless params present.}
@returns(200) Site seal retrieved
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 409: Certificate state does not allow seal, 422: 'locale' is invalid, 500: Internal server error}

@endpoint POST /v1/certificates/{certificateId}/verifyDomainControl
@desc Check Domain Control
@required {certificateId: any # Certificate id to lookup}
@returns(204) Domain control was successful
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Certificate id not found, 409: Domain control was not successful <br> Certificate state does not allow domain control, 500: Internal server error}

@endpoint GET /v2/certificates
@desc Search for certificate details by entitlement
@required {entitlementId: any # Entitlement id to lookup}
@optional {latest: any # Fetch only the most recent certificate}
@returns(200) Certificate details retrieved
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 422: Entitlement id not provided, 500: Internal server error}

@endpoint POST /v2/certificates
@desc Create a pending order for certificate
@required {subscriptionCertificateCreate: any # The certificate order information}
@optional {X-Market-Id: any # Setting locale for communications such as emails and error messages}
@returns(202) Request was successful
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 409: Certificate state does not allow renew, 422: `email` is not empty<br>`csr` is invalid, 500: Internal server error}

@endpoint GET /v2/certificates/download
@desc Download certificate by entitlement
@required {entitlementId: any # Entitlement id to download}
@returns(200) Certificate retrieved
@errors {400: Request was malformed, 401: Authentication info not sent or invalid, 403: Authenticated user is not allowed access, 404: Entitlement id not found, 409: Certificate state does not allow download, 422: Entitlement id not provided, 500: Internal server error}

@endgroup

@group customers
@endpoint GET /v2/customers/{customerId}/certificates
@desc Retrieve customer's certificates
@required {customerId: any # An identifier for a customer}
@optional {offset: any # Number of results to skip for pagination, limit: any # Maximum number of items to return}
@returns(200) Customer certificate information retrieved.
@errors {401: Authentication info not sent or is invalid, 403: Authenticated user is not allowed access, 422: Application-specific request error, 429: Too many requests received within interval, 500: Internal server error}

@endpoint GET /v2/customers/{customerId}/certificates/{certificateId}
@desc Retrieve individual certificate details
@required {customerId: any # An identifier for a customer, certificateId: any # Certificate id to lookup}
@returns(200) Certificate details retrieved
@errors {401: Authentication info not sent or is invalid, 403: Authenticated user is not allowed access, 404: Resource not found, 422: Application-specific request error, 429: Too many requests received within interval, 500: Internal server error}

@endpoint GET /v2/customers/{customerId}/certificates/{certificateId}/domainVerifications
@desc Retrieve domain verification status
@required {customerId: any # An identifier for a customer, certificateId: any # Certificate id to lookup}
@returns(200) Domain verification status list for specified certificateId.
@errors {401: Authentication info not sent or is invalid, 403: Authenticated user is not allowed access, 404: Resource not found, 422: Application-specific request error, 429: Too many requests received within interval, 500: Internal server error}

@endpoint GET /v2/customers/{customerId}/certificates/{certificateId}/domainVerifications/{domain}
@desc Retrieve detailed information for supplied domain
@required {customerId: any # An identifier for a customer, certificateId: any # Certificate id to lookup, domain: any # A valid domain name in the certificate request}
@returns(200) Retrieve detailed information for supplied domain, including domain verification details and Certificate Authority Authorization (CAA) verification details.
@errors {401: Authentication info not sent or is invalid, 403: Authenticated user is not allowed access, 404: Resource not found, 422: Application-specific request error, 429: Too many requests received within interval, 500: Internal server error}

@endpoint GET /v2/customers/{customerId}/certificates/acme/externalAccountBinding
@desc Retrieves the external account binding for the specified customer
@required {customerId: any # An identifier for a customer}
@returns(200) Acme key identifier and HMAC key for the external account binding. Directory URI is also provided for making ACME requests.
@errors {401: Authentication info not sent or is invalid, 403: Authenticated user is not allowed access, 404: Resource not found, 422: Application-specific request error, 429: Too many requests received within interval, 500: Internal server error}

@endgroup

@group certificates
@endpoint GET /v2/certificates/subscriptions/search
@desc Get a page of subscriptions by domain
@optional {pageSize: any # The number of records to return per query., page: any # The page number. <b>(First page is <i>one</i> instead of zero.)</b>, domain: any # Filter by domain name / common name. This will look for the text inside the content of the domain. This is not a "find domains that start with x" search., status: any # The certificate lifecycle stage. <br> Active, Expired, and Revoked are all Issued certificates. <br> Active means the validity period includes today. <br> Expired means the validity period was prior to today. <br> Revoked means that the certificate has been revoked. <br> Pending means that the certificate is still going through the issuance process and has not been signed or issued yet. <br> Denied means that the certificate went from pending to denied for any valid denial reason.  (Customer canceled request, CAA records exist for the domain, fraud, etc...), type: any # The type of certificate in terms of the number of applicable domains., validation: any # The validation type for the certificate.  Standard/Basic Validation (DV).  Organizational/Deluxe Vetting (OV). Extended/Premium Validation (EV).}
@returns(200) OK

@endpoint GET /v2/certificates/subscription/{guid}
@desc GET a page of certificates for a specific domain product
@required {guid: any # The Subscription GUID containing the certificates being requested.}
@optional {pageSize: any # The number of records to return per query., page: any # The page number. <b>(First page is <i>one</i> instead of zero.)</b>, domain: any # Filter by domain name / common name. This will look for the text inside the content of the domain. This is not a "find domains that start with x" search., status: any # The certificate lifecycle stage. <br> Active, Expired, and Revoked are all Issued certificates. <br> Active means the validity period includes today. <br> Expired means the validity period was prior to today. <br> Revoked means that the certificate has been revoked. <br> Pending means that the certificate is still going through the issuance process and has not been signed or issued yet. <br> Denied means that the certificate went from pending to denied for any valid denial reason.  (Customer canceled request, CAA records exist for the domain, fraud, etc...), type: any # The type of certificate in terms of the number of applicable domains., validation: any # The validation type for the certificate.  Standard/Basic Validation (DV).  Organizational/Deluxe Vetting (OV). Extended/Premium Validation (EV).}
@returns(200) OK

@endgroup

@end
